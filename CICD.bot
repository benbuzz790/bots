     "_find_all_string_locations_in_source": "<function _find_all_string_locations_in_source at 0x0000021C0276FB00>",
     "_analyze_string_at_position_in_source": "<function _analyze_string_at_position_in_source at 0x0000021C0276F7E0>",
     "_process_string_literals": "<function _process_string_literals at 0x0000021C0276F920>",
     "_find_all_string_locations": "<function _find_all_string_locations at 0x0000021C0276F9C0>",
