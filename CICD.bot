     "_find_block_in_content": "<function _find_block_in_content at 0x0000021C02A807C0>",
     "_get_line_indentation": "<function _get_line_indentation at 0x0000021C02A80860>",
     "_check_match_type": "<function _check_match_type at 0x0000021C02A80900>",
