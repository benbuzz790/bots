                                              "content": "\n        1:import ast\n        2:import os\n        3:from bots.utils.helpers import _process_error, _clean, _py_ast_to_source\n        4:import textwrap\n        5:\n        6:class NodeTransformerWithAsyncSupport(ast.NodeTransformer):\n        7:    \"\"\"Base class for AST transformers that need to handle both sync and async functions.\"\"\"\n        8:\n        9:    def __init__(self):\n        10:        self.success = False\n        11:\n        12:    def visit_FunctionDef(self, node):\n        13:        return self._handle_function(node)\n        14:\n        15:    def visit_AsyncFunctionDef(self, node):\n        16:        return self._handle_function(node)\n        17:\n        18:    def _handle_function(self, node):\n        19:        \"\"\"Override this method in subclasses to implement specific transformation logic\"\"\"\n        20:        raise NotImplementedError\n        21:\n        22:class FunctionReplacer(NodeTransformerWithAsyncSupport):\n        23:\n        24:    def __init__(self, new_func_node):\n        25:        super().__init__()\n        26:        self.new_func_node = new_func_node\n        27:\n        28:    def _handle_function(self, node):\n        29:        if node.name == self.new_func_node.name:\n        30:            self.success = True\n        31:            return self.new_func_node\n        32:        return node\n        33:\n        34:class MethodAdder(NodeTransformerWithAsyncSupport):\n        35:\n        36:    def __init__(self, class_name, new_method_node):\n        37:        super().__init__()\n        38:        self.class_name = class_name\n        39:        self.new_method_node = new_method_node\n        40:\n        41:    def visit_ClassDef(self, node):\n        42:        if node.name == self.class_name:\n        43:            self.success = True\n        44:            node.body.append(self.new_method_node)\n        45:            return node\n        46:        return node\n        47:\n        48:    def _handle_function(self, node):\n        49:        return node\n        50:\n        51:def add_imports(file_path: str, code: str) -> str:\n        52:    \"\"\"\n        53:    Adds multiple import statements to a Python file.\n        54:    Avoids adding duplicate imports.\n        55:\n        56:    Parameters:\n        57:    - file_path (str): The path to the file where the imports will be added\n        58:    - code (str): Import statements, which can include parenthesized multi-line imports\n        59:\n        60:    Returns a confirmation message or an error message.\n        61:\n        62:    cost: very low\n        63:    \"\"\"\n        64:    try:\n        65:        abs_path = _make_file(file_path)\n        66:        lines = code.strip().split('\\n')\n        67:        import_blocks = []\n        68:        current_block = []\n        69:        in_parentheses = False\n        70:        for line in lines:\n        71:            stripped = line.strip()\n        72:            if not stripped:\n        73:                continue\n        74:            if '(' in stripped and (not stripped.endswith(')')):\n        75:                in_parentheses = True\n        76:                current_block.append(stripped)\n        77:            elif ')' in stripped and in_parentheses:\n        78:                in_parentheses = False\n        79:                current_block.append(stripped)\n        80:                import_blocks.append('\\n'.join(current_block))\n        81:                current_block = []\n        82:            elif in_parentheses:\n        83:                current_block.append(stripped)\n        84:            elif current_block:\n        85:                current_block.append(stripped)\n        86:            else:\n        87:                import_blocks.append(stripped)\n        88:        if current_block:\n        89:            import_blocks.append('\\n'.join(current_block))\n        90:        new_import_nodes = []\n        91:        for stmt in import_blocks:\n        92:            try:\n        93:                node = ast.parse(_clean(stmt)).body[0]\n        94:                if not isinstance(node, (ast.Import, ast.ImportFrom)):\n        95:                    return _process_error(ValueError(f'Invalid import statement: {stmt}'))\n        96:                new_import_nodes.append(node)\n        97:            except Exception as e:\n        98:                return _process_error(ValueError(f'Error parsing import statement \"{stmt}\": {str(e)}'))\n        99:        try:\n        100:            with open(abs_path, 'r', encoding='utf-8') as file:\n        101:                content = file.read()\n        102:        except Exception as e:\n        103:            return _process_error(ValueError(f'Error reading file {abs_path}: {str(e)}'))\n        104:        if not content.strip():\n        105:            with open(abs_path, 'w', encoding='utf-8') as file:\n        106:                file.write('\\n'.join(import_blocks) + '\\n')\n        107:            return f\"{len(import_blocks)} imports have been added to new file '{abs_path}'.\"\n        108:        try:\n        109:            tree = ast.parse(content)\n        110:        except Exception as e:\n        111:            return _process_error(ValueError(f'Error parsing the file {abs_path}: {str(e)}'))\n        112:        added_imports = []\n        113:        existing_imports = []\n        114:\n        115:        def normalize_import(node):\n        116:            \"\"\"Helper to normalize import node to string for comparison\"\"\"\n        117:            return _py_ast_to_source(node).strip().replace(' ', '')\n        118:        for new_node in new_import_nodes:\n        119:            new_stmt_normalized = normalize_import(new_node)\n        120:            is_duplicate = False\n        121:            for existing_node in tree.body:\n        122:                if isinstance(existing_node, (ast.Import, ast.ImportFrom)):\n        123:                    if normalize_import(existing_node) == new_stmt_normalized:\n        124:                        existing_imports.append(_py_ast_to_source(new_node).strip())\n        125:                        is_duplicate = True\n        126:                        break\n        127:            if not is_duplicate:\n        128:                added_imports.append(_py_ast_to_source(new_node).strip())\n        129:        if added_imports:\n        130:            last_import_idx = -1\n        131:            for i, node in enumerate(tree.body):\n        132:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        133:                    last_import_idx = i\n        134:            for node in new_import_nodes:\n        135:                if _py_ast_to_source(node).strip() in added_imports:\n        136:                    tree.body.insert(last_import_idx + 1, node)\n        137:                    last_import_idx += 1\n        138:            try:\n        139:                updated_content = _py_ast_to_source(tree)\n        140:                with open(abs_path, 'w', encoding='utf-8') as file:\n        141:                    file.write(updated_content)\n        142:            except Exception as e:\n        143:                return _process_error(e)\n        144:        result_parts = []\n        145:        if added_imports:\n        146:            result_parts.append(f\"Added {len(added_imports)} new imports to '{abs_path}'\")\n        147:        if existing_imports:\n        148:            result_parts.append(f'Found {len(existing_imports)} existing imports')\n        149:        if not result_parts:\n        150:            raise ValueError('No valid import statements found')\n        151:        return '. '.join(result_parts) + '.'\n        152:    except Exception as e:\n        153:        return _process_error(e)\n        154:\n        155:def remove_import(file_path: str, import_to_remove: str) -> str:\n        156:    \"\"\"\n        157:    Removes an import statement from a Python file.\n        158:\n        159:    Parameters:\n        160:    - file_path (str): The path to the file to modify\n        161:    - import_to_remove (str): The import statement to remove (e.g., \"import os\" or \"from typing import List\")\n        162:        Must match the existing import statement exactly.\n        163:\n        164:    Returns a confirmation message or an error message.\n        165:\n        166:    cost: very low\n        167:    \"\"\"\n        168:    if not os.path.exists(file_path):\n        169:        return _process_error(ValueError(f'File {file_path} does not exist'))\n        170:    try:\n        171:        remove_node = ast.parse(import_to_remove).body[0]\n        172:        if not isinstance(remove_node, (ast.Import, ast.ImportFrom)):\n        173:            return _process_error(ValueError('Provided statement is not a valid import'))\n        174:    except Exception as e:\n        175:        return _process_error(ValueError(f'Error parsing import statement: {str(e)}'))\n        176:    try:\n        177:        with open(file_path, 'r', encoding='utf-8') as file:\n        178:            content = file.read()\n        179:        tree = ast.parse(content)\n        180:    except Exception as e:\n        181:        return _process_error(ValueError(f'Error parsing the file {file_path}: {str(e)}'))\n        182:    original_length = len(tree.body)\n        183:    new_body = []\n        184:    found = False\n        185:    for node in tree.body:\n        186:        if isinstance(node, (ast.Import, ast.ImportFrom)):\n        187:            node_str = _py_ast_to_source(node).strip()\n        188:            if node_str == import_to_remove:\n        189:                found = True\n        190:                continue\n        191:        new_body.append(node)\n        192:    if not found:\n        193:        return f\"Import '{import_to_remove}' not found in '{file_path}'.\"\n        194:    tree.body = new_body\n        195:    try:\n        196:        updated_content = _py_ast_to_source(tree)\n        197:        with open(file_path, 'w', encoding='utf-8') as file:\n        198:            file.write(updated_content)\n        199:    except Exception as e:\n        200:        return _process_error(e)\n        201:    return f\"Import '{import_to_remove}' has been removed from '{file_path}'.\"\n        202:\n        203:def replace_import(file_path: str, old_import: str, new_import: str) -> str:\n        204:    \"\"\"\n        205:    Replaces an existing import statement in a Python file.\n        206:\n        207:    Parameters:\n        208:    - file_path (str): The path to the file to modify\n        209:    - old_import (str): The existing import statement to replace\n        210:    - new_import (str): The new import statement\n        211:\n        212:    Returns a confirmation message or an error message.\n        213:\n        214:    cost: very low\n        215:    \"\"\"\n        216:    if not os.path.exists(file_path):\n        217:        return _process_error(ValueError(f'File {file_path} does not exist'))\n        218:    try:\n        219:        old_node = ast.parse(_clean(old_import)).body[0]\n        220:        new_node = ast.parse(_clean(new_import)).body[0]\n        221:        if not isinstance(old_node, (ast.Import, ast.ImportFrom)) or not isinstance(new_node, (ast.Import, ast.ImportFrom)):\n        222:            return _process_error(ValueError('Both statements must be valid imports'))\n        223:    except Exception as e:\n        224:        return _process_error(ValueError(f'Error parsing import statements: {str(e)}'))\n        225:    try:\n        226:        with open(file_path, 'r', encoding='utf-8') as file:\n        227:            content = file.read()\n        228:        tree = ast.parse(content)\n        229:    except Exception as e:\n        230:        return _process_error(ValueError(f'Error parsing the file {file_path}: {str(e)}'))\n        231:    found = False\n        232:    for i, node in enumerate(tree.body):\n        233:        if isinstance(node, (ast.Import, ast.ImportFrom)):\n        234:            node_str = _py_ast_to_source(node).strip()\n        235:            if node_str == old_import:\n        236:                tree.body[i] = new_node\n        237:                found = True\n        238:                break\n        239:    if not found:\n        240:        return f\"Import '{old_import}' not found in '{file_path}'.\"\n        241:    try:\n        242:        updated_content = _py_ast_to_source(tree)\n        243:        with open(file_path, 'w', encoding='utf-8') as file:\n        244:            file.write(updated_content)\n        245:    except Exception as e:\n        246:        return _process_error(e)\n        247:    return f\"Import '{old_import}' has been updated to '{new_import}' in '{file_path}'.\"\n        248:\n        249:def add_class(file_path: str, class_def: str) -> str:\n        250:    \"\"\"\n        251:    Adds a new class definition to an existing Python file.\n        252:\n        253:    Parameters:\n        254:    - file_path (str): The path to the file where the new class will be added\n        255:    - class_def (str): The new class definition as a string\n        256:\n        257:    Returns a confirmation message or an error message.\n        258:\n        259:    cost: low\n        260:    \"\"\"\n        261:    try:\n        262:        abs_path = _make_file(file_path)\n        263:        try:\n        264:            new_tree = ast.parse(_clean(class_def))\n        265:            new_class_node = None\n        266:            for node in new_tree.body:\n        267:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        268:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        269:                elif isinstance(node, ast.ClassDef):\n        270:                    new_class_node = node\n        271:            if new_class_node is None:\n        272:                return _process_error(ValueError('No class definition found in provided code'))\n        273:            with open(abs_path, 'r', encoding='utf-8') as file:\n        274:                content = file.read()\n        275:            tree = ast.parse(content)\n        276:        except Exception as e:\n        277:            return _process_error(ValueError(f'Error processing code: {str(e)}'))\n        278:        tree.body.append(new_class_node)\n        279:        try:\n        280:            updated_content = _py_ast_to_source(tree)\n        281:            with open(abs_path, 'w', encoding='utf-8') as file:\n        282:                file.write(updated_content)\n        283:        except Exception as e:\n        284:            return _process_error(e)\n        285:        return f\"Class '{new_class_node.name}' has been added to '{abs_path}'.\"\n        286:    except Exception as e:\n        287:        return _process_error(e)\n        288:\n        289:def replace_class(file_path: str, new_class_def: str, old_class_name: str=None) -> str:\n        290:    \"\"\"\n        291:    Replaces a class definition in a file with a new class definition.\n        292:\n        293:    Parameters:\n        294:    - file_path (str): The path to the file to modify\n        295:    - new_class_def (str): The new class definition\n        296:    - old_class_name (str, optional): The name of the class to replace\n        297:\n        298:    Returns a confirmation message or an error message.\n        299:\n        300:    cost: low\n        301:    \"\"\"\n        302:    try:\n        303:        abs_path = _make_file(file_path)\n        304:        try:\n        305:            new_tree = ast.parse(_clean(new_class_def))\n        306:            new_class_node = None\n        307:            for node in new_tree.body:\n        308:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        309:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        310:                elif isinstance(node, ast.ClassDef):\n        311:                    new_class_node = node\n        312:                    if old_class_name is None:\n        313:                        old_class_name = node.name\n        314:            if new_class_node is None:\n        315:                return _process_error(ValueError('No class definition found in provided code'))\n        316:            with open(abs_path, 'r', encoding='utf-8') as file:\n        317:                content = file.read()\n        318:            tree = ast.parse(content)\n        319:        except Exception as e:\n        320:            return _process_error(ValueError(f'Error processing code: {str(e)}'))\n        321:\n        322:        class ClassReplacer(NodeTransformerWithAsyncSupport):\n        323:\n        324:            def visit_ClassDef(self, node):\n        325:                if node.name == old_class_name:\n        326:                    self.success = True\n        327:                    return new_class_node\n        328:                return node\n        329:\n        330:            def _handle_function(self, node):\n        331:                return node\n        332:        transformer = ClassReplacer()\n        333:        tree = transformer.visit(tree)\n        334:        if not transformer.success:\n        335:            tree.body.append(new_class_node)\n        336:        try:\n        337:            updated_content = _py_ast_to_source(tree)\n        338:            with open(abs_path, 'w', encoding='utf-8') as file:\n        339:                file.write(updated_content)\n        340:        except Exception as e:\n        341:            return _process_error(e)\n        342:        action = 'replaced in' if transformer.success else 'added to'\n        343:        return f\"Class '{new_class_node.name}' has been {action} '{abs_path}'.\"\n        344:    except Exception as e:\n        345:        return _process_error(e)\n        346:\n        347:def add_function_to_class(file_path: str, class_name: str, new_method_def: str) -> str:\n        348:    \"\"\"\n        349:    Adds one or more methods to an existing class in a Python file.\n        350:\n        351:    Parameters:\n        352:    - file_path (str): The path to the file to modify\n        353:    - class_name (str): The name of the class to modify\n        354:    - new_method_def (str): One or more method definitions as a string\n        355:\n        356:    Returns a confirmation message or an error message.\n        357:\n        358:    cost: very low\n        359:    \"\"\"\n        360:    try:\n        361:        tree = ast.parse(_clean(new_method_def))\n        362:        messages = []\n        363:        for node in tree.body:\n        364:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        365:                add_imports(file_path, _py_ast_to_source(node).strip())\n        366:        found_method = False\n        367:        for node in tree.body:\n        368:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        369:                found_method = True\n        370:                method_source = _py_ast_to_source(node)\n        371:                result = _add_single_function_to_class(file_path, class_name, method_source)\n        372:                messages.append(result)\n        373:        if not found_method:\n        374:            return _process_error(ValueError('No method definitions found in provided code'))\n        375:        return '\\n'.join(messages)\n        376:    except Exception as e:\n        377:        return _process_error(e)\n        378:\n        379:def add_function_to_file(file_path: str, new_function_def: str, class_name: str=None) -> str:\n        380:    \"\"\"\n        381:    Adds one or more function definitions to an existing Python file.\n        382:\n        383:    When adding complex code blocks:\n        384:    - Imports are moved to the top of the file\n        385:    - Functions are added in order of appearance\n        386:    - Non-function code (assignments, if blocks, etc.) is preserved but may be reordered\n        387:    - Comments are not preserved (limitation of AST)\n        388:\n        389:    Parameters:\n        390:    - file_path (str): The path to the file to modify\n        391:    - new_function_def (str): One or more function definitions as a string\n        392:    - class_name (str, optional): If provided, add functions to this class\n        393:\n        394:    Returns a confirmation message or an error message.\n        395:\n        396:    cost: very low\n        397:    \"\"\"\n        398:    try:\n        399:        tree = ast.parse(_clean(new_function_def))\n        400:        messages = []\n        401:        for node in tree.body:\n        402:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        403:                add_imports(file_path, _py_ast_to_source(node).strip())\n        404:        found_function = False\n        405:        remaining_nodes = []\n        406:        for node in tree.body:\n        407:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        408:                found_function = True\n        409:                function_source = _py_ast_to_source(node)\n        410:                if class_name:\n        411:                    result = add_function_to_class(file_path, class_name, function_source)\n        412:                else:\n        413:                    result = _add_single_function_to_file(file_path, function_source)\n        414:                messages.append(result)\n        415:            elif not isinstance(node, (ast.Import, ast.ImportFrom)):\n        416:                remaining_nodes.append(node)\n        417:        if not found_function:\n        418:            return _process_error(ValueError('No function definitions found in provided code'))\n        419:        if remaining_nodes:\n        420:            with open(file_path, 'r', encoding='utf-8') as file:\n        421:                content = file.read()\n        422:            existing_tree = ast.parse(content)\n        423:            existing_tree.body.extend(remaining_nodes)\n        424:            updated_content = _py_ast_to_source(existing_tree)\n        425:            with open(file_path, 'w', encoding='utf-8') as file:\n        426:                file.write(updated_content)\n        427:            messages.append(f'Added {len(remaining_nodes)} additional code blocks')\n        428:        return '\\n'.join(messages)\n        429:    except Exception as e:\n        430:        return _process_error(e)\n        431:\n        432:def replace_function(file_path: str, new_function_def: str, class_name: str=None) -> str:\n        433:    \"\"\"\n        434:    Replaces one or more function definitions in a file with new function definitions.\n        435:\n        436:    Parameters:\n        437:    - file_path (str): The path to the file to modify\n        438:    - new_function_def (str): One or more function definitions as a string\n        439:    - class_name (str, optional): If provided, only replace functions within this class\n        440:\n        441:    Returns a confirmation message or an error message.\n        442:\n        443:    cost: very low\n        444:    \"\"\"\n        445:    try:\n        446:        tree = ast.parse(_clean(new_function_def))\n        447:        messages = []\n        448:        for node in tree.body:\n        449:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        450:                add_imports(file_path, _py_ast_to_source(node).strip())\n        451:        found_function = False\n        452:        for node in tree.body:\n        453:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        454:                found_function = True\n        455:                function_source = _py_ast_to_source(node)\n        456:                result = _replace_single_function(file_path, function_source, class_name)\n        457:                messages.append(result)\n        458:        if not found_function:\n        459:            return _process_error(ValueError('No function definitions found in provided code'))\n        460:        return '\\n'.join(messages)\n        461:    except Exception as e:\n        462:        return _process_error(e)\n        463:\n        464:def _make_file(file_path: str) -> str:\n        465:    \"\"\"\n        466:    Creates a file and its parent directories if they don't exist.\n        467:    Converts relative paths to absolute paths.\n        468:\n        469:    Parameters:\n        470:    - file_path (str): The path to the file to be created\n        471:\n        472:    Returns:\n        473:    - str: The absolute path to the file\n        474:\n        475:    Raises:\n        476:    - ValueError: If there's an error creating the file or directories,\n        477:                 or if the file_path is empty\n        478:    \"\"\"\n        479:    if not file_path:\n        480:        raise ValueError('File path cannot be empty')\n        481:    abs_path = os.path.abspath(file_path)\n        482:    dir_path = os.path.dirname(abs_path)\n        483:    if dir_path:\n        484:        try:\n        485:            os.makedirs(dir_path, exist_ok=True)\n        486:        except Exception as e:\n        487:            raise ValueError(f'Error creating directories {dir_path}: {str(e)}')\n        488:    if not os.path.exists(abs_path):\n        489:        try:\n        490:            with open(abs_path, 'w', encoding='utf-8') as f:\n        491:                f.write('')\n        492:        except Exception as e:\n        493:            raise ValueError(f'Error creating file {abs_path}: {str(e)}')\n        494:    return abs_path\n        495:\n        496:def _add_single_function_to_class(file_path: str, class_name: str, new_method_def: str) -> str:\n        497:    \"\"\"Adds a single method to a class.\"\"\"\n        498:    try:\n        499:        abs_path = _make_file(file_path)\n        500:        try:\n        501:            new_tree = ast.parse(_clean(new_method_def))\n        502:            new_method_node = None\n        503:            for node in new_tree.body:\n        504:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        505:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        506:                elif isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        507:                    new_method_node = node\n        508:            if new_method_node is None:\n        509:                return _process_error(ValueError('No method definition found in provided code'))\n        510:            with open(abs_path, 'r', encoding='utf-8') as file:\n        511:                content = file.read()\n        512:            if not content.strip():\n        513:                content = f'class {class_name}:\\n    pass\\n'\n        514:            tree = ast.parse(content)\n        515:        except Exception as e:\n        516:            return _process_error(ValueError(f'Error processing code: {str(e)}'))\n        517:        transformer = MethodAdder(class_name, new_method_node)\n        518:        tree = transformer.visit(tree)\n        519:        if not transformer.success:\n        520:            return _process_error(ValueError(f\"Class '{class_name}' not found in the file.\"))\n        521:        try:\n        522:            updated_content = _py_ast_to_source(tree)\n        523:            with open(abs_path, 'w', encoding='utf-8') as file:\n        524:                file.write(updated_content)\n        525:        except Exception as e:\n        526:            return _process_error(e)\n        527:        return f\"Method '{new_method_node.name}' has been added to class '{class_name}' in '{abs_path}'.\"\n        528:    except Exception as e:\n        529:        return _process_error(e)\n        530:\n        531:def _add_single_function_to_file(file_path: str, new_function_def: str) -> str:\n        532:    \"\"\"Adds a single function and preserves all code blocks, including any code following the function.\"\"\"\n        533:    try:\n        534:        abs_path = _make_file(file_path)\n        535:        try:\n        536:            new_tree = ast.parse(_clean(new_function_def))\n        537:            new_func_node = None\n        538:            found_func = False\n        539:            new_nodes = []\n        540:            for node in new_tree.body:\n        541:                if not found_func and isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        542:                    new_func_node = node\n        543:                    found_func = True\n        544:                elif found_func:\n        545:                    new_nodes.append(node)\n        546:            if not new_func_node:\n        547:                return _process_error(ValueError('No function definition found in provided code'))\n        548:        except Exception as e:\n        549:            return _process_error(ValueError(f'Error in code: {str(e)}'))\n        550:        with open(abs_path, 'r', encoding='utf-8') as file:\n        551:            content = file.read()\n        552:        if not content.strip():\n        553:            try:\n        554:                with open(abs_path, 'w', encoding='utf-8') as file:\n        555:                    file.write(_py_ast_to_source(new_tree))\n        556:                return f\"Code with function '{new_func_node.name}' has been added to new file '{abs_path}'.\"\n        557:            except Exception as e:\n        558:                return _process_error(e)\n        559:        try:\n        560:            existing_tree = ast.parse(content)\n        561:            combined_body = []\n        562:            imports = []\n        563:            for node in existing_tree.body + new_tree.body:\n        564:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        565:                    imports.append(node)\n        566:            combined_body.extend(imports)\n        567:            for node in existing_tree.body:\n        568:                if not isinstance(node, (ast.Import, ast.ImportFrom)):\n        569:                    combined_body.append(node)\n        570:            combined_body.append(new_func_node)\n        571:            combined_body.extend(new_nodes)\n        572:            combined_tree = ast.Module(body=combined_body, type_ignores=[])\n        573:            updated_content = _py_ast_to_source(combined_tree)\n        574:            with open(abs_path, 'w', encoding='utf-8') as file:\n        575:                file.write(updated_content)\n        576:        except Exception as e:\n        577:            return _process_error(e)\n        578:        return f\"Code with function '{new_func_node.name}' has been added to '{abs_path}'.\"\n        579:    except Exception as e:\n        580:        return _process_error(e)\n        581:\n        582:def _replace_single_function(file_path: str, new_function_def: str, class_name: str=None) -> str:\n        583:    \"\"\"Replaces a single function in a file, optionally within a specific class.\n        584:\n        585:    Args:\n        586:        file_path: Path to the file to modify\n        587:        new_function_def: The new function definition\n        588:        class_name: If provided, only replace within this class\n        589:    \"\"\"\n        590:    try:\n        591:        abs_path = _make_file(file_path)\n        592:        try:\n        593:            new_tree = ast.parse(_clean(new_function_def))\n        594:            new_func_node = None\n        595:            for node in new_tree.body:\n        596:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        597:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        598:                elif isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        599:                    new_func_node = node\n        600:            if new_func_node is None:\n        601:                return _process_error(ValueError('No function definition found in provided code'))\n        602:            with open(abs_path, 'r', encoding='utf-8') as file:\n        603:                content = file.read()\n        604:            tree = ast.parse(content)\n        605:        except Exception as e:\n        606:            return _process_error(ValueError(f'Error processing code: {str(e)}'))\n        607:\n        608:        class ClassScopedFunctionReplacer(ast.NodeTransformer):\n        609:\n        610:            def __init__(self, new_func_node, target_class=None):\n        611:                self.new_func_node = new_func_node\n        612:                self.target_class = target_class\n        613:                self.success = False\n        614:                self.in_target_class = False\n        615:\n        616:            def visit_ClassDef(self, node):\n        617:                if self.target_class is None or node.name == self.target_class:\n        618:                    old_in_target_class = self.in_target_class\n        619:                    self.in_target_class = True\n        620:                    node = self.generic_visit(node)\n        621:                    self.in_target_class = old_in_target_class\n        622:                return node\n        623:\n        624:            def visit_FunctionDef(self, node):\n        625:                if node.name == self.new_func_node.name:\n        626:                    if self.target_class is None or self.in_target_class:\n        627:                        self.success = True\n        628:                        return self.new_func_node\n        629:                return node\n        630:\n        631:            def visit_AsyncFunctionDef(self, node):\n        632:                return self.visit_FunctionDef(node)\n        633:        transformer = ClassScopedFunctionReplacer(new_func_node, class_name)\n        634:        tree = transformer.visit(tree)\n        635:        if not transformer.success:\n        636:            if class_name:\n        637:                return _process_error(ValueError(f\"Function '{new_func_node.name}' not found in class '{class_name}'\"))\n        638:            tree.body.append(new_func_node)\n        639:        try:\n        640:            updated_content = _py_ast_to_source(tree)\n        641:            with open(abs_path, 'w', encoding='utf-8') as file:\n        642:                file.write(updated_content)\n        643:        except Exception as e:\n        644:            return _process_error(e)\n        645:        context = f\"in class '{class_name}'\" if class_name else 'in file'\n        646:        action = 'replaced' if transformer.success else 'added'\n        647:        return f\"Function '{new_func_node.name}' has been {action} {context} '{abs_path}'.\"\n        648:    except Exception as e:\n        649:        return _process_error(e)\n        650:\n        651:def python_edit(target_scope: str, code: str, *, insert_after: str=None) -> str:\n        652:    \"\"\"\n        653:    Edit Python code using pytest-style scope syntax.\n        654:\n        655:    Parameters:\n        656:    ----------\n        657:    target_scope : str\n        658:        Location to edit in pytest-style scope syntax:\n        659:        - \"file.py\" (whole file)\n        660:        - \"file.py::MyClass\" (class)\n        661:        - \"file.py::my_function\" (function)\n        662:        - \"file.py::MyClass::method\" (method)\n        663:        - \"file.py::Outer::Inner::method\" (nested)\n        664:        - \"file.py::utils::helper_func\" (nested function)\n        665:\n        666:    code : str\n        667:        Python code to insert/replace. Will be cleaned/dedented.\n        668:        Import statements will be automatically extracted and handled.\n        669:\n        670:    insert_after : str, optional\n        671:        Where to insert the code. Can be either:\n        672:        - \"__FILE_START__\" (special token for file beginning)\n        673:        - A scope (\"MyClass::method\")\n        674:        - An exact line match\n        675:        If not specified, replaces the node at target_scope.\n        676:\n        677:    Returns:\n        678:    --------\n        679:    str\n        680:        Description of what was modified or error message\n        681:    \"\"\"\n        682:    try:\n        683:        file_path, *path_elements = target_scope.split('::')\n        684:        if not file_path.endswith('.py'):\n        685:            return _process_error(ValueError(f'File path must end with .py: {file_path}'))\n        686:        for element in path_elements:\n        687:            if not element.isidentifier():\n        688:                return _process_error(ValueError(f'Invalid identifier in path: {element}'))\n        689:        abs_path = _make_file(file_path)\n        690:        try:\n        691:            new_tree = ast.parse(_clean(code))\n        692:            import_nodes = []\n        693:            code_nodes = []\n        694:            for node in new_tree.body:\n        695:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        696:                    import_nodes.append(node)\n        697:                else:\n        698:                    code_nodes.append(node)\n        699:        except Exception as e:\n        700:            return _process_error(ValueError(f'Error parsing new code: {str(e)}'))\n        701:        try:\n        702:            with open(abs_path, 'r', encoding='utf-8') as file:\n        703:                content = file.read()\n        704:            file_lines = content.split('\\n')\n        705:            tree = ast.parse(content) if content.strip() else ast.Module(body=[], type_ignores=[])\n        706:        except Exception as e:\n        707:            return _process_error(ValueError(f'Error reading/parsing file {abs_path}: {str(e)}'))\n        708:        existing_imports = []\n        709:        non_imports = []\n        710:        for node in tree.body:\n        711:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        712:                existing_imports.append(node)\n        713:            else:\n        714:                non_imports.append(node)\n        715:        if insert_after == '__FILE_START__':\n        716:            tree.body = existing_imports + import_nodes + code_nodes + non_imports\n        717:            try:\n        718:                updated_content = _py_ast_to_source(tree)\n        719:                with open(abs_path, 'w', encoding='utf-8') as file:\n        720:                    file.write(updated_content)\n        721:                return f\"Code inserted at start of '{abs_path}'.\"\n        722:            except Exception as e:\n        723:                return _process_error(e)\n        724:        if not path_elements:\n        725:            tree.body = existing_imports + import_nodes + non_imports + code_nodes\n        726:            try:\n        727:                updated_content = _py_ast_to_source(tree)\n        728:                with open(abs_path, 'w', encoding='utf-8') as file:\n        729:                    file.write(updated_content)\n        730:                return f\"Code added at file level in '{abs_path}'.\"\n        731:            except Exception as e:\n        732:                return _process_error(e)\n        733:        tree.body = existing_imports + import_nodes + non_imports\n        734:        transformer = ScopeTransformer(path_elements, code_nodes, insert_after, file_lines)\n        735:        modified_tree = transformer.visit(tree)\n        736:        if not transformer.success:\n        737:            if insert_after:\n        738:                return _process_error(ValueError(f'Insert point not found: {insert_after}'))\n        739:            else:\n        740:                return _process_error(ValueError(f'Target scope not found: {target_scope}'))\n        741:        try:\n        742:            updated_content = _py_ast_to_source(modified_tree)\n        743:            with open(abs_path, 'w', encoding='utf-8') as file:\n        744:                file.write(updated_content)\n        745:        except Exception as e:\n        746:            return _process_error(e)\n        747:        action = 'inserted after' if insert_after else 'replaced at'\n        748:        scope_str = '::'.join(path_elements) if path_elements else 'file level'\n        749:        return f\"Code {action} {scope_str} in '{abs_path}'.\"\n        750:    except Exception as e:\n        751:        return _process_error(e)\n        752:\n        753:class ScopeTransformer(ast.NodeTransformer):\n        754:    \"\"\"AST transformer that handles scope-based Python code modifications.\"\"\"\n        755:\n        756:    def __init__(self, path_elements, new_nodes, insert_after=None, file_lines=None):\n        757:        self.original_path = path_elements\n        758:        self.new_nodes = new_nodes\n        759:        self.insert_after = insert_after\n        760:        self.file_lines = file_lines\n        761:        self.current_path = []\n        762:        self.success = False\n        763:        self.line_match_count = 0\n        764:\n        765:    def visit_ClassDef(self, node):\n        766:        \"\"\"Visit a class definition node.\"\"\"\n        767:        if not self.original_path or node.name != self.original_path[0]:\n        768:            return self.generic_visit(node)\n        769:        self.current_path.append(node.name)\n        770:        remaining_path = self.original_path[1:]\n        771:        if not remaining_path:\n        772:            if self.insert_after:\n        773:                node = self._handle_insertion(node)\n        774:            else:\n        775:                self.success = True\n        776:                if len(self.new_nodes) == 1:\n        777:                    return self.new_nodes[0]\n        778:                else:\n        779:                    node.body = self.new_nodes\n        780:                    return node\n        781:        else:\n        782:            saved_path = self.original_path\n        783:            self.original_path = remaining_path\n        784:            node.body = [self.visit(child) for child in node.body]\n        785:            self.original_path = saved_path\n        786:        self.current_path.pop()\n        787:        return node\n        788:\n        789:    def visit_FunctionDef(self, node):\n        790:        \"\"\"Visit a function definition node.\"\"\"\n        791:        return self._handle_function_node(node)\n        792:\n        793:    def visit_AsyncFunctionDef(self, node):\n        794:        \"\"\"Visit an async function definition node.\"\"\"\n        795:        return self._handle_function_node(node)\n        796:\n        797:    def _handle_function_node(self, node):\n        798:        \"\"\"Common handling for both regular and async functions.\"\"\"\n        799:        if not self.original_path or node.name != self.original_path[0]:\n        800:            return self.generic_visit(node)\n        801:        self.current_path.append(node.name)\n        802:        remaining_path = self.original_path[1:]\n        803:        if not remaining_path:\n        804:            if self.insert_after:\n        805:                node = self._handle_insertion(node)\n        806:            else:\n        807:                self.success = True\n        808:                if len(self.new_nodes) == 1:\n        809:                    return self.new_nodes[0]\n        810:                else:\n        811:                    node.body = self.new_nodes\n        812:                    return node\n        813:        else:\n        814:            saved_path = self.original_path\n        815:            self.original_path = remaining_path\n        816:            node.body = [self.visit(child) for child in node.body]\n        817:            self.original_path = saved_path\n        818:        self.current_path.pop()\n        819:        return node\n        820:\n        821:    def _handle_insertion(self, node):\n        822:        \"\"\"Handle inserting nodes after a specific point.\"\"\"\n        823:        if isinstance(self.insert_after, str) and '::' not in self.insert_after:\n        824:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        825:                print(f'\\nDEBUG - Function node: {node.name}')\n        826:                print(f'DEBUG - Line range: {node.lineno} to {node.end_lineno}')\n        827:                func_lines = self.file_lines[node.lineno - 1:node.end_lineno]\n        828:                print(f'DEBUG - Function lines:\\n{func_lines}')\n        829:                target = self.insert_after.strip()\n        830:                print(f\"DEBUG - Looking for target: '{target}'\")\n        831:                for i, line in enumerate(func_lines):\n        832:                    line = line.rstrip()\n        833:                    print(f\"DEBUG - Checking line: '{line}'\")\n        834:                    if line.strip() == target:\n        835:                        print(f'DEBUG - Found match at line {i}')\n        836:                        self.line_match_count += 1\n        837:                        if self.line_match_count == 1:\n        838:                            base_indent = len(line) - len(line.lstrip())\n        839:                            print(f'DEBUG - Base indent: {base_indent}')\n        840:                            insertion = []\n        841:                            for new_node in self.new_nodes:\n        842:                                node_lines = _py_ast_to_source(new_node).split('\\n')\n        843:                                for nl in node_lines:\n        844:                                    if nl.strip():\n        845:                                        insertion.append(' ' * base_indent + nl.lstrip())\n        846:                                    else:\n        847:                                        insertion.append('')\n        848:                            print(f'DEBUG - Insertion lines: {insertion}')\n        849:                            func_lines[i:i + 1] = [func_lines[i]] + insertion\n        850:                            self.success = True\n        851:                            break\n        852:                if self.line_match_count == 0:\n        853:                    print('DEBUG - No matches found')\n        854:                    return node\n        855:                elif self.line_match_count > 1:\n        856:                    raise ValueError(f'Ambiguous insert_after - found {self.line_match_count} matches for: {self.insert_after}')\n        857:                new_source = '\\n'.join(func_lines)\n        858:                print(f'DEBUG - New source:\\n{new_source}')\n        859:                new_body = ast.parse(new_source).body\n        860:                if new_body:\n        861:           