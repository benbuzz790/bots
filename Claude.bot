     if True:\\n            x = 1\\n            if True:\\n                y = 2\\n    '\n        139:    result = python_edit(f'{test_file}::OuterClass', new_method, insert_after='OuterClass::method')\n        140:    with open(test_file) as f:\n        141:        content = f.read()\n        142:    assert '    def indented_method' in content\n        143:    assert '        if True:' in content\n        144:    assert '            x = 1' in content\n        145:\n        146:def test_empty_file(tmp_path):\n        147:    \"\"\"Test handling empty target file\"\"\"\n        148:    empty_file = setup_test_file(tmp_path, '')\n        149:    result = python_edit(empty_file, 'x = 42')\n        150:    assert 'added' in result.lower()\n        151:    with open(empty_file) as f:\n        152:        content = f.read()\n        153:    assert content.strip() == 'x = 42'\n        154:\n        155:def test_multiline_imports(test_file):\n        156:    \"\"\"Test handling multiline import statements\"\"\"\n        157:    new_code = '\\n    from typing import (\\n        List,\\n        Dict,\\n        Optional,\\n        Union\\n    )\\n\\n    x = 42\\n    '\n        158:    result = python_edit(test_file, new_code)\n        159:    with open(test_file) as f:\n        160:        content = f.read()\n        161:    assert 'Union' in content\n        162:    assert content.index('Union') < content.index('x = 42')\n        163:\n        164:def test_line_comment_preservation(tmp_path):\n        165:    \"\"\"Test that comments are preserved when inserting after them\"\"\"\n        166:    content = '\\n    def my_func():\\n        # First comment\\n        x = 1\\n        # Target comment\\n        y = 2\\n    '\n        167:    test_file = setup_test_file(tmp_path, content)\n        168:    result = python_edit(f'{test_file}::my_func', 'z = 3', insert_after='# Target comment')\n        169:    with open(test_file) as f:\n        170:        content = f.read()\n        171:    print(f'DEBUG - Result content:\\n{content}')\n        172:    assert '# Target comment' in content\n        173:    assert 'z = 3' in content\n        174:    assert content.index('# Target comment') < content.index('z = 3')\n        175:    assert content.index('z = 3') < content.index('y = 2')\n        176:\n        177:def test_import_at_file_start(tmp_path):\n        178:    \"\"\"Test that imports are added at the start of the file\"\"\"\n        179:    content = '\\n    x = 1\\n    y = 2\\n    '\n        180:    test_file = setup_test_file(tmp_path, content)\n        181:    result = python_edit(test_file, 'import sys\\nz = 3')\n        182:    with open(test_file) as f:\n        183:        content = f.read()\n        184:    print(f'DEBUG - Result content:\\n{content}')\n        185:    assert 'import sys' in content\n        186:    assert content.index('import sys') < content.index('x = 1')\n        187:\n        188:def test_nested_scope_insertion(tmp_path):\n        189:    \"\"\"Test inserting into deeply nested scopes\"\"\"\n        190:    content = '\\n    class Outer:\\n        class Inner:\\n            def method(self):\\n                x = 1\\n    '\n        191:    test_file = setup_test_file(tmp_path, content)\n        192:    result = python_edit(f'{test_file}::Outer::Inner::method', 'y = 2', insert_after='x = 1')\n        193:    with open(test_file) as f:\n        194:        content = f.read()\n        195:    print(f'DEBUG - Result content:\\n{content}')\n        196:    assert 'y = 2' in content\n        197:    assert content.index('x = 1') < content.index('y = 2')\n        198:\n        199:def test_indentation_in_class(tmp_path):\n        200:    \"\"\"Test that proper indentation is maintained in class methods\"\"\"\n        201:    content = '\\n    class MyClass:\\n        def method_one(self):\\n            pass\\n    '\n        202:    test_file = setup_test_file(tmp_path, content)\n        203:    new_method = '\\n   