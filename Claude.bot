                                                                                                                                                                                      "content": "\n        1:import ast\n        2:import os\n        3:import textwrap\n        4:TOKEN_START = ';;;'\n        5:TOKEN_END = ';;;'\n        6:from bots.utils.helpers import _process_error, _clean, _py_ast_to_source\n        7:import hashlib\n        8:import re\n        9:from typing import Dict, Tuple\n        10:from typing import Dict, Tuple, Union\n        11:\n        12:def python_edit(target_scope: str, code: str, *, insert_after: str=None) -> str:\n        13:    \"\"\"\n        14:    Edit Python code using pytest-style scope syntax.\n        15:    Default behavior: Replace entire target scope.\n        16:\n        17:    Parameters:\n        18:    ----------\n        19:    target_scope : str\n        20:        Location to edit in pytest-style scope syntax:\n        21:        - \"file.py\" (whole file)\n        22:        - \"file.py::MyClass\" (class)\n        23:        - \"file.py::my_function\" (function)\n        24:        - \"file.py::MyClass::method\" (method)\n        25:        - \"file.py::Outer::Inner::method\" (nested)\n        26:        - \"file.py::utils::helper_func\" (nested function)\n        27:\n        28:    code : str\n        29:        Python code to insert/replace. Will be cleaned/dedented.\n        30:        Import statements will be automatically extracted and handled.\n        31:\n        32:    insert_after : str, optional\n        33:        Where to insert the code. Can be either:\n        34:        - \"__FILE_START__\" (special token for file beginning)\n        35:        - A scope (\"MyClass::method\")\n        36:        - An exact line match (like a context line in git patches)\n        37:        If not specified, replaces the node at target_scope.\n        38:\n        39:    Returns:\n        40:    --------\n        41:    str\n        42:        Description of what was modified or error message\n        43:    \"\"\"\n        44:    try:\n        45:        file_path, *path_elements = target_scope.split('::')\n        46:        if not file_path.endswith('.py'):\n        47:            return _process_error(ValueError(f'File path must end with .py: {file_path}'))\n        48:        for element in path_elements:\n        49:            if not element.isidentifier():\n        50:                return _process_error(ValueError(f'Invalid identifier in path: {element}'))\n        51:        abs_path = _make_file(file_path)\n        52:        cleaned_code = _clean(code)\n        53:        tokenized_code, new_code_tokens = _tokenize_source(cleaned_code)\n        54:        try:\n        55:            new_tree = ast.parse(tokenized_code)\n        56:            import_nodes = []\n        57:            code_nodes = []\n        58:            for node in new_tree.body:\n        59:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        60:                    import_nodes.append(node)\n        61:                else:\n        62:                    code_nodes.append(node)\n        63:        except Exception as e:\n        64:            return _process_error(ValueError(f'Error parsing new code: {str(e)}'))\n        65:        try:\n        66:            with open(abs_path, 'r', encoding='utf-8') as file:\n        67:                content = file.read()\n        68:            tokenized_content, file_tokens = _tokenize_source(content) if content.strip() else ('', {})\n        69:            file_lines = tokenized_content.split('\\n')\n        70:            tree = ast.parse(tokenized_content) if content.strip() else ast.Module(body=[], type_ignores=[])\n        71:        except Exception as e:\n        72:            return _process_error(ValueError(f'Error reading/parsing file {abs_path}: {str(e)}'))\n        73:        existing_imports = []\n        74:        non_imports = []\n        75:        for node in tree.body:\n        76:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        77:                existing_imports.append(node)\n        78:            else:\n        79:                non_imports.append(node)\n        80:        if insert_after == '__FILE_START__':\n        81:            tree.body = import_nodes + code_nodes + existing_imports + non_imports\n        82:            try:\n        83:                updated_content = _py_ast_to_source(tree)\n        84:                all_tokens = {**file_tokens, **new_code_tokens}\n        85:                final_content = _detokenize_source(updated_content, all_tokens)\n        86:                with open(abs_path, 'w', encoding='utf-8') as file:\n        87:                    file.write(final_content)\n        88:                return f\"Code inserted at start of '{abs_path}'.\"\n        89:            except Exception as e:\n        90:                return _process_error(e)\n        91:        if not path_elements:\n        92:            tree.body = existing_imports + import_nodes + non_imports + code_nodes\n        93:            try:\n        94:                updated_content = _py_ast_to_source(tree)\n        95:                all_tokens = {**file_tokens, **new_code_tokens}\n        96:                final_content = _detokenize_source(updated_content, all_tokens)\n        97:                with open(abs_path, 'w', encoding='utf-8') as file:\n        98:                    file.write(final_content)\n        99:                return f\"Code added at file level in '{abs_path}'.\"\n        100:            except Exception as e:\n        101:                return _process_error(e)\n        102:        tree.body = existing_imports + import_nodes + non_imports\n        103:        transformer = ScopeTransformer(path_elements, code_nodes, insert_after, file_lines, file_tokens, new_code_tokens)\n        104:        modified_tree = transformer.visit(tree)\n        105:        if not transformer.success:\n        106:            if insert_after:\n        107:                return _process_error(ValueError(f'Insert point not found: {insert_after}'))\n        108:            else:\n        109:                return _process_error(ValueError(f'Target scope not found: {target_scope}'))\n        110:        try:\n        111:            updated_content = _py_ast_to_source(modified_tree)\n        112:            all_tokens = {**file_tokens, **new_code_tokens}\n        113:            final_content = _detokenize_source(updated_content, all_tokens)\n        114:            with open(abs_path, 'w', encoding='utf-8') as file:\n        115:                file.write(final_content)\n        116:            action = 'inserted after' if insert_after else 'replaced at'\n        117:            scope_str = '::'.join(path_elements) if path_elements else 'file level'\n        118:            return f\"Code {action} {scope_str} in '{abs_path}'.\"\n        119:        except Exception as e:\n        120:            return _process_error(e)\n        121:    except Exception as e:\n        122:        return _process_error(e)\n        123:\n        124:def _make_file(file_path: str) -> str:\n        125:    \"\"\"\n        126:    Creates a file and its parent directories if they don't exist.\n        127:    Converts relative paths to absolute paths.\n        128:\n        129:    Parameters:\n        130:    - file_path (str): The path to the file to be created\n        131:\n        132:    Returns:\n        133:    - str: The absolute path to the file\n        134:\n        135:    Raises:\n        136:    - ValueError: If there's an error creating the file or directories,\n        137:                 or if the file_path is empty\n        138:    \"\"\"\n        139:    if not file_path:\n        140:        raise ValueError('File path cannot be empty')\n        141:    abs_path = os.path.abspath(file_path)\n        142:    dir_path = os.path.dirname(abs_path)\n        143:    if dir_path:\n        144:        try:\n        145:            os.makedirs(dir_path, exist_ok=True)\n        146:        except Exception as e:\n        147:            raise ValueError(f'Error creating directories {dir_path}: {str(e)}')\n        148:    if not os.path.exists(abs_path):\n        149:        try:\n        150:            with open(abs_path, 'w', encoding='utf-8') as f:\n        151:                f.write('')\n        152:        except Exception as e:\n        153:            raise ValueError(f'Error creating file {abs_path}: {str(e)}')\n        154:    return abs_path\n        155:\n        156:class ScopeTransformer(ast.NodeTransformer):\n        157:    \"\"\"AST transformer that handles scope-based Python code modifications.\"\"\"\n        158:\n        159:    def __init__(self, path_elements, new_nodes, insert_after=None, file_lines=None, file_tokens=None, new_tokens=None):\n        160:        self.original_path = path_elements\n        161:        self.new_nodes = new_nodes\n        162:        self.insert_after = insert_after\n        163:        self.file_lines = file_lines\n        164:        self.file_tokens = file_tokens or {}\n        165:        self.new_tokens = new_tokens or {}\n        166:        self.current_path = []\n        167:        self.success = False\n        168:        self.line_match_count = 0\n        169:        self.all_tokens = {**self.file_tokens, **self.new_tokens}\n        170:\n        171:    def visit_ClassDef(self, node):\n        172:        \"\"\"Visit a class definition node.\"\"\"\n        173:        if not self.original_path or node.name != self.original_path[0]:\n        174:            return self.generic_visit(node)\n        175:        self.current_path.append(node.name)\n        176:        remaining_path = self.original_path[1:]\n        177:        if not remaining_path:\n        178:            if self.insert_after:\n        179:                node = self._handle_insertion(node)\n        180:            else:\n        181:                self.success = True\n        182:                if len(self.new_nodes) == 1:\n        183:                    return self.new_nodes[0]\n        184:                else:\n        185:                    node.body = self.new_nodes\n        186:                    return node\n        187:        else:\n        188:            saved_path = self.original_path\n        189:            self.original_path = remaining_path\n        190:            node.body = [self.visit(child) for child in node.body]\n        191:            self.original_path = saved_path\n        192:        self.current_path.pop()\n        193:        return node\n        194:\n        195:    def visit_FunctionDef(self, node):\n        196:        \"\"\"Visit a function definition node.\"\"\"\n        197:        return self._handle_function_node(node)\n        198:\n        199:    def visit_AsyncFunctionDef(self, node):\n        200:        \"\"\"Visit an async function definition node.\"\"\"\n        201:        return self._handle_function_node(node)\n        202:\n        203:    def _handle_function_node(self, node):\n        204:        \"\"\"Common handling for both regular and async functions.\"\"\"\n        205:        if not self.original_path or node.name != self.original_path[0]:\n        206:            return self.generic_visit(node)\n        207:        self.current_path.append(node.name)\n        208:        remaining_path = self.original_path[1:]\n        209:        if not remaining_path:\n        210:            if self.insert_after:\n        211:                node = self._handle_insertion(node)\n        212:            else:\n        213:                self.success = True\n        214:                if len(self.new_nodes) == 1:\n        215:                    return self.new_nodes[0]\n        216:                else:\n        217:                    node.body = 