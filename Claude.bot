y replace within this class\n        588:    \"\"\"\n        589:    try:\n        590:        abs_path = _make_file(file_path)\n        591:        try:\n        592:            new_tree = ast.parse(_clean(new_function_def))\n        593:            new_func_node = None\n        594:            for node in new_tree.body:\n        595:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        596:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        597:                elif isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        598:                    new_func_node = node\n        599:            if new_func_node is None:\n        600:                return _process_error(ValueError('No function definition found in provided code'))\n        601:            with open(abs_path, 'r', encoding='utf-8') as file:\n        602:                content = file.read()\n        603:            tree = ast.parse(content)\n        604:        except Exception as e:\n        605:            return _process_error(ValueError(f'Error processing code: {str(e)}'))\n        606:\n        607:        class ClassScopedFunctionReplacer(ast.NodeTransformer):\n        608:\n        609:            def __init__(self, new_func_node, target_class=None):\n        610:                self.new_func_node = new_func_node\n        611:                self.target_class = target_class\n        612:                self.success = False\n        613:                self.in_target_class = False\n        614:\n        615:            def visit_ClassDef(self, node):\n        616:                if self.target_class is None or node.name == self.target_class:\n        617:                    old_in_target_class = self.in_target_class\n        618:                    self.in_target_class = True\n        619:                    node = self.generic_visit(node)\n        620:                    self.in_target_class = old_in_target_class\n        621:                return node\n        622:\n        623:            def visit_FunctionDef(self, node):\n        624:                if node.name == self.new_func_node.name:\n        625:                    if self.target_class is None or self.in_target_class:\n        626:                        self.success = True\n        627:                        return self.new_func_node\n        628:                return node\n        629:\n        630:            def visit_AsyncFunctionDef(self, node):\n        631:                return self.visit_FunctionDef(node)\n        632:        transformer = ClassScopedFunctionReplacer(new_func_node, class_name)\n        633:        tree = transformer.visit(tree)\n        634:        if not transformer.success:\n        635:            if class_name:\n        636:                return _process_error(ValueError(f\"Function '{new_func_node.name}' not found in class '{class_name}'\"))\n        637:            tree.body.append(new_func_node)\n        638:        try:\n        639:            updated_content = _py_ast_to_source(tree)\n        640:            with open(abs_path, 'w', encoding='utf-8') as file:\n        641:                file.write(updated_content)\n        642:        except Exception as e:\n        643:            return _process_error(e)\n        644:        context = f\"in class '{class_name}'\" if class_name else 'in file'\n        645:        action = 'replaced' if transformer.success else 'added'\n        646:        return f\"Function '{new_func_node.name}' has been {action} {context} '{abs_path}'.\"\n        647:    except Exception as e:\n        648:        return _process_error(e)\n        649:\n        650:def python_edit(target_scope: str, code: str, *, insert_after: str=None) -> str:\n        651:    \"\"\"\n        652:    Edit Python code using pytest-style scope syntax.\n        653:\n        654:    Parameters:\n        655:    ----------\n        656:    target_scope : str\n        657:        Location to edit in pytest-style scope syntax:\n        658:        - \"file.py\" (whole file)\n        659:        - \"file.py::MyClass\" (class)\n        660:        - \"file.py::my_function\" (function)\n        661:        - \"file.py::MyClass::method\" (method)\n        662:        - \"file.py::Outer::Inner::method\" (nested)\n        663:        - \"file.py::utils::helper_func\" (nested function)\n        664:\n        665:    code : str\n        666:        Python code to insert/replace. Will be cleaned/dedented.\n        667:        Import statements will be automatically extracted and handled.\n        668:\n        669:    insert_after : str, optional\n        670:        Where to insert the code. Can be either:\n        671:        - \"__FILE_START__\" (special token for file beginning)\n        672:        - A scope (\"MyClass::method\")\n        673:        - An exact line match\n        674:        If not specified, replaces the node at target_scope.\n        675:\n        676:    Returns:\n        677:    --------\n        678:    str\n        679:        Description of what was modified or error message\n        680:    \"\"\"\n        681:    try:\n        682:        file_path, *path_elements = target_scope.split('::')\n        683:        if not file_path.endswith('.py'):\n        684:            return _process_error(ValueError(f'File path must end with .py: {file_path}'))\n        685:        for element in path_elements:\n        686:            if not element.isidentifier():\n        687:                return _process_error(ValueError(f'Invalid identifier in path: {element}'))\n        688:        abs_path = _make_file(file_path)\n        689:        try:\n        690:            new_tree = ast.parse(_clean(code))\n        691:            import_nodes = []\n        692:            code_nodes = []\n        693:            for node in new_tree.body:\n        694:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        695:                    import_nodes.append(node)\n        696:                else:\n        697:                    code_nodes.append(node)\n        698:        except Exception as e:\n        699:            return _process_error(ValueError(f'Error parsing new code: {str(e)}'))\n        700:        if import_nodes:\n        701:            imports_code = '\\n'.join((_py_ast_to_source(node) for node in import_nodes))\n        702:            add_imports(file_path, imports_code)\n        703:        try:\n        704:            with open(abs_path, 'r', encoding='utf-8') as file:\n        705:                content = file.read()\n        706:            tree = ast.parse(content)\n        707:        except Exception as e:\n        708:            return _process_error(ValueError(f'Error reading/parsing file {abs_path}: {str(e)}'))\n        709:        if insert_after == '__FILE_START__':\n        710:            tree.body = code_nodes + tree.body\n        711:            try:\n        712:                updated_content = _py_ast_to_source(tree)\n        713:                with open(abs_path, 'w', encoding='utf-8') as file:\n        714:                    file.write(updated_content)\n        715:                return f\"Code inserted at start of '{abs_path}'.\"\n        716:            except Exception as e:\n        717:                return _process_error(e)\n        718:        transformer = ScopeTransformer(path_elements, code_nodes, insert_after)\n        719:        tree = transformer.visit(tree)\n        720:        if not transformer.success:\n        721:            if insert_after:\n        722:                return _process_error(ValueError(f'Insert point not found: {insert_after}'))\n        723:            else:\n        724:                return _process_error(ValueError(f'Target scope not found: {target_scope}'))\n        725:        try:\n        726:            updated_content = _py_ast_to_source(tree)\n        727:            with open(abs_path, 'w', encoding='utf-8') as file:\n        728:                file.write(updated_content)\n        729:        except Exception as e:\n        730:            return _process_error(e)\n        731:        action = 'inserted after' if insert_after else 'replaced at'\n        732:        scope_str = '::'.join(path_elements) if path_elements else 'file level'\n        733:        return f\"Code {action} {scope_str} in '{abs_path}'.\"\n        734:    except Exception as e:\n        735:        return _process_error(e)\n        736:\n        737:class ScopeTransformer(ast.NodeTransformer):\n        738:    \"\"\"AST transformer that handles scope-based Python code modifications.\"\"\"\n        739:\n        740:    def __init__(self, path_elements, new_nodes, insert_after=None):\n        741:        self.path = path_elements\n        742:        self.new_nodes = new_nodes\n        743:        self.insert_after = insert_after\n        744:        self.current_path = []\n        745:        self.success = False\n        746:        self.line_match_count = 0\n        747:\n        748:    def visit_ClassDef(self, node):\n        749:        \"\"\"Visit a class definition node.\"\"\"\n        750:        if not self.path or node.name != self.path[0]:\n        751:            return self.generic_visit(node)\n        752:        self.current_path.append(node.name)\n        753:        if len(self.current_path) == len(self.path):\n        754:            if self.insert_after:\n        755:                node = self._handle_insertion(node)\n        756:            else:\n        757:                self.success = True\n        758:                return self.new_nodes[0] if len(self.new_nodes) == 1 else node\n        759:        else:\n        760:            node = self.generic_visit(node)\n        761:        self.current_path.pop()\n        762:        return node\n        763:\n        764:    def visit_FunctionDef(self, node):\n        765:        \"\"\"Visit a function definition node.\"\"\"\n        766:        return self._handle_function_node(node)\n        767:\n        768:    def visit_AsyncFunctionDef(self, node):\n        769:        \"\"\"Visit an async function definition node.\"\"\"\n        770:        return self._handle_function_node(node)\n        771:\n        772:    def _handle_function_node(self, node):\n        773:        \"\"\"Common handling for both regular and async functions.\"\"\"\n        774:        if not self.path or node.name != self.path[0]:\n        775:            return self.generic_visit(node)\n        776:        self.current_path.append(node.name)\n        777:        if len(self.current_path) == len(self.path):\n        778:            if self.insert_after:\n        779:                node = self._handle_insertion(node)\n        780:            else:\n        781:                self.success = True\n        782:                return self.new_nodes[0] if len(self.new_nodes) == 1 else node\n        783:        else:\n        784:            node = self.generic_visit(node)\n        785:        self.current_path.pop()\n        786:        return node\n        787:\n        788:    def _handle_insertion(self, node):\n        789:        \"\"\"Handle inserting nodes after a specific point.\"\"\"\n        790:        if isinstance(self.insert_after, str) and '::' not in self.insert_after:\n        791:            source = _py_ast_to_source(node)\n        792:            lines = source.split('\\n')\n        793:            for i, line in enumerate(lines):\n        794:                if line.strip() == self.insert_after.strip():\n        795:                    self.line_match_count += 1\n        796:                    if self.line_match_count == 1:\n        797:                        indentation = len(line) - len(line.lstrip())\n        798:                        new_lines = []\n        799:                        for new_node in self.new_nodes:\n        800:                            new_source = _py_ast_to_source(new_node)\n        801:                            new_lines.extend(new_source.split('\\n'))\n        802:                        indented_lines = [' ' * indentation + line if line.strip() else line for line in new_lines]\n        803:                        lines[i:i + 1] = [lines[i]] + indented_lines\n        804:                        self.success = True\n        805:            if self.line_match_count == 0:\n        806:                return node\n        807:            elif self.line_match_count > 1:\n        808:                raise ValueError(f'Ambiguous insert_after - found {self.line_match_count} matches for: {self.insert_after}')\n        809:            new_source = '\\n'.join(lines)\n        810:            return ast.parse(new_source).body[0]\n        811:        else:\n        812:            if self.insert_after:\n        813:                insert_path = self.insert_after.split('::')\n        814:                if insert_path == self.current_path:\n        815:                    if isinstance(node, (ast.ClassDef, ast.Module)):\n        816:                        node.body.extend(self.new_nodes)\n        817:                    else:\n        818:                        new_body = []\n        819:                        for stmt in node.body:\n        820:                            new_body.append(stmt)\n        821:                        new_body.extend(self.new_nodes)\n        822:                        node.body = new_body\n        823:                    self.success = True\n        824:            return node"
