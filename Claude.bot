9:    ast.parse(tokenized)\n        520:    restored = detokenize_source(tokenized, token_map)\n        521:    print(f'DEBUG - Restored:\\n{restored}')\n        522:    assert restored == source\n        523:\n        524:def test_minimal_complex_indent():\n        525:    \"\"\"Test tokenization with complex indentation patterns\"\"\"\n        526:    source = 'def test():\\n        # Comment at level 1\\n        if True:\\n            # Comment at level 2\\n            if True:\\n                \"\"\"\\n                Docstring at\\n                level 3\\n                \"\"\"\\n                # Comment at level 3\\n                pass'\n        527:    tokenized, token_map = tokenize_source(source)\n        528:    print(f'DEBUG - Tokenized:\\n{tokenized}')\n        529:    print(f'DEBUG - Token map:\\n{token_map}')\n        530:    ast.parse(tokenized)\n        531:    restored = detokenize_source(tokenized, token_map)\n        532:    print(f'DEBUG - Restored:\\n{restored}')\n        533:    assert restored == source"
