                                                                                                                                                                                                                                                                                                                                                                                                                                 "file_path": "bots/tools/pytest_style_edit.py",
                                                                                                                                                                                                                                                                                                                                                                                                                                 "new_function_def": "\n                                                def _handle_file_level_edit(tree, import_nodes, code_nodes, file_lines, insert_at_start=False):\n                                                    \"\"\"Handle file-level edits with source preservation.\"\"\"\n                                                    # Separate imports and non-imports from existing tree\n                                                    existing_imports = []\n                                                    non_imports = []\n                                                    for node in tree.body:\n                                                        if isinstance(node, (ast.Import, ast.ImportFrom)):\n                                                            existing_imports.append(node)\n                                                        else:\n                                                            non_imports.append(node)\n                                                    \n                                                    # Order nodes based on insertion point\n                                                    if insert_at_start:\n                                                        all_nodes = import_nodes + code_nodes + existing_imports + non_imports\n                                                    else:\n                                                        all_nodes = existing_imports + import_nodes + non_imports + code_nodes\n                                                    \n                                                    # Find base indentation from original file\n                                                    base_indent = ''\n                                                    for line in file_lines:\n                                                        if line.strip():\n                                                            base_indent = ' ' * (len(line) - len(line.lstrip()))\n                                                            break\n                                                    \n                                                    # Preserve source of each node with proper indentation\n                                                    result_lines = []\n                                                    prev_node_had_comment = False\n                                                    \n                                                    for node in all_nodes:\n                                                        preserved = SourcePreservingNode(node, file_lines, base_indent)\n                                                        node_lines = preserved.to_string().split('\\n')\n                                                        \n                                                        # Add blank line between nodes unless previous ended with comment\n                                                        if result_lines and not prev_node_had_comment:\n                                                            result_lines.append('')\n                                                        \n                                                        result_lines.extend(node_lines)\n                                                        \n                                                        # Check if this node ends with a comment\n                                                        prev_node_had_comment = any(l.strip().startswith('#') for l in node_lines[-2:])\n                                                    \n                                                    # Ensure final newline\n                                                    return '\\n'.join(result_lines) + '\\n'"
                                                                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                                                                               }
