:    Returns:\n        321:    - tokenized_source: Source with tokens inserted\n        322:    - token_map: Mapping of tokens to original content\n        323:    \"\"\"\n        324:\n        325:    def contains_token(s: str) -> bool:\n        326:        return '__TOKEN__' in s\n        327:    token_map = {}\n        328:    current_hash = get_file_hash(source)\n        329:    token_counter = 0\n        330:    tokenized = source\n        331:    triple_quote_patterns = [r'\"\"\"[^\"\\\\]*(?:(?:\\\\.|\"(?!\"\"))[^\"\\\\]*)*\"\"\"', r\"'''[^'\\\\]*(?:(?:\\\\.|'(?!''))[^'\\\\]*)*'''\"]\n        332:    for pattern in triple_quote_patterns:\n        333:        while True:\n        334:            match = re.search(pattern, tokenized)\n        335:            if not match:\n        336:                break\n        337:            string_content = match.group()\n        338:            if contains_token(string_content):\n        339:                continue\n        340:            token_name, hex_val = create_token(string_content, token_counter, current_hash)\n        341:            token_map[hex_val] = string_content\n        342:            tokenized = tokenized[:match.start()] + hex_val + tokenized[match.end():]\n        343:            token_counter += 1\n        344:    lines = tokenized.split('\\n')\n        345:    processed_lines = []\n        346:    for line in lines:\n        347:        if not line.strip():\n        348:            processed_lines.append(line)\n        349:            continue\n        350:        indent = len(line) - len(line.lstrip())\n        351:        indentation = ' ' * indent\n        352:        content = line[indent:]\n        353:        if contains_token(content):\n        354:            processed_lines.append(line)\n        355:            continue\n        356:        if content.strip().startswith('#'):\n        357:            token_name, hex_val = create_token(content, token_counter, current_hash)\n        358:            token_map[hex_val] = content\n        359:            processed_lines.append(indentation + hex_val)\n        360:            token_counter += 1\n        361:            continue\n        362:        processed_line = content\n        363:        # Use simpler patterns to avoid catastrophic backtracking\n        364:        # Match strings but avoid catastrophic backtracking by using possessive quantifiers\n        365:        string_patterns = [r'\"[^\"\\\\]*(?:\\\\.[^\"\\\\]*)*\"', r\"'[^'\\\\]*(?:\\\\.[^'\\\\]*)*'\"]\n        366:        for pattern in string_patterns:\n        367:            while True:\n        368:                match = re.search(pattern, processed_line)\n        369:                if not match:\n        370:                    break\n        371:                string_content = match.group()\n        372:                if contains_token(string_content):\n        373:                    continue\n        374:                token_name, hex_val = create_token(string_content, token_counter, current_hash)\n        375:                token_map[hex_val] = string_content\n        376:                processed_line = processed_line[:match.start()] + hex_val + processed_line[match.end():]\n        377:                token_counter += 1\n        378:        # Handle inline comments - check for # that's not inside a token\n        379:        if '#' in processed_line:\n        380:            comment_start = processed_line.index('#')\n        381:            code = processed_line[:comment_start]\n        382:            comment = processed_line[comment_start:]\n        383:            token_name, hex_val = create_token(comment, token_counter, current_hash)\n        384:            token_map[hex_val] = comment\n        385:            # Preserve exact spacing between code and comment\n        386:            processed_line = code + hex_val\n        387:            token_counter += 1\n        388:            token_counter += 1\n        389:        processed_lines.append(indentation + processed_line)\n        390:    return ('\\n'.join(processed_lines), token_map)\n        391:\n        392:def detokenize_source(tokenized_source: str, token_map: Dict[str, str]) -> str:\n        393:    \"\"\"\n        394:    Restore original source from tokenized version.\n        395:\n        396:    Handles proper indentation of multiline content.\n        397:    \"\"\"\n        398:    result = tokenized_source\n        399:    for token_name, original in sorted(token_map.items(), key=lambda x: len(x[0]), reverse=True):\n        400:        while True:\n        401:            start = result.find(token_name)\n        402:            if start == -1:\n        403:                break\n        404:            if '\\n' in original:\n        405:                indent = get_indentation_at_position(result, start)\n        406:                indented = indent_multiline_content(original, indent)\n        407:                result = result[:start] + indented + result[start + len(token_name):]\n        408:            else:\n        409:                result = result[:start] + original + result[start + len(token_name):]\n        410:    return result\n        411:\n        412:def get_indentation_at_position(source: str, pos: int) -> str:\n        413:    \"\"\"Get the indentation level at a given position in source\"\"\"\n        414:    line_start = source.rfind('\\n', 0, pos) + 1\n        415:    return source[line_start:pos].replace(source[line_start:pos].lstrip(), '')\n        416:\n        417:def indent_multiline_content(content: str, indent: str) -> str:\n        418:    \"\"\"Indent multiline content while preserving internal formatting\"\"\"\n        419:    if not content.strip():\n        420:        return content\n        421:    lines = content.split('\\n')\n        422:    if len(lines) == 1:\n        423:        return content\n        424:    if all((line.startswith(' ') for line in lines[1:] if line.stri