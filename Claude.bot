 = source.split('\\n')\n        1569:        indents = [len(line) - len(line.lstrip()) for line in lines if line.strip()]\n        1570:        if not indents:\n        1571:            return source\n        1572:        min_indent = min(indents)\n        1573:        if min_indent == 0:\n        1574:            return source\n        1575:        return '\\n'.join((line[min_indent:] if line.strip() else '' for line in lines))\n        1576:\n        1577:    def _handle_insertion(self, node):\n        1578:        \"\"\"Handle inserting nodes after a specific point.\"\"\"\n        1579:        if isinstance(self.insert_after, str) and '::' not in self.insert_after:\n        1580:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        1581:                print(f'\\nDEBUG - Function node: {node.name}')\n        1582:                if node.lineno == node.end_lineno:\n        1583:                    line = self.file_lines[node.lineno - 1]\n        1584:                    return self._handle_one_line_function(node, line)\n        1585:                orig_source = self._preserve_node_source(node)\n        1586:                print(f'DEBUG - Original source:\\n{orig_source}')\n        1587:                norm_source = self._normalize_indentation(orig_source)\n        1588:                print(f'DEBUG - Normalized source:\\n{norm_source}')\n        1589:                lines = norm_source.split('\\n')\n        1590:                def_line = lines[0]\n        1591:                body_lines = lines[1:]\n        1592:                target = self.insert_after.strip()\n        1593:                print(f\"DEBUG - Looking for target: '{target}'\")\n        1594:                for i, line in enumerate(body_lines):\n        1595:                    line = line.rstrip()\n        1596:                    print(f\"DEBUG - Checking line: '{line}'\")\n        1597:                    if line.strip() == target:\n        1598:                    