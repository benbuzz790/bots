st that chat uses the loaded bot\n                    with patch('bots.flows.functional_prompts.chain') as mock_chain:\n                        mock_chain.return_value = ([\"response\"], [MagicMock()])\n                        \n                        # Call chat with the loaded bot\n                        cli._handle_chat(cli.context.bot_instance, \"Hello\")\n                        \n                        # Verify that chain was called with the loaded bot, not the original\n                        mock_chain.assert_called_once()\n                        called_bot = mock_chain.call_args[0][0]  # First argument to chain()\n                        self.assertEqual(called_bot, loaded_bot)\n                        self.assertNotEqual(called_bot, original_bot)\n            \n            if __name__ == '__main__':\n                unittest.main()\n            '@ | Out-File -FilePath \"tests/test_cli_integration.py\" -Encoding UTF8"
