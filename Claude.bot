                                                                                                                                                                                     "new_function_def": "\n                                                            def tokenize_source(source: str) -> Tuple[str, Dict[str, str]]:\n                                                                \"\"\"\n                                                                Tokenize source code, preserving exact formatting.\n                                                                \n                                                                Returns:\n                                                                - tokenized_source: Source with tokens inserted\n                                                                - token_map: Mapping of tokens to original content\n                                                                \"\"\"\n                                                                def contains_token(s: str) -> bool:\n                                                                    return \"TOKEN__\" in s\n                                                                \n                                                                token_map = {}\n                                                                current_hash = get_file_hash(source)\n                                                                token_counter = 0\n                                                                \n                                                                # Process line by line to maintain indentation\n                                                                lines = source.split('\\n')\n                                                                for i, line in enumerate(lines):\n                                                                    if contains_token(line):\n                                                                        continue\n                                                                        \n                                                                    # Get the indentation of this line\n                                                                    indent = len(line) - len(line.lstrip())\n                                                                    indentation = line[:indent]\n                                                                    content = line[indent:]\n                                                                    \n                                                                    # Process the line content\n                                                                    processed_line = content\n                                                                    \n                                                                    # Handle full-line comments and blank lines\n                                                                    if not content.strip() or content.strip().startswith('#'):\n                                                                        token = create_token(content, token_counter, current_hash)\n                                                                        token_map[token] = content\n                                                                        lines[i] = indentation + token\n                                                                        token_counter += 1\n                                                                        continue\n                                                                    \n                                                                    # Handle strings first\n                                                                    for pattern in [\n                                                                        r'\"\"\"(?:[^\"\\\\]|\\\\.)*\"\"\"',\n                                                                        r\"'''(?:[^'\\\\]|\\\\.)*'''\",\n                                                                        r'\"(?:[^\"\\\\]|\\\\.)*\"',\n                                                                        r\"'(?:[^'\\\\]|\\\\.)*'\"\n                                                                    ]:\n                                                                        while True:\n                                                                            match = re.search(pattern, processed_line)\n                                                                            if not match:\n                                                                                break\n                                                                            string_content = match.group()\n                                                                            token = create_token(string_content, token_counter, current_hash)\n                                                                            token_map[token] = string_content\n                                                                            processed_line = (\n                                                                                processed_line[:match.start()] +\n                                                                                token +\n                                                                                processed_line[match.end():]\n                                                                            )\n                                                                            token_counter += 1\n                                                                    \n                                                                    # Handle inline comments last\n                                                                    if '#' in processed_line:\n                                                                        code, comment = processed_line.split('#', 1)\n                                                                        comment = '#' + comment\n                                                                        token = create_token(comment, token_counter, current_hash)\n                                                                        token_map[token] = comment\n                                                                        processed_line = code.rstrip() + token\n                                                                        token_counter += 1\n                                                                    \n                                                                    lines[i] = indentation + processed_line\n                                                                \n                                                                return '\\n'.join(lines), token_map"
