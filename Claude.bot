                                                                                                                                                                                                                                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "type": "tool_result",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "tool_use_id": "toolu_01Xhi649Xz1jaJiaVxr6495w",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "content": "\n        1:import ast\n        2:import os\n        3:import textwrap\n        4:from bots.utils.helpers import _process_error, _clean, _py_ast_to_source\n        5:\n        6:def python_edit(target_scope: str, code: str, *, insert_after: str=None) -> str:\n        7:    \"\"\"\n        8:    Edit Python code using pytest-style scope syntax.\n        9:\n        10:    Parameters:\n        11:    ----------\n        12:    target_scope : str\n        13:        Location to edit in pytest-style scope syntax:\n        14:        - \"file.py\" (whole file)\n        15:        - \"file.py::MyClass\" (class)\n        16:        - \"file.py::my_function\" (function)\n        17:        - \"file.py::MyClass::method\" (method)\n        18:        - \"file.py::Outer::Inner::method\" (nested)\n        19:        - \"file.py::utils::helper_func\" (nested function)\n        20:\n        21:    code : str\n        22:        Python code to insert/replace. Will be cleaned/dedented.\n        23:        Import statements will be automatically extracted and handled.\n        24:\n        25:    insert_after : str, optional\n        26:        Where to insert the code. Can be either:\n        27:        - \"__FILE_START__\" (special token for file beginning)\n        28:        - A scope (\"MyClass::method\")\n        29:        - An exact line match\n        30:        If not specified, replaces the node at target_scope.\n        31:\n        32:    Returns:\n        33:    --------\n        34:    str\n        35:        Description of what was modified or error message\n        36:    \"\"\"\n        37:    try:\n        38:        file_path, *path_elements = target_scope.split('::')\n        39:        if not file_path.endswith('.py'):\n        40:            return _process_error(ValueError(f'File path must end with .py: {file_path}'))\n        41:        for element in path_elements:\n        42:            if not element.isidentifier():\n        43:                return _process_error(ValueError(f'Invalid identifier in path: {element}'))\n        44:        abs_path = _make_file(file_path)\n        45:        try:\n        46:            new_tree = ast.parse(_clean(code))\n        47:            import_nodes = []\n        48:            code_nodes = []\n        49:            for node in new_tree.body:\n        50:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        51:                    import_nodes.append(node)\n        52:                else:\n        53:                    code_nodes.append(node)\n        54:        except Exception as e:\n        55:            return _process_error(ValueError(f'Error parsing new code: {str(e)}'))\n        56:        try:\n        57:            with open(abs_path, 'r', encoding='utf-8') as file:\n        58:                content = file.read()\n        59:            file_lines = content.split('\\n')\n        60:            tree = ast.parse(content) if content.strip() else ast.Module(body=[], type_ignores=[])\n        61:        except Exception as e:\n        62:            return _process_error(ValueError(f'Error reading/parsing file {abs_path}: {str(e)}'))\n        63:        existing_imports = []\n        64:        non_imports = []\n        65:        for node in tree.body:\n        66:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        67:                existing_imports.append(node)\n        68:            else:\n        69:                non_imports.append(node)\n        70:        if insert_after == '__FILE_START__':\n        71:            tree.body = import_nodes + code_nodes + existing_imports + non_imports\n        72:            try:\n        73:                updated_content = _py_ast_to_source(tree)\n        74:                with open(abs_path, 'w', encoding='utf-8') as file:\n        75:                    file.write(updated_content)\n        76:                return f\"Code inserted at start of '{abs_path}'.\"\n        77:            except Exception as e:\n        78:                return _process_error(e)\n        79:        if not path_elements:\n        80:            tree.body = existing_imports + import_nodes + non_imports + code_nodes\n        81:            try:\n        82:                updated_content = _py_ast_to_source(tree)\n        83:                with open(abs_path, 'w', encoding='utf-8') as file:\n        84:                    file.write(updated_content)\n        85:                return f\"Code added at file level in '{abs_path}'.\"\n        86:            except Exception as e:\n        87:                return _process_error(e)\n        88:        tree.body = existing_imports + import_nodes + non_imports\n        89:        transformer = ScopeTransformer(path_elements, code_nodes, insert_after, file_lines)\n        90:        modified_tree = transformer.visit(tree)\n        91:        if not transformer.success:\n        92:            if insert_after:\n        93:                return _process_error(ValueError(f'Insert point not found: {insert_after}'))\n        94:            else:\n        95:                return _process_error(ValueError(f'Target scope not found: {target_scope}'))\n        96:        try:\n        97:            updated_content = _py_ast_to_source(modified_tree)\n        98:            with open(abs_path, 'w', encoding='utf-8') as file:\n        99:                file.write(updated_content)\n        100:        except Exception as e:\n        101:            return _process_error(e)\n        102:        action = 'inserted after' if insert_after else 'replaced at'\n        103:        scope_str = '::'.join(path_elements) if path_elements else 'file level'\n        104:        return f\"Code {action} {scope_str} in '{abs_path}'.\"\n        105:    except Exception as e:\n        106:        return _process_error(e)\n        107:\n        108:def _make_file(file_path: str) -> str:\n        109:    \"\"\"\n        110:    Creates a file and its parent directories if they don't exist.\n        111:    Converts relative paths to absolute paths.\n        112:\n        113:    Parameters:\n        114:    - file_path (str): The path to the file to be created\n        115:\n        116:    Returns:\n        117:    - str: The absolute path to the file\n        118:\n        119:    Raises:\n        120:    - ValueError: If there's an error creating the file or directories,\n        121:                 or if the file_path is empty\n        122:    \"\"\"\n        123:    if not file_path:\n        124:        raise ValueError('File path cannot be empty')\n        125:    abs_path = os.path.abspath(file_path)\n        126:    dir_path = os.path.dirname(abs_path)\n        127:    if dir_path:\n        128:        try:\n        129:            os.makedirs(dir_path, exist_ok=True)\n        130:        except Exception as e:\n        131:            raise ValueError(f'Error creating directories {dir_path}: {str(e)}')\n        132:    if not os.path.exists(abs_path):\n        133:        try:\n        134:            with open(abs_path, 'w', encoding='utf-8') as f:\n        135:                f.write('')\n        136:        except Exception as e:\n        137:            raise ValueError(f'Error creating file {abs_path}: {str(e)}')\n        138:    return abs_path\n        139:\n        140:class ScopeTransformer(ast.NodeTransformer):\n        141:    \"\"\"AST transformer that handles scope-based Python code modifications.\"\"\"\n        142:\n        143:    def __init__(self, path_elements, new_nodes, insert_after=None, file_lines=None):\n        144:        self.original_path = path_elements\n        145:        self.new_nodes = new_nodes\n        146:        self.insert_after = insert_after\n        147:        self.file_lines = file_lines\n        148:        self.current_path = []\n        149:        self.success = False\n        150:        self.line_match_count = 0\n        151:\n        152:    def visit_ClassDef(self, node):\n        153:        \"\"\"Visit a class definition node.\"\"\"\n        154:        if not self.original_path or node.name != self.original_path[0]:\n        155:            return self.generic_visit(node)\n        156:        self.current_path.append(node.name)\n        157:        remaining_path = self.original_path[1:]\n        158:        if not remaining_path:\n        159:            if self.insert_after:\n        160:                node = self._handle_insertion(node)\n        161:            else:\n        162:                self.success = True\n        163:                if len(self.new_nodes) == 1:\n        164:                    return self.new_nodes[0]\n        165:                else:\n        166:                    node.body = self.new_nodes\n        167:                    return node\n        168:        else:\n        169:            saved_path = self.original_path\n        170:            self.original_path = remaining_path\n        171:            node.body = [self.visit(child) for child in node.body]\n        172:            self.original_path = saved_path\n        173:        self.current_path.pop()\n        174:        return node\n        175:\n        176:    def visit_FunctionDef(self, node):\n        177:        \"\"\"Visit a function definition node.\"\"\"\n        178:        return self._handle_function_node(node)\n        179:\n        180:    def visit_AsyncFunctionDef(self, node):\n        181:        \"\"\"Visit an async function definition node.\"\"\"\n        182:        return self._handle_function_node(node)\n        183:\n        184:    def _handle_function_node(self, node):\n        185:        \"\"\"Common handling for both regular and async functions.\"\"\"\n        186:        if not self.original_path or node.name != self.original_path[0]:\n        187:            return self.generic_visit(node)\n        188:        self.current_path.append(node.name)\n        189:        remaining_path = self.original_path[1:]\n        190:        if not remaining_path:\n        191:            if self.insert_after:\n        192:                node = self._handle_insertion(node)\n        193:            else:\n        194:                self.success = True\n        195:                if len(self.new_nodes) == 1:\n        196:                    return self.new_nodes[0]\n        197:                else:\n        198:                    node.body = self.new_nodes\n        199:                    return node\n        200:        else:\n        201:            saved_path = self.original_path\n        202:            self.original_path = remaining_path\n        203:            node.body = [self.visit(child) for child in node.body]\n        204:            self.original_path = saved_path\n        205:        self.current_path.pop()\n        206:        return node\n        207:\n        208:    def _handle_one_line_function(self, node, line):\n        209:        \"\"\"Special handling for one-line function definitions\"\"\"\n        210:        if ': pass' in line or ':pass' in line:\n        211:            base_indent = len(line) - len(line.lstrip())\n        212:            def_line = line.rstrip()\n        213:            if self.insert_after == 'pass':\n        214:                def_line = def_line.replace(': pass', ':').replace(':pass', ':')\n        215:                body_indent = base_indent + 4\n        216:                body_lines = []\n        217:                body_lines.append(' ' * body_indent + 'pass')\n        218:                for new_node in self.new_nodes:\n        219:                    node_lines = _py_ast_to_source(new_node).split('\\n')\n        220:                    for nl in node_lines:\n        221:                        if nl.strip():\n        222:                            body_lines.append(' ' * body_indent + nl.lstrip())\n        223:                new_source = def_line + '\\n' + '\\n'.join(body_lines)\n        224:                try:\n        225:                    new_node = ast.parse(new_source).body[0]\n        226:                    self.success = True\n        227:                    return new_node\n        228:                except Exception:\n        229:                    normalized = textwrap.dedent(new_source)\n        230:                    try:\n        231:                        new_node = ast.parse(normalized).body[0]\n        232:                        self.success = True\n        233:                        return new_node\n        234:                    except Exception:\n        235:                        pass\n        236:        return node\n        237:\n        238:    def _handle_insertion(self, node):\n        239:        \"\"\"Handle inserting nodes after a specific point.\"\"\"\n        240:        if isinstance(self.insert_after, str) and '::' not in self.insert_after:\n        241:            if not isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        242:                return node\n        243:            # Handle one-line functions\n        244:            if node.lineno == node.end_lineno:\n        245:                return self._handle_one_line_function(node, self.file_lines[node.lineno - 1])\n        246:            # Get the original source lines including comments\n        247:            func_lines = self.file_lines[node.lineno - 1:node.end_lineno]\n        248:            if not func_lines:\n        249:                return node\n        250:            # Find the target line while preserving exact whitespace\n        251:            target = self.insert_after.strip()\n        252:            for i, line in enumerate(func_lines):\n        253:                if line.strip() == target:\n        254:                    self.line_match_count += 1\n        255:                    if self.line_match_count == 1:\n        256:                        # Get exact indentation from the target line\n        257:                        current_indent = len(line) - len(line.lstrip())\n        258:                        # Create properly indented insertion lines\n        259:                        insertion = []\n        260:                        for new_node in self.new_nodes:\n        261:                            node_lines = _py_ast_to_source(new_node).split('\\n')\n        262:                            for nl in node_lines:\n        263:                                if nl.strip():\n        264:                                    insertion.append(' ' * current_indent + nl.lstrip())\n        265:                                else:\n        266:                                    # Preserve blank line indentation\n        267:                                    insertion.append(' ' * current_indent)\n        268:                        # Insert after the target line, preserving the target\n        269:                        func_lines[i:i + 1] = [func_lines[i]] + insertion\n        270:                        self.success = True\n        271:                        break\n        272:            if self.line_match_count == 0:\n        273:                return node\n        274:            elif self.line_match_count > 1:\n        275:                raise ValueError(f'Ambiguous insert_after - found {self.line_match_count} matches for: {self.insert_after}')\n        276:            # Store the modified source on the node\n        277:            node._source = '\\n'.join(func_lines)\n        278:            self.success = True\n        279:            return node\n        280:        else:\n        281:            # Handle scope-based insertion\n        282:            if self.insert_after:\n        283:                target_path = self.insert_after.split('::')\n        284:                current_path = self.current_path\n        285:                if len(current_path) == len(target_path) and all(c == t for c, t in zip(current_path, target_path)):\n        286:                    self.success = True\n        287:                    if isinstance(node, ast.ClassDef):\n        288:                        node.body.extend(self.new_nodes)\n        289:                    else:\n        290:                        for new_node in self.new_nodes:\n        291:                            node.body.append(new_node)\n        292:            return node\n        293:    def _preserve_node_source(self, node):\n        294:        \"\"\"Get the original source of a node, preserving comments and formatting\"\"\"\n        295:        if hasattr(node, 'lineno') and hasattr(node, 'end_lineno'):\n        296:            lines = self.file_lines[node.lineno - 1:node.end_lineno]\n        297:            return '\\n'.join(lines)\n        298:        return _py_ast_to_source(node)"
