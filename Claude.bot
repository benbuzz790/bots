dentation level at a given position in source\"\"\"\n        424:    line_start = source.rfind('\\n', 0, pos) + 1\n        425:    return source[line_start:pos].replace(source[line_start:pos].lstrip(), '')\n        426:\n        427:def indent_multiline_content(content: str, indent: str) -> str:\n        428:    \"\"\"Indent multiline content while preserving internal formatting\"\"\"\n        429:    if not content.strip():\n        430:        return content\n        431:    lines = content.split('\\n')\n        432:    if len(lines) == 1:\n        433:        return content\n        434:    if all((line.startswith(' ') for line in lines[1:] if line.strip())):\n        435:        return content\n        436:    result = [lines[0]]\n        437:    for line in lines[1:]:\n        438:        if line.strip():\n        439:            result.append(indent + line)\n        440:        else:\n        441:            result.append(line)\n        442:    return '\\n'.join(result)"
