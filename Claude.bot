                                                                                                                                                                                                                                                                                                                                             "code": "#!/usr/bin/env python3\n\"\"\"\nScript to fix test_terminal_tools.py by adding cwd output stripping to failing tests.\n\"\"\"\n\nimport re\n\ndef fix_test_file():\n    with open('tests/test_terminal_tools.py', 'r', encoding='utf-8') as f:\n        content = f.read()\n    \n    # Add helper function after assertContainsNormalized\n    helper_function = \"\"\"\n    def strip_cwd_output(self, text: str) -> str:\n        \\\"\\\"\\\"\n        Strip the [System: current directory <...>] line from the beginning of output.\n        This is added by the terminal tools to show the current working directory.\n        \\\"\\\"\\\"\n        if not text:\n            return text\n        lines = text.splitlines()\n        if lines and lines[0].startswith('[System: current directory'):\n            return '\\\\n'.join(lines[1:])\n        return text\n\"\"\"\n    \n    # Find the end of assertContainsNormalized method\n    pattern = r'(def assertContainsNormalized.*?self\\.assertTrue.*?\\n)'\n    match = re.search(pattern, content, re.DOTALL)\n    if match:\n        insert_pos = match.end()\n        content = content[:insert_pos] + helper_function + content[insert_pos:]\n    \n    # Simple replacements for the failing tests\n    replacements = [\n        # test_stateful_basic_use\n        (\"self.assertEqual(self.normalize_text('Hello, World!'), self.normalize_text(result))\",\n         \"self.assertEqual(self.normalize_text('Hello, World!'), self.normalize_text(self.strip_cwd_output(result)))\"),\n        \n        # test_stateful_no_output\n        (\"self.assertEqual(self.normalize_text(''), self.normalize_text(result))\",\n         \"self.assertEqual(self.normalize_text(''), self.normalize_text(self.strip_cwd_output(result)))\"),\n        \n        # test_stateful_encoding_environment\n        (\"self.assertEqual(self.normalize_text('utf-8'), self.normalize_text(result))\",\n         \"self.assertEqual(self.normalize_text('utf-8'), self.normalize_text(self.strip_cwd_output(result)))\"),\n        \n        # test_basic_input_handling\n        (\"self.assertEqual(self.normalize_text('TestUser'), self.normalize_text(result))\",\n         \"self.assertEqual(self.normalize_text('TestUser'), self.normalize_text(self.strip_cwd_output(result)))\"),\n        \n        # test_multiple_input_requests\n        (\"self.assertEqual(self.normalize_text('Value1 and Value2'), self.normalize_text(output))\",\n         \"self.assertEqual(self.normalize_text('Value1 and Value2'), self.normalize_text(self.strip_cwd_output(output)))\"),\n        \n        (\"self.assertEqual(self.normalize_text('NewValue1 and Value2'), self.normalize_text(output))\",\n         \"self.assertEqual(self.normalize_text('NewValue1 and Value2'), self.normalize_text(self.strip_cwd_output(output)))\"),\n        \n        # Line splitting fixes\n        (\"lines = output.splitlines()\",\n         \"lines = self.strip_cwd_output(output).splitlines()\"),\n        \n        (\"lines = result.splitlines()\",\n         \"lines = self.strip_cwd_output(result).splitlines()\"),\n    ]\n    \n    for old, new in replacements:\n        content = content.replace(old, new)\n    \n    with open('tests/test_terminal_tools.py', 'w', encoding='utf-8') as f:\n        f.write(content)\n    \n    print(\"Fixed test_terminal_tools.py\")\n\nif __name__ == '__main__':\n    fix_test_file()"
                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                           }
