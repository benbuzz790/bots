  1121:                    print('DEBUG - No matches found')\n        1122:                    return node\n        1123:                elif self.line_match_count > 1:\n        1124:                    raise ValueError(f'Ambiguous insert_after - found {self.line_match_count} matches for: {self.insert_after}')\n        1125:                body_source = '\\n'.join((line[base_indent:] for line in body_lines))\n        1126:                print(f'DEBUG - Body source:\\n{body_source}')\n        1127:                try:\n        1128:                    body_tree = ast.parse(body_source)\n        1129:                    node.body = body_tree.body\n        1130:                    return node\n        1131:                except Exception as e:\n        1132:                    print(f'DEBUG - Parse error: {str(e)}')\n        1133:                    return node\n        1134:            return node\n        1135:        else:\n        1136:            if self.insert_after:\n        1137:                target_path = self.insert_after.split('::')\n        1138:                current_path = self.current_path\n        1139:                print(f'DEBUG - Scope insertion: target={target_path}, current={current_path}')\n        1140:                if len(current_path) == len(target_path) and all((c == t for c, t in zip(current_path, target_path))):\n        1141:                    self.success = True\n        1142:                    if isinstance(node, ast.ClassDef):\n        1143:                        node.body.extend(self.new_nodes)\n        1144:                    else:\n        1145:                        for new_node in self.new_nodes:\n        1146:                            node.body.append(new_node)\n        1147:            return node\n        1148:\n        1149:    def _get_node_source(self, node):\n        1150:        \"\"\"Get the full source of a node, including comments\"\"\"\n        1151:        if not hasattr(node, 'lineno') or not hasattr(node, 'end_lineno'):\n        1152:            return _py_ast_to_source(node)\n        1153:        lines = self.file_lines[node.lineno - 1:node.end_lineno]\n        1154:        return '\\n'.join(lines)\n        1155:\n        1156:    def _get_node_body_source(self, node):\n        1157:        \"\"\"Get the body source of a node, including comments\"\"\"\n        1158:        if not hasattr(node, 'lineno') or not hasattr(node, 'end_lineno'):\n        1159:            return _py_ast_to_source(node)\n        1160:        lines = self.file_lines[node.lineno:node.end_lineno]\n        1161:        if not lines:\n        1162:            return ''\n        1163:        base_indent = 0\n        1164:        for line in lines:\n        1165:            if line.strip():\n        1166:                base_indent = len(line) - len(line.lstrip())\n        1167:                break\n        1168:        return '\\n'.join((line[base_indent:] if line.strip() else '' for line in lines))\n        1169:\n        1170:    def _handle_insertion(self, node):\n        1171:        \"\"\"Handle inserting nodes after a specific point.\"\"\"\n        1172:        if isinstance(self.insert_after, str) and '::' not in self.insert_after:\n        1173:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        1174:                print(f'\\nDEBUG - Function node: {node.name}')\n        1175:                body_source = self._get_node_body_source(node)\n        1176:                body_lines = body_source.split('\\n')\n        1177:                print(f'DEBUG - Body source:\\n{body_source}')\n        1178:                target = self.insert_after.strip()\n        1179:                print(f\"DEBUG - Looking for target: '{target}'\")\n        1180:                for i, line in enumerate(body_lines):\n        1181:                    line = line.rstrip()\n        1182:                    print(f\"DEBUG - Checking line: '{line}'\")\n        1183:                    if line.strip() == target:\n        1184:                        print(f'DEBUG - Found match at line {i}')\n        1185:                        self.line_match_count += 1\n        1186:                        if self.line_match_count == 1:\n        1187:                            base_indent = len(line) - len(line.lstrip())\n        1188:                            print(f'DEBUG - Base indent: {base_indent}')\n        1189:                            insertion = []\n        1190:                            for new_node in self.new_nodes:\n        1191:                                node_lines = _py_ast_to_source(new_node).split('\\n')\n        1192:                                for nl in node_lines:\n        1193:                                    if nl.strip():\n        1194:                                        insertion.append(' ' * base_indent + nl.lstrip())\n        1195:                                    else:\n        1196:                                        insertion.append('')\n        1197:                            print(f'DEBUG - Insertion lines: {insertion}')\n        1198:                            body_lines[i:i + 1] = [body_lines[i]] + insertion\n        1199:                            self.success = True\n        1200:                            break\n        1201:                if self.line_match_count == 0:\n        1202:                    print('DEBUG - No matches found')\n        1203:                    return node\n        1204:                elif self.line_match_count > 1:\n        1205:                    raise ValueError(f'Ambiguous insert_after - found {self.line_match_count} matches for: {self.insert_after}')\n        1206:                func_def = self._get_node_source(node).split('\\n')[0]\n        1207:                new_source = func_def + '\\n' + '\\n'.join(body_lines)\n        1208:                print(f'DEBUG - New source:\\n{new_source}')\n        1209:                try:\n        1210:                    new_node = ast.parse(new_source).body[0]\n        1211:                    return new_node\n        1212:                except Exception as e:\n        1213:                    print(f'DEBUG - Parse error: {str(e)}')\n        1214:                    return node\n        1215:        else:\n        1216:            if self.insert_after:\n        1217:                target_path = self.insert_after.split('::')\n        1218:                current_path = self.current_path\n        1219:                print(f'DEBUG - Scope insertion: target={target_path}, current={current_path}')\n        1220:                if target_path == current_path:\n        1221:                    self.success = True\n        1222:                    if isinstance(node, ast.ClassDef):\n        1223:                        node.body.extend(self.new_nodes)\n        1224:                    else:\n        1225:                        for new_node in self.new_nodes:\n        1226:                            node.body.append(new_node)\n        1227:            return node\n        1228:\n        1229:    def _get_node_body_source(self, node):\n        1230:        \"\"\"Get the body source of a node, including comments, preserving indentation\"\"\"\n        1231:        if not hasattr(node, 'lineno') or not hasattr(node, 'end_lineno'):\n        1232:            return _py_ast_to_source(node)\n        1233:        if node.lineno == node.end_lineno:\n        1234:            line = self.file_lines[node.lineno - 1]\n        1235:            if ': pass' in line:\n        1236:                base_indent = len(line) - len(line.lstrip())\n        1237:                return ' ' * (base_indent + 4) + 'pass'\n        1238:        lines = self.file_lines[node.lineno:node.end_lineno]\n        1239:        if not lines:\n        1240:            return ''\n        1241:        def_line = self.file_lines[node.lineno - 1]\n        1242:        base_indent = len(def_line) - len(def_line.lstrip())\n        1243:        body_indent = base_indent + 4\n        1244:        return '\\n'.join((' ' * body_indent + line.lstrip() if line.strip() else '' for line in lines))\n        1245:\n        1246:    def _handle_insertion(self, node):\n        1247:        \"\"\"Handle inserting nodes after a specific point.\"\"\"\n        1248:        if isinstance(self.insert_after, str) and '::' not in self.insert_after:\n        1249:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        1250:                print(f'\\nDEBUG - Function node: {node.name}')\n        1251:                def_line = self.file_lines[node.lineno - 1]\n        1252:                base_indent = len(def_line) - len(def_line.lstrip())\n        1253:                body_indent = base_indent + 4\n        1254:                body_source = self._get_node_body_source(node)\n        1255:                body_lines = body_source.split('\\n')\n        1256:                print(f'DEBUG - Body source:\\n{body_source}')\n        1257:                target = self.insert_after.strip()\n        1258:                print(f\"DEBUG - Looking for target: '{target}'\")\n        1259:                for i, line in enumerate(body_lines):\n        1260:                    line = line.rstrip()\n        1261:                    print(f\"DEBUG - Checking line: '{line}'\")\n        1262:                    if line.strip() == target:\n        1263:                        print(f'DEBUG - Found match at line {i}')\n        1264:                        self.line_match_count += 1\n        1265:                        if self.line_match_count == 1:\n        1266:                            insertion = []\n        1267:                            for new_node in self.new_nodes:\n        1268:                                node_lines = _py_ast_to_source(new_node).split('\\n')\n        1269:                                for nl in node_lines:\n        1270:                                    if nl.strip():\n     