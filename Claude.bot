89:                            node.body.append(new_node)\n        1390:            return node\n        1391:\n        1392:    def _handle_one_line_function(self, node, line):\n        1393:        \"\"\"Special handling for one-line function definitions\"\"\"\n        1394:        print(f'DEBUG - Handling one-line function: {line}')\n        1395:        if ': pass' in line or ':pass' in line:\n        1396:            base_indent = len(line) - len(line.lstrip())\n        1397:            def_line = line.rstrip()\n        1398:            if self.insert_after == 'pass':\n        1399:                def_line = def_line.replace(': pass', ':').replace(':pass', ':')\n        1400:                body_indent = base_indent + 4\n        1401:                body_lines = []\n        1402:                body_lines.append(' ' * body_indent + 'pass')\n        1403:                for new_node in self.new_nodes:\n        1404:                    node_lines = _py_ast_to_source(new_node).split('\\n')\n        1405:                    for nl in node_lines:\n        1406:                        if nl.strip():\n        1407:                            body_lines.append(' ' * body_indent + nl.lstrip())\n        1408:                new_source = def_line + '\\n' + '\\n'.join(body_lines)\n        1409:                print(f'DEBUG - Expanded source:\\n{new_source}')\n        1410:                try:\n        1411:                    new_node = ast.parse(new_source).body[0]\n        1412:                    self.success = True\n        1413:                    return new_node\n        1414:                except Exception as e:\n        1415:                    print(f'DEBUG - Parse error: {str(e)}')\n        1416:                    normalized = textwrap.dedent(new_source)\n        1417:                    try:\n        1418:                        new_node = ast.parse(normalized).body[0]\n        1419:                        self.success = True\n        1420:                        return new_node\n        1421:                    except Exception as e2:\n        1422:                        print(f'DEBUG - Second parse error: {str(e2)}')\n        1423:        return node\n        1424:\n        1425:    def _preserve_node_source(self, node):\n        1426:        \"\"\"Get the original source of a node, preserving comments and formatting\"\"\"\n        1427:        if hasattr(node, 'lineno') and hasattr(node, 'end_lineno'):\n        1428:            lines = self.file_lines[node.lineno - 1:node.end_lineno]\n        1429:            return '\\n'.join(lines)\n        1430:        return _py_ast_to_source(node)\n        1431:\n        1432:    def _handle_insertion(self, node):\n        1433:        \"\"\"Handle inserting nodes after a specific point.\"\"\"\n        1434:        if isinstance(self.insert_after, str) and '::' not in self.insert_after:\n        1435:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        1436:                print(f'\\nDEBUG - Function node: {node.name}')\n        1437:                if node.lineno == node.end_lineno:\n        1438:                    line = self.file_lines[node.lineno - 1]\n        1439:                    return self._handle_one_line_function(node, line)\n        1440:                orig_source = self._preserve_node_source(node)\n        1441:                print(f'DEBUG - Original source:\\n{orig_source}')\n        1442:                lines = orig_source.split('\\n')\n        1443:                def_line = lines[0]\n        1444:                body_lines = lines[1:]\n        1445:                base_indent = len(def_line) - len(def_line.lstrip())\n        1446:                body_indent = base_indent + 4\n        1447:                target = self.insert_after.strip()\n        1448:                print(f\"DEBUG - Looking for target: '{target}'\")\n        1449:                for i, line in enumerate(body_lines):\n        1450:                    line = line.rstrip()\n        1451:                    print(f\"DEBUG - Checking line: '{line}'\")\n        1452:                    if line.strip() == target:\n        1453:                        print(f'DEBUG - Found match at line {i}')\n        1454:                        self.line_match_count += 1\n        1455:                        if self.line_match_count == 1:\n        1456:                            insertion = []\n        1457:                            for new_node in self.new_nodes:\n        1458:                                node_lines = _py_ast_to_source(new_node).split('\\n')\n        1459:                                for nl in node_lines:\n        1460:                                    if nl.strip():\n        1461:                                        insertion.append(' ' * body_indent + nl.lstrip())\n        1462:                                    else:\n        1463:                                        insertion.append('')\n        1464:                            print(f'DEBUG - Insertion lines: {insertion}')\n        1465:                            body_lines[i:i + 1] = [body_lines[i]] + insertion\n        1466:                            self.success = True\n        1467:                            break\n        1468:                if self.line_match_count == 0:\n        1469:                    print('DEBUG - No matches found')\n        1470:                    return node\n        1471:                elif self.line_match_count > 1:\n        1472:                    raise ValueError(f'Ambiguous insert_after - found {self.line_match_count} matches for: {self.insert_after}')\n        1473:                new_source = def_line + '\\n' + '\\n'.join((l for l in body_lines if l is not None))\n        1474:                print(f'DEBUG - New source:\\n{new_source}')\n        1475:                try:\n        1476:                    body_source = '\\n'.join((l.strip() for l in body_lines if l.strip()))\n        1477:                    body_tree = ast.parse(body_source)\n        1478:                    node.body = body_tree.body\n        1479:                    return node\n        1480:                except Exception as e:\n        1481:                    print(f'DEBUG - Parse error: {str(e)}')\n        1482:                    return node\n        1483:            return node\n        1484:        else:\n        1485:            if self.insert_after:\n        1486:                target_path = self.insert_after.split('::')\n        1487:                current_path = self.current_path\n        1488:                print(f'DEBUG - Scope insertion: target={target_path}, current={current_path}')\n        1489:                if target_path == current_path:\n        1490:                    self.success = True\n        1491:                    if isinstance(node, ast.ClassDef):\n        1492:                        node.body.extend(self.new_nodes)\n        1493:                    else:\n        1494:                        for new_node in self.new_nodes:\n        1495:                            node.body.append(new_node)\n        1496:            return node\n        1497:\n        1498:    def _handle_insertion(self, node):\n        1499:        \"\"\"Handle inserting nodes after a specific point.\"\"\"\n        1500:        if isinstance(self.insert_after, str) and '::' not in self.insert_after:\n        1501:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        1502:                print(f'\\nDEBUG - Function node: {node.name}')\n        1503:                if node.lineno == node.end_lineno:\n        1504:                    line = self.file_lines[node.lineno - 1]\n        1505:                    return self._handle_one_line_function(node, line)\n        1506:                orig_source = self._preserve_node_source(node)\n        1507:                print(f'DEBUG - Original source:\\n{orig_source}')\n        1508:                lines = orig_source.split('\\n'