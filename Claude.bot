                                                                                                              "content": "\n        1:import os\n        2:import pytest\n        3:from textwrap import dedent\n        4:from bots.tools.python_edit import python_edit\n        5:from bots.tools.python_edit import tokenize_source, detokenize_source\n        6:import ast\n        7:\n        8:def setup_test_file(tmp_path, content):\n        9:    \"\"\"Helper to create a test file with given content\"\"\"\n        10:    if isinstance(tmp_path, str):\n        11:        os.makedirs(tmp_path, exist_ok=True)\n        12:        test_file = os.path.join(tmp_path, 'test_file.py')\n        13:    else:\n        14:        test_file = os.path.join(str(tmp_path), 'test_file.py')\n        15:    with open(test_file, 'w', encoding='utf-8') as f:\n        16:        f.write(dedent(content))\n        17:    return test_file\n        18:\n        19:@pytest.fixture\n        20:def test_file(tmp_path):\n        21:    \"\"\"Create a test file with various Python constructs\"\"\"\n        22:    content = '\\n        import os\\n        from typing import List, Optional\\n\\n        def outer_func():\\n            def inner_func():\\n                pass\\n            return inner_func\\n\\n        class OuterClass:\\n            def method(self):\\n                pass\\n\\n            class InnerClass:\\n                @staticmethod\\n                def static_method():\\n                    pass\\n\\n                async def async_method(self):\\n                    pass\\n\\n            def another_method(self):\\n                # Insert here\\n                pass\\n    '\n        23:    return setup_test_file(tmp_path, content)\n        24:\n        25:def test_basic_file_level_edit(test_file):\n        26:    \"\"\"Test adding code at file level\"\"\"\n        27:    result = python_edit(test_file, 'x = 42')\n        28:    assert 'file level' in result\n        29:    with open(test_file) as f:\n        30:        content = f.read()\n        31:    assert 'x = 42' in content\n        32:\n        33:def test_file_start_insertion(test_file):\n        34:    \"\"\"Test inserting at file start\"\"\"\n        35:    result = python_edit(test_file, 'import sys', insert_after='__FILE_START__')\n        36:    assert 'start' in result\n        37:    with open(test_file) as f:\n        38:        lines = f.readlines()\n        39:        assert 'import sys' in lines[0]\n        40:\n        41:def test_class_replacement(test_file):\n        42:    \"\"\"Test replacing a class\"\"\"\n        43:    new_class = '\\n    class OuterClass:\\n        def new_method(self):\\n            pass\\n    '\n        44:    result = python_edit(f'{test_file}::OuterClass', new_class)\n        45:    assert 'OuterClass' in result\n        46:    with open(test_file) as f:\n        47:        content = f.read()\n        48:    assert 'new_method' in content\n        49:    assert 'another_method' not in content\n        50:\n        51:def test_nested_class_method(test_file):\n        52:    \"\"\"Test modifying a method in a nested class\"\"\"\n        53:    new_method = '\\n    async def async_method(self):\\n        return 42\\n    '\n        54:    result = python_edit(f'{test_file}::OuterClass::InnerClass::async_method', new_method)\n        55:    assert 'async_method' in result\n        56:    with open(test_file) as f:\n        57:        content = f.read()\n        58:    assert 'return 42' in content\n        59:\n        60:def test_nested_function(test_file):\n        61:    \"\"\"Test modifying a nested function\"\"\"\n        62:    new_func = '\\n    def inner_func():\\n        return 42\\n    '\n        63:    result = python_edit(f'{test_file}::outer_func::inner_func', new_func)\n        64:    assert 'inner_func' in result\n        65:    with open(test_file) as f:\n        66:        content = f.read()\n        67:    assert 'return 42' i