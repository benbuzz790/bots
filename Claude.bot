ized: {tokenized}')\n        418:        print(f'DEBUG - Token map: {token_map}')\n        419:        ast.parse(tokenized)\n        420:        assert detokenize_source(tokenized, token_map) == source\n        421:\n        422:    def test_minimal_tokenize_with_comment():\n        423:        \"\"\"Test tokenization with just a comment\"\"\"\n        424:        source = '# A comment'\n        425:        tokenized, token_map = tokenize_source(source)\n        426:        print(f'DEBUG - Tokenized: {tokenized}')\n        427:        print(f'DEBUG - Token map: {token_map}')\n        428:        ast.parse(tokenized)\n        429:        assert detokenize_source(tokenized, token_map) == source\n        430:\n        431:    def test_minimal_edit():\n        432:        \"\"\"Test the most basic possible edit\"\"\"\n        433:        with open('minimal.py', 'w') as f:\n        434:            f.write('# Empty\\n')\n        435:        result = python_edit('minimal.py', 'x = 1')\n        436:        print(f'DEBUG - Result: {result}')\n        437:        with open('minimal.py') as f:\n        438:            content = f.read()\n        439:        print(f'DEBUG - Content: {content}')\n        440:        assert 'file level' in result\n        441:\n        442:def test_tokenize_basic():\n        443:    \"\"\"Test basic tokenization of comments and strings\"\"\"\n        444:    source = '\\n    # Header comment\\n    x = \"string literal\"  # Inline comment\\n    y = 1\\n    '\n        445:    tokenized, token_map = tokenize_source(source)\n        446:    assert '# Header comment' not in tokenized\n        447:    assert '\"string literal\"' not in tokenized\n        448:    assert '# Inline comment' not in tokenized\n        449:    assert '__TOKEN__' in tokenized\n        450:    assert detokenize_source(tokenized, token_map) == source\n        451:    restored = detokenize_source(tokenized, token_map)\n        452:    assert restored == source\n        453:\n        454:def test_tokenize_multiline():\n        455:    \"\"\"Test tokenization of multiline strings and nested structures\"\"\"\n        456:    source = '\\n    def func():\\n        \"\"\"\\n        Multiline\\n        docstring\\n        \"\"\"\\n        # Comment\\n        if True:\\n            # Nested comment\\n            x = 1\\n    '\n        457:    tokenized, token_map = tokenize_source(source)\n        458:    assert '\"\"\"' not in tokenized\n        459:    assert '# Comment' not in tokenized\n        460:    assert '# Nested comment' not in tokenized\n        461:    restored = detokenize_source(tokenized, token_map)\n        462:    assert restored == source\n        463:\n        464:def test_tokenize_edge_cases():\n        465:    \"\"\"Test tokenization of edge cases\"\"\"\n        466:    source = '\\n    x = 1; y = 2  # Multiple statements\\n    # Comment with ; semicolon\\n    s = \"String # with hash\"\\n    q = \\'String ; with semicolon\\'\\n    \"\"\"\\n    Multiline string\\n    # with comment\\n    ; with semicolon\\n    \"\"\"\\n    '\n        467:    tokenized, token_map = tokenize_source(source)\n        468:    assert '__TOKEN__' in tokenized\n        469:    assert detokenize_source(tokenized, token_map) == source\n        470:    restored = detokenize_source(tokenized, token_map)\n        471:    assert restored == source\n        472:\n        473:def test_minimal_tokenize():\n        474:    \"\"\"Test tokenization of minimal valid Python\"\"\"\n        475:    source = 'x = 1'\n        476:    tokenized, token_map = tokenize_source(source)\n        477:    print(f'DEBUG - Tokenized: {tokenized}')\n        478:    print(f'DEBUG - Token map: {token_map}')\n        479:    ast.parse(tokenized)\n        480:    assert detokenize_source(tokenized, token_map) == source\n        481:\n        482:def test_minimal_tokenize_with_comment():\n        483:    \"\"\"Test tokenization with just a comment\"\"\"\n        484:    source = '# A