                                                                                                                                                                                                                                                                                                        "name": "replace_function",
                                                                                                                                                                                                                                                                                                        "input": {
                                                                                                                                                                                                                                                                                                         "file_path": "bots/tools/python_edit.py",
                                                                                                                                                                                                                                                                                                         "new_function_def": "\n                                                                                                                                                            def create_token(content: str, index: int, current_hash: str) -> str:\n                                                                                                                                                                \"\"\"Create a token with our specific pattern\"\"\"\n                                                                                                                                                                # Convert content to a hex string to avoid any syntax issues\n                                                                                                                                                                hex_content = content.encode('utf-8').hex()\n                                                                                                                                                                token_name = f\"\u00abTOKEN__{current_hash}_{index}\u00bb\"\n                                                                                                                                                                return token_name, hex_content"
                                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                                       }
