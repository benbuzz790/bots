                                                                                                                                                                                                                     "file_path": "bots/tools/python_edit.py",
                                                                                                                                                                                                                     "new_function_def": "\n                                                def tokenize_source(source: str) -> Tuple[str, Dict[str, str]]:\n                                                    \"\"\"\n                                                    Tokenize source code, preserving exact formatting.\n                                                    \n                                                    Returns:\n                                                    - tokenized_source: Source with tokens inserted\n                                                    - token_map: Mapping of tokens to original content\n                                                    \"\"\"\n                                                    def contains_token(s: str) -> bool:\n                                                        return \"TOKEN__\" in s\n                                                    \n                                                    token_dict = {}  # Will become __tokens__ = {...}\n                                                    token_map = {}   # For detokenization\n                                                    current_hash = get_file_hash(source)\n                                                    token_counter = 0\n                                                    \n                                                    # Process line by line to maintain indentation\n                                                    lines = source.split('\\n')\n                                                    for i, line in enumerate(lines):\n                                                        if contains_token(line):\n                                                            continue\n                                                            \n                                                        # Get the indentation of this line\n                                                        indent = len(line) - len(line.lstrip())\n                                                        indentation = line[:indent]\n                                                        content = line[indent:]\n                                                        \n                                                        # Handle full-line comments and blank lines first\n                                                        if not content.strip() or content.strip().startswith('#'):\n                                                            token_name, hex_val = create_token(content, token_counter, current_hash)\n                                                            token_dict[token_name] = hex_val\n                                                            token_map[token_name] = content\n                                                            lines[i] = indentation + token_name\n                                                            token_counter += 1\n                                                            continue\n                                                        \n                                                        # Process the line content\n                                                        processed_line = content\n                                                        \n                                                        # Handle strings\n                                                        string_patterns = [\n                                                            r'\"\"\"(?:[^\"\\\\]|\\\\.)*\"\"\"',\n                                                            r\"'''(?:[^'\\\\]|\\\\.)*'''\",\n                                                            r'\"(?:[^\"\\\\]|\\\\.)*\"',\n                                                            r\"'(?:[^'\\\\]|\\\\.)*'\"\n                                                        ]\n                                                        \n                                                        for pattern in string_patterns:\n                                                            matches = list(re.finditer(pattern, processed_line))\n                                                            offset = 0\n                                                            for match in matches:\n                                                                start, end = match.span()\n                                                                start += offset\n                                                                end += offset\n                                                                string_content = processed_line[start:end]\n                                                                token_name, hex_val = create_token(string_content, token_counter, current_hash)\n                                                                token_dict[token_name] = hex_val\n                                                                token_map[token_name] = string_content\n                                                                processed_line = processed_line[:start] + token_name + processed_line[end:]\n                                                                offset += len(token_name) - len(string_content)\n                                                                token_counter += 1\n                                                        \n                                                        # Handle inline comments last\n                                                        if '#' in processed_line and not any(token in processed_line.split('#', 1)[1] for token in token_map):\n                                                            code, comment = processed_line.split('#', 1)\n                                                            comment = '#' + comment\n                                                            token_name, hex_val = create_token(comment, token_counter, current_hash)\n                                                            token_dict[token_name] = hex_val\n                                                            token_map[token_name] = comment\n                                                            processed_line = code.rstrip() + token_name\n                                                            token_counter += 1\n                                                        \n                                                        lines[i] = indentation + processed_line\n                                                    \n                                                    # Create the token dictionary assignment at the top\n                                                    if token_dict:\n                                                        token_lines = ['__tokens__ = {']\n                                                        for name, val in token_dict.items():\n                                                            token_lines.append(f'    \"{name}\": {val},')\n                                                        token_lines.append('}')\n                                                        lines.insert(0, '\\n'.join(token_lines))\n                                                    \n                                                    return '\\n'.join(lines), token_map"
                                                                                                                                                                                                                    }
                                                                                                                                                                                                                   }
