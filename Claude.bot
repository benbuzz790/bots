es[-1]\n        271:\n        272:def test_line_insert_basic():\n        273:    \"\"\"Test inserting after a simple line in a function\"\"\"\n        274:    content = '\\n    def test_func():\\n        x = 1\\n        # marker\\n        z = 3\\n    '\n        275:    test_file = setup_test_file('tmp', content)\n        276:    result = python_edit(f'{test_file}::test_func', 'y = 2', insert_after='# marker')\n        277:    with open(test_file) as f:\n        278:        content = f.read()\n        279:    print(f'DEBUG - Result content:\\n{content}')\n        280:    assert '# marker\\n' in content\n        281:    assert 'y = 2' in content\n        282:    assert content.index('# marker') < content.index('y = 2')\n        283:    assert content.index('y = 2') < content.index('z = 3')\n        284:\n        285:def test_line_insert_indentation():\n        286:    \"\"\"Test that inserted code maintains proper indentation\"\"\"\n        287:    content = '\\n    def test_func():\\n        if True:\\n            x = 1\\n            # marker\\n            z = 3\\n    '\n        288:    test_file = setup_test_file('tmp', content)\n        289:    result = python_edit(f'{test_file}::test_func', 'y = 2', insert_after='# marker')\n        290:    with open(test_file) as f:\n        291:        content = f.read()\n        292:    print(f'DEBUG - Result content:\\n{content}')\n        293:    lines = content.split('\\n')\n        294:    marker_line = next((i for i, line in enumerate(lines) if '# marker' in line))\n        295:    y_line = next((i for i, line in enumerate(lines) if 'y = 2' in line))\n        296:    assert marker_line < y_line\n        297:    assert len(lines[marker_line]) - len(lines[marker_line].lstrip()) == len(lines[y_line]) - len(lines[y_line].lstrip())\n        298:\n        299:def test_line_insert_preservation():\n        300:    \"\"\"Test that the line we insert after is preserved\"\"\"\n        301:    content = '\\n    def simple():\\n       