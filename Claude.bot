                                                                                                                      "content": "\n        1:import ast\n        2:import os\n        3:import textwrap\n        4:TOKEN_START = ';;;'\n        5:TOKEN_END = ';;;'\n        6:from bots.utils.helpers import _process_error, _clean, _py_ast_to_source\n        7:import hashlib\n        8:import re\n        9:from typing import Dict, Tuple\n        10:from typing import Dict, Tuple, Union\n        11:\n        12:def python_edit(target_scope: str, code: str, *, insert_after: str=None) -> str:\n        13:    \"\"\"\n        14:    Edit Python code using pytest-style scope syntax.\n        15:\n        16:    Parameters:\n        17:    ----------\n        18:    target_scope : str\n        19:        Location to edit in pytest-style scope syntax:\n        20:        - \"file.py\" (whole file)\n        21:        - \"file.py::MyClass\" (class)\n        22:        - \"file.py::my_function\" (function)\n        23:        - \"file.py::MyClass::method\" (method)\n        24:        - \"file.py::Outer::Inner::method\" (nested)\n        25:        - \"file.py::utils::helper_func\" (nested function)\n        26:\n        27:    code : str\n        28:        Python code to insert/replace. Will be cleaned/dedented.\n        29:        Import statements will be automatically extracted and handled.\n        30:\n        31:    insert_after : str, optional\n        32:        Where to insert the code. Can be either:\n        33:        - \"__FILE_START__\" (special token for file beginning)\n        34:        - A scope (\"MyClass::method\")\n        35:        - An exact line match\n        36:        If not specified, replaces the node at target_scope.\n        37:\n        38:    Returns:\n        39:    --------\n        40:    str\n        41:        Description of what was modified or error message\n        42:    \"\"\"\n        43:    try:\n        44:        file_path, *path_elements = target_scope.split('::')\n        45:        if not file_path.endswith('.py'):\n        46:            return _process_error(ValueError(f'File path must end with .py: {file_path}'))\n        47:        for element in path_elements:\n        48:            if not element.isidentifier():\n        49:                return _process_error(ValueError(f'Invalid identifier in path: {element}'))\n        50:        abs_path = _make_file(file_path)\n        51:        cleaned_code = _clean(code)\n        52:        tokenized_code, new_code_tokens = tokenize_source(cleaned_code)\n        53:        try:\n        54:            new_tree = ast.parse(tokenized_code)\n        55:            import_nodes = []\n        56:            code_nodes = []\n        57:            for node in new_tree.body:\n        58:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        59:                    import_nodes.append(node)\n        60:                else:\n        61:                    code_nodes.append(node)\n        62:        except Exception as e:\n        63:            return _process_error(ValueError(f'Error parsing new code: {str(e)}'))\n        64:        try:\n        65:            with open(abs_path, 'r', encoding='utf-8') as file:\n        66:                content = file.read()\n        67:            tokenized_content, file_tokens = tokenize_source(content) if content.strip() else ('', {})\n        68:            file_lines = tokenized_content.split('\\n')\n        69:            print(f'DEBUG - Tokenized content:\\n{tokenized_content}')\n        70:            print(f'DEBUG - File tokens:\\n{file_tokens}')\n        71:            print(f'DEBUG - File lines:\\n{file_lines}')\n        72:            tree = ast.parse(tokenized_content) if content.strip() else ast.Module(body=[], type_ignores=[])\n        73:        except Exception as e:\n        74:            return _process_error(ValueError(f'Error reading/parsing file {abs_path}: {str(e)}'))\n        75:        existing_imports = []\n        76:        non_imports = []\n        77:        for node in tree.body:\n        78:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        79:                existing_imports.append(node)\n        80:            else:\n        81:                non_imports.append(node)\n        82:        if insert_after == '__FILE_START__':\n        83:            tree.body = import_nodes + code_nodes + existing_imports + non_imports\n        84:            try:\n        85:                updated_content = _py_ast_to_source(tree)\n        86:                all_tokens = {**file_tokens, **new_code_tokens}\n        87:                final_content = detokenize_source(updated_content, all_tokens)\n        88:                with open(abs_path, 'w', encoding='utf-8') as file:\n        89:                    file.write(final_content)\n        90:                return f\"Code inserted at start of '{abs_path}'.\"\n        91:            except Exception as e:\n        92:                return _process_error(e)\n        93:        if not path_elements:\n        94:            tree.body = existing_imports + import_nodes + non_imports + code_nodes\n        95:            try:\n        96:                updated_content = _py_ast_to_source(tree)\n        97:                all_tokens = {**file_tokens, **new_code_tokens}\n        98:                final_content = detokenize_source(updated_content, all_tokens)\n        99:                with open(abs_path, 'w', encoding='utf-8') as file:\n        100:                    file.write(final_content)\n        101:                return f\"Code added at file level in '{abs_path}'.\"\n        102:            except Exception as e:\n        103:                return _process_error(e)\n        104:        tree.body = existing_imports + import_nodes + non_imports\n        105:        transformer = ScopeTransformer(path_elements, code_nodes, insert_after, file_lines, file_tokens, new_code_tokens)\n        106:        modified_tree = transformer.visit(tree)\n        107:        if not transformer.success:\n        108:            if insert_after:\n        109:                return _process_error(ValueError(f'Insert point not found: {insert_after}'))\n        110:            else:\n        111:                return _process_error(ValueError(f'Target scope not found: {target_scope}'))\n        112:        try:\n        113:            updated_content = _py_ast_to_source(modified_tree)\n        114:            all_tokens = {**file_tokens, **new_code_tokens}\n        115:            final_content = detokenize_source(updated_content, all_tokens)\n        116:            with open(abs_path, 'w', encoding='utf-8') as file:\n        117:                file.write(final_content)\n        118:            action = 'inserted after' if insert_after else 'replaced at'\n        119:            scope_str = '::'.join(path_elements) if path_elements else 'file level'\n        120:            return f\"Code {action} {scope_str} in '{abs_path}'.\"\n        121:        except Exception as e:\n        122:            return _process_error(e)\n        123:    except Exception as e:\n        124:        return _process_error(e)\n        125:\n        126:def _make_file(file_path: str) -> str:\n        127:    \"\"\"\n        128:    Creates a file and its parent directories if they don't exist.\n        129:    Converts relative paths to absolute paths.\n        130:\n        131:    Parameters:\n        132:    - file_path (str): The path to the file to be created\n        133:\n        134:    Returns:\n        135:    - str: The absolute path to the file\n        136:\n        137:    Raises:\n        138:    - ValueError: If there's an error creating the file or directories,\n        139:                 or if the file_path is empty\n        140:    \"\"\"\n        141:    if not file_path:\n        142:        raise ValueError('File path cannot be empty')\n        143:    abs_path = os.path.abspath(file_path)\n        144:    dir_path = os.path.dirname(abs_path)\n        145:    if dir_path:\n        146:        try:\n        147:            os.makedirs(dir_path, exist_ok=True)\n        148:        except Exception as e:\n        149:            raise ValueError(f'Error creating directories {dir_path}: {str(e)}')\n        150:    if not os.path.exists(abs_path):\n        151:        try:\n        152:            with open(abs_path, 'w', encoding='utf-8') as f:\n        153:                f.write('')\n        154:        except Exception as e:\n        155:            raise ValueError(f'Error creating file {abs_path}: {str(e)}')\n        156:    return abs_path\n        157:\n        158:class ScopeTransformer(ast.NodeTransformer):\n        159:    \"\"\"AST transformer that handles scope-based Python code modifications.\"\"\"\n        160:\n        161:    def __init__(self, path_elements, new_nodes, insert_after=None, file_lines=None, file_tokens=None, new_tokens=None):\n        162:        self.original_path = path_elements\n        163:        self.new_nodes = new_nodes\n        164:        self.insert_after = insert_after\n        165:        self.file_lines = file_lines\n        166:        self.file_tokens = file_tokens or {}\n        167:        self.new_tokens = new_tokens or {}\n        168:        self.current_path = []\n        169:        self.success = False\n        170:        self.line_match_count = 0\n        171:        self.all_tokens = {**self.file_tokens, **self.new_tokens}\n        172:\n        173:    def visit_ClassDef(self, node):\n        174:        \"\"\"Visit a class definition node.\"\"\"\n        175:        if not self.original_path or node.name != self.original_path[0]:\n        176:            return self.generic_visit(node)\n        177:        self.current_path.append(node.name)\n        178:        remaining_path = self.original_path[1:]\n        179:        if not remaining_path:\n        180:            if self.insert_after:\n        181:                node = self._handle_insertion(node)\n        182:            else:\n        183:                self.success = True\n        184:                if len(self.new_nodes) == 1:\n        185:                    return self.new_nodes[0]\n        186:                else:\n        187:                    node.body = self.new_nodes\n        188:                    return node\n        189:        else:\n        190:            saved_path = self.original_path\n        191:            self.original_path = remaining_path\n        192:            node.body = [self.visit(child) for child in node.body]\n        193:            self.original_path = saved_path\n        194:        self.current_path.pop()\n        195:        return node\n        196:\n        197:    def visit_FunctionDef(self, node):\n        198:        \"\"\"Visit a function definition node.\"\"\"\n        199:        return self._handle_function_node(node)\n        200:\n        201:    def visit_AsyncFunctionDef(self, node):\n        202:        \"\"\"Visit an async function definition node.\"\"\"\n        203:        return self._handle_function_node(node)\n        204:\n        205:    def _handle_function_node(self, node):\n        206:        \"\"\"Common handling for both regular and async functions.\"\"\"\n        207:        if not self.original_path or node.name != self.original_path[0]:\n        208:            return self.generic_visit(node)\n        209:        self.current_path.append(node.name)\n        210:        remaining_path = self.original_path[1:]\n        211:        if not remaining_path:\n        212:            if self.insert_after:\n        213:                node = self._handle_insertion(node)\n        214:            else:\n        215:                self.success = True\n        216:                if len(self.new_nodes) == 1:\n        217:                    return self.new_nodes[0]\n        218:                else:\n        219:                    node.body = self.new_nodes\n        220:                    return node\n        221:        else:\n        222:            saved_path = self.original_path\n        223:            self.original_path = remaining_path\n        224:            node.body = [self.visit(child) for child in node.body]\n        225:            self.original_path = saved_path\n        226:        self.current_path.pop()\n        227:        return node\n        228:\n        229:    def _handle_one_line_function(self, node, line):\n        230:        \"\"\"Special handling for one-line function definitions\"\"\"\n        231:        if ': pass' in line or ':pass' in line:\n        232:            base_indent = len(line) - len(line.lstrip())\n        233:            def_line = line.rstrip()\n        234:            if self.insert_after == 'pass':\n        235:                def_line = def_line.replace(': pass', ':').replace(':pass', ':')\n        236:                body_indent = base_indent + 4\n        237:                body_lines = []\n        238:                body_lines.append(' ' * body_indent + 'pass')\n        239:                for new_node in self.new_nodes:\n        240:                    node_lines = _py_ast_to_source(new_node).split('\\n')\n        241:                    for nl in node_lines:\n        242:                        if nl.strip():\n        243:                            body_lines.append(' ' * body_indent + nl.lstrip())\n        244:                new_source = def_line + '\\n' + '\\n'.join(body_lines)\n        245:                try:\n        246:                    new_node = ast.parse(new_source).body[0]\n        247:                    self.success = True\n        248:                    return new_node\n        249:                except Exception:\n        250:                    normalized = textwrap.dedent(new_source)\n        251:                    try:\n        252:                        new_node = ast.parse(normalized).body[0]\n        253:                        self.success = True\n        254:                        return new_node\n        255:                    except Exception:\n        256:                        pass\n        257:        return node\n        258:\n        259:    def _handle_insertion(self, node):\n        260:        \"\"\"Handle inserting nodes after a specific point.\"\"\"\n        261:        if isinstance(self.insert_after, str) and '::' not in self.insert_after:\n        262:            if not isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        263:                return node\n        264:            if node.lineno == node.end_lineno:\n        265:                return self._handle_one_line_function(node, self.file_lines[node.lineno - 1])\n        266:            func_lines = self.file_lines[node.lineno - 1:node.end_lineno]\n        267:            if not func_lines:\n        268:                return node\n        269:            target = self.insert_after.strip()\n        270:            for i, line in enumerate(func_lines):\n        271:                if line.strip() == target:\n        272:                    self.line_match_count += 1\n        273:                    if self.line_match_count == 1:\n        274:                        current_indent = len(line) - len(line.lstrip())\n        275:                        insertion = []\n        276:                        for new_node in self.new_nodes:\n        277:                            node_lines = _py_ast_to_source(new_node).split('\\n')\n        278:                            for nl in node_lines:\n        279:                                if nl.strip():\n        280:                                    insertion.append(' ' * current_indent + nl.lstrip())\n        281:                                else:\n        282:                                    insertion.append(' ' * current_indent)\n        283:                        func_lines[i:i + 1] = [func_lines[i]] + insertion\n        284:                        self.success = True\n        285:                        break\n        286:            if self.line_match_count == 0:\n        287:                return node\n        288:            elif self.line_match_count > 1:\n        289:                raise ValueError(f'Ambiguous insert_after - found {self.line_match_count} matches for: {self.insert_after}')\n        290:            node._source = '\\n'.join(func_lines)\n        291:            self.success = True\n        292:            return node\n        293:        else:\n        294:            if self.insert_after:\n        295:                target_path = self.insert_after.split('::')\n        296:                current_path = self.current_path\n        297:                if len(current_path) == len(target_path) and all((c == t for c, t in zip(current_path, target_path))):\n        298:                    self.success = True\n        299:                    if isinstance(node, ast.ClassDef):\n        300:                        node.body.extend(self.new_nodes)\n        301:                    else:\n        302:                        for new_node in self.new_nodes:\n        303:                            node.body.append(new_node)\n        304:            return node\n        305:\n        306:def create_token(content: str, index: int, current_hash: str) -> str:\n        307:    \"\"\"Create a token with our specific pattern\"\"\"\n        308:    hex_content = content.encode('utf-8').hex()\n        309:    token_name = f'TOKEN__{current_hash}_{index}'\n        310:    return (token_name, f\"'__TOKEN__{hex_content}__'\")\n        311:\n        312:def get_file_hash(content: str) -> str:\n        313:    \"\"\"Create a short hash of file content\"\"\"\n        314:    return hashlib.sha256(content.encode()).hexdigest()[:8]\n        315:\n        316:def tokenize_source(source: str) -> Tuple[str, Dict[str, str]]:\n        317:    \"\"\"\n        318:    Tokenize source code, preserving exact formatting.\n        319:\n        320:    Returns:\n        321:    - tokenized_source: Source with tokens inserted\n        322:    - token_map: Mapping of tokens to original content\n        323:    \"\"\"\n        324:\n        325:    def contains_token(s: str) -> bool:\n        326:        return '__TOKEN__' in s\n        327:    token_map = {}\n        328:    current_hash = get_file_hash(source)\n        329:    token_counter = 0\n        330:    tokenized = source\n        331:    triple_quote_patterns = [r'\"\"\"[^\"\\\\]*(?:(?:\\\\.|\"(?!\"\"))[^\"\\\\]*)*\"\"\"', r\"'''[^'\\\\]*(?:(?:\\\\.|'(?!''))[^'\\\\]*)*'''\"]\n        332:    for pattern in triple_quote_patterns:\n        333:        while True:\n        334:            match = re.search(pattern, tokenized)\n        335:            if not match:\n        336:                break\n        337:            string_content = match.group()\n        338:            if contains_token(string_content):\n        339:                continue\n        340:            token_name, hex_val = create_token(string_content, token_counter, current_hash)\n        341:            token_map[hex_val] = string_content\n        342:            tokenized = tokenized[:match.start()] + hex_val + tokenized[match.end():]\n        343:            token_counter += 1\n        344:    lines = tokenized.split('\\n')\n        345:    processed_lines = []\n        346:    for line in lines:\n        347:        if not line.strip():\n        348:            processed_lines.append(line)\n        349:            continue\n        350:        indent = len(line) - len(line.lstrip())\n        351:        indentation = ' ' * indent\n        352:        content = line[indent:]\n        353:        if contains_token(content):\n        354:            processed_lines.append(line)\n        355:            continue\n        356:        if content.strip().startswith('#'):\n        357:            token_name, hex_val = create_token(content, token_counter, current_hash)\n        358:            token_map[hex_val] = content\n        359:            processed_lines.append(indentation + hex_val)\n        360:            token_counter += 1\n        361:            continue\n        362:        processed_line = content\n        363:        # Use simpler patterns to avoid catastrophic backtracking\n        364:        # Match strings but avoid catastrophic backtracking by using possessive quantifiers\n        365:        string_patterns = [r'\"[^\"\\\\]*(?:\\\\.[^\"\\\\]*)*\"', r\"'[^'\\\\]*(?:\\\\.[^'\\\\]*)*'\"]\n        366:        for pattern in string_patterns:\n        367:            while True:\n        368:                match = re.search(pattern, processed_line)\n        369:                if not match:\n        370:                    break\n        371:                string_content = match.group()\n        372:                if contains_token(string_content):\n        373:                    continue\n        374:                token_name, hex_val = create_token(string_content, token_counter, current_hash)\n        375:                token_map[hex_val] = string_content\n        376:                processed_line = processed_line[:match.start()] + hex_val + processed_line[match.end():]\n        377:                token_counter += 1\n        378:        if '#' in processed_line and (not contains_token(processed_line)):\n        379:            comment_start = processed_line.index('#')\n        380:            code = processed_line[:comment_start]\n        381:            comment = processed_line[comment_start:]\n        382:            token_name, hex_val = create_token(comment, token_counter, current_hash)\n        383:            token_map[hex_val] = comment\n        384:            processed_line = code.rstrip() + ' ' + hex_val\n        385:            token_counter += 1\n        386:        processed_lines.append(indentation + processed_line)\n        387:    return ('\\n'.join(processed_lines), token_map)\n        388:\n        389:def detokenize_source(tokenized_source: str, token_map: Dict[str, str]) -> str:\n        390:    \"\"\"\n        391:    Restore original source from tokenized version.\n        392:\n        393:    Handles proper indentation of multiline content.\n        394:    \"\"\"\n        395:    result = tokenized_source\n        396:    for token_name, original in sorted(token_map.items(), key=lambda x: len(x[0]), reverse=True):\n        397:        while True:\n        398:            start = result.find(token_name)\n        399:            if start == -1:\n        400:                break\n        401:            if '\\n' in original:\n        402:                indent = get_indentation_at_position(result, start)\n        403:                indented = indent_multiline_content(original, indent)\n        404:                result = result[:start] + indented + result[start + len(token_name):]\n        405:            else:\n        406:                result = result[:start] + original + result[start + len(token_name):]\n        407:    return result\n        408:\n        409:def get_indentation_at_position(source: str, pos: int) -> str:\n        410:    \"\"\"Get the indentation level at a given position in source\"\"\"\n        411:    line_start = source.rfind('\\n', 0, pos) + 1\n        412:    return source[line_start:pos].replace(source[line_start:pos].lstrip(), '')\n        413:\n        414:def indent_multiline_content(content: str, indent: str) -> str:\n        415:    \"\"\"Indent multiline content while preserving internal formatting\"\"\"\n        416:    if not content.strip():\n        417:        return content\n        418:    lines = content.split('\\n')\n        419:    if len(lines) == 1:\n        420:        return content\n        421:    if all((line.startswith(' ') for line in lines[1:] if line.strip())):\n        422:        return content\n        423:    result = [lines[0]]\n        424:    for line in lines[1:]:\n        425:        if line.strip():\n        426:            result.append(indent + line)\n        427:        else:\n        428:            result.append(line)\n        429:    return '\\n'.join(result)"
