hex_val = create_token(string_content, token_counter, current_hash)\n        355:            token_map[hex_val] = string_content\n        356:            tokenized = tokenized[:match.start()] + hex_val + tokenized[match.end():]\n        357:            token_counter += 1\n        358:    lines = tokenized.split('\\n')\n        359:    processed_lines = []\n        360:    for line in lines:\n        361:        if not line.strip():\n        362:            processed_lines.append(line)\n        363:            continue\n        364:        indent = len(line) - len(line.lstrip())\n        365:        indentation = ' ' * indent\n        366:        content = line[indent:]\n        367:        if contains_token(content):\n        368:            processed_lines.append(line)\n        369:            continue\n        370:        if content.strip().startswith('#'):\n        371:            token_name, hex_val = create_token(content, token_counter, current_hash)\n        372:            token_map[hex_val] = content\n        373:            processed_lines.append(indentation + hex_val)\n        374:            token_counter += 1\n        375:            continue\n        376:        processed_line = content\n        377:        string_patterns = ['\"[^\"\\\\\\\\]*(?:\\\\\\\\.[^\"\\\\\\\\]*)*\"', \"'[^'\\\\\\\\]*(?:\\\\\\\\.[^'\\\\\\\\]*)*'\"]\n        378:        for pattern in string_patterns:\n        379:            while True:\n        380:                match = re.search(pattern, processed_line)\n        381:                if not match:\n        382:                    break\n        383:                string_content = match.group()\n        384:                if contains_token(string_content):\n        385:                    continue\n        386:                token_name, hex_val = create_token(string_content, token_counter, current_hash)\n        387:                token_map[hex_val] = string_content\n        388:                processed_line = processed_lin