                                                                                                                                                                                                                                                                                                                                                              "content": "\n        1:import ast\n        2:import os\n        3:import textwrap\n        4:from bots.utils.helpers import _process_error, _clean, _py_ast_to_source\n        5:\n        6:def python_edit(target_scope: str, code: str, *, insert_after: str=None) -> str:\n        7:    \"\"\"\n        8:    Edit Python code using pytest-style scope syntax.\n        9:\n        10:    Parameters:\n        11:    ----------\n        12:    target_scope : str\n        13:        Location to edit in pytest-style scope syntax:\n        14:        - \"file.py\" (whole file)\n        15:        - \"file.py::MyClass\" (class)\n        16:        - \"file.py::my_function\" (function)\n        17:        - \"file.py::MyClass::method\" (method)\n        18:        - \"file.py::Outer::Inner::method\" (nested)\n        19:        - \"file.py::utils::helper_func\" (nested function)\n        20:\n        21:    code : str\n        22:        Python code to insert/replace. Will be cleaned/dedented.\n        23:        Import statements will be automatically extracted and handled.\n        24:\n        25:    insert_after : str, optional\n        26:        Where to insert the code. Can be either:\n        27:        - \"__FILE_START__\" (special token for file beginning)\n        28:        - A scope (\"MyClass::method\")\n        29:        - An exact line match\n        30:        If not specified, replaces the node at target_scope.\n        31:\n        32:    Returns:\n        33:    --------\n        34:    str\n        35:        Description of what was modified or error message\n        36:    \"\"\"\n        37:    try:\n        38:        file_path, *path_elements = target_scope.split('::')\n        39:        if not file_path.endswith('.py'):\n        40:            return _process_error(ValueError(f'File path must end with .py: {file_path}'))\n        41:        for element in path_elements:\n        42:            if not element.isidentifier():\n        43:                return _process_error(ValueError(f'Invalid identifier in path: {element}'))\n        44:        abs_path = _make_file(file_path)\n        45:        try:\n        46:            new_tree = ast.parse(_clean(code))\n        47:            import_nodes = []\n        48:            code_nodes = []\n        49:            for node in new_tree.body:\n        50:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        51:                    import_nodes.append(node)\n        52:                else:\n        53:                    code_nodes.append(node)\n        54:        except Exception as e:\n        55:            return _process_error(ValueError(f'Error parsing new code: {str(e)}'))\n        56:        try:\n        57:            with open(abs_path, 'r', encoding='utf-8') as file:\n        58:                content = file.read()\n        59:            file_lines = content.split('\\n')\n        60:            tree = ast.parse(content) if content.strip() else ast.Module(body=[], type_ignores=[])\n        61:        except Exception as e:\n        62:            return _process_error(ValueError(f'Error reading/parsing file {abs_path}: {str(e)}'))\n        63:        existing_imports = []\n        64:        non_imports = []\n        65:        for node in tree.body:\n        66:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        67:                existing_imports.append(node)\n        68:            else:\n        69:                non_imports.append(node)\n        70:        if insert_after == '__FILE_START__':\n        71:            tree.body = import_nodes + code_nodes + existing_imports + non_imports\n        72:            try:\n        73:                updated_content = _py_ast_to_source(tree)\n        74:                with open(abs_path, 'w', encoding='utf-8') as file:\n        75:                    file.write(updated_content)\n        76:                return f\"Code inserted at start of '{abs_path}'.\"\n        77:            except Exception as e:\n        78:                return _process_error(e)\n        79:        if not path_elements:\n        80:            tree.body = existing_imports + import_nodes + non_imports + code_nodes\n        81:            try:\n        82:                updated_content = _py_ast_to_source(tree)\n        83:                with open(abs_path, 'w', encoding='utf-8') as file:\n        84:                    file.write(updated_content)\n        85:                return f\"Code added at file level in '{abs_path}'.\"\n        86:            except Exception as e:\n        87:                return _process_error(e)\n        88:        tree.body = existing_imports + import_nodes + non_imports\n        89:        transformer = ScopeTransformer(path_elements, code_nodes, insert_after, file_lines)\n        90:        modified_tree = transformer.visit(tree)\n        91:        if not transformer.success:\n        92:            if insert_after:\n        93:                return _process_error(ValueError(f'Insert point not found: {insert_after}'))\n        94:            else:\n        95:                return _process_error(ValueError(f'Target scope not found: {target_scope}'))\n        96:        try:\n        97:            updated_content = _py_ast_to_source(modified_tree)\n        98:            with open(abs_path, 'w', encoding='utf-8') as file:\n        99:                file.write(updated_content)\n        100:        except Exception as e:\n        101:            return _process_error(e)\n        102:        action = 'inserted after' if insert_after else 'replaced at'\n        103:     