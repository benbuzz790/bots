                                                                                                                                                                                                                                                              "content": "\n        1:import ast\n        2:import os\n        3:import textwrap\n        4:TOKEN_START = ';;;'\n        5:TOKEN_END = ';;;'\n        6:from bots.utils.helpers import _process_error, _clean, _py_ast_to_source\n        7:import hashlib\n        8:import re\n        9:from typing import Dict, Tuple\n        10:from typing import Dict, Tuple, Union\n        11:\n        12:def python_edit(target_scope: str, code: str, *, insert_after: str=None) -> str:\n        13:    \"\"\"\n        14:    Edit Python code using pytest-style scope syntax.\n        15:\n        16:    Parameters:\n        17:    ----------\n        18:    target_scope : str\n        19:        Location to edit in pytest-style scope syntax:\n        20:        - \"file.py\" (whole file)\n        21:        - \"file.py::MyClass\" (class)\n        22:        - \"file.py::my_function\" (function)\n        23:        - \"file.py::MyClass::method\" (method)\n        24:        - \"file.py::Outer::Inner::method\" (nested)\n        25:        - \"file.py::utils::helper_func\" (nested function)\n        26:\n        27:    code : str\n        28:        Python code to insert/replace. Will be cleaned/dedented.\n        29:        Import statements will be automatically extracted and handled.\n        30:\n        31:    insert_after : str, optional\n        32:        Where to insert the code. Can be either:\n        33:        - \"__FILE_START__\" (special token for file beginning)\n        34:        - A scope (\"MyClass::method\")\n        35:        - An exact line match\n        36:        If not specified, replaces the node at target_scope.\n        37:\n        38:    Returns:\n        39:    --------\n        40:    str\n        41:        Description of what was modified or error message\n        42:    \"\"\"\n        43:    try:\n        44:        file_path, *path_elements = target_scope.split('::')\n        45:        if not file_path.endswith('.py'):\n        46:            return _process_error(ValueError(f'File path must end with .py: {file_path}'))\n        47:        for element in path_elements:\n        48:            if not element.isidentifier():\n        49:                return _process_error(ValueError(f'Invalid identifier in path: {element}'))\n        50:        abs_path = _make_file(file_path)\n        51:        cleaned_code = _clean(code)\n        52:        tokenized_code, new_code_tokens = tokenize_source(cleaned_code)\n        53:        try:\n        54:            new_tree = ast.parse(tokenized_code)\n        55:            import_nodes = []\n        56:            code_nodes = []\n        57:            for node in new_tree.body:\n        58:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        59:                    import_nodes.append(node)\n        60:                else:\n        61:                    code_nodes.append(node)\n        62:        except Exception as e:\n        63:            return _process_error(ValueError(f'Error parsing new code: {str(e)}'))\n        64:        try:\n        65:            with open(abs_path, 'r', encoding='utf-8') as file:\n        66:                content = file.read()\n        67:            tokenized_content, file_tokens = tokenize_source(content) if content.strip() else ('', {})\n        68:            file_lines = tokenized_content.split('\\n')\n        69:            print(f'DEBUG - Tokenized content:\\n{tokenized_content}')\n        70:            print(f'DEBUG - File tokens:\\n{file_tokens}')\n        71:            print(f'DEBUG - File lines:\\n{file_lines}')\n        72:            tree = ast.parse(tokenized_content) if content.strip() else ast.Module(body=[], type_ignores=[])\n        73:        except Exception as e:\n        74:            return _process_error(ValueError(f'Error reading/parsing file {abs_path}: {str(e)}'))\n        75:        existing_imports = []\n        76:        non_imports = []\n        77:        for node in tree.body:\n        78:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        79:                existing_imports.append(node)\n        80:            else:\n        81:                non_imports.append(node)\n        82:        if insert_after == '__FILE_START__':\n        83:            tree.body = import_nodes + code_nodes + existing_imports + non_imports\n        84:            try:\n        85:                updated_content = _py_ast_to_source(tree)\n        86:                all_tokens = {**file_tokens, **new_code_tokens}\n        87:                final_content = detokenize_source(updated_content, all_tokens)\n        88:                with open(abs_path, 'w', encoding='utf-8') as file:\n        89:                    file.write(final_content)\n        90:                return f\"Code inserted at start of '{abs_path}'.\"\n        91:            except Exception as e:\n        92:                return _process_error(e)\n        93:        if not path_elements:\n        94:            tree.body = existing_imports + import_nodes + non_imports + code_nodes\n        95:            try:\n        96:                updated_content = _py_ast_to_source(tree)\n        97:                all_tokens = {**file_tokens, **new_code_tokens}\n        98:                final_content = detokenize_source(updated_content, all_tokens)\n        99:                with open(abs_path, 'w', encoding='utf-8') as file:\n        100:                    file.write(final_content)\n        101:                return f\"Code added at file level in '{abs_path}'.\"\n        102:            except Exception as e:\n        103:                return _process_error(e)\n        104:        tree.body = existing_imports + import_nodes + non_imports\n        105:        transformer = ScopeTransformer(path_elements, code_nodes, insert_after, file_lines, file_tokens, new_code_tokens)\n        106:        modified_tree = transformer.visit(tree)\n        107:        if not transformer.success:\n        108:            if insert_after:\n        109:                return _process_error(ValueError(f'Insert point not found: {insert_after}'))\n        110:            else:\n        111:                return _process_error(ValueError(f'Target scope not found: {target_scope}'))\n        112:        try:\n        113:            updated_content = _py_ast_to_source(modified_tree)\n        114:            all_tokens = {**file_tokens, **new_code_tokens}\n        115:            final_content = detokenize_source(updated_content, all_tokens)\n        116:            with open(abs_path, 'w', encoding='utf-8') as file:\n        117:                file.write(final_content)\n        118:            action = 'inserted after' if insert_after else 'replaced at'\n        119:            scope_str = '::'.join(path_elements) if path_elements else 'file level'\n        120:            return f\"Code {action} {scope_str} in '{abs_path}'.\"\n        121:        except Exception as e:\n        122:            return _process_error(e)\n        123:    except Exception as e:\n        124:        return _process_error(e)\n        125:\n        126:def _make_file(file_path: str) -> str:\n        127:    \"\"\"\n        128:    Creates a file and its parent directories if they don't exist.\n        129:    Converts relative paths to absolute paths.\n        130:\n        131:    Parameters:\n        132:    - file_path (str): The path to the file to be created\n        133:\n        134:    Returns:\n        135:    - str: The absolute path to the file\n        136:\n        137:    Raises:\n        138:    - ValueError: If there's an error creating the file or directories,\n        139:                 or if the file_path is empty\n        140:    \"\"\"\n        141:    if not file_path:\n        142:        raise ValueError('File path cannot be empty')\n        143:    abs_path = os.path.abspath(file_path)\n        144:    dir_path = os.path.dirname(abs_path)\n        145:    if dir_path:\n        146:        try:\n        147:            os.makedirs(dir_path, exist_ok=True)\n        148:        except Exception as e:\n        149:            raise ValueError(f'Error creating directories {dir_path}: {str(e)}')\n        150:    if not os.path.exists(abs_path):\n        151:        try:\n        152:            with open(abs_path, 'w', encoding='utf-8') as f:\n        153:                f.write('')\n        154:        except Exception as e:\n        155:            raise ValueError(f'Error creating file {abs_path}: {str(e)}')\n        156:    return abs_path\n        157:\n        158:class ScopeTransformer(ast.NodeTransformer):\n        159:    \"\"\"AST transformer that handles scope-based Python code modifications.\"\"\"\n        160:\n        161:    def __init__(self, path_elements, new_nodes, insert_after=None, file_lines=None, file_tokens=None, new_tokens=None):\n        162:        self.original_path = path_elements\n        163:        self.new_nodes = new_nodes\n        164:        self.insert_after = insert_after\n        165:        self.file_lines = file_lines\n        166:        self.file_tokens = file_tokens or {}\n        167:        self.new_tokens = new_tokens or {}\n        168:        self.current_path = []\n        169:        self.success = False\n        170:        self.line_match_count = 0\n        171:        self.all_tokens = {**self.file_tokens, **self.new_tokens}\n        172:\n        173:    def visit_ClassDef(self, node):\n        174:        \"\"\"Visit a class definition node.\"\"\"\n        175:        if not self.original_path or node.name != self.original_path[0]:\n        176:            return self.generic_visit(node)\n        177:        self.current_path.append(node.name)\n        178:        remaining_path = self.original_path[1:]\n        179:        if not remaining_path:\n        180:            if self.insert_after:\n        181:                node = self._handle_insertion(node)\n        182:            else:\n        183:                self.success = True\n        184:                if len(self.new_nodes) == 1:\n        185:                    return self.new_nodes[0]\n        186:                else:\n        187:                    node.body = self.new_nodes\n        188:                    return node\n        189:        else:\n        190:            saved_path = self.original_path\n        191:            self.original_path = remaining_path\n        192:            node.body = [self.visit(child) for child in node.body]\n        193:            self.original_path = saved_path\n        194:        self.current_path.pop()\n        195:        return node\n        196:\n        197:    def visit_FunctionDef(self, node):\n        198:        \"\"\"Visit a function definition node.\"\"\"\n        199:        return self._handle_function_node(node)\n        200:\n        201:    def visit_AsyncFunctionDef(self, node):\n        202:        \"\"\"Visit an async function definition node.\"\"\"\n        203:        return self._handle_function_node(node)\n        204:\n        205:    def _handle_function_node(self, node):\n        206:        \"\"\"Common handling for both regular and async functions.\"\"\"\n        207:        if not self.original_path or node.name != self.original_path[0]:\n        208:            return self.generic_visit(node)\n        209:        self.current_path.append(node.name)\n        210:        remaining_path = self.original_path[1:]\n        211:        if not remaining_path:\n        212:            if self.insert_after:\n        213:                node = self._handle_insertion(node)\n        214:            else:\n        215:                self.success = True\n        216:                if len(self.new_nodes) == 1:\n        217:                    return self.new_nodes[0]\n        218:                else:\n        219:                    node.body = self.new_nodes\n        220:                    return node\n        221:        else:\n        222:            saved_path = self.original_path\n        223:            self.original_path = remaining_path\n        224:            node.body = [self.visit(child) for child in node.body]\n        225:            self.original_path = saved_path\n        226:        self.current_path.pop()\n        227:        return node\n        228:\n        229:    def _handle_one_line_function(self, node, line):\n        230:        \"\"\"Special handling for one-line function definitions\"\"\"\n        231:        if ': pass' in line or ':pass' in line:\n        232:            base_indent = len(line) - len(line.lstrip())\n        233:            def_line = line.rstrip()\n        234:            if self.insert_after == 'pass':\n        235:                def_line = def_line.replace(': pass', ':').replace(':pass', ':')\n        236:                body_indent = base_indent + 4\n        237:                body_lines = []\n        238:                body_lines.append(' ' * body_indent + 'pass')\n        239:                for new_node in self.new_nodes:\n        240:                    node_lines = _py_ast_to_source(new_node).split('\\n')\n        241:                    for nl in node_lines:\n        242:                        if nl.strip():\n        243:                            body_lines.append(' ' * body_indent + nl.lstrip())\n        244:                new_source = def_line + '\\n' + '\\n'.join(body_lines)\n        245:                try:\n        246:                    new_node = ast.parse(new_source).body[0]\n        247:                    self.success = True\n        248:                    return new_node\n        249:                except Exception:\n        250:                    normalized = textwrap.dedent(new_source)\n        251:                    try:\n        252:                        new_node = ast.parse(normalized).body[0]\n        253:                        self.success = True\n        254:                        return new_node\n        255:                    except Exception:\n        256:                        pass\n        257:        return node\n        258:\n        259:    def _handle_insertion(self, node):\n        260:        \"\"\"Handle inserting nodes after a specific point.\"\"\"\n        261:        if isinstance(self.insert_after, str) and '::' not in self.insert_after:\n        262:            if not isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        263:                return node\n        264:            if node.lineno == node.end_lineno:\n        265:                return self._handle_one_line_function(node, self.file_lines[node.lineno - 1])\n        266:            func_lines = self.file_lines[node.lineno - 1:node.end_lineno]\n        267:            if not func_lines:\n        268:                return node\n        269:            target = self.insert_after.strip()\n        270:            target_line_idx = None\n        271:            for i, line in enumerate(func_lines):\n        272:                detokenized_line = detokenize_source(line, self.all_tokens)\n        273:                if detokenized_line.strip() == target:\n        274:                    self.line_match_count += 1\n        275:                    if self.line_match_count == 1:\n        276:                        target_line_idx = i\n        277:            if self.line_match_count == 0:\n        278:                return node\n        279:            elif self.line_match_count > 1:\n        280:                raise ValueError(f'Ambiguous insert_after - found {self.line_match_count} matches for: {self.insert_after}')\n        281:            target_absolute_line = node.lineno + target_line_idx\n        282:            containing_node = self._find_containing_node(node, target_absolute_line)\n        283:            if containing_node and containing_node is not node:\n        284:                self._insert_into_node(containing_node, target_absolute_line)\n        285:            else:\n        286:                insert_index = len(node.body)\n        287:                for idx, child in enumerate(node.body):\n        288:                    if hasattr(child, 'lineno') and child.lineno > target_absolute_line:\n        289:                        insert_index = idx\n        290:                        break\n        291:                if insert_index == len(node.body):\n        292:                    node.body.extend(self.new_nodes)\n        293:                else:\n        294:                    for i, new_node in enumerate(self.new_nodes):\n        295:                        node.body.insert(insert_index + i, new_node)\n        296:            self.success = True\n        297:            return node\n        298:        else:\n        299:            if self.insert_after:\n        300:                target_path = self.insert_after.split('::')\n        301:                current_path = self.current_path\n        302:                if len(target_path) > 1 and len(current_path) == len(target_path) - 1:\n        303:                    if all((c == t for c, t in zip(current_path, target_path[:len(current_path)]))):\n        304:                        target_name = target_path[-1]\n        305:                        insert_index = None\n        306:                        for idx, child in enumerate(node.body):\n        307:                            if hasattr(child, 'name') and child.name == target_name:\n        308:                                insert_index = idx + 1\n        309:                                break\n        310:                        if insert_index is not None:\n        311:                            for i, new_node in enumerate(self.new_nodes):\n        312:                                node.body.insert(insert_index + i, new_node)\n        313:                            self.success = True\n        314:                            return node\n        315:                if len(current_path) == len(target_path) and all((c == t for c, t in zip(current_path, target_path))):\n        316:                    self.success = True\n        317:                    if isinstance(node, ast.ClassDef):\n        318:                        node.body.extend(self.new_nodes)\n        319:                    else:\n        320:                        for new_node in self.new_nodes:\n        321:                            node.body.append(new_node)\n        322:            return node\n        323:\n        324:    def _find_containing_node(self, node, target_line):\n        325:        \"\"\"Find the deepest AST node with a body that contains the target line.\"\"\"\n        326:        if not (hasattr(node, 'lineno') and hasattr(node, 'end_lineno')):\n        327:            return None\n        328:        if not node.lineno <= target_line <= node.end_lineno:\n        329:            return None\n        330:        deepest_with_body = node if hasattr(node, 'body') else None\n        331:        if hasattr(node, 'body'):\n        332:            for child in node.body:\n        333:                deeper_node = self._find_containing_node(child, target_line)\n        334:                if deeper_node:\n        335:                    return deeper_node\n        336:        if hasattr(node, 'orelse'):\n        337:            for child in node.orelse:\n        338:                deeper_node = self._find_containing_node(child, target_line)\n        339:                if deeper_node:\n        340:                    return deeper_node\n        341:        if deepest_with_body:\n        342:            return deepest_with_body\n        343:        return None\n        344:\n        345:    def _insert_into_node(self, node, target_line):\n        346:        \"\"\"Insert new nodes into the given node after the target line.\"\"\"\n        347:        if not hasattr(node, 'body'):\n        348:            return\n        349:        insert_index = len(node.body)\n        350:        for idx, child in enumerate(node.body):\n        351:            if hasattr(child, 'lineno') and child.lineno > target_line:\n        352:                insert_index = idx\n        353:                break\n        354:        for i, new_node in enumerate(self.new_nodes):\n        355:            node.body.insert(insert_index + i, new_node)\n        356:\n        357:def create_token(content: str, index: int, current_hash: str) -> str:\n        358:    \"\"\"Create a token with our specific pattern\"\"\"\n        359:    hex_content = content.encode('utf-8').hex()\n        360:    token_name = f'TOKEN__{current_hash}_{index}'\n        361:    return (token_name, f';\"\"\"{hex_content}\"\"\"')\n        362:\n        363:def get_file_hash(content: str) -> str:\n        364:    \"\"\"Create a short hash of file content\"\"\"\n        365:    return hashlib.sha256(content.encode()).hexdigest()[:8]\n        366:\n        367:def tokenize_source(source: str) -> Tuple[str, Dict[str, str]]:\n        368:    \"\"\"\n        369:    Tokenize source code, preserving exact formatting.\n        370:\n        371:    Returns:\n        372:    - tokenized_source: Source with tokens inserted\n        373:    - token_map: Mapping of tokens to original content\n        374:    \"\"\"\n        375:\n        376:    def contains_token(s: str) -> bool:\n        377:        return ';\"\"\"' in s and '\"\"\"' in s\n        378:    token_map = {}\n        379:    current_hash = get_file_hash(source)\n        380:    token_counter = 0\n        381:    tokenized = source\n        382:    triple_quote_patterns = ['\"\"\"[^\"\\\\\\\\]*(?:(?:\\\\\\\\.|\"(?!\"\"))[^\"\\\\\\\\]*)*\"\"\"', \"'''[^'\\\\\\\\]*(?:(?:\\\\\\\\.|'(?!''))[^'\\\\\\\\]*)*'''\"]\n        383:    for pattern in triple_quote_patterns:\n        384:        while True:\n        385:            match = re.search(pattern, tokenized)\n        386:            if not match:\n        387:                break\n        388:            string_content = match.group()\n        389:            if contains_token(string_content):\n        390:                continue\n        391:            token_name, hex_val = create_token(string_content, token_counter, current_hash)\n        392:            token_map[hex_val] = string_content\n        393:            tokenized = tokenized[:match.start()] + hex_val + tokenized[match.end():]\n        394:            token_counter += 1\n        395:    lines = tokenized.split('\\n')\n        396:    processed_lines = []\n        397:    for line in lines:\n        398:        if not line.strip():\n        399:            processed_lines.append(line)\n        400:            continue\n        401:        indent = len(line) - len(line.lstrip())\n        402:        indentation = ' ' * indent\n        403:        content = line[indent:]\n        404:        if contains_token(content):\n        405:            processed_lines.append(line)\n        406:            continue\n        407:        if content.strip().startswith('#'):\n        408:            token_name, hex_val = create_token(content, token_counter, current_hash)\n        409:            token_map[hex_val] = content\n        410:            processed_lines.append(indentation + 'pass' + hex_val)\n        411:            token_counter += 1\n        412:            continue\n        413:        processed_line = content\n        414:        string_patterns = ['\"[^\"\\\\\\\\]*(?:\\\\\\\\.[^\"\\\\\\\\]*)*\"', \"'[^'\\\\\\\\]*(?:\\\\\\\\.[^'\\\\\\\\]*)*'\"]\n        415:        for pattern in string_patterns:\n        416:            while True:\n        417:                match = re.search(pattern, processed_line)\n        418:                if not match:\n        419:                    break\n        420:                string_content = match.group()\n        421:                if contains_token(string_content):\n        422:                    continue\n        423:                token_name, hex_val = create_token(string_content, token_counter, current_hash)\n        424:                token_map[hex_val] = string_content\n        425:                processed_line = processed_line[:match.start()] + hex_val + processed_line[match.end():]\n        426:                token_counter += 1\n        427:        if '#' in processed_line:\n        428:            comment_start = processed_line.index('#')\n        429:            code = processed_line[:comment_start].rstrip()\n        430:            comment = processed_line[comment_start:]\n        431:            token_name, hex_val = create_token(comment, token_counter, current_hash)\n        432:            token_map[hex_val] = comment\n        433:            processed_line = code + hex_val\n        434:            token_counter += 1\n        435:        processed_lines.append(indentation + processed_line)\n        436:    return ('\\n'.join(processed_lines), token_map)\n        437:\n        438:def detokenize_source(tokenized_source: str, token_map: Dict[str, str]) -> str:\n        439:    \"\"\"\n        440:    Restore original source from tokenized version.\n        441:\n        442:    Handles proper indentation of multiline content.\n        443:    \"\"\"\n        444:    result = tokenized_source\n        445:    for token_name, original in token_map.items():\n        446:        if token_name.startswith(';\"\"\"') and token_name.endswith('\"\"\"'):\n        447:            hex_content = token_name[4:-3]\n        448:            patterns = [f\"'{hex_content}'\", f'\"{hex_content}\"']\n        449:            for pattern in patterns:\n        450:                while pattern in result:\n        451:                    lines = result.split('\\n')\n        452:                    for i, line in enumerate(lines):\n        453:                        if line.strip() == pattern:\n        454:                            indent = len(line) - len(line.lstrip())\n        455:                            lines[i] = ' ' * indent + original\n        456:                            result = '\\n'.join(lines)\n        457:                            break\n        458:                        elif pattern in line and line.strip() != pattern:\n        459:                            if 'pass' in line and line.index('pass') < line.index(pattern):\n        460:                                indent = len(line) - len(line.lstrip())\n        461:                                lines[i] = ' ' * indent + original\n        462:                            else:\n        463:                                lines[i] = line.replace(pattern, '  ' + original)\n        464:                            result = '\\n'.join(lines)\n        465:                            break\n        466:                    else:\n        467:                        break\n        468:    for token_name, original in sorted(token_map.items(), key=lambda x: len(x[0]), reverse=True):\n        469:        while token_name in result:\n        470:            start = result.find(token_name)\n        471:            if start == -1:\n        472:                break\n        473:            if '\\n' in original:\n        474:                indent = get_indentation_at_position(result, start)\n        475:                indented = indent_multiline_content(original, indent)\n        476:                result = result[:start] + indented + result[start + len(token_name):]\n        477:            else:\n        478:                result = result[:start] + original + result[start + len(token_name):]\n        479:    return result\n        480:\n        481:def get_indentation_at_position(source: str, pos: int) -> str:\n        482:    \"\"\"Get the indentation level at a given position in source\"\"\"\n        483:    line_start = source.rfind('\\n', 0, pos) + 1\n        484:    return source[line_start:pos].replace(source[line_start:pos].lstrip(), '')\n        485:\n        486:def indent_multiline_content(content: str, indent: str) -> str:\n        487:    \"\"\"Indent multiline content while preserving internal formatting\"\"\"\n        488:    if not content.strip():\n        489:        return content\n        490:    lines = content.split('\\n')\n        491:    if len(lines) == 1:\n        492:        return content\n        493:    if all((line.startswith(' ') for line in lines[1:] if line.strip())):\n        494:        return content\n        495:    result = [lines[0]]\n        496:    for line in lines[1:]:\n        497:        if line.strip():\n        498:            result.append(indent + line)\n        499:        else:\n        500:            result.append(line)\n        501:    return '\\n'.join(result)"
