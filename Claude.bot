y\n                test_add_tools_openai.py\n                test_auto_terminal.py\n                test_basic.py\n                test_bots.py\n                test_code_tools.py\n                test_decorators.py\n                test_github_flows.py\n                test_helpers.py\n                test_oaibot.py\n                test_par_branch.py\n                test_par_dispatch.py\n                test_patch_edit.py\n                test_python_edit.py\n                test_python_tools.py\n                test_save_load_anthropic.py\n                test_save_load_openai.py\n                test_terminal_tools.py\n                test_tool_handler.py\n                __init__.py\n            tmp/\n                test_file.py"
