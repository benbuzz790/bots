                                                                                                                                                                     "class_name": "ScopeTransformer",
                                                                                                                                                                     "new_method_def": "\n                            def _handle_insertion(self, node):\n                                \"\"\"Handle inserting nodes after a specific point.\"\"\"\n                                if isinstance(self.insert_after, str) and '::' not in self.insert_after:\n                                    # Line-based insertion\n                                    if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n                                        # For functions, we need to look at the body\n                                        source = '\\n'.join(_py_ast_to_source(stmt) for stmt in node.body)\n                                        lines = [l.rstrip() for l in source.split('\\n')]\n                                        target = self.insert_after.strip()\n                                        \n                                        # Find the line and its indentation\n                                        for i, line in enumerate(lines):\n                                            if line.strip() == target:\n                                                self.line_match_count += 1\n                                                if self.line_match_count == 1:\n                                                    # Get base indentation from function def\n                                                    func_source = _py_ast_to_source(node)\n                                                    base_indent = len(func_source.split('\\n')[0]) - len(func_source.split('\\n')[0].lstrip())\n                                                    # Add one level for function body\n                                                    base_indent += 4\n                                                    \n                                                    # Insert new nodes with matching indentation\n                                                    insertion = []\n                                                    for new_node in self.new_nodes:\n                                                        node_lines = _py_ast_to_source(new_node).split('\\n')\n                                                        for nl in node_lines:\n                                                            if nl.strip():\n                                                                insertion.append(' ' * base_indent + nl.lstrip())\n                                                            else:\n                                                                insertion.append('')\n                                                    \n                                                    # Insert after the matching line\n                                                    lines[i:i+1] = [lines[i]] + insertion\n                                                    self.success = True\n                                                    break\n                                        \n                                        if self.line_match_count == 0:\n                                            return node\n                                        elif self.line_match_count > 1:\n                                            raise ValueError(f\"Ambiguous insert_after - found {self.line_match_count} matches for: {self.insert_after}\")\n                                        \n                                        # Parse the modified lines back into nodes\n                                        new_body = ast.parse('\\n'.join(lines)).body\n                                        node.body = new_body\n                                        return node\n                                    else:\n                                        # For other nodes, use the original approach\n                                        source = _py_ast_to_source(node)\n                                        lines = [l.rstrip() for l in source.split('\\n')]\n                                        target = self.insert_after.strip()\n                                        \n                                        for i, line in enumerate(lines):\n                                            if line.strip() == target:\n                                                self.line_match_count += 1\n                                                if self.line_match_count == 1:\n                                                    base_indent = len(line) - len(line.lstrip())\n                                                    insertion = []\n                                                    for new_node in self.new_nodes:\n                                                        node_lines = _py_ast_to_source(new_node).split('\\n')\n                                                        for nl in node_lines:\n                                                            if nl.strip():\n                                                                insertion.append(' ' * base_indent + nl.lstrip())\n                                                            else:\n                                                                insertion.append('')\n                                                    lines[i:i+1] = [lines[i]] + insertion\n                                                    self.success = True\n                                                    break\n                                        \n                                        if self.line_match_count == 0:\n                                            return node\n                                        elif self.line_match_count > 1:\n                                            raise ValueError(f\"Ambiguous insert_after - found {self.line_match_count} matches for: {self.insert_after}\")\n                                        \n                                        new_source = '\\n'.join(lines)\n                                        return ast.parse(new_source).body[0]\n                                else:\n                                    # Scope-based insertion\n                                    if self.insert_after:\n                                        target_path = self.insert_after.split('::')\n                                        current_path = '::'.join(self.current_path)\n                                        \n                                        # Check if we're at the target scope\n                                        if current_path == self.insert_after:\n                                            self.success = True\n                                            if isinstance(node, ast.ClassDef):\n                                                # For classes, append to body\n                                                node.body.extend(self.new_nodes)\n                                            else:\n                                                # For functions, need to handle indentation\n                                                for new_node in self.new_nodes:\n                                                    node.body.append(new_node)\n                                    return node"
