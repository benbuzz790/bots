                          "content": "\n        1:import os\n        2:import unittest\n        3:from bots.tools.code_tools import apply_git_patch\n        4:import textwrap\n        5:\n        6:class TestGitPatch(unittest.TestCase):\n        7:\n        8:    def setUp(self):\n        9:        self.test_file = 'test_patch_file.txt'\n        10:        with open(self.test_file, 'w') as f:\n        11:            f.write('line 1\\nline 2\\nline 3\\nline 4\\nline 5\\n')\n        12:\n        13:    def tearDown(self):\n        14:        if os.path.exists(self.test_file):\n        15:            os.remove(self.test_file)\n        16:\n        17:    def test_simple_addition(self):\n        18:        patch = textwrap.dedent('\\n@@ -2,2 +2,3 @@\\nline 2\\n+new line\\nline 3')\n        19:        result = apply_git_patch(self.test_file, patch)\n        20:        self.assertIn('Successfully', result)\n        21:        self.assertNotIn('ignoring whitespace', result, 'Expected exact match but got whitespace-ignored match')\n        22:        with open(self.test_file, 'r') as f:\n        23:            content = f.read()\n        24:        self.assertEqual(content, 'line 1\\nline 2\\nnew line\\nline 3\\nline 4\\nline 5\\n')\n        25:\n        26:    def test_simple_deletion(self):\n        27:        patch = textwrap.dedent('\\n@@ -2,3 +2,2 @@\\nline 2\\n-line 3\\nline 4')\n        28:        result = apply_git_patch(self.test_file, patch)\n        29:        self.assertIn('Successfully', result)\n        30:        self.assertNotIn('ignoring whitespace', result, 'Expected exact match but got whitespace-ignored match')\n        31:        with open(self.test_file, 'r') as f:\n        32:            content = f.read()\n        33:        self.assertEqual(content, 'line 1\\nline 2\\nline 4\\nline 5\\n')\n        34:\n        35:    def test_replacement(self):\n        36:        patch = textwrap.dedent('\\n@@ -2,3 +2,3 @@\\nline 2\\n-line 3\\n+modified line 3\\nline 4')\n        37:        result = apply_git_patch(self.test_file, patch)\n        38:        self.assertIn('Successfully', result)\n        39:        with open(self.test_file, 'r') as f:\n        40:            content = f.read()\n        41:        self.assertEqual(content, 'line 1\\nline 2\\nmodified line 3\\nline 4\\nline 5\\n')\n        42:\n        43:    def test_multiple_hunks(self):\n        44:        patch = textwrap.dedent('\\n@@ -1,2 +1,3 @@\\nline 1\\n+inserted at start\\nline 2\\n@@ -4,2 +5,3 @@\\nline 4\\n+inserted at end\\nline 5')\n        45:        result = apply_git_patch(self.test_file, patch)\n        46:        self.assertIn('Successfully', result)\n        47:        with open(self.test_file, 'r') as f:\n        48:            content = f.read()\n        49:        self.assertEqual(content, 'line 1\\ninserted at start\\nline 2\\nline 3\\nline 4\\ninserted at end\\nline 5\\n')\n        50:\n        51:    def test_invalid_patch_format(self):\n        52:        patch = 'not a valid patch format'\n        53:        result = apply_git_patch(self.test_file, patch)\n        54:        self.assertIn('Error', result)\n        55:        self.assertIn('No valid patch hunks', result)\n        56:\n        57:    def test_context_mismatch(self):\n        58:        patch = textwrap.dedent('\\n@@ -2,3 +2,3 @@\\nwrong context\\n-line 3\\n+modified line 3\\nline 4')\n        59:        result = apply_git_patch(self.test_file, patch)\n        60:        self.assertIn('Error', result)\n        61:        self.assertIn('Could not find matching content', result)\n        62:\n        63:    def test_empty_patch(self):\n        64:        patch = ''\n        65:        result = apply_git_patch(self.test_file, patch)\n        66:        self.assertIn('Error', result)\n        67:        self.assertIn('patch_content is empty', result)\n        68:\n        69:    def test_new_file(self):\n        70:        new_file = 'new_test_file.txt'\n        71:        if os.path.exists(new_file):\n        72:            os.remove(new_file)\n        73:        patch = textwrap.dedent('\\n@@ -0,0 +1,3 @@\\n+first line\\n+second line\\n+third line')\n        74:        try:\n        75:            result = apply_git_patch(new_file, patch)\n        76:            self.assertIn('Successfully', result)\n        77:            with open(new_file, 'r') as f:\n        78:                content = f.read()\n        79:            self.assertEqual(content, 'first line\\nsecond line\\nthird line\\n')\n        80:        finally:\n        81:            if os.path.exists(new_file):\n        82:                os.remove(new_file)\n        83:\n        84:    def test_match_at_different_line(self):\n        85:        \"\"\"Test that content is matched even if line numbers don't match\"\"\"\n        86:        with open(self.test_file, 'w') as f:\n        87:            f.write('header\\nline 1\\nline 2\\nline 3\\nline 4\\nline 5\\n')\n        88:        patch = textwrap.dedent('\\n@@ -2,2 +2,2 @@\\nline 2\\n-line 3\\n+modified line 3')\n        89:        result = apply_git_patch(self.test_file, patch)\n        90:        self.assertIn('Successfully', result)\n        91:        self.assertIn('Note: Applied hunk at line', result)\n        92:\n        93:    def test_match_with_different_whitespace(self):\n        94:        \"\"\"Test that content is matched even with different indentation\"\"\"\n        95:        with open(self.test_file, 'w') as f:\n        96:            f.write('def test():\\n    line 1\\n    line 2\\n        line 3\\n    line 4\\n')\n        97:        patch = textwrap.dedent('\\n@@ -2,2 +2,2 @@\\nline 2\\n-line 3\\n+modified line 3')\n        98:        print('\\nFile content:')\n        99:        with open(self.test_file, 'r') as f:\n        100:            print(repr(f.read()))\n        101:        print('\\nPatch content:')\n        102:        print(repr(patch))\n        103:        result = apply_git_patch(self.test_file, patch)\n        104:        print('\\nResult:', result)\n        105:        with open(self.test_file, 'r') as f:\n        106:            print('\\nFinal content:')\n        107:            print(repr(f.read()))\n        108:        self.assertIn('Successfully', result)\n        109:        self.assertIn('ignoring whitespace', result)\n        110:\n        111:    def test_similar_but_not_exact_match(self):\n        112:        \"\"\"Test that similar but not exact matches are reported\"\"\"\n        113:        with open(self.test_file, 'w') as f:\n        114:            f.write('line 1\\nline two\\nline 3\\nline 4\\n')\n        115:        patch = textwrap.dedent('\\n@@ -2,2 +2,2 @@\\nline 2\\n-line 3\\n+modified line 3')\n        116:        result = apply_git_patch(self.test_file, patch)\n        117:        self.assertIn('Error', result)\n        118:        self.assertIn('Could not find matching content', result)\n        119:\n        120:    def test_no_match_found(self):\n        121:        \"\"\"Test that appropriate error is returned when no match is found\"\"\"\n        122:        with open(self.test_file, 'w') as f:\n        123:            f.write('completely\\ndifferent\\ncontent\\n')\n        124:        patch = textwrap.dedent('\\n        @@ -2,2 +2,2 @@\\n         line 2\\n        -line 3\\n        +modified line 3')\n        125:        result = apply_git_patch(self.test_file, patch)\n        126:        self.assertIn('Error', result)\n        127:        self.assertTrue('Could not find matching content anywhere in file' in result or 'Context mismatch' in result, f'Expected error message about missing content, got: {result}')\n        128:\n        129:    def test_whitespace_only_difference(self):\n        130:        \"\"\"Test matching when only whitespace differs\"\"\"\n        131:        with open(self.test_file, 'w') as f:\n        132:            f.write('    line 1\\n        line 2\\n    line 3\\n')\n        133:        patch = textwrap.dedent('\\n@@ -1,3 +1,3 @@\\nline 1\\n-line 2\\n+modified line 2\\nline 3')\n        134:        result = apply_git_patch(self.test_file, patch)\n        135:        self.assertIn('Successfully', result)\n        136:        self.assertIn('ignoring whitespace', result)\n        137:        with open(self.test_file, 'r') as f:\n        138:            content = f.read()\n        139:        self.assertEqual(content, '    line 1\\n        modified line 2\\n    line 3\\n')\n        140:\n        141:    def test_indentation_preservation_simple(self):\n        142:        \"\"\"Test that existing indentation is preserved on modified lines\"\"\"\n        143:        with open(self.test_file, 'w') as f:\n        144:            f.write('line 1\\n    indented line\\n        double indented\\n')\n        145:        patch = textwrap.dedent('\\n@@ -2,1 +2,1 @@\\nindented line\\n-double indented\\n+modified line')\n        146:        result = apply_git_patch(self.test_file, patch)\n        147:        self.assertIn('Successfully', result)\n        148:        with open(self.test_file, 'r') as f:\n        149:            content = f.read()\n        150:        self.assertEqual(content, 'line 1\\n    indented line\\n        modified line\\n')\n        151:\n        152:    def test_find_block_with_context(self):\n        153:        \"\"\"Test finding a block with surrounding context\"\"\"\n        154:        with open(self.test_file, 'w') as f:\n        155:            f.write('header\\n    block start\\n    target line\\n    block end\\nfooter\\n')\n        156:        patch = textwrap.dedent('\\n@@ -2,3 +2,3 @@\\nblock start\\n-target line\\n+modified line\\nblock end')\n        157:        result = apply_git_patch(self.test_file, patch)\n        158:        self.assertIn('Successfully', result)\n        159:        with open(self.test_file, 'r') as f:\n        160:            content = f.read()\n        161:        self.assertEqual(content, 'header\\n    block start\\n    modified line\\n    block end\\nfooter\\n')\n        162:\n        163:    def test_match_with_different_whitespace_debug(self):\n        164:        \"\"\"Debug version to see what's happening with whitespace matching\"\"\"\n        165:        with open(self.test_file, 'w') as f:\n        166:            f.write('def test():\\n    line 1\\n    line 2\\n        line 3\\n    line 4\\n')\n        167:        patch = textwrap.dedent('\\n@@ -2,2 +2,2 @@\\nline 2\\n-line 3\\n+modified line 3')\n        168:        print('\\nFile content:')\n        169:        with open(self.test_file, 'r') as f:\n        170:            print(repr(f.read()))\n        171:        print('\\nPatch content:')\n        172:        print(repr(patch))\n        173:        result = apply_git_patch(self.test_file, patch)\n        174:        print('\\nResult:', result)\n        175:        with open(self.test_file, 'r') as f:\n        176:            print('\\nFinal content:')\n        177:            print(repr(f.read()))\n        178:\n        179:    def test_multiple_possible_matches(self):\n        180:        \"\"\"Test behavior when multiple potential matches exist\"\"\"\n        181:        with open(self.test_file, 'w') as f:\n        182:            f.write('def test1():\\n    line 1\\n    line 2\\ndef test2():\\n    line 1\\n    line 2\\n')\n        183:        patch = textwrap.dedent('\\n@@ -2,2 +2,2 @@\\nline 1\\n-line 2\\n+modified line')\n        184:        result = apply_git_patch(self.test_file, patch)\n        185:        if 'multiple' in result.lower() or 'ambiguous' in result.lower():\n        186:            self.assertTrue(True)\n        187:        else:\n        188:            with open(self.test_file, 'r') as f:\n        189:                content = f.read()\n        190:            self.assertTrue(content.startswith('def test1():\\n    line 1\\n    modified line\\n'), f'Expected modification at first match, but got:\\n{content}')\n        191:\n        192:    def test_create_in_new_directory(self):\n        193:        \"\"\"Test creating a file in a directory that doesn't exist yet\"\"\"\n        194:        new_dir = os.path.join(self.test_file + '_newdir', 'subdir', 'deeperdir')\n        195:        new_file = os.path.join(new_dir, 'newfile.txt')\n        196:        patch = textwrap.dedent('\\n@@ -0,0 +1,3 @@\\n+line 1\\n+line 2\\n+line 3')\n        197:        try:\n        198:            self.assertFalse(os.path.exists(new_dir))\n        199:            result = apply_git_patch(new_file, patch)\n        200:            self.assertIn('Successfully', result)\n        201:            self.assertTrue(os.path.exists(new_file))\n        202:            with open(new_file, 'r') as f:\n        203:                content = f.read()\n        204:            self.assertEqual(content, 'line 1\\nline 2\\nline 3\\n')\n        205:        finally:\n        206:            if os.path.exists(os.path.dirname(new_dir)):\n        207:                import shutil\n        208:                shutil.rmtree(os.path.dirname(new_dir))\n        209:\n        210:    def test_double_slash_handling(self):\n        211:        \"\"\"Test that double slashes in paths are handled correctly\"\"\"\n        212:        test_path = 'test//path//file.txt'\n        213:        patch = textwrap.dedent('\\n@@ -0,0 +1,1 @@\\n+test content')\n        214:        full_path = os.path.join(self.test_file + '_dir', test_path)\n        215:        try:\n        216:            result = apply_git_patch(full_path, patch)\n        217:            self.assertIn('Successfully', result)\n        218:            normalized_path = os.path.normpath(full_path)\n        219:            self.assertTrue(os.path.exists(normalized_path))\n        220:            with open(normalized_path, 'r') as f:\n        221:                content = f.read()\n        222:            self.assertEqual(content.strip(), 'test content')\n        223:        finally:\n        224:            if os.path.exists(os.path.dirname(full_path)):\n        225:                import shutil\n        226:                shutil.rmtree(os.path.dirname(os.path.dirname(full_path)))\n        227:\n        228:    def test_path_normalization(self):\n        229:        \"\"\"Test that both forward and backward slashes work in paths\"\"\"\n        230:        test_paths = ['test/path/file.txt', 'test\\\\path\\\\file.txt', 'test/path\\\\mixed/slashes\\\\file.txt']\n        231:        patch = textwrap.dedent('\\n@@ -0,0 +1,1 @@\\n+test content')\n        232:        for path in test_paths:\n        233:            full_path = os.path.join(self.test_file + '_dir', path)\n        234:            try:\n        235:                result = apply_git_patch(full_path, patch)\n        236:                self.assertIn('Successfully', result)\n        237:                self.assertTrue(os.path.exists(os.path.normpath(full_path)))\n        238:                with open(os.path.normpath(full_path), 'r') as f:\n        239:                    content = f.read()\n        240:                self.assertEqual(content.strip(), 'test content')\n        241:            finally:\n        242:                if os.path.exists(os.path.dirname(full_path)):\n        243:                    import shutil\n        244:                    shutil.rmtree(os.path.dirname(os.path.dirname(full_path)))\n        245:\n        246:    def test_class_indentation_preservation(self):\n        247:        \"\"\"Test that class and method indentation is properly preserved when applying patches\"\"\"\n        248:        with open(self.test_file, 'w') as f:\n        249:            f.write('class MyClass:\\n    def method1(self):\\n        return \"original\"\\n\\n    def method2(self):\\n        return \"test\"\\n')\n        250:        patch = textwrap.dedent('\\n@@ -1,6 +1,6 @@\\nclass MyClass:\\n    def method1(self):\\n-        return \"original\"\\n+        return \"modified\"\\n\\n    def method2(self):\\n        return \"test\"')\n        251:        result = apply_git_patch(self.test_file, patch)\n        252:        self.assertIn('Successfully', result)\n        253:        with open(self.test_file, 'r') as f:\n        254:            content = f.read()\n        255:        expected = 'class MyClass:\\n    def method1(self):\\n        return \"modified\"\\n\\n    def method2(self):\\n        return \"test\"\\n'\n        256:        self.assertEqual(content, expected, f'Indentation was not preserved.\\nExpected:\\n{repr(expected)}\\nGot:\\n{repr(content)}')\n        257:\n        258:    def test_adding_to_import_only_file(self):\n        259:        \"\"\"Test that adding content to a file with only imports preserves indentation\"\"\"\n        260:        with open(self.test_file, 'w') as f:\n        261:            f.write('import numpy as np\\nimport time\\nfrom typing import List, Tuple\\n')\n        262:        patch = '@@ -1,3 +1,54 @@\\nimport numpy as np\\nimport time\\nfrom typing import List, Tuple\\n+\\n+class GameOfLife:\\n+    def __init__(self, size: Tuple[int, int]):\\n+        self.size = size\\n+        self.grid = np.random.choice([0, 1], size=size, p=[0.85, 0.15])\\n+    \\n+    def get_neighbors(self, pos: Tuple[int, int]) -> int:\\n+        \"\"\"Count live neighbors for a given cell position.\"\"\"\\n+        row, col = pos\\n+        count = 0\\n+        for i in [-1, 0, 1]:\\n+            for j in [-1, 0, 1]:\\n+                if i == 0 and j == 0:\\n+                    continue\\n+                r = (row + i) % self.size[0]\\n+                c = (col + j) % self.size[1]\\n+                count += self.grid[r, c]\\n+        return count\\n+    \\n+    def step(self) -> None:\\n+        \"\"\"Advance the game by one generation.\"\"\"\\n+        new_grid = np.copy(self.grid)\\n+        for i in range(self.size[0]):\\n+            for j in range(self.size[1]):\\n+                neighbors = self.get_neighbors((i, j))\\n+                if self.grid[i, j] == 1:\\n+                    if neighbors < 2 or neighbors > 3:\\n+                        new_grid[i, j] = 0\\n+                else:\\n+                    if neighbors == 3:\\n+                        new_grid[i, j] = 1\\n+        self.grid = new_grid\\n+    \\n+    def display(self) -> None:\\n+        \"\"\"Display the current state of the game.\"\"\"\\n+        for row in self.grid:\\n+            print(\\'\\'.join([\\'\u25a0\\' if cell else \\'\u25a1\\' for cell in row]))\\n+\\n+def main():\\n+    # Initialize game with a 20x40 grid\\n+    game = GameOfLife((20, 40))\\n+    \\n+    # Run for 100 generations\\n+    for _ in range(100):\\n+        print(\"\\\\033[2J\\\\033[H\")  # Clear screen\\n+        game.display()\\n+        game.step()\\n+        time.sleep(0.1)\\n+\\n+if __name__ == \"__main__\":\\n+    main()'\n        263:        result = apply_git_patch(self.test_file, patch)\n        264:        self.assertIn('Successfully', result)\n        265:        with open(self.test_file, 'r') as f:\n        266:            content = f.read()\n        267:        expected = 'import numpy as np\\nimport time\\nfrom typing import List, Tuple\\n\\nclass GameOfLife:\\n    def __init__(self, size: Tuple[int, int]):\\n        self.size = size\\n        self.grid = np.random.choice([0, 1], size=size, p=[0.85, 0.15])\\n\\n    def get_neighbors(self, pos: Tuple[int, int]) -> int:\\n        \"\"\"Count live neighbors for a given cell position.\"\"\"\\n        row, col = pos\\n        count = 0\\n        for i in [-1, 0, 1]:\\n            for j in [-1, 0, 1]:\\n                if i == 0 and j == 0:\\n                    continue\\n                r = (row + i) % self.size[0]\\n                c = (col + j) % self.size[1]\\n                count += self.grid[r, c]\\n        return count\\n\\n    def step(self) -> None:\\n        \"\"\"Advance the game by one generation.\"\"\"\\n        new_grid = np.copy(self.grid)\\n        for i in range(self.size[0]):\\n            for j in range(self.size[1]):\\n                neighbors = self.get_neighbors((i, j))\\n                if self.grid[i, j] == 1:\\n                    if neighbors < 2 or neighbors > 3:\\n                        new_grid[i, j] = 0\\n                else:\\n                    if neighbors == 3:\\n                        new_grid[i, j] = 1\\n        self.grid = new_grid\\n\\n    def display(self) -> None:\\n        \"\"\"Display the current state of the game.\"\"\"\\n        for row in self.grid:\\n            print(\\'\\'.join([\\'\u25a0\\' if cell else \\'\u25a1\\' for cell in row]))\\n\\ndef main():\\n    # Initialize game with a 20x40 grid\\n    game = GameOfLife((20, 40))\\n\\n    # Run for 100 generations\\n    for _ in range(100):\\n        print(\"\\\\033[2J\\\\033[H\")  # Clear screen\\n        game.display()\\n        game.step()\\n        time.sleep(0.1)\\n\\nif __name__ == \"__main__\":\\n    main()\\n'\n        268:        self.assertEqual(content, expected, f'Content or indentation mismatch.\\nExpected:\\n{repr(expected)}\\nGot:\\n{repr(content)}')\n        269:\n        270:    def test_relative_indentation_preservation(self):\n        271:        \"\"\"Test that relative indentation between lines is preserved while adjusting to target indent\"\"\"\n        272:        with open(self.test_file, 'w') as f:\n        273:            f.write('line 1\\nbase indent\\nline 3\\n')\n        274:        patch = textwrap.dedent('\\n@@ -2,1 +2,4 @@\\nbase indent\\n+    indented:\\n+        double indented\\n+            triple indented')\n        275:        result = apply_git_patch(self.test_file, patch)\n        276:        self.assertIn('Successfully', result)\n        277:        with open(self.test_file, 'r') as f:\n        278:            content = f.read()\n        279:        expected = 'line 1\\nbase indent\\n    indented:\\n        double indented\\n            triple indented\\nline 3\\n'\n        280:        self.assertEqual(content, expected, f'Relative indentation not preserved.\\nExpected:\\n{repr(expected)}\\nGot:\\n{repr(content)}')\n        281:        with open(self.test_file, 'w') as f:\n        282:            f.write('line 1\\n    indented line\\nline 3\\n')\n        283:        patch = textwrap.dedent('\\n@@ -2,1 +2,4 @@\\n    indented line\\n+    same level\\n+        more indented\\n+            most indented')\n        284:        result = apply_git_patch(self.test_file, patch)\n        285:        self.assertIn('Successfully', result)\n        286:        with open(self.test_file, 'r') as f:\n        287:            content = f.read()\n        288:        expected = 'line 1\\n    indented line\\n    same level\\n        more indented\\n            most indented\\nline 3\\n'\n        289:        self.assertEqual(content, expected, f'Relative indentation not preserved when adding to indented line.\\nExpected:\\n{repr(expected)}\\nGot:\\n{repr(content)}')\n        290:\n        291:class TestGitPatchHunkParsing(unittest.TestCase):\n        292:\n        293:    def setUp(self):\n        294:        self.test_file = 'test_hunk_parse.txt'\n        295:        with open(self.test_file, 'w') as f:\n        296:            f.write('line 1\\nline 2\\nline 3\\nline 4\\nline 5\\n')\n        297:\n        298:    def tearDown(self):\n        299:        if os.path.exists(self.test_file):\n        300:            os.remove(self.test_file)\n        301:\n        302:    def test_malformed_hunk_header(self):\n        303:        \"\"\"Test various malformed hunk headers\"\"\"\n        304:        bad_headers = ['@@ -2,2 +2,2\\n line 2\\n-line 3\\n+modified line 3', '@@ -2 +2 @@\\n line 2\\n-line 3\\n+modified line 3', '@@ -a,2 +2,2 @@\\n line 2\\n-line 3\\n+modified line 3', '@@ -2,2 2,2 @@\\n line 2\\n-line 3\\n+modified line 3', '@@ -2,2 +2,2 @@ extra\\n line 2\\n-line 3\\n+modified line 3']\n        305:        for header in bad_headers:\n        306:            result = apply_git_patch(self.test_file, header)\n        307:            self.assertIn('Error', result, f'Expected error for malformed header: {header}')\n        308:\n        309:    def test_incorrect_line_counts(self):\n        310:        \"\"\"Test hunks where the stated line count doesn't match content\"\"\"\n        311:        patches = ['@@ -2,2 +2,2 @@\\n line 2\\n line 3\\n line 4\\n-line 5\\n+modified line', '@@ -2,3 +2,3 @@\\n line 2\\n-line 3\\n+modified line']\n        312:        for patch in patches:\n        313:            result = apply_git_patch(self.test_file, patch)\n        314:            self.assertIn('Error', result, f'Expected error for incorrect line count: {patch}')\n        315:\n        316:    def test_empty_lines_in_hunk(self):\n        317:        \"\"\"Test hunks with empty lines in various positions\"\"\"\n        318:        patch = textwrap.dedent('\\n@@ -2,4 +2,4 @@\\nline 2\\n\\n-line 3\\n+modified line 3\\nline 4')\n        319:        result = apply_git_patch(self.test_file, patch)\n        320:        self.assertIn('Successfully', result)\n        321:\n        322:    def test_missing_context_lines(self):\n        323:        \"\"\"Test hunks with no context lines\"\"\"\n        324:        patch = textwrap.dedent('\\n@@ -2,1 +2,1 @@\\n-line 2\\n+modified line 2')\n        325:        result = apply_git_patch(self.test_file, patch)\n        326:        self.assertIn('Successfully', result)\n        327:        with open(self.test_file, 'r') as f:\n        328:            content = f.read()\n        329:        self.assertEqual(content, 'line 1\\nmodified line 2\\nline 3\\nline 4\\nline 5\\n')\n        330:\n        331:    def test_malformed_change_lines(self):\n        332:        \"\"\"Test hunks with malformed change lines\"\"\"\n        333:        bad_patches = ['@@ -2,2 +2,2 @@\\nline 2\\n-line 3\\n+modified line 3', '@@ -2,2 +2,2 @@\\n line 2\\n*line 3\\n#modified line 3', '@@ -2,2 +2,2 @@\\n  line 2\\n -line 3\\n + modified line 