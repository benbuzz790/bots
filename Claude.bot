                                                                                                                                                                                                "input": {
                                                                                                                                                                                                 "file_path": "bots/tools/python_editing_tools.py",
                                                                                                                                                                                                 "old_class_name": "ScopeTransformer",
                                                                                                                                                                                                 "new_class_def": "\n            class ScopeTransformer(ast.NodeTransformer):\n                \"\"\"AST transformer that handles scope-based Python code modifications.\"\"\"\n                \n                def __init__(self, path_elements, new_nodes, insert_after=None, file_lines=None):\n                    self.original_path = path_elements\n                    self.new_nodes = new_nodes\n                    self.insert_after = insert_after\n                    self.file_lines = file_lines\n                    self.current_path = []\n                    self.success = False\n                    self.line_match_count = 0\n                \n                def visit_ClassDef(self, node):\n                    \"\"\"Visit a class definition node.\"\"\"\n                    # Check if we're at the right path element\n                    if not self.original_path or node.name != self.original_path[0]:\n                        return self.generic_visit(node)\n                    \n                    # Update our current position\n                    self.current_path.append(node.name)\n                    remaining_path = self.original_path[1:]\n                    \n                    if not remaining_path:  # We're at the target\n                        if self.insert_after:\n                            node = self._handle_insertion(node)\n                        else:\n                            self.success = True\n                            if len(self.new_nodes) == 1:\n                                return self.new_nodes[0]\n                            else:\n                                node.body = self.new_nodes\n                                return node\n                    else:\n                        # Still need to go deeper - modify the node's body\n                        saved_path = self.original_path\n                        self.original_path = remaining_path\n                        node.body = [self.visit(child) for child in node.body]\n                        self.original_path = saved_path\n                    \n                    self.current_path.pop()\n                    return node\n                \n                def visit_FunctionDef(self, node):\n                    \"\"\"Visit a function definition node.\"\"\"\n                    return self._handle_function_node(node)\n                \n                def visit_AsyncFunctionDef(self, node):\n                    \"\"\"Visit an async function definition node.\"\"\"\n                    return self._handle_function_node(node)\n                \n                def _handle_function_node(self, node):\n                    \"\"\"Common handling for both regular and async functions.\"\"\"\n                    if not self.original_path or node.name != self.original_path[0]:\n                        return self.generic_visit(node)\n                    \n                    self.current_path.append(node.name)\n                    remaining_path = self.original_path[1:]\n                    \n                    if not remaining_path:  # We're at the target\n                        if self.insert_after:\n                            node = self._handle_insertion(node)\n                        else:\n                            self.success = True\n                            if len(self.new_nodes) == 1:\n                                return self.new_nodes[0]\n                            else:\n                                node.body = self.new_nodes\n                                return node\n                    else:\n                        # Still need to go deeper\n                        saved_path = self.original_path\n                        self.original_path = remaining_path\n                        node.body = [self.visit(child) for child in node.body]\n                        self.original_path = saved_path\n                    \n                    self.current_path.pop()\n                    return node\n                \n                def _handle_insertion(self, node):\n                    \"\"\"Handle inserting nodes after a specific point.\"\"\"\n                    if isinstance(self.insert_after, str) and '::' not in self.insert_after:\n                        # Line-based insertion\n                        if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n                            print(f\"\\nDEBUG - Function node: {node.name}\")\n                            print(f\"DEBUG - Line range: {node.lineno} to {node.end_lineno}\")\n                            \n                            # Get the function's source lines including comments\n                            func_lines = self.file_lines[node.lineno-1:node.end_lineno]\n                            print(f\"DEBUG - Function lines:\\n{func_lines}\")\n                            \n                            # Find the line and its indentation\n                            target = self.insert_after.strip()\n                            print(f\"DEBUG - Looking for target: '{target}'\")\n                            \n                            for i, line in enumerate(func_lines):\n                                line = line.rstrip()\n                                print(f\"DEBUG - Checking line: '{line}'\")\n                                if line.strip() == target:\n                                    print(f\"DEBUG - Found match at line {i}\")\n                                    self.line_match_count += 1\n                                    if self.line_match_count == 1:\n                                        # Get base indentation from the matching line\n                                        base_indent = len(line) - len(line.lstrip())\n                                        print(f\"DEBUG - Base indent: {base_indent}\")\n                                        \n                                        # Insert new nodes with matching indentation\n                                        insertion = []\n                                        for new_node in self.new_nodes:\n                                            node_lines = _py_ast_to_source(new_node).split('\\n')\n                                            for nl in node_lines:\n                                                if nl.strip():\n                                                    insertion.append(' ' * base_indent + nl.lstrip())\n                                                else:\n                                                    insertion.append('')\n                                        print(f\"DEBUG - Insertion lines: {insertion}\")\n                                        \n                                        # Insert after the matching line\n                                        func_lines[i:i+1] = [func_lines[i]] + insertion\n                                        self.success = True\n                                        break\n                            \n                            if self.line_match_count == 0:\n                                print(\"DEBUG - No matches found\")\n                                return node\n                            elif self.line_match_count > 1:\n                                raise ValueError(f\"Ambiguous insert_after - found {self.line_match_count} matches for: {self.insert_after}\")\n                            \n                            # Parse the modified lines back into nodes\n                            new_source = '\\n'.join(func_lines)\n                            print(f\"DEBUG - New source:\\n{new_source}\")\n                            new_body = ast.parse(new_source).body\n                            if new_body:  # Only update if we got valid nodes\n                                node.body = new_body[0].body if isinstance(new_body[0], (ast.FunctionDef, ast.AsyncFunctionDef)) else new_body\n                            return node\n                        else:\n                            # For other nodes, use the original approach\n                            source = _py_ast_to_source(node)\n                            lines = [l.rstrip() for l in source.split('\\n')]\n                            target = self.insert_after.strip()\n                            \n                            for i, line in enumerate(lines):\n                                if line.strip() == target:\n                                    self.line_match_count += 1\n                                    if self.line_match_count == 1:\n                                        base_indent = len(line) - len(line.lstrip())\n                                        insertion = []\n                                        for new_node in self.new_nodes:\n                                            node_lines = _py_ast_to_source(new_node).split('\\n')\n                                            for nl in node_lines:\n                                                if nl.strip():\n                                                    insertion.append(' ' * base_indent + nl.lstrip())\n                                                else:\n                                                    insertion.append('')\n                                        lines[i:i+1] = [lines[i]] + insertion\n                                        self.success = True\n                                        break\n                            \n                            if self.line_match_count == 0:\n                                return node\n                            elif self.line_match_count > 1:\n                                raise ValueError(f\"Ambiguous insert_after - found {self.line_match_count} matches for: {self.insert_after}\")\n                            \n                            new_source = '\\n'.join(lines)\n                            return ast.parse(new_source).body[0]\n                    else:\n                        # Scope-based insertion\n                        if self.insert_after:\n                            target_path = self.insert_after.split('::')\n                            current_path = '::'.join(self.current_path)\n                            print(f\"DEBUG - Scope insertion: target={target_path}, current={current_path}\")\n                            \n                            # Check if we're at the target scope\n                            if current_path == self.insert_after:\n                                self.success = True\n                                if isinstance(node, ast.ClassDef):\n                                    # For classes, append to body\n                                    node.body.extend(self.new_nodes)\n                                else:\n                                    # For functions, need to handle indentation\n                                    for new_node in self.new_nodes:\n                                        node.body.append(new_node)\n                        return node"
                                                                                                                                                                                                }
                                                                                                                                                                                               }
