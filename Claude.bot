e(node, ast.ClassDef):\n        316:                    node.body.extend(self.new_nodes)\n        317:                else:\n        318:                    for new_node in self.new_nodes:\n        319:                        node.body.append(new_node)\n        320:        return node\n        321:\n        322:            if self.line_match_count == 0:\n        323:                return node\n        324:            elif self.line_match_count > 1:\n        325:                raise ValueError(f'Ambiguous insert_after - found {self.line_match_count} matches for: {self.insert_after}')\n        326:\n        327:            # Reconstruct the source and parse back to AST\n        328:            new_source = '\\n'.join(source_lines)\n        329:            try:\n        330:                new_node = ast.parse(new_source).body[0]\n        331:                return new_node\n        332:            except Exception:\n        333:                return node\n        334:            return node\n        335:        else:\n        336:            if self.insert_after:\n        337:                target_path = self.insert_after.split('::')\n        338:                current_path = self.current_path\n        339:                if len(current_path) == len(target_path) and all((c == t for c, t in zip(current_path, target_path))):\n        340:                    self.success = True\n        341:                    if isinstance(node, ast.ClassDef):\n        342:                        node.body.extend(self.new_nodes)\n        343:                    else:\n        344:                        for new_node in self.new_nodes:\n        345:                            node.body.append(new_node)\n        346:            return node\n        347:\n        348:    def _preserve_node_source(self, node):\n        349:        \"\"\"Get the original source of a node, preserving comments and formatting\"\"\"\n        350:        if hasattr(node, 'lineno') and hasattr(node, 'end_line