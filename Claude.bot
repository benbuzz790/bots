                                                                                                                                                                                                             "new_function_def": "\n                                    def detokenize_source(tokenized_source: str, token_map: Dict[str, str]) -> str:\n                                        \"\"\"\n                                        Restore original source from tokenized version.\n                                        \n                                        Handles proper indentation of multiline content.\n                                        \"\"\"\n                                        result = tokenized_source\n                                        # Sort by length to avoid partial replacements\n                                        for token_name, original in sorted(token_map.items(), key=lambda x: len(x[0]), reverse=True):\n                                            # Replace all occurrences of this token\n                                            while True:\n                                                # For standalone comments, look for pass;\"\"\"...\"\"\" pattern\n                                                pass_pattern = f'pass{token_name}'\n                                                start = result.find(pass_pattern)\n                                                if start != -1:\n                                                    # Found with pass prefix, replace the whole thing\n                                                    line_start = result.rfind('\\n', 0, start) + 1\n                                                    indent = result[line_start:start]\n                                                    # Replace with just the original content\n                                                    result = result[:line_start] + indent + original + result[start + len(pass_pattern):]\n                                                    continue\n                                                \n                                                # Look for the token itself\n                                                start = result.find(token_name)\n                                                if start == -1:\n                                                    break\n                                                    \n                                                # Check if we need to add spacing for inline comments\n                                                # If the character before the token is not whitespace or semicolon, add a space\n                                                if start > 0 and result[start-1] not in ' \\t;':\n                                                    # This is likely an inline comment that needs spacing\n                                                    result = result[:start] + '  ' + original + result[start + len(token_name):]\n                                                else:\n                                                    # Handle multiline content\n                                                    if '\\n' in original:\n                                                        indent = get_indentation_at_position(result, start)\n                                                        indented = indent_multiline_content(original, indent)\n                                                        result = result[:start] + indented + result[start + len(token_name):]\n                                                    else:\n                                                        result = result[:start] + original + result[start + len(token_name):]\n                                        return result"
                                                                                                                                                                                                            }
