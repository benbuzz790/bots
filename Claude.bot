                                                                  "content": "\n        1:import ast\n        2:import os\n        3:from bots.utils.helpers import _process_error, _clean, _py_ast_to_source\n        4:\n        5:class NodeTransformerWithAsyncSupport(ast.NodeTransformer):\n        6:    \"\"\"Base class for AST transformers that need to handle both sync and async functions.\"\"\"\n        7:\n        8:    def __init__(self):\n        9:        self.success = False\n        10:\n        11:    def visit_FunctionDef(self, node):\n        12:        return self._handle_function(node)\n        13:\n        14:    def visit_AsyncFunctionDef(self, node):\n        15:        return self._handle_function(node)\n        16:\n        17:    def _handle_function(self, node):\n        18:        \"\"\"Override this method in subclasses to implement specific transformation logic\"\"\"\n        19:        raise NotImplementedError\n        20:\n        21:class FunctionReplacer(NodeTransformerWithAsyncSupport):\n        22:\n        23:    def __init__(self, new_func_node):\n        24:        super().__init__()\n        25:        self.new_func_node = new_func_node\n        26:\n        27:    def _handle_function(self, node):\n        28:        if node.name == self.new_func_node.name:\n        29:            self.success = True\n        30:            return self.new_func_node\n        31:        return node\n        32:\n        33:class MethodAdder(NodeTransformerWithAsyncSupport):\n        34:\n        35:    def __init__(self, class_name, new_method_node):\n        36:        super().__init__()\n        37:        self.class_name = class_name\n        38:        self.new_method_node = new_method_node\n        39:\n        40:    def visit_ClassDef(self, node):\n        41:        if node.name == self.class_name:\n        42:            self.success = True\n        43:            node.body.append(self.new_method_node)\n        44:            return node\n        45:        return node\n        46:\n        47:    def _handle_function(self, node):\n        48:        return node\n        49:\n        50:def add_imports(file_path: str, code: str) -> str:\n        51:    \"\"\"\n        52:    Adds multiple import statements to a Python file.\n        53:    Avoids adding duplicate imports.\n        54:\n        55:    Parameters:\n        56:    - file_path (str): The path to the file where the imports will be added\n        57:    - code (str): Import statements, which can include parenthesized multi-line imports\n        58:\n        59:    Returns a confirmation message or an error message.\n        60:\n        61:    cost: very low\n        62:    \"\"\"\n        63:    try:\n        64:        abs_path = _make_file(file_path)\n        65:        lines = code.strip().split('\\n')\n        66:        import_blocks = []\n        67:        current_block = []\n        68:        in_parentheses = False\n        69:        for line in lines:\n        70:            stripped = line.strip()\n        71:            if not stripped:\n        72:                continue\n        73:            if '(' in stripped and (not stripped.endswith(')')):\n        74:                in_parentheses = True\n        75:                current_block.append(stripped)\n        76:            elif ')' in stripped and in_parentheses:\n        77:                in_parentheses = False\n        78:                current_block.append(stripped)\n        79:                import_blocks.append('\\n'.join(current_block))\n        80:                current_block = []\n        81:            elif in_parentheses:\n        82:                current_block.append(stripped)\n        83:            elif current_block:\n        84:                current_block.append(stripped)\n        85:            else:\n        86:                import_blocks.append(stripped)\n        87:        if current_block:\n        88:            import_blocks.append('\\n'.join(current_block))\n        89:        new_import_nodes = []\n        90:        for stmt in import_blocks:\n        91:            try:\n        92:                node = ast.parse(_clean(stmt)).body[0]\n        93:                if not isinstance(node, (ast.Import, ast.ImportFrom)):\n        94:                    return _process_error(ValueError(f'Invalid import statement: {stmt}'))\n        95:                new_import_nodes.append(node)\n        96:            except Exception as e:\n        97:                return _process_error(ValueError(f'Error parsing import statement \"{stmt}\": {str(e)}'))\n        98:        try:\n        99:            with open(abs_path, 'r', encoding='utf-8') as file:\n        100:                content = file.read()\n        101:        except Exception as e:\n        102:            return _process_error(ValueError(f'Error reading file {abs_path}: {str(e)}'))\n        103:        if not content.strip():\n        104:            with open(abs_path, 'w', encoding='utf-8') as file:\n        105:                file.write('\\n'.join(import_blocks) + '\\n')\n        106:            return f\"{len(import_blocks)} imports have been added to new file '{abs_path}'.\"\n        107:        try:\n        108:            tree = ast.parse(content)\n        109:        except Exception as e:\n        110:            return _process_error(ValueError(f'Error parsing the file {abs_path}: {str(e)}'))\n        111:        added_imports = []\n        112:        existing_imports = []\n        113:\n        114:        def normalize_import(node):\n        115:            \"\"\"Helper to normalize import node to string for comparison\"\"\"\n        116:            return _py_ast_to_source(node).strip().replace(' ', '')\n        117:        for new_node in new_import_nodes:\n        118:            new_stmt_normalized = normalize_import(new_node)\n        119:            is_duplicate = False\n        120:            for existing_node in tree.body:\n        121:                if isinstance(existing_node, (ast.Import, ast.ImportFrom)):\n        122:                    if normalize_import(existing_node) == new_stmt_normalized:\n        123:                        existing_imports.append(_py_ast_to_source(new_node).strip())\n        124:                        is_duplicate = True\n        125:                        break\n        126:            if not is_duplicate:\n        127:                added_imports.append(_py_ast_to_source(new_node).strip())\n        128:        if added_imports:\n        129:            last_import_idx = -1\n        130:            for i, node in enumerate(tree.body):\n        131:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        132:                    last_import_idx = i\n        133:            for node in new_import_nodes:\n        134:                if _py_ast_to_source(node).strip() in added_imports:\n        135:                    tree.body.insert(last_import_idx + 1, node)\n        136:                    last_import_idx += 1\n        137:            try:\n        138:                updated_content = _py_ast_to_source(tree)\n        139:                with open(abs_path, 'w', encoding='utf-8') as file:\n        140:                    file.write(updated_content)\n        141:            except Exception as e:\n        142:                return _process_error(e)\n        143:        result_parts = []\n        144:        if added_imports:\n        145:            result_parts.append(f\"Added {len(added_imports)} new imports to '{abs_path}'\")\n        146:        if existing_imports:\n        147:            result_parts.append(f'Found {len(existing_imports)} existing imports')\n        148:        if not result_parts:\n        149:            raise ValueError('No valid import statements found')\n        150:        return '. '.join(result_parts) + '.'\n        151:    except Exception as e:\n        152:        return _process_error(e)\n        153:\n        154:def remove_import(file_path: str, import_to_remove: str) -> str:\n        155:    \"\"\"\n        156:    Removes an import statement from a Python file.\n        157:\n        158:    Parameters:\n        159:    - file_path (str): The path to the file to modify\n        160:    - import_to_remove (str): The import statement to remove (e.g., \"import os\" or \"from typing import List\")\n        161:        Must match the existing import statement exactly.\n        162:\n        163:    Returns a confirmation message or an error message.\n        164:\n        165:    cost: very low\n        166:    \"\"\"\n        167:    if not os.path.exists(file_path):\n        168:        return _process_error(ValueError(f'File {file_path} does not exist'))\n        169:    try:\n        170:        remove_node = ast.parse(import_to_remove).body[0]\n        171:        if not isinstance(remove_node, (ast.Import, ast.ImportFrom)):\n        172:            return _process_error(ValueError('Provided statement is not a valid import'))\n        173:    except Exception as e:\n        174:        return _process_error(ValueError(f'Error parsing import statement: {str(e)}'))\n        175:    try:\n        176:        with open(file_path, 'r', encoding='utf-8') as file:\n        177:            content = file.read()\n        178:        tree = ast.parse(content)\n        179:    except Exception as e:\n        180:        return _process_error(ValueError(f'Error parsing the file {file_path}: {str(e)}'))\n        181:    original_length = len(tree.body)\n        182:    new_body = []\n        183:    found = False\n        184:    for node in tree.body:\n        185:        if isinstance(node, (ast.Import, ast.ImportFrom)):\n        186:            node_str = _py_ast_to_source(node).strip()\n        187:            if node_str == import_to_remove:\n        188:                found = True\n        189:                continue\n        190:        new_body.append(node)\n        191:    if not found:\n        192:        return f\"Import '{import_to_remove}' not found in '{file_path}'.\"\n        193:    tree.body = new_body\n        194:    try:\n        195:        updated_content = _py_ast_to_source(tree)\n        196:        with open(file_path, 'w', encoding='utf-8') as file:\n        197:            file.write(updated_content)\n        198:    except Exception as e:\n        199:        return _process_error(e)\n        200:    return f\"Import '{import_to_remove}' has been removed from '{file_path}'.\"\n        201:\n        202:def replace_import(file_path: str, old_import: str, new_import: str) -> str:\n        203:    \"\"\"\n        204:    Replaces an existing import statement in a Python file.\n        205:\n        206:    Parameters:\n        207:    - file_path (str): The path to the file to modify\n        208:    - old_import (str): The existing import statement to replace\n        209:    - new_import (str): The new import statement\n        210:\n        211:    Returns a confirmation message or an error message.\n        212:\n        213:    cost: very low\n        214:    \"\"\"\n        215:    if not os.path.exists(file_path):\n        216:        return _process_error(ValueError(f'File {file_path} does not exist'))\n        217:    try:\n        218:        old_node = ast.parse(_clean(old_import)).body[0]\n        219:        new_node = ast.parse(_clean(new_import)).body[0]\n        220:        if not isinstance(old_node, (ast.Import, ast.ImportFrom)) or not isinstance(new_node, (ast.Import, ast.ImportFrom)):\n        221:            return _process_error(ValueError('Both statements must be valid imports'))\n        222:    except Exception as e:\n        223:        return _process_error(ValueError(f'Error parsing import statements: {str(e)}'))\n        224:    try:\n        225:        with open(file_path, 'r', encoding='utf-8') as file:\n        226:            content = file.read()\n        227:        tree = ast.parse(content)\n        228:    except Exception as e:\n        229:        return _process_error(ValueError(f'Error parsing the file {file_path}: {str(e)}'))\n        230:    found = False\n        231:    for i, node in enumerate(tree.body):\n        232:        if isinstance(node, (ast.Import, ast.ImportFrom)):\n        233:            node_str = _py_ast_to_source(node).strip()\n        234:            if node_str == old_import:\n        235:                tree.body[i] = new_node\n        236:                found = True\n        237:                break\n        238:    if not found:\n        239:        return f\"Import '{old_import}' not found in '{file_path}'.\"\n        240:    try:\n        241:        updated_content = _py_ast_to_source(tree)\n        242:        with open(file_path, 'w', encoding='utf-8') as file:\n        243:            file.write(updated_content)\n        244:    except Exception as e:\n        245:        return _process_error(e)\n        246:    return f\"Import '{old_import}' has been updated to '{new_import}' in '{file_path}'.\"\n        247:\n        248:def add_class(file_path: str, class_def: str) -> str:\n        249:    \"\"\"\n        250:    Adds a new class definition to an existing Python file.\n        251:\n        252:    Parameters:\n        253:    - file_path (str): The path to the file where the new class will be added\n        254:    - class_def (str): The new class definition as a string\n        255:\n        256:    Returns a confirmation message or an error message.\n        257:\n        258:    cost: low\n        259:    \"\"\"\n        260:    try:\n        261:        abs_path = _make_file(file_path)\n        262:        try:\n        263:            new_tree = ast.parse(_clean(class_def))\n        264:            new_class_node = None\n        265:            for node in new_tree.body:\n        266:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        267:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        268:                elif isinstance(node, ast.ClassDef):\n        269:                    new_class_node = node\n        270:            if new_class_node is None:\n        271:                return _process_error(ValueError('No class definition found in provided code'))\n        272:            with open(abs_path, 'r', encoding='utf-8') as file:\n        273:                content = file.read()\n        274:            tree = ast.parse(content)\n        275:        except Exception as e:\n        276:            return _process_error(ValueError(f'Error processing code: {str(e)}'))\n        277:        tree.body.append(new_class_node)\n        278:        try:\n        279:            updated_content = _py_ast_to_source(tree)\n        280:            with open(abs_path, 'w', encoding='utf-8') as file:\n        281:                file.write(updated_content)\n        282:        except Exception as e:\n        283:            return _process_error(e)\n        284:        return f\"Class '{new_class_node.name}' has been added to '{abs_path}'.\"\n        285:    except Exception as e:\n        286:        return _process_error(e)\n        287:\n        288:def replace_class(file_path: str, new_class_def: str, old_class_name: str=None) -> str:\n        289:    \"\"\"\n        290:    Replaces a class definition in a file with a new class definition.\n        291:\n        292:    Parameters:\n        293:    - file_path (str): The path to the file to modify\n        294:    - new_class_def (str): The new class definition\n        295:    - old_class_name (str, optional): The name of the class to replace\n        296:\n        297:    Returns a confirmation message or an error message.\n        298:\n        299:    cost: low\n        300:    \"\"\"\n        301:    try:\n        302:        abs_path = _make_file(file_path)\n        303:        try:\n        304:            new_tree = ast.parse(_clean(new_class_def))\n        305:            new_class_node = None\n        306:            for node in new_tree.body:\n        307:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        308:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        309:                elif isinstance(node, ast.ClassDef):\n        310:                    new_class_node = node\n        311:                    if old_class_name is None:\n        312:                        old_class_name = node.name\n        313:            if new_class_node is None:\n        314:                return _process_error(ValueError('No class definition found in provided code'))\n        315:            with open(abs_path, 'r', encoding='utf-8') as file:\n        316:                content = file.read()\n        317:            tree = ast.parse(content)\n        318:        except Exception as e:\n        319:            return _process_error(ValueError(f'Error processing code: {str(e)}'))\n        320:\n        321:        class ClassReplacer(NodeTransformerWithAsyncSupport):\n        322:\n        323:            def visit_ClassDef(self, node):\n        324:                if node.name == old_class_name:\n        325:                    self.success = True\n        326:                    return new_class_node\n        327:                return node\n        328:\n        329:            def _handle_function(self, node):\n        330:                return node\n        331:        transformer = ClassReplacer()\n        332:        tree = transformer.visit(tree)\n        333:        if not transformer.success:\n        334:            tree.body.append(new_class_node)\n        335:        try:\n        336:            updated_content = _py_ast_to_source(tree)\n        337:            with open(abs_path, 'w', encoding='utf-8') as file:\n        338:                file.write(updated_content)\n        339:        except Exception as e:\n        340:            return _process_error(e)\n        341:        action = 'replaced in' if transformer.success else 'added to'\n        342:        return f\"Class '{new_class_node.name}' has been {action} '{abs_path}'.\"\n        343:    except Exception as e:\n        344:        return _process_error(e)\n        345:\n        346:def add_function_to_class(file_path: str, class_name: str, new_method_def: str) -> str:\n        347:    \"\"\"\n        348:    Adds one or more methods to an existing class in a Python file.\n        349:\n        350:    Parameters:\n        351:    - file_path (str): The path to the file to modify\n        352:    - class_name (str): The name of the class to modify\n        353:    - new_method_def (str): One or more method definitions as a string\n        354:\n        355:    Returns a confirmation message or an error message.\n        356:\n        357:    cost: very low\n        358:    \"\"\"\n        359:    try:\n        360:        tree = ast.parse(_clean(new_method_def))\n        361:        messages = []\n        362:        for node in tree.body:\n        363:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        364:                add_imports(file_path, _py_ast_to_source(node).strip())\n        365:        found_method = False\n        366:        for node in tree.body:\n        367:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        368:                found_method = True\n        369:                method_source = _py_ast_to_source(node)\n        370:                result = _add_single_function_to_class(file_path, class_name, method_source)\n        371:                messages.append(result)\n        372:        if not found_method:\n        373:            return _process_error(ValueError('No method definitions found in provided code'))\n        374:        return '\\n'.join(messages)\n        375:    except Exception as e:\n        376:        return _process_error(e)\n        377:\n        378:def add_function_to_file(file_path: str, new_function_def: str, class_name: str=None) -> str:\n        379:    \"\"\"\n        380:    Adds one or more function definitions to an existing Python file.\n        381:\n        382:    When adding complex code blocks:\n        383:    - Imports are moved to the top of the file\n        384:    - Functions are added in order of appearance\n        385:    - Non-function code (assignments, if blocks, etc.) is preserved but may be reordered\n        386:    - Comments are not preserved (limitation of AST)\n        387:\n        388:    Parameters:\n        389:    - file_path (str): The path to the file to modify\n        390:    - new_function_def (str): One or more function definitions as a string\n        391:    - class_name (str, optional): If provided, add functions to this class\n        392:\n        393:    Returns a confirmation message or an error message.\n        394:\n        395:    cost: very low\n        396:    \"\"\"\n        397:    try:\n        398:        tree = ast.parse(_clean(new_function_def))\n        399:        messages = []\n        400:        for node in tree.body:\n        401:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        402:                add_imports(file_path, _py_ast_to_source(node).strip())\n        403:        found_function = False\n        404:        remaining_nodes = []\n        405:        for node in tree.body:\n        406:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        407:                found_function = True\n        408:                function_source = _py_ast_to_source(node)\n        409:                if class_name:\n        410:                    result = add_function_to_class(file_path, class_name, function_source)\n        411:                else:\n        412:                    result = _add_single_function_to_file(file_path, function_source)\n        413:                messages.append(result)\n        414:            elif not isinstance(node, (ast.Import, ast.ImportFrom)):\n        415:                remaining_nodes.append(node)\n        416:        if not found_function:\n        417:            return _process_error(ValueError('No function definitions found in provided code'))\n        418:        if remaining_nodes:\n        419:            with open(file_path, 'r', encoding='utf-8') as file:\n        420:                content = file.read()\n        421:            existing_tree = ast.parse(content)\n        422:            existing_tree.body.extend(remaining_nodes)\n        423:            updated_content = _py_ast_to_source(existing_tree)\n        424:            with open(file_path, 'w', encoding='utf-8') as file:\n        425:                file.write(updated_content)\n        426:            messages.append(f'Added {len(remaining_nodes)} additional code blocks')\n        427:        return '\\n'.join(messages)\n        428:    except Exception as e:\n        429:        return _process_error(e)\n        430:\n        431:def replace_function(file_path: str, new_function_def: str, class_name: str=None) -> str:\n        432:    \"\"\"\n        433:    Replaces one or more function definitions in a file with new function definitions.\n        434:\n        435:    Parameters:\n        436:    - file_path (str): The path to the file to modify\n        437:    - new_function_def (str): One or more function definitions as a string\n        438:    - class_name (str, optional): If provided, only replace functions within this class\n        439:\n        440:    Returns a confirmation message or an error message.\n        441:\n        442:    cost: very low\n        443:    \"\"\"\n        444:    try:\n        445:        tree = ast.parse(_clean(new_function_def))\n        446:        messages = []\n        447:        for node in tree.body:\n        448:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        449:                add_imports(file_path, _py_ast_to_source(node).strip())\n        450:        found_function = False\n        451:        for node in tree.body:\n        452:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        453:                found_function = True\n        454:                function_source = _py_ast_to_source(node)\n        455:                result = _replace_single_function(file_path, function_source, class_name)\n        456:                messages.append(result)\n        457:        if not found_function:\n        458:            return _process_error(ValueError('No function definitions found in provided code'))\n        459:        return '\\n'.join(messages)\n        460:    except Exception as e:\n        461:        return _process_error(e)\n        462:\n        463:def _make_file(file_path: str) -> str:\n        464:    \"\"\"\n        465:    Creates a file and its parent directories if they don't exist.\n        466:    Converts relative paths to absolute paths.\n        467:\n        468:    Parameters:\n        469:    - file_path (str): The path to the file to be created\n        470:\n        471:    Returns:\n        472:    - str: The absolute path to the file\n        473:\n        474:    Raises:\n        475:    - ValueError: If there's an error creating the file or directories,\n        476:                 or if the file_path is empty\n        477:    \"\"\"\n        478:    if not file_path:\n        479:        raise ValueError('File path cannot be empty')\n        480:    abs_path = os.path.abspath(file_path)\n        481:    dir_path = os.path.dirname(abs_path)\n        482:    if dir_path:\n        483:        try:\n        484:            os.makedirs(dir_path, exist_ok=True)\n        485:        except Exception as e:\n        486:            raise ValueError(f'Error creating directories {dir_path}: {str(e)}')\n        487:    if not os.path.exists(abs_path):\n        488:        try:\n        489:            with open(abs_path, 'w', encoding='utf-8') as f:\n        490:                f.write('')\n        491:        except Exception as e:\n        492:            raise ValueError(f'Error creating file {abs_path}: {str(e)}')\n        493:    return abs_path\n        494:\n        495:def _add_single_function_to_class(file_path: str, class_name: str, new_method_def: str) -> str:\n        496:    \"\"\"Adds a single method to a class.\"\"\"\n        497:    try:\n        498:        abs_path = _make_file(file_path)\n        499:        try:\n        500:            new_tree = ast.parse(_clean(new_method_def))\n        501:            new_method_node = None\n        502:            for node in new_tree.body:\n        503:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        504:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        505:                elif isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        506:                    new_method_node = node\n        507:            if new_method_node is None:\n        508:                return _process_error(ValueError('No method definition found in provided code'))\n        509:            with open(abs_path, 'r', encoding='utf-8') as file:\n        510:                content = file.read()\n        511:            if not content.strip():\n        512:                content = f'class {class_name}:\\n    pass\\n'\n        513:            tree = ast.parse(content)\n        514:        except Exception as e:\n        515:            return _process_error(ValueError(f'Error processing code: {str(e)}'))\n        516:        transformer = MethodAdder(class_name, new_method_node)\n        517:        tree = transformer.visit(tree)\n        518:        if not transformer.success:\n        519:            return _process_error(ValueError(f\"Class '{class_name}' not found in the file.\"))\n        520:        try:\n        521:            updated_content = _py_ast_to_source(tree)\n        522:            with open(abs_path, 'w', encoding='utf-8') as file:\n        523:                file.write(updated_content)\n        524:        except Exception as e:\n        525:            return _process_error(e)\n        526:        return f\"Method '{new_method_node.name}' has been added to class '{class_name}' in '{abs_path}'.\"\n        527:    except Exception as e:\n        528:        return _process_error(e)\n        529:\n        530:def _add_single_function_to_file(file_path: str, new_function_def: str) -> str:\n        531:    \"\"\"Adds a single function and preserves all code blocks, including any code following the function.\"\"\"\n        532:    try:\n        533:        abs_path = _make_file(file_path)\n        534:        try:\n        535:            new_tree = ast.parse(_clean(new_function_def))\n        536:            new_func_node = None\n        537:            found_func = False\n        538:            new_nodes = []\n        539:            for node in new_tree.body:\n        540:                if not found_func and isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        541:                    new_func_node = node\n        542:                    found_func = True\n        543:                elif found_func:\n        544:                    new_nodes.append(node)\n        545:            if not new_func_node:\n        546:                return _process_error(ValueError('No function definition found in provided code'))\n        547:        except Exception as e:\n        548:            return _process_error(ValueError(f'Error in code: {str(e)}'))\n        549:        with open(abs_path, 'r', encoding='utf-8') as file:\n        550:            content = file.read()\n        551:        if not content.strip():\n        552:            try:\n        553:                with open(abs_path, 'w', encoding='utf-8') as file:\n        554:                    file.write(_py_ast_to_source(new_tr