                                                                                                                                                                                                                                                                                     "new_function_def": "\n                                    def _tokenize_source(source: str) -> Tuple[str, Dict[str, str]]:\n                                        \"\"\"\n                                        Tokenize source code, preserving exact formatting.\n                                    \n                                        Returns:\n                                        - tokenized_source: Source with tokens inserted\n                                        - token_map: Mapping of tokens to original content with metadata\n                                        \"\"\"\n                                        \n                                        def contains_token(s: str) -> bool:\n                                            return '__TOKEN__' in s\n                                        \n                                        token_map = {}\n                                        current_hash = _get_file_hash(source)\n                                        token_counter = 0\n                                        \n                                        # Step 1: Handle multiline strings first (they can span multiple lines)\n                                        tokenized = source\n                                        processed_positions = set()\n                                        iteration_count = 0\n                                        MAX_ITERATIONS = 10\n                                        \n                                        def find_complete_triple_quote(text, start_pos=0):\n                                            \"\"\"Find complete triple-quoted strings manually\"\"\"\n                                            for quote_type in ['\"\"\"', \"'''\"]:\n                                                open_pos = text.find(quote_type, start_pos)\n                                                if open_pos == -1:\n                                                    continue\n                                                close_pos = text.find(quote_type, open_pos + 3)\n                                                if close_pos == -1:\n                                                    continue\n                                                complete_string = text[open_pos:close_pos + 3]\n                                                if not contains_token(complete_string):\n                                                    return (open_pos, close_pos + 3, complete_string)\n                                            return (None, None, None)\n                                        \n                                        while iteration_count < MAX_ITERATIONS:\n                                            iteration_count += 1\n                                            old_tokenized = tokenized\n                                            start_pos, end_pos, string_content = find_complete_triple_quote(tokenized)\n                                            if start_pos is None:\n                                                break\n                                            if start_pos in processed_positions or len(string_content) > 1000:\n                                                break\n                                            processed_positions.add(start_pos)\n                                            token_name, hex_val = _create_token(string_content, token_counter, current_hash)\n                                            token_map[hex_val] = {\n                                                'content': string_content,\n                                                'type': 'multiline_string'\n                                            }\n                                            tokenized = tokenized[:start_pos] + hex_val + tokenized[end_pos:]\n                                            token_counter += 1\n                                            if tokenized == old_tokenized:\n                                                break\n                                        \n                                        # Step 2: Process each line to identify all items to tokenize\n                                        lines = tokenized.split('\\n')\n                                        processed_lines = []\n                                        \n                                        for line in lines:\n                                            if not line.strip():\n                                                processed_lines.append(line)\n                                                continue\n                                                \n                                            indent = len(line) - len(line.lstrip())\n                                            indentation = ' ' * indent\n                                            content = line[indent:]\n                                            \n                                            if contains_token(content):\n                                                processed_lines.append(line)\n                                                continue\n                                            \n                                            # Identify all items to tokenize on this line\n                                            items_to_tokenize = []\n                                            \n                                            # Check for standalone comment\n                                            if content.strip().startswith('#'):\n                                                items_to_tokenize.append({\n                                                    'content': content.strip(),\n                                                    'type': 'standalone_comment',\n                                                    'start': 0,\n                                                    'end': len(content),\n                                                    'replacement_template': '\"\"\"{}\"\"\"'  # Template for token\n                                                })\n                                            else:\n                                                # Check for inline comment\n                                                if '#' in content:\n                                                    comment_start = content.index('#')\n                                                    code_part = content[:comment_start]\n                                                    comment_part = content[comment_start:]\n                                                    items_to_tokenize.append({\n                                                        'content': comment_part,\n                                                        'type': 'inline_comment',\n                                                        'start': comment_start,\n                                                        'end': len(content),\n                                                        'code_part': code_part.rstrip(),\n                                                        'replacement_template': '; \"\"\"{}\"\"\"'  # Template for token\n                                                    })\n                                                    # Update content to exclude comment for string processing\n                                                    content = code_part\n                                                \n                                                # Check for string literals (only in non-comment part)\n                                                if not contains_token(content):\n                                                    for quote_char in ['\"', \"'\"]:\n                                                        if quote_char in content:\n                                                            start = content.find(quote_char)\n                                                            if start != -1:\n                                                                end = start + 1\n                                                                while end < len(content):\n                                                                    if content[end] == quote_char:\n                                                                        string_content = content[start:end + 1]\n                                                                        if not contains_token(string_content):\n                                                                            items_to_tokenize.append({\n                                                                                'content': string_content,\n                                                                                'type': 'string_literal',\n                                                                                'start': start,\n                                                                                'end': end + 1,\n                                                                                'replacement_template': '{}'  # Template for token\n                                                                            })\n                                                                        break\n                                                                    elif content[end] == '\\\\' and end + 1 < len(content):\n                                                                        end += 2\n                                                                    else:\n                                                                        end += 1\n                                                            break\n                                            \n                                            # Process items (longest first to avoid conflicts)\n                                            items_to_tokenize.sort(key=lambda x: x['end'] - x['start'], reverse=True)\n                                            \n                                            processed_content = content\n                                            for item in items_to_tokenize:\n                                                token_name, hex_val = _create_token(item['content'], token_counter, current_hash)\n                                                token_map[hex_val] = {\n                                                    'content': item['content'],\n                                                    'type': item['type']\n                                                }\n                                                \n                                                # Add code_part for inline comments\n                                                if item['type'] == 'inline_comment':\n                                                    token_map[hex_val]['code_part'] = item['code_part']\n                                                \n                                                # Replace content with token\n                                                replacement = item['replacement_template'].format(hex_val)\n                                                if item['type'] == 'standalone_comment':\n                                                    processed_content = replacement\n                                                elif item['type'] == 'inline_comment':\n                                                    processed_content = item['code_part'] + replacement\n                                                else:  # string_literal\n                                                    processed_content = (processed_content[:item['start']] + \n                                                                       hex_val + \n                                                                       processed_content[item['end']:])\n                                                \n                                                token_counter += 1\n                                            \n                                            processed_lines.append(indentation + processed_content)\n                                        \n                                        return ('\\n'.join(processed_lines), token_map)"
