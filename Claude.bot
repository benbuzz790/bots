                                                  "content": "\n        1:import os\n        2:import pytest\n        3:from textwrap import dedent\n        4:from bots.tools.python_editing_tools import python_edit\n        5:\n        6:def setup_test_file(tmp_path, content):\n        7:    \"\"\"Helper to create a test file with given content\"\"\"\n        8:    if isinstance(tmp_path, str):\n        9:        os.makedirs(tmp_path, exist_ok=True)\n        10:        test_file = os.path.join(tmp_path, 'test_file.py')\n        11:    else:\n        12:        test_file = os.path.join(str(tmp_path), 'test_file.py')\n        13:    with open(test_file, 'w', encoding='utf-8') as f:\n        14:        f.write(dedent(content))\n        15:    return test_file\n        16:\n        17:@pytest.fixture\n        18:def test_file(tmp_path):\n        19:    \"\"\"Create a test file with various Python constructs\"\"\"\n        20:    content = '\\n        import os\\n        from typing import List, Optional\\n\\n        def outer_func():\\n            def inner_func():\\n                pass\\n            return inner_func\\n\\n        class OuterClass:\\n            def method(self):\\n                pass\\n\\n            class InnerClass:\\n                @staticmethod\\n                def static_method():\\n                    pass\\n\\n                async def async_method(self):\\n                    pass\\n\\n            def another_method(self):\\n                # Insert here\\n                pass\\n    '\n        21:    return setup_test_file(tmp_path, content)\n        22:\n        23:def test_basic_file_level_edit(test_file):\n        24:    \"\"\"Test adding code at file level\"\"\"\n        25:    result = python_edit(test_file, 'x = 42')\n        26:    assert 'file level' in result\n        27:    with open(test_file) as f:\n        28:        content = f.read()\n        29:    assert 'x = 42' in content\n        30:\n        31:def test_file_start_insertion(test_file):\n        32:    \"\"\"Test inserting at file start\"\"\"\n        33:    result = python_edit(test_file, 'import sys', insert_after='__FILE_START__')\n        34:    assert 'start' in result\n        35:    with open(test_file) as f:\n        36:        lines = f.readlines()\n        37:        assert 'import sys' in lines[0]\n        38:\n        39:def test_class_replacement(test_file):\n        40:    \"\"\"Test replacing a class\"\"\"\n        41:    new_class = '\\n    class OuterClass:\\n        def new_method(self):\\n            pass\\n    '\n        42:    result = python_edit(f'{test_file}::OuterClass', new_class)\n        43:    assert 'OuterClass' in result\n        44:    with open(test_file) as f:\n        45:        content = f.read()\n        46:    assert 'new_method' in content\n        47:    assert 'another_method' not in content\n        48:\n        49:def test_nested_class_method(test_file):\n        50:    \"\"\"Test modifying a method in a nested class\"\"\"\n        51:    new_method = '\\n    async def async_method(self):\\n        return 42\\n    '\n        52:    result = python_edit(f'{test_file}::OuterClass::InnerClass::async_method', new_method)\n        53:    assert 'async_method' in result\n        54:    with open(test_file) as f:\n        55:        content = f.read()\n        56:    assert 'return 42' in content\n        57:\n        58:def test_nested_function(test_file):\n        59:    \"\"\"Test modifying a nested function\"\"\"\n        60:    new_func = '\\n    def inner_func():\\n        return 42\\n    '\n        61:    result = python_edit(f'{test_file}::outer_func::inner_func', new_func)\n        62:    assert 'inner_func' in result\n        63:    with open(test_file) as f:\n        64:        content = f.read()\n        65:    assert 'return 42' in content\n        66:\n        67:def test_insert_after_line(test_file):\n        68:    \"\"\"Test inserting after specific line\"\"\"\n        69:    new_code = 'x = 42'\n        70:    result = python_edit(f'{test_file}::OuterClass::another_method', new_code, insert_after='# Insert here')\n        71:    with open(test_file) as f:\n        72:        print(f'\\nDEBUG - File content:\\n{f.read()}')\n        73:    print(f'\\nDEBUG - Result: {result}')\n        74:    assert 'inserted after' in result\n        75:    with open(test_file) as f:\n        76:        content = f.read()\n        77:    assert '# Insert here\\n' in content\n        78:    assert 'x = 42' in content\n        79:\n        80:def test_insert_after_scope(test_file):\n        81:    \"\"\"Test inserting after a scope\"\"\"\n        82:    new_method = '\\n    def extra_method(self):\\n        pass\\n    '\n        83:    result = python_edit(f'{test_file}::OuterClass', new_method, insert_after='OuterClass::another_method')\n        84:    assert 'inserted after' in result\n        85:    with open(test_file) as f:\n        86:        content = f.read()\n        87:    assert 'extra_method' in content\n        88:    assert content.index('extra_method') > content.index('another_method')\n        89:\n        90:def test_import_handling(test_file):\n        91:    \"\"\"Test automatic import handling\"\"\"\n        92:    new_code = '\\n    import sys\\n    from typing import Dict\\n\\n    def new_func():\\n        pass\\n    '\n        93:    result = python_edit(test_file, new_code)\n        94:    with open(test_file) as f:\n        95:        content = f.read()\n        96:    assert 'import sys' in content\n        97:    assert 'from typing import Dict' in content\n        98:    assert content.index('import sys') < content.index('def new_func')\n        99:\n        100:def test_decorated_method(test_file):\n        101:    \"\"\"Test handling decorated methods\"\"\"\n        102:    new_method = '\\n    @staticmethod\\n    @property\\n    def static_method():\\n        return 42\\n    '\n        103:    result = python_edit(f'{test_file}: