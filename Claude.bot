       abs_path = _make_file(file_path)\n        588:        try:\n        589:            new_tree = ast.parse(_clean(new_function_def))\n        590:            new_func_node = None\n        591:            found_func = False\n        592:            new_nodes = []\n        593:            for node in new_tree.body:\n        594:                if not found_func and isinstance(node, (ast.FunctionDef,\n        595:                    ast.AsyncFunctionDef)):\n        596:                    new_func_node = node\n        597:                    found_func = True\n        598:                elif found_func:\n        599:                    new_nodes.append(node)\n        600:            if not new_func_node:\n        601:                return _process_error(ValueError(\n        602:                    'No function definition found in provided code'))\n        603:        except Exception as e:\n        604:            return _process_error(ValueError(f'Error in code: {str(e)}'))\n        605:        with open(abs_path, 'r', encoding='utf-8') as file:\n        606:            content = file.read()\n        607:        if not content.strip():\n        608:            try:\n        609:                with open(abs_path, 'w', encoding='utf-8') as file:\n        610:                    file.write(_py_ast_to_source(new_tree))\n        611:                return (\n        612:                    f\"Code with function '{new_func_node.name}' has been added to new file '{abs_path}'.\"\n        613:                    )\n        614:            except Exception as e:\n        615:                return _process_error(e)\n        616:        try:\n        617:            existing_tree = ast.parse(content)\n        618:            combined_body = []\n        619:            imports = []\n        620:            for node in (existing_tree.body + new_tree.body):\n        621:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        622:                    imports.append(node)\n        623:            combined_body.extend(imports)\n        624:            for node in existing_tree.body:\n        625:                if not isinstance(node, (ast.Import, ast.ImportFrom)):\n        626:                    combined_body.append(node)\n        627:            combined_body.append(new_func_node)\n        628:            combined_body.extend(new_nodes)\n        629:            combined_tree = ast.Module(body=combined_body, type_ignores=[])\n        630:            updated_content = _py_ast_to_source(combined_tree)\n        631:            with open(abs_path, 'w', encoding='utf-8') as file:\n        632:                file.write(updated_content)\n        633:        except Exception as e:\n        634:            return _process_error(e)\n        635:        return (\n        636:            f\"Code with function '{new_func_node.name}' has been added to '{abs_path}'.\"\n        637:            )\n        638:    except Exception as e:\n        639:        return _process_error(e)\n        640:\n        641:\n        642:def _replace_single_function(file_path: str, new_function_def: str,\n        643:    class_name: str=None) ->str:\n        644:    \"\"\"Replaces a single function in a file, optionally within a specific class.\n        645:\n        646:    Args:\n        647:        file_path: Path to the file to modify\n        648:        new_function_def: The new function definition\n        649:        class_name: If provided, only replace within this class\n        650:    \"\"\"\n        651:    try:\n        652:        abs_path = _make_file(file_path)\n        653:        try:\n        654:            new_tree = ast.parse(_clean(new_function_def))\n        655:            new_func_node = None\n        656:            for node in new_tree.body:\n        657:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        658:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        659:                elif isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        660:                    new_func_node = node\n        661:            if new_func_node is None:\n        662:                return _process_error(ValueError(\n        663:                    'No function definition found in provided code'))\n        664:            with open(abs_path, 'r', encoding='utf-8') as file:\n        665:                content = file.read()\n        666:            tree = ast.parse(content)\n        667:        except Exception as e:\n        668:            return _process_error(ValueError(\n        669:                f'Error processing code: {str(e)}'))\n        670:\n        671:\n        672:        class ClassScopedFunctionReplacer(ast.NodeTransformer):\n        673:\n        674:            def __init__(self, new_func_node, target_class=None):\n        675:                self.new_func_node = new_func_node\n        676:                self.target_class = target_class\n        677:                self.success = False\n        678:                self.in_target_class = False\n        679:\n        680:            def visit_ClassDef(self, node):\n        681:                if self.target_class is None or node.name == self.target_class:\n        682:                    old_in_target_class = self.in_target_class\n        683:                    self.in_target_class = True\n        684:                    node = self.generic_visit(node)\n        685:                    self.in_target_class = old_in_target_class\n        686:                return node\n        687:\n        688:            def visit_FunctionDef(self, node):\n        689:                if node.name == self.new_func_node.name:\n        690:                    if self.target_class is None or self.in_target_class:\n        691:                        self.success = True\n        692:                        return self.new_func_node\n        693:                return node\n        694:\n        695:            def visit_AsyncFunctionDef(self, node):\n        696:                return self.visit_FunctionDef(node)\n        697:        transformer = ClassScopedFunctionReplacer(new_func_node, class_name)\n        698:        tree = transformer.visit(tree)\n        699:        if not transformer.success:\n        700:            if class_name:\n        701:                return _process_error(ValueError(\n        702:                    f\"Function '{new_func_node.name}' not found in class '{class_name}'\"\n        703:                    ))\n        704:            tree.body.append(new_func_node)\n        705:        try:\n        706:            updated_content = _py_ast_to_source(tree)\n        707:            with open(abs_path, 'w', encoding='utf-8') as file:\n        708:                file.write(updated_content)\n        709:        except Exception as e:\n        710:            return _process_error(e)\n        711:        context = f\"in class '{class_name}'\" if class_name else 'in file'\n        712:        action = 'replaced' if transformer.success else 'added'\n        713:        return (\n        714:            f\"Function '{new_func_node.name}' has been {action} {context} '{abs_path}'.\"\n        715:            )\n        716:    except Exception as e:\n        717:        return _process_error(e)"
