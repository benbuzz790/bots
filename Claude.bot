                                                                                                                                                                                                                                                                                                                                                                                                             "new_class_def": "\n                                                class SourcePreservingNode:\n                                                    \"\"\"Wrapper for AST nodes that preserves original source.\"\"\"\n                                                    \n                                                    def __init__(self, node, original_lines, base_indent=''):\n                                                        self.node = node\n                                                        self.base_indent = base_indent\n                                                        \n                                                        if hasattr(node, 'lineno') and hasattr(node, 'end_lineno'):\n                                                            # Get the node's lines\n                                                            node_lines = original_lines[node.lineno - 1:node.end_lineno]\n                                                            \n                                                            # Find the common indentation\n                                                            indents = [len(l) - len(l.lstrip()) for l in node_lines if l.strip()]\n                                                            if indents:\n                                                                self.base_indent = ' ' * min(indents)\n                                                            \n                                                            self.source = '\\n'.join(node_lines)\n                                                            \n                                                            # Store leading comments and blank lines\n                                                            self.leading_lines = []\n                                                            i = node.lineno - 2  # Line before node\n                                                            while i >= 0:\n                                                                line = original_lines[i].rstrip()\n                                                                if line.strip().startswith('#') or not line.strip():\n                                                                    # Preserve exact indentation for comments\n                                                                    self.leading_lines.insert(0, line)\n                                                                else:\n                                                                    break\n                                                                i -= 1\n                                                            \n                                                            # Store trailing blank lines\n                                                            self.trailing_lines = []\n                                                            i = node.end_lineno\n                                                            while i < len(original_lines):\n                                                                line = original_lines[i].rstrip()\n                                                                if not line.strip():\n                                                                    self.trailing_lines.append(line)\n                                                                else:\n                                                                    break\n                                                                i += 1\n                                                        else:\n                                                            # For new nodes, apply the base indentation\n                                                            self.source = '\\n'.join(\n                                                                self.base_indent + line if line.strip() else line\n                                                                for line in _py_ast_to_source(node).split('\\n')\n                                                            )\n                                                            self.leading_lines = []\n                                                            self.trailing_lines = []\n                                                    \n                                                    def to_string(self):\n                                                        \"\"\"Convert back to string, preserving formatting.\"\"\"\n                                                        parts = []\n                                                        if self.leading_lines:\n                                                            parts.extend(self.leading_lines)\n                                                        parts.append(self.source)\n                                                        if self.trailing_lines:\n                                                            parts.extend(self.trailing_lines)\n                                                        return '\\n'.join(parts)"
                                                                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                                                           }
