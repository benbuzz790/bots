      else:\n        1301:                        for new_node in self.new_nodes:\n        1302:                            node.body.append(new_node)\n        1303:            return node\n        1304:\n        1305:    def _handle_one_line_function(self, node, line):\n        1306:        \"\"\"Special handling for one-line function definitions\"\"\"\n        1307:        print(f'DEBUG - Handling one-line function: {line}')\n        1308:        if ': pass' in line or ':pass' in line:\n        1309:            base_indent = len(line) - len(line.lstrip())\n        1310:            if self.insert_after == 'pass':\n        1311:                def_line = line.replace(': pass', ':').replace(':pass', ':')\n        1312:                body_lines = ['    ' * (base_indent // 4 + 1) + 'pass']\n        1313:                for new_node in self.new_nodes:\n        1314:                    node_lines = _py_ast_to_source(new_node).split('\\n')\n        1315:                    for nl in node_lines:\n        1316:                        if nl.strip():\n        1317:                            body_lines.append('    ' * (base_indent // 4 + 1) + nl.lstrip())\n        1318:                        else:\n        1319:                            body_lines.append('')\n        1320:                new_source = def_line + '\\n' + '\\n'.join(body_lines)\n        1321:                print(f'DEBUG - Expanded source:\\n{new_source}')\n        1322:                try:\n        1323:                    new_node = ast.parse(new_source).body[0]\n        1324:                    self.success = True\n        1325:                    return new_node\n        1326:                except Exception as e:\n        1327:                    print(f'DEBUG - Parse error: {str(e)}')\n        1328:        return node\n        1329:\n        1330:    def _handle_insertion(self, node):\n        1331:        \"\"\"Handle inserting nodes after a specific point.\"\"\"\n        1332:        if isinstance(se