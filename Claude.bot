                          "content": "\n        1:import os\n        2:import pytest\n        3:from textwrap import dedent\n        4:from bots.tools.python_edit import python_edit\n        5:from bots.tools.python_edit import _tokenize_source, _detokenize_source\n        6:import ast\n        7:\n        8:def setup_test_file(tmp_path, content):\n        9:    \"\"\"Helper to create a test file with given content\"\"\"\n        10:    if isinstance(tmp_path, str):\n        11:        os.makedirs(tmp_path, exist_ok=True)\n        12:        test_file = os.path.join(tmp_path, 'test_file.py')\n        13:    else:\n        14:        test_file = os.path.join(str(tmp_path), 'test_file.py')\n        15:    with open(test_file, 'w', encoding='utf-8') as f:\n        16:        f.write(dedent(content))\n        17:    return test_file\n        18:\n        19:@pytest.fixture\n        20:def test_file(tmp_path):\n        21:    \"\"\"Create a test file with various Python constructs\"\"\"\n        22:    content = '\\n        import os\\n        from typing import List, Optional\\n\\n        def outer_func():\\n            def inner_func():\\n                pass\\n            return inner_func\\n\\n        class OuterClass:\\n            def method(self):\\n                pass\\n\\n            class InnerClass:\\n                @staticmethod\\n                def static_method():\\n                    pass\\n\\n                async def async_method(self):\\n                    pass\\n\\n            def another_method(self):\\n                # Insert here\\n                pass\\n    '\n        23:    return setup_test_file(tmp_path, content)\n        24:\n        25:def test_basic_file_level_edit(test_file):\n        26:    \"\"\"Test adding code at file level\"\"\"\n        27:    result = python_edit(test_file, 'x = 42')\n        28:    assert 'file level' in result\n        29:    with open(test_file) as f:\n        30:        content = f.read()\n        31:    assert 'x = 42' in content\n        32:\n        33:def test_file_start_insertion(test_file):\n        34:    \"\"\"Test inserting at file start\"\"\"\n        35:    result = python_edit(test_file, 'import sys', insert_after='__FILE_START__')\n        36:    assert 'start' in result\n        37:    with open(test_file) as f:\n        38:        lines = f.readlines()\n        39:        assert 'import sys' in lines[0]\n        40:\n        41:def test_class_replacement(test_file):\n        42:    \"\"\"Test replacing a class\"\"\"\n        43:    new_class = '\\n    class OuterClass:\\n        def new_method(self):\\n            pass\\n    '\n        44:    result = python_edit(f'{test_file}::OuterClass', new_class)\n        45:    assert 'OuterClass' in result\n        46:    with open(test_file) as f:\n        47:        content = f.read()\n        48:    assert 'new_method' in content\n        49:    assert 'another_method' not in content\n        50:\n        51:def test_nested_class_method(test_file):\n        52:    \"\"\"Test modifying a method in a nested class\"\"\"\n        53:    new_method = '\\n    async def async_method(self):\\n        return 42\\n    '\n        54:    result = python_edit(f'{test_file}::OuterClass::InnerClass::async_method', new_method)\n        55:    assert 'async_method' in result\n        56:    with open(test_file) as f:\n        57:        content = f.read()\n        58:    assert 'return 42' in content\n        59:\n        60:def test_nested_function(test_file):\n        61:    \"\"\"Test modifying a nested function\"\"\"\n        62:    new_func = '\\n    def inner_func():\\n        return 42\\n    '\n        63:    result = python_edit(f'{test_file}::outer_func::inner_func', new_func)\n        64:    assert 'inner_func' in result\n        65:    with open(test_file) as f:\n        66:        content = f.read()\n        67:    assert 'return 42' in content\n        68:\n        69:def test_insert_after_line(test_file):\n        70:    \"\"\"Test inserting after specific line\"\"\"\n        71:    new_code = 'x = 42'\n        72:    result = python_edit(f'{test_file}::OuterClass::another_method', new_code, insert_after='# Insert here')\n        73:    with open(test_file) as f:\n        74:        print(f'\\nDEBUG - File content:\\n{f.read()}')\n        75:    print(f'\\nDEBUG - Result: {result}')\n        76:    assert 'inserted after' in result\n        77:    with open(test_file) as f:\n        78:        content = f.read()\n        79:    assert '# Insert here\\n' in content\n        80:    assert 'x = 42' in content\n        81:\n        82:def test_insert_after_scope(test_file):\n        83:    \"\"\"Test inserting after a scope\"\"\"\n        84:    new_method = '\\n    def extra_method(self):\\n        pass\\n    '\n        85:    result = python_edit(f'{test_file}::OuterClass', new_method, insert_after='OuterClass::another_method')\n        86:    assert 'inserted after' in result\n        87:    with open(test_file) as f:\n        88:        content = f.read()\n        89:    assert 'extra_method' in content\n        90:    assert content.index('extra_method') > content.index('another_method')\n        91:\n        92:def test_import_handling(test_file):\n        93:    \"\"\"Test automatic import handling\"\"\"\n        94:    new_code = '\\n    import sys\\n    from typing import Dict\\n\\n    def new_func():\\n        pass\\n    '\n        95:    result = python_edit(test_file, new_code)\n        96:    with open(test_file) as f:\n        97:        content = f.read()\n        98:    assert 'import sys' in content\n        99:    assert 'from typing import Dict' in content\n        100:    assert content.index('import sys') < content.index('def new_func')\n        101:\n        102:def test_decorated_method(test_file):\n        103:    \"\"\"Test handling decorated methods\"\"\"\n        104:    new_method = '\\n    @staticmethod\\n    @property\\n    def static_method():\\n        return 42\\n    '\n        105:    result = python_edit(f'{test_file}::OuterClass::InnerClass::static_method', new_method)\n        106:    assert 'static_method' in result\n        107:    with open(test_file) as f:\n        108:        content = f.read()\n        109:    assert '@property' in content\n        110:    assert 'return 42' in content\n        111:\n        112:def test_error_invalid_scope(test_file):\n        113:    \"\"\"Test error handling for invalid scope\"\"\"\n        114:    result = python_edit(f'{test_file}::NonExistentClass', 'pass')\n        115:    assert 'not found' in result.lower()\n        116:\n        117:def test_error_ambiguous_insert(test_file):\n        118:    \"\"\"Test error handling for ambiguous insert point\"\"\"\n        119:    content = '\\n    def func():\\n        # Insert here\\n        x = 1\\n        # Insert here\\n        y = 2\\n    '\n        120:    test_file = setup_test_file(os.path.dirname(test_file), content)\n        121:    result = python_edit(test_file, 'z = 3', insert_after='# Insert here')\n        122:    assert 'ambiguous' in result.lower()\n        123:\n        124:def test_error_invalid_code(test_file):\n        125:    \"\"\"Test error handling for invalid Python code\"\"\"\n        126:    result = python_edit(test_file, 'this is not valid python')\n        127:    assert 'error' in result.lower()\n        128:\n        129:def test_async_function(test_file):\n        130:    \"\"\"Test handling async functions\"\"\"\n        131:    new_func = '\\n    async def new_async():\\n        await something()\\n    '\n        132:    result = python_edit(test_file, new_func)\n        133:    assert 'added' in result.lower()\n        134:    with open(test_file) as f:\n        135:        content = f.read()\n        136:    assert 'async def new_async' in content\n        137:\n        138:def test_indentation_preservation(test_file):\n        139:    \"\"\"Test proper indentation is maintained\"\"\"\n        140:    new_method = '\\n    def indented_method(self):\\n        if True:\\n            x = 1\\n            if True:\\n                y = 2\\n    '\n        141:    result = python_edit(f'{test_file}::OuterClass', new_method, insert_after='OuterClass::method')\n        142:    with open(test_file) as f:\n        143:        content = f.read()\n        144:    assert '    def indented_method' in content\n        145:    assert '        if True:' in content\n        146:    assert '            x = 1' in content\n        147:\n        148:def test_empty_file(tmp_path):\n        149:    \"\"\"Test handling empty target file\"\"\"\n        150:    empty_file = setup_test_file(tmp_path, '')\n        151:    result = python_edit(empty_file, 'x = 42')\n        152:    assert 'added' in result.lower()\n        153:    with open(empty_file) as f:\n        154:        content = f.read()\n        155:    assert content.strip() == 'x = 42'\n        156:\n        157:def test_multiline_imports(test_file):\n        158:    \"\"\"Test handling multiline import statements\"\"\"\n        159:    new_code = '\\n    from typing import (\\n        List,\\n        Dict,\\n        Optional,\\n        Union\\n    )\\n\\n    x = 42\\n    '\n        160:    result = python_edit(test_file, new_code)\n        161:    with open(test_file) as f:\n        162:        content = f.read()\n        163:    assert 'Union' in content\n        164:    assert content.index('Union') < content.index('x = 42')\n        165:\n        166:def test_line_comment_preservation(tmp_path):\n        167:    \"\"\"Test that comments are preserved when inserting after them\"\"\"\n        168:    content = '\\n    def my_func():\\n        # First comment\\n        x = 1\\n        # Target comment\\n        y = 2\\n    '\n        169:    test_file = setup_test_file(tmp_path, content)\n        170:    result = python_edit(f'{test_file}::my_func', 'z = 3', insert_after='# Target comment')\n        171:    with open(test_file) as f:\n        172:        content = f.read()\n        173:    print(f'DEBUG - Result content:\\n{content}')\n        174:    assert '# Target comment' in content\n        175:    assert 'z = 3' in content\n        176:    assert content.index('# Target comment') < content.index('z = 3')\n        177:    assert content.index('z = 3') < content.index('y = 2')\n        178:\n        179:def test_import_at_file_start(tmp_path):\n        180:    \"\"\"Test that imports are added at the start of the file\"\"\"\n        181:    content = '\\n    x = 1\\n    y = 2\\n    '\n        182:    test_file = setup_test_file(tmp_path, content)\n        183:    result = python_edit(test_file, 'import sys\\nz = 3')\n        184:    with open(test_file) as f:\n        185:        content = f.read()\n        186:    print(f'DEBUG - Result content:\\n{content}')\n        187:    assert 'import sys' in content\n        188:    assert content.index('import sys') < content.index('x = 1')\n        189:\n        190:def test_nested_scope_insertion(tmp_path):\n        191:    \"\"\"Test inserting into deeply nested scopes\"\"\"\n        192:    content = '\\n    class Outer:\\n        class Inner:\\n            def method(self):\\n                x = 1\\n    '\n        193:    test_file = setup_test_file(tmp_path, content)\n        194:    result = python_edit(f'{test_file}::Outer::Inner::method', 'y = 2', insert_after='x = 1')\n        195:    with open(test_file) as f:\n        196:        content = f.read()\n        197:    print(f'DEBUG - Result content:\\n{content}')\n        198:    assert 'y = 2' in content\n        199:    assert content.index('x = 1') < content.index('y = 2')\n        200:\n        201:def test_indentation_in_class(tmp_path):\n        202:    \"\"\"Test that proper indentation is maintained in class methods\"\"\"\n        203:    content = '\\n    class MyClass:\\n        def method_one(self):\\n            pass\\n    '\n        204:    test_file = setup_test_file(tmp_path, content)\n        205:    new_method = '\\n    def method_two(self):\\n        if True:\\n            x = 1\\n    '\n        206:    result = python_edit(f'{test_file}::MyClass', new_method, insert_after='MyClass::method_one')\n        207:    with open(test_file) as f:\n        208:        content = f.read()\n        209:    print(f'DEBUG - Result content:\\n{content}')\n        210:    assert '    def method_two(self):' in content\n        211:    assert '        if True:' in content\n        212:    assert '            x = 1' in content\n        213:\n        214:def test_scope_path_matching(tmp_path):\n        215:    \"\"\"Test that scope paths are correctly matched\"\"\"\n        216:    content = '\\n    class ClassA:\\n        def method(self): pass\\n    class ClassB:\\n        def method(self): pass\\n    '\n        217:    test_file = setup_test_file(tmp_path, content)\n        218:    result = python_edit(f'{test_file}::ClassB::method', 'x = 1', insert_after='pass')\n        219:    with open(test_file) as f:\n        220:        content = f.read()\n        221:    print(f'DEBUG - Result content:\\n{content}')\n        222:    lines = content.split('\\n')\n        223:    classA_method = next((i for i, line in enumerate(lines) if 'ClassA' in line))\n        224:    classB_method = next((i for i, line in enumerate(lines) if 'ClassB' in line))\n        225:    x_equals_1 = next((i for i, line in enumerate(lines) if 'x = 1' in line))\n        226:    assert classA_method < classB_method < x_equals_1\n        227:\n        228:def test_file_start_insertion_empty():\n        229:    \"\"\"Test inserting at start of empty file\"\"\"\n        230:    test_file = setup_test_file('tmp', '')\n        231:    result = python_edit(test_file, 'import sys', insert_after='__FILE_START__')\n        232:    with open(test_file) as f:\n        233:        content = f.read()\n        234:    assert content.strip() == 'import sys'\n        235:\n        236:def test_file_start_insertion_with_imports():\n        237:    \"\"\"Test inserting at start of file that already has imports\"\"\"\n        238:    content = '\\n    import os\\n    from typing import List\\n\\n    x = 1\\n    '\n        239:    test_file = setup_test_file('tmp', content)\n        240:    result = python_edit(test_file, 'import sys', insert_after='__FILE_START__')\n        241:    with open(test_file) as f:\n        242:        lines = f.readlines()\n        243:    print(f'DEBUG - File lines: {lines}')\n        244:    assert 'import sys\\n' == lines[0]\n        245:    assert 'import os\\n' in lines[1:]\n        246:    assert 'x = 1' in lines[-1]\n        247:\n        248:def test_file_start_insertion_with_code():\n        249:    \"\"\"Test inserting at start of file that has no imports\"\"\"\n        250:    content = '\\n    x = 1\\n    y = 2\\n    '\n        251:    test_file = setup_test_file('tmp', content)\n        252:    result = python_edit(test_file, 'import sys', insert_after='__FILE_START__')\n        253:    with open(test_file) as f:\n        254:        lines = f.readlines()\n        255:    print(f'DEBUG - File lines: {lines}')\n        256:    assert 'import sys\\n' == lines[0]\n        257:    assert 'x = 1' in lines[1]\n        258:\n        259:def test_file_start_insertion_multiple():\n        260:    \"\"\"Test multiple insertions at file start come in correct order\"\"\"\n        261:    content = 'x = 1'\n        262:    test_file = setup_test_file('tmp', content)\n        263:    python_edit(test_file, 'import sys', insert_after='__FILE_START__')\n        264:    python_edit(test_file, 'import os', insert_after='__FILE_START__')\n        265:    with open(test_file) as f:\n        266:        lines = f.readlines()\n        267:    print(f'DEBUG - File lines: {lines}')\n        268:    assert 'import os\\n' == lines[0]\n        269:    assert 'import sys\\n' == lines[1]\n        270:    assert 'x = 1' in lines[-1]\n        271:\n        272:def test_line_insert_basic():\n        273:    \"\"\"Test inserting after a simple line in a function\"\"\"\n        274:    content = '\\n    def test_func():\\n        x = 1\\n        # marker\\n        z = 3\\n    '\n        275:    test_file = setup_test_file('tmp', content)\n        276:    result = python_edit(f'{test_file}::test_func', 'y = 2', insert_after='# marker')\n        277:    with open(test_file) as f:\n        278:        content = f.read()\n        279:    print(f'DEBUG - Result content:\\n{content}')\n        280:    assert '# marker\\n' in content\n        281:    assert 'y = 2' in content\n        282:    assert content.index('# marker') < content.index('y = 2')\n        283:    assert content.index('y = 2') < content.index('z = 3')\n        284:\n        285:def test_line_insert_indentation():\n        286:    \"\"\"Test that inserted code maintains proper indentation\"\"\"\n        287:    content = '\\n    def test_func():\\n        if True:\\n            x = 1\\n            # marker\\n            z = 3\\n    '\n        288:    test_file = setup_test_file('tmp', content)\n        289:    result = python_edit(f'{test_file}::test_func', 'y = 2', insert_after='# marker')\n        290:    with open(test_file) as f:\n        291:        content = f.read()\n        292:    print(f'DEBUG - Result content:\\n{content}')\n        293:    lines = content.split('\\n')\n        294:    marker_line = next((i for i, line in enumerate(lines) if '# marker' in line))\n        295:    y_line = next((i for i, line in enumerate(lines) if 'y = 2' in line))\n        296:    assert marker_line < y_line\n        297:    assert len(lines[marker_line]) - len(lines[marker_line].lstrip()) == len(lines[y_line]) - len(lines[y_line].lstrip())\n        298:\n        299:def test_line_insert_preservation():\n        300:    \"\"\"Test that the line we insert after is preserved\"\"\"\n        301:    content = '\\n    def simple():\\n        # keep me\\n        pass\\n    '\n        302:    test_file = setup_test_file('tmp', content)\n        303:    result = python_edit(f'{test_file}::simple', 'x = 1', insert_after='# keep me')\n        304:    with open(test_file) as f:\n        305:        content = f.read()\n        306:    print(f'DEBUG - File content:\\n{content}')\n        307:    print(f'DEBUG - Result: {result}')\n        308:    lines = [l.strip() for l in content.split('\\n') if l.strip()]\n        309:    print(f'DEBUG - Stripped lines: {lines}')\n        310:    assert lines == ['def simple():', '# keep me', 'x = 1', 'pass']\n        311:\n        312:def test_line_insert_ast_handling():\n        313:    \"\"\"Test that comments and non-AST lines are preserved during insertion\"\"\"\n        314:    content = '\\n    def func():\\n        x = 1  # comment one\\n        # standalone comment\\n        y = 2  # comment two\\n    '\n        315:    test_file = setup_test_file('tmp', content)\n        316:    result = python_edit(f'{test_file}::func', 'z = 3', insert_after='# standalone comment')\n        317:    print(f'DEBUG - python_edit result: {result}')\n        318:    with open(test_file) as f:\n        319:        content = f.read()\n        320:    print(f'DEBUG - File content:\\n{content}')\n        321:    lines = [l.strip() for l in content.split('\\n') if l.strip()]\n        322:    print(f'DEBUG - Stripped lines: {lines}')\n        323:    assert 'comment one' in content\n        324:    assert '# standalone comment' in content\n        325:    assert 'comment two' in content\n        326:    assert lines.index('# standalone comment') < lines.index('z = 3')\n        327:\n        328:@pytest.mark.skip #Timeout\n        329:def test_line_insert_function_body():\n        330:    \"\"\"Test that we correctly handle function body when inserting lines\"\"\"\n        331:    content = '\\n    def example():\\n        \"\"\"Docstring.\"\"\"\\n        # First comment\\n        x = 1  # Inline comment\\n\\n        # Marker\\n        y = 2\\n    '\n        332:    test_file = setup_test_file('tmp', content)\n        333:    result = python_edit(f'{test_file}::example', 'z = 3', insert_after='# Marker')\n        334:    with open(test_file) as f:\n        335:        content = f.read()\n        336:    print(f'DEBUG - File content:\\n{content}')\n        337:    assert '\"\"\"Docstring.\"\"\"' in content\n        338:    assert '# First comment' in content\n        339:    assert 'Inline comment' in content\n        340:    assert '# Marker' in content\n        341:    lines = [l.strip() for l in content.split('\\n') if l.strip()]\n        342:    print(f'DEBUG - Stripped lines: {lines}')\n        343:    marker_idx = lines.index('# Marker')\n        344:    z_idx = lines.index('z = 3')\n        345:    y_idx = lines.index('y = 2')\n        346:    assert marker_idx < z_idx < y_idx, 'Lines should be in correct order'\n        347:\n        348:def test_line_insert_exact_preservation():\n        349:    \"\"\"Test that lines are preserved exactly as they appear in the source\"\"\"\n        350:    content = '\\n    def func():\\n        x = 1  # comment one\\n\\n        # marker with spaces around\\n\\n        y = 2  # comment two\\n    '\n        351:    test_file = setup_test_file('tmp', content)\n        352:    result = python_edit(f'{test_file}::func', 'z = 3', insert_after='# marker with spaces around')\n        353:    with open(test_file) as f:\n        354:        content = f.read()\n        355:    print(f'DEBUG - File content:\\n{content}')\n        356:    assert 'x = 1  # comment one' in content\n        357:    assert '# marker with spaces around' in content\n        358:    assert 'y = 2  # comment two' in content\n        359:    lines = content.split('\\n')\n        360:    marker_idx = next((i for i, line in enumerate(lines) if '# marker with spaces around' in line))\n        361:    assert lines[marker_idx - 1].strip() == '', 'Should preserve blank line before marker'\n        362:    assert lines[marker_idx + 1].strip() == '', 'Should preserve blank line after marker'\n        363:\n        364:@pytest.mark.skip #Timeout\n        365:def test_source_preservation():\n        366:    \"\"\"Test that source lines are preserved exactly when modifying a function\"\"\"\n        367:    content = '\\n    def example():\\n        \"\"\"This is a docstring.\"\"\"\\n\\n        # First we do x\\n        x = 1  # comment about x\\n\\n        # Then we do y\\n        y = 2  # comment about y\\n    '\n        368:    test_file = setup_test_file('tmp', content)\n        369:    result = python_edit(f'{test_file}::example', 'z = 3', insert_after='# Then we do y')\n        370:    with open(test_file) as f:\n        371:        content = f.read()\n        372:    print(f'DEBUG - File content:\\n{content}')\n        373:    assert '\"\"\"This is a docstring.\"\"\"' in content\n        374:    assert '# First we do x' in content\n        375:    assert 'x = 1  # comment about x' in content\n        376:    assert '# Then we do y' in content\n        377:    assert 'z = 3' in content\n        378:    assert 'y = 2  # comment about y' in content\n        379:    lines = content.split('\\n')\n        380:\n        381:    def line_number(text):\n        382:        return next((i for i, line in enumerate(lines) if text in line))\n        383:    assert line_number('# Then we do y') < line_number('z = 3') < line_number('y = 2')\n        384:\n        385:@pytest.mark.skip #Timeout\n        386:def test_ast_tree_preservation():\n        387:    \"\"\"Test that source preservation works through AST tree reconstruction\"\"\"\n        388:    content = '\\n    # Top level comment\\n    import os  # os import\\n\\n    def example():  # example function\\n        \"\"\"Docstring.\"\"\"\\n\\n        # First we do x\\n        x = 1  # comment about x\\n\\n        # Then we do y\\n        y = 2  # comment about y\\n    '\n        389:    test_file = setup_test_file('tmp', content)\n        390:    result = python_edit(f'{test_file}::example', 'z = 3', insert_after='# Then we do y')\n        391:    with open(test_file) as f:\n        392:        content = f.read()\n        393:    print(f'DEBUG - File content:\\n{content}')\n        394:    assert '# Top level comment' in content\n        395:    assert 'import os  # os import' in content\n        396:    assert 'def example():  # example function' in content\n        397:    assert '\"\"\"Docstring.\"\"\"' in content\n        398:    assert '# First we do x' in content\n        399:    assert 'x = 1  # comment about x' in content\n        400:    assert '# Then we do y' in content\n        401:    assert 'z = 3' in content\n        402:    assert 'y = 2  # comment about y' in content\n        403:\n        404:def test_file_level_preservation():\n        405:    \"\"\"Test that file-level operations preserve formatting\"\"\"\n        406:    content = '\\n    # Top level comment\\n    import os  # os import\\n\\n    # Another comment\\n    x = 1  # first assignment\\n\\n    # Final comment\\n    y = 2  # second assignment\\n    '\n        407:    test_file = setup_test_file('tmp', content)\n        408:    result = python_edit(test_file, 'z = 3', insert_after='__FILE_START__')\n        409:    with open(test_file) as f:\n        410:        content = f.read()\n        411:    print(f'DEBUG - File content:\\n{content}')\n        412:    expected = '\\n    # Top level comment\\n    import os  # os import\\n\\n    z = 3\\n\\n    # Another comment\\n    x = 1  # first assignment\\n\\n    # Final comment\\n    y = 2  # second assignment\\n    '.strip()\n        413:    print(f'DEBUG - Expected:\\n{expected}')\n        414:    assert content.strip() == expected\n        415:\n        416:    def test_minimal_tokenize():\n        417:        \"\"\"Test tokenization of minimal valid Python\"\"\"\n        418:        source = 'x = 1'\n        419:        tokenized, token_map = _tokenize_source(source)\n        420:        print(f'DEBUG - Tokenized: {tokenized}')\n        421:        print(f'DEBUG - Token map: {token_map}')\n        422:        ast.parse(tokenized)\n        423:        assert _detokenize_source(tokenized, token_map) == source\n        424:\n        425:    def test_minimal_tokenize_with_comment():\n        426:        \"\"\"Test tokenization with just a comment\"\"\"\n        427:        source = '# A comment'\n        428:        tokenized, token_map = _tokenize_source(source)\n        429:        print(f'DEBUG - Tokenized: {tokenized}')\n        430:        print(f'DEBUG - Token map: {token_map}')\n        431:        ast.parse(tokenized)\n        432:        assert _detokenize_source(tokenized, token_map) == source\n        433:\n        434:    def test_minimal_edit():\n        435:        \"\"\"Test the most basic possible edit\"\"\"\n        436:        with open('minimal.py', 'w') as f:\n        437:            f.write('# Empty\\n')\n        438:        result = python_edit('minimal.py', 'x = 1')\n        439:        print(f'DEBUG - Result: {result}')\n        440:        with open('minimal.py') as f:\n        441:            content = f.read()\n        442:        print(f'DEBUG - Content: {content}')\n        443:        assert 'file level' in result\n        444:\n        445:@pytest.mark.skip #Timeout\n        446:def test_tokenize_basic():\n        447:    \"\"\"Test basic tokenization of comments and strings\"\"\"\n        448:    source = '\\n    # Header comment\\n    x = \"string literal\"  # Inline comment\\n    y = 1\\n    '\n        449:    tokenized, token_map = _tokenize_source(source)\n        450:    assert '# Header comment' not in tokenized\n        451:    assert '\"string literal\"' not in tokenized\n        452:    assert '# Inline comment' not in tokenized\n        453:    assert '__TOKEN__' in tokenized\n        454:    assert _detokenize_source(tokenized, token_map) == source\n        455:    restored = _detokenize_source(tokenized, token_map)\n        456:    assert restored == source\n        457:\n        458:@pytest.mark.skip #Timeout\n        459:def test_tokenize_multiline():\n        460:    \"\"\"Test tokenization of multiline strings and nested structures\"\"\"\n        461:    source = '\\n    def func():\\n        \"\"\"\\n        Multiline\\n        docstring\\n        \"\"\"\\n        # Comment\\n        if True:\\n            # Nested comment\\n            x = 1\\n    '\n        462:    tokenized, token_map = _tokenize_source(source)\n        463:    assert '\"\"\"' not in tokenized\n        464:    assert '# Comment' not in tokenized\n        465:    assert '# Nested comment' not in tokenized\n        466:    restored = _detokenize_source(tokenized, token_map)\n        467:    assert restored == source\n        468:\n        469:@pytest.mark.skip #Timeout\n        470:def test_tokenize_edge_cases():\n        471:    \"\"\"Test tokenization of edge cases\"\"\"\n        472:    source = '\\n    x = 1; y = 2  # Multiple statements\\n    # Comment with ; semicolon\\n    s = \"String # with hash\"\\n    q = \\'String ; with semicolon\\'\\n    \"\"\"\\n    Multiline string\\n    # with comment\\n    ; with semicolon\\n    \"\"\"\\n    '\n        473:    tokenized, token_map = _tokenize_source(source)\n        474:    assert '__TOKEN__' in tokenized\n        475:    assert _detokenize_source(tokenized, token_map) == source\n        476:    restored = _detokenize_source(tokenized, token_map)\n        477:    assert restored == source\n        478:\n        479:def test_minimal_tokenize():\n        480:    \"\"\"Test tokenization of minimal valid Python\"\"\"\n        481:    source = 'x = 1'\n        482:    tokenized, token_map = _tokenize_source(source)\n        483:    print(f'DEBUG - Tokenized: {tokenized}')\n        484:    print(f'DEBUG - Token map: {token_map}')\n        485:    ast.parse(tokenized)\n        486:    assert _detokenize_source(tokenized, token_map) == source\n        487:\n        488:def test_minimal_tokenize_with_comment():\n        489:    \"\"\"Test tokenization with just a comment\"\"\"\n        490:    source = '# A comment'\n        491:    tokenized, token_map = _tokenize_source(source)\n        492:    print(f'DEBUG - Tokenized: {tokenized}')\n        493:    print(f'DEBUG - Token map: {token_map}')\n        494:    ast.parse(tokenized)\n        495:    assert _detokenize_source(tokenized, token_map) == source\n        496:\n        497:def test_minimal_edit():\n        498:    \"\"\"Test the most basic possible edit\"\"\"\n        499:    with open('minimal.py', 'w') as f:\n        500:        f.write('# Empty\\n')\n        501:    result = python_edit('minimal.py', 'x = 1')\n        502:    print(f'DEBUG - Result: {result}')\n        503:    with open('minimal.py') as f:\n        504:        content = f.read()\n        505:    print(f'DEBUG - Content: {content}')\n        506:    assert 'file level' in result\n        507:\n        508:def test_minimal_multiline():\n        509:    \"\"\"Test tokenization of multiline content\"\"\"\n        510:    source = 'def test():\\n        \"\"\"\\n        Docstring\\n        with lines\\n        \"\"\"\\n        pass'\n        511:    tokenized, token_map = _tokenize_source(source)\n        512:    print(f'DEBUG - Tokenized:\\n{tokenized}')\n        513:    print(f'DEBUG - Token map:\\n{token_map}')\n        514:    ast.parse(tokenized)\n        515:    restored = _detokenize_source(tokenized, token_map)\n        516:    print(f'DEBUG - Restored:\\n{restored}')\n        517:    assert restored == source\n        518:\n        519:def test_minimal_nested_multiline():\n        520:    \"\"\"Test tokenization of nested multiline content\"\"\"\n        521:    source = 'def outer():\\n        \"\"\"Outer docstring\"\"\"\\n        def inner():\\n            \"\"\"\\n            Inner\\n            docst