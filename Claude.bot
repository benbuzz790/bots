                                                                                                                                                                                                                                                                                                                                                                                  "content": "\n        1:import ast\n        2:import os\n        3:import textwrap\n        4:from bots.utils.helpers import _process_error, _clean, _py_ast_to_source\n        5:import hashlib\n        6:import re\n        7:from typing import Dict, Tuple\n        8:from typing import Dict, Tuple, Union\n        9:\n        10:def python_edit(target_scope: str, code: str, *, insert_after: str=None) -> str:\n        11:    \"\"\"\n        12:    Edit Python code using pytest-style scope syntax.\n        13:\n        14:    Parameters:\n        15:    ----------\n        16:    target_scope : str\n        17:        Location to edit in pytest-style scope syntax:\n        18:        - \"file.py\" (whole file)\n        19:        - \"file.py::MyClass\" (class)\n        20:        - \"file.py::my_function\" (function)\n        21:        - \"file.py::MyClass::method\" (method)\n        22:        - \"file.py::Outer::Inner::method\" (nested)\n        23:        - \"file.py::utils::helper_func\" (nested function)\n        24:\n        25:    code : str\n        26:        Python code to insert/replace. Will be cleaned/dedented.\n        27:        Import statements will be automatically extracted and handled.\n        28:\n        29:    insert_after : str, optional\n        30:        Where to insert the code. Can be either:\n        31:        - \"__FILE_START__\" (special token for file beginning)\n        32:        - A scope (\"MyClass::method\")\n        33:        - An exact line match\n        34:        If not specified, replaces the node at target_scope.\n        35:\n        36:    Returns:\n        37:    --------\n        38:    str\n        39:        Description of what was modified or error message\n        40:    \"\"\"\n        41:    try:\n        42:        file_path, *path_elements = target_scope.split('::')\n        43:        if not file_path.endswith('.py'):\n        44:            return _process_error(ValueError(f'File path must end with .py: {file_path}'))\n        45:        for element in path_elements:\n        46:            if not element.isidentifier():\n        47:                return _process_error(ValueError(f'Invalid identifier in path: {element}'))\n        48:        abs_path = _make_file(file_path)\n        49:        try:\n        50:            new_tree = ast.parse(_clean(code))\n        51:            import_nodes = []\n        52:            code_nodes = []\n        53:            for node in new_tree.body:\n        54:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        55:                    import_nodes.append(node)\n        56:                else:\n        57:                    code_nodes.append(node)\n        58:        except Exception as e:\n        59:            return _process_error(ValueError(f'Error parsing new code: {str(e)}'))\n        60:        try:\n        61:            with open(abs_path, 'r', encoding='utf-8') as file:\n        62:                content = file.read()\n        63:            file_lines = content.split('\\n')\n        64:            tree = ast.parse(content) if content.strip() else ast.Module(body=[], type_ignores=[])\n        65:        except Exception as e:\n        66:            return _process_error(ValueError(f'Error reading/parsing file {abs_path}: {str(e)}'))\n        67:        existing_imports = []\n        68:        non_imports = []\n        69:        for node in tree.body:\n        70:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        71:                existing_imports.append(node)\n        72:            else:\n        73:                non_imports.append(node)\n        74:        if insert_after == '__FILE_START__':\n        75:            tree.body = import_nodes + code_nodes + existing_imports + non_imports\n        76:            try:\n        77:                updated_content = _py_ast_to_source(tree)\n        78:                with open(abs_path, 'w', encoding='utf-8') as file:\n        79:                    file.write(updated_content)\n        80:                return f\"Code inserted at start of '{abs_path}'.\"\n        81:            except Exception as e:\n        82:                return _process_error(e)\n        83:        if not path_elements:\n        84:            tree.body = existing_imports + import_nodes + non_imports + code_nodes\n        85:            try:\n        86:                updated_content = _py_ast_to_source(tree)\n        87:                with open(abs_path, 'w', encoding='utf-8') as file:\n        88:                    file.write(updated_content)\n        89:                return f\"Code added at file level in '{abs_path}'.\"\n        90:            except Exception as e:\n        91:                return _process_error(e)\n        92:        tree.body = existing_imports + import_nodes + non_imports\n        93:        transformer = ScopeTransformer(path_elements, code_nodes, insert_after, file_lines)\n        94:        modified_tree = transformer.visit(tree)\n        95:        if not transformer.success:\n        96:            if insert_after:\n        97:                return _process_error(ValueError(f'Insert point not found: {insert_after}'))\n        98:            else:\n        99:                return _process_error(ValueError(f'Target scope not found: {target_scope}'))\n        100:        try:\n        101:            updated_content = _py_ast_to_source(modified_tree)\n        102:            with open(abs_path, 'w', encoding='utf-8') as file:\n        103:                file.write(updated_content)\n        104:        except Exception as e:\n        105:            return _process_error(e)\n        106:        action = 'inserted after' if insert_after else 'replaced at'\n        107:        scope_str = '::'.join(path_elements) if path_elements else 'file level'\n        108:        return f\"Code {action} {scope_str} in '{abs_path}'.\"\n        109:    except Exception as e:\n        110:        return _process_error(e)\n        111:\n        112:def _make_file(file_path: str) -> str:\n        113:    \"\"\"\n        114:    Creates a file and its parent directories if they don't exist.\n        115:    Converts relative paths to absolute paths.\n        116:\n        117:    Parameters:\n        118:    - file_path (str): The path to the file to be created\n        119:\n        120:    Returns:\n        121:    - str: The absolute path to the file\n        122:\n        123:    Raises:\n        124:    - ValueError: If there's an error creating the file or directories,\n        125:                 or if the file_path is empty\n        126:    \"\"\"\n        127:    if not file_path:\n        128:        raise ValueError('File path cannot be empty')\n        129:    abs_path = os.path.abspath(file_path)\n        130:    dir_path = os.path.dirname(abs_path)\n        131:    if dir_path:\n        132:        try:\n        133:            os.makedirs(dir_path, exist_ok=True)\n        134:        except Exception as e:\n        135:            raise ValueError(f'Error creating directories {dir_path}: {str(e)}')\n        136:    if not os.path.exists(abs_path):\n        137:        try:\n        138:            with open(abs_path, 'w', encoding='utf-8') as f:\n        139:                f.write('')\n        140:        except Exception as e:\n        141:            raise ValueError(f'Error creating file {abs_path}: {str(e)}')\n        142:    return abs_path\n        143:\n        144:class ScopeTransformer(ast.NodeTransformer):\n        145:    \"\"\"AST transformer that handles scope-based Python code modifications.\"\"\"\n        146:\n        147:    def __init__(self, path_elements, new_nodes, insert_after=None, file_lines=None):\n        148:        self.original_path = path_elements\n        149:        self.new_nodes = new_nodes\n        150:        self.insert_after = insert_after\n        151:        self.file_lines = file_lines\n        152:        self.current_path = []\n        153:        self.success = False\n        154:        self.line_match_count = 0\n        155:\n        156:    def visit_ClassDef(self, node):\n        157:        \"\"\"Visit a class definition node.\"\"\"\n        158:        if not self.original_path or node.name != self.original_path[0]:\n        159:            return self.generic_visit(node)\n        160:        self.current_path.append(node.name)\n        161:        remaining_path = self.original_path[1:]\n        162:        if not remaining_path:\n        163:            if self.insert_after:\n        164:                node = self._handle_insertion(node)\n        165:            else:\n        166:                self.success = True\n        167:                if len(self.new_nodes) == 1:\n        168:                    return self.new_nodes[0]\n        169:                else:\n        170:                    node.body = self.new_nodes\n        171:                    return node\n        172:        else:\n        173:            saved_path = self.original_path\n        174:            self.original_path = remaining_path\n        175:            node.body = [self.visit(child) for child in node.body]\n        176:            self.original_path = saved_path\n        177:        self.current_path.pop()\n        178:        return node\n        179:\n        180:    def visit_FunctionDef(self, node):\n        181:        \"\"\"Visit a function definition node.\"\"\"\n        182:        return self._handle_function_node(node)\n        183:\n        184:    def visit_AsyncFunctionDef(self, node):\n        185:        \"\"\"Visit an async function definition node.\"\"\"\n        186:        return self._handle_function_node(node)\n        187:\n        188:    def _handle_function_node(self, node):\n        189:        \"\"\"Common handling for both regular and async functions.\"\"\"\n        190:        if not self.original_path or node.name != self.original_path[0]:\n        191:            return self.generic_visit(node)\n        192:        self.current_path.append(node.name)\n        193:        remaining_path = self.original_path[1:]\n        194:        if not remaining_path:\n        195:            if self.insert_after:\n        196:                node = self._handle_insertion(node)\n        197:            else:\n        198:                self.success = True\n        199:                if len(self.new_nodes) == 1:\n        200:                    return self.new_nodes[0]\n        201:                else:\n        202:                    node.body = self.new_nodes\n        203:                    return node\n        204:        else:\n        205:            saved_path = self.original_path\n        206:            self.original_path = remaining_path\n        207:            node.body = [self.visit(child) for child in node.body]\n        208:            self.original_path = saved_path\n        209:        self.current_path.pop()\n        210:        return node\n        211:\n        212:    def _handle_one_line_function(self, node, line):\n        213:        \"\"\"Special handling for one-line function definitions\"\"\"\n        214:        if ': pass' in line or ':pass' in line:\n        215:            base_indent = len(line) - len(line.lstrip())\n        216:            def_line = line.rstrip()\n        217:            if self.insert_after == 'pass':\n        218:                def_line = def_line.replace(': pass', ':').replace(':pass', ':')\n        219:                body_indent = base_indent + 4\n        220:                body_lines = []\n        221:                body_lines.append(' ' * body_indent + 'pass')\n        222:                for new_node in self.new_nodes:\n        223:                    node_lines = _py_ast_to_source(new_node).split('\\n')\n        224:                    for nl in node_lines:\n        225:                        if nl.strip():\n        226:                            body_lines.append(' ' * body_indent + nl.lstrip())\n        227:                new_source = def_line + '\\n' + '\\n'.join(body_lines)\n        228:                try:\n        229:                    new_node = ast.parse(new_source).body[0]\n        230:                    self.success = True\n        231:                    return new_node\n        232:                except Exception:\n        233:                    normalized = textwrap.dedent(new_source)\n        234:                    try:\n        235:                        new_node = ast.parse(normalized).body[0]\n        236:                        self.success = True\n        237:                        return new_node\n        238:                    except Exception:\n        239:                        pass\n        240:        return node\n        241:\n        242:    def _handle_insertion(self, node):\n        243:        \"\"\"Handle inserting nodes after a specific point.\"\"\"\n        244:        if isinstance(self.insert_after, str) and '::' not in self.insert_after:\n        245:            if not isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        246:                return node\n        247:            if node.lineno == node.end_lineno:\n        248:                return self._handle_one_line_function(node, self.file_lines[node.lineno - 1])\n        249:            func_lines = self.file_lines[node.lineno - 1:node.end_lineno]\n        250:            if not func_lines:\n        251:                return node\n        252:            target = self.insert_after.strip()\n        253:            for i, line in enumerate(func_lines):\n        254:                if line.strip() == target:\n        255:                    self.line_match_count += 1\n        256:                    if self.line_match_count == 1:\n        257:                        current_indent = len(line) - len(line.lstrip())\n        258:                        insertion = []\n        259:                        for new_node in self.new_nodes:\n        260:                            node_lines = _py_ast_to_source(new_node).split('\\n')\n        261:                            for nl in node_lines:\n        262:                                if nl.strip():\n        263:                                    insertion.append(' ' * current_indent + nl.lstrip())\n        264:                                else:\n        265:                                    insertion.append(' ' * current_indent)\n        266:                        func_lines[i:i + 1] = [func_lines[i]] + insertion\n        267:                        self.success = True\n        268:                        break\n        269:            if self.line_match_count == 0:\n        270:                return node\n        271:            elif self.line_match_count > 1:\n        272:                raise ValueError(f'Ambiguous insert_after - found {self.line_match_count} matches for: {self.insert_after}')\n        273:            node._source = '\\n'.join(func_lines)\n        274:            self.success = True\n        275:            return node\n        276:        else:\n        277:            if self.insert_after:\n        278:                target_path = self.insert_after.split('::')\n        279:                current_path = self.current_path\n        280:                if len(current_path) == len(target_path) and all((c == t for c, t in zip(current_path, target_path))):\n        281:                    self.success = True\n        282:                    if isinstance(node, ast.ClassDef):\n        283:                        node.body.extend(self.new_nodes)\n        284:                    else:\n        285:                        for new_node in self.new_nodes:\n        286:                            node.body.append(new_node)\n        287:            return node\n        288:\n        289:    def _preserve_node_source(self, node):\n        290:        \"\"\"Get the original source of a node, preserving comments and formatting\"\"\"\n        291:        if hasattr(node, 'lineno') and hasattr(node, 'end_lineno'):\n        292:            lines = self.file_lines[node.lineno - 1:node.end_lineno]\n        293:            return '\\n'.join(lines)\n        294:        return _py_ast_to_source(node)\n        295:\n        296:def create_token(content: str, index: int, current_hash: str) -> str:\n        297:    \"\"\"Create a token with our specific pattern\"\"\"\n        298:    hex_content = content.encode('utf-8').hex()\n        299:    token_name = f'TOKEN__{current_hash}_{index}'\n        300:    return (token_name, hex_content)\n        301:\n        302:def get_file_hash(content: str) -> str:\n        303:    \"\"\"Create a short hash of file content\"\"\"\n        304:    return hashlib.sha256(content.encode()).hexdigest()[:8]\n        305:\n        306:def tokenize_source(source: str) -> Tuple[str, Dict[str, str]]:\n        307:    \"\"\"\n        308:    Tokenize source code, preserving exact formatting.\n        309:\n        310:    Returns:\n        311:    - tokenized_source: Source with tokens inserted\n        312:    - token_map: Mapping of tokens to original content\n        313:    \"\"\"\n        314:\n        315:    def contains_token(s: str) -> bool:\n        316:        return TOKEN_START + 'TOKEN__' in s\n        317:\n        318:    def make_token_ref(name: str) -> str:\n        319:        \"\"\"Create a reference to a token\"\"\"\n        320:        return f'{TOKEN_START}{name}{TOKEN_END}'\n        321:    token_map = {}\n        322:    current_hash = get_file_hash(source)\n        323:    token_counter = 0\n        324:    lines = source.split('\\n')\n        325:    leading_empty = []\n        326:    while lines and (not lines[0].strip()):\n        327:        leading_empty.append(lines.pop(0))\n        328:    processed_lines = []\n        329:    for line in lines:\n        330:        if contains_token(line):\n        331:            processed_lines.append(line)\n        332:            continue\n        333:        indent = len(line) - len(line.lstrip())\n        334:        indentation = ' ' * indent\n        335:        content = line[indent:]\n        336:        if not content.strip():\n        337:            processed_lines.append(line)\n        338:            continue\n        339:        if content.strip().startswith('#'):\n        340:            token_name, hex_val = create_token(content, token_counter, current_hash)\n        341:            token_map[token_name] = content\n        342:            processed_lines.append(indentation + make_token_ref(token_name))\n        343:            token_counter += 1\n        344:            continue\n        345:        processed_line = content\n        346:        string_patterns = ['\"\"\"(?:[^\"\\\\\\\\]|\\\\\\\\.)*\"\"\"', \"'''(?:[^'\\\\\\\\]|\\\\\\\\.)*'''\", '\"(?:[^\"\\\\\\\\]|\\\\\\\\.)*\"', \"'(?:[^'\\\\\\\\]|\\\\\\\\.)*'\"]\n        347:        for pattern in string_patterns:\n        348:            matches = list(re.finditer(pattern, processed_line))\n        349:            offset = 0\n        350:            for match in matches:\n        351:                start, end = match.span()\n        352:                start += offset\n        353:                end += offset\n        354:                string_content = processed_line[start:end]\n        355:                token_name, hex_val = create_token(string_content, token_counter, current_hash)\n        356:                token_map[token_name] = string_content\n        357:                processed_line = processed_line[:start] + make_token_ref(token_name) + processed_line[end:]\n        358:                offset += len(make_token_ref(token_name)) - len(string_content)\n        359:                token_counter += 1\n        360:        if '#' in processed_line and (not any((token in processed_line.split('#', 1)[1] for token in token_map))):\n        361:            comment_start = processed_line.index('#')\n        362:            code = processed_line[:comment_start]\n        363:            comment = processed_line[comment_start:]\n        364:            token_name, hex_val = create_token(comment, token_counter, current_hash)\n        365:            token_map[token_name] = comment\n        366:            processed_line = code + make_token_ref(token_name)\n        367:            token_counter += 1\n        368:        processed_lines.append(indentation + processed_line)\n        369:    final_lines = leading_empty + processed_lines\n        370:    return ('\\n'.join(final_lines), token_map)\n        371:\n        372:def detokenize_source(tokenized_source: str, token_map: Dict[str, str]) -> str:\n        373:    \"\"\"\n        374:    Restore original source from tokenized version.\n        375:\n        376:    Handles proper indentation of multiline content.\n        377:    \"\"\"\n        378:    result = tokenized_source\n        379:    for token_name, original in token_map.items():\n        380:        token_pattern = f'{TOKEN_START}{token_name}{TOKEN_END}'\n        381:        if '\\n' in original:\n        382:            for match in re.finditer(re.escape(token_pattern), result):\n        383:                indent = get_indentation_at_position(result, match.start())\n        384:                indented = indent_multiline_content(original, indent)\n        385:                result = result[:match.start()] + indented + result[match.end():]\n        386:        else:\n        387:            result = result.replace(token_pattern, original)\n        388:    return result\n        389:\n        390:def get_indentation_at_position(source: str, pos: int) -> str:\n        391:    \"\"\"Get the indentation level at a given position in source\"\"\"\n        392:    line_start = source.rfind('\\n', 0, pos) + 1\n        393:    return source[line_start:pos].replace(source[line_start:pos].lstrip(), '')\n        394:\n        395:def indent_multiline_content(content: str, indent: str) -> str:\n        396:    \"\"\"Indent multiline content while preserving internal formatting\"\"\"\n        397:    if not content.strip():\n        398:        return content\n        399:    lines = content.split('\\n')\n        400:    if len(lines) == 1:\n        401:        return content\n        402:    if all((line.startswith(' ') for line in lines[1:] if line.strip())):\n        403:        return content\n        404:    result = [lines[0]]\n        405:    for line in lines[1:]:\n        406:        if line.strip():\n        407:            result.append(indent + line)\n        408:        else:\n        409:            result.append(line)\n        410:    return '\\n'.join(result)"
