before marker'\n        361:    assert lines[marker_idx + 1].strip() == '', 'Should preserve blank line after marker'\n        362:\n        363:def test_source_preservation():\n        364:    \"\"\"Test that source lines are preserved exactly when modifying a function\"\"\"\n        365:    content = '\\n    def example():\\n        \"\"\"This is a docstring.\"\"\"\\n\\n        # First we do x\\n        x = 1  # comment about x\\n\\n        # Then we do y\\n        y = 2  # comment about y\\n    '\n        366:    test_file = setup_test_file('tmp', content)\n        367:    result = python_edit(f'{test_file}::example', 'z = 3', insert_after='# Then we do y')\n        368:    with open(test_file) as f:\n        369:        content = f.read()\n        370:    print(f'DEBUG - File content:\\n{content}')\n        371:    assert '\"\"\"This is a docstring.\"\"\"' in content\n        372:    assert '# First we do x' in content\n        373:    assert 'x = 1  # comment about x' in content\n        374:    assert '# Then we do y' in content\n        375:    assert 'z = 3' in content\n        376:    assert 'y = 2  # comment about y' in content\n        377:    lines = content.split('\\n')\n        378:\n        379:    def line_number(text):\n        380:        return next((i for i, line in enumerate(lines) if text in line))\n        381:    assert line_number('# Then we do y') < line_number('z = 3') < line_number('y = 2')\n        382:\n        383:def test_ast_tree_preservation():\n        384:    \"\"\"Test that source preservation works through AST tree reconstruction\"\"\"\n        385:    content = '\\n    # Top level comment\\n    import os  # os import\\n\\n    def example():  # example function\\n        \"\"\"Docstring.\"\"\"\\n\\n        # First we do x\\n        x = 1  # comment about x\\n\\n        # Then we do y\\n        y = 2  # comment about y\\n    '\n        386:    test_file = setup_test_file('tmp', content)\n        387:    result = python_edit(f'{te