                                                                                                                                                                                                                                                                                                                                                                                 "class_def": "\n                                    class SourcePreservingNode:\n                                        \"\"\"Wrapper for AST nodes that preserves original source.\"\"\"\n                                        \n                                        def __init__(self, node, original_lines):\n                                            self.node = node\n                                            if hasattr(node, 'lineno') and hasattr(node, 'end_lineno'):\n                                                self.source = '\\n'.join(original_lines[node.lineno - 1:node.end_lineno])\n                                                # Store leading and trailing lines\n                                                self.leading_lines = []\n                                                self.trailing_lines = []\n                                                # Find comments before node\n                                                i = node.lineno - 2  # Line before node\n                                                while i >= 0 and (original_lines[i].strip().startswith('#') or not original_lines[i].strip()):\n                                                    self.leading_lines.insert(0, original_lines[i])\n                                                    i -= 1\n                                                # Find blank lines after node\n                                                i = node.end_lineno\n                                                while i < len(original_lines) and not original_lines[i].strip():\n                                                    self.trailing_lines.append(original_lines[i])\n                                                    i += 1\n                                            else:\n                                                self.source = _py_ast_to_source(node)\n                                                self.leading_lines = []\n                                                self.trailing_lines = []\n                                        \n                                        def to_string(self):\n                                            \"\"\"Convert back to string, preserving formatting.\"\"\"\n                                            parts = []\n                                            if self.leading_lines:\n                                                parts.extend(self.leading_lines)\n                                            parts.append(self.source)\n                                            if self.trailing_lines:\n                                                parts.extend(self.trailing_lines)\n                                            return '\\n'.join(parts)"
                                                                                                                                                                                                                                                                                                                                                                                }
