                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                      "content": "Now let me implement the enhanced detokenization with inline comment reunification:",
                                                                                                                                                                                                                                                                                      "pending_results": [],
                                                                                                                                                                                                                                                                                      "role": "assistant",
                                                                                                                                                                                                                                                                                      "tool_calls": [
                                                                                                                                                                                                                                                                                       {
                                                                                                                                                                                                                                                                                        "type": "tool_use",
                                                                                                                                                                                                                                                                                        "id": "toolu_01YLmrnjWHHyZWNynDHu5Ydi",
                                                                                                                                                                                                                                                                                        "name": "replace_function",
                                                                                                                                                                                                                                                                                        "input": {
                                                                                                                                                                                                                                                                                         "file_path": "bots/tools/python_edit.py",
                                                                                                                                                                                                                                                                                         "new_function_def": "\n                                                                                    def _detokenize_source(tokenized_source: str, token_map: Dict[str, str]) -> str:\n                                                                                        \"\"\"\n                                                                                        Restore original source from tokenized version.\n                                                                                    \n                                                                                        Handles proper indentation of multiline content and reunites inline comments.\n                                                                                        \"\"\"\n                                                                                        result = tokenized_source\n                                                                                        \n                                                                                        # First pass: Replace all tokens with their content\n                                                                                        for token_value, token_data in token_map.items():\n                                                                                            # Handle both old format (string) and new format (dict)\n                                                                                            if isinstance(token_data, dict):\n                                                                                                original = token_data['content']\n                                                                                                token_type = token_data.get('type', 'unknown')\n                                                                                            else:\n                                                                                                original = token_data\n                                                                                                token_type = 'legacy'\n                                                                                            \n                                                                                            while token_value in result:\n                                                                                                start = result.find(token_value)\n                                                                                                if start == -1:\n                                                                                                    break\n                                                                                                \n                                                                                                # Check if this token is part of a standalone comment pattern\n                                                                                                line_start = result.rfind('\\n', 0, start) + 1\n                                                                                                line_end = result.find('\\n', start)\n                                                                                                if line_end == -1:\n                                                                                                    line_end = len(result)\n                                                                                                line = result[line_start:line_end]\n                                                                                                \n                                                                                                # Check if this line matches any standalone comment pattern\n                                                                                                line_stripped = line.strip()\n                                                                                                is_standalone_comment = (\n                                                                                                    line_stripped == f'\"\"\"{token_value}\"\"\"' or\n                                                                                                    line_stripped == f\"'{token_value}'\" or\n                                                                                                    line_stripped == f'\"{token_value}\"'\n                                                                                                )\n                                                                                                \n                                                                                                # Check if this is an inline comment pattern (ends with ; \"\"\"__TOKEN__\"\"\")\n                                                                                                is_inline_comment = (\n                                                                                                    line_stripped.endswith(f'; \"\"\"{token_value}\"\"\"') or\n                                                                                                    line_stripped.endswith(f\"; '{token_value}'\") or\n                                                                                                    line_stripped.endswith(f'; \"{token_value}\"')\n                                                                                                )\n                                                                                                \n                                                                                                if is_standalone_comment:\n                                                                                                    # This is a standalone comment - replace the entire string literal\n                                                                                                    indent = line[:len(line) - len(line.lstrip())]\n                                                                                                    replacement = indent + original\n                                                                                                    result = result[:line_start] + replacement + result[line_end:]\n                                                                                                elif is_inline_comment:\n                                                                                                    # This is an inline comment - replace the semicolon and string literal\n                                                                                                    # Find the semicolon and replace \"; \"\"\"token\"\"\" with the original comment\n                                                                                                    semicolon_pos = result.rfind(';', line_start, start)\n                                                                                                    if semicolon_pos != -1:\n                                                                                                        # Replace from semicolon to end of token\n                                                                                                        token_end = start + len(token_value)\n                                                                                                        # Find the end of the string literal\n                                                                                                        if result[token_end:token_end+3] == '\"\"\"':\n                                                                                                            token_end += 3\n                                                                                                        elif result[token_end:token_end+1] in [\"'\", '\"']:\n                                                                                                            token_end += 1\n                                                                                                        result = result[:semicolon_pos] + original + result[token_end:]\n                                                                                                    else:\n                                                                                                        # Fallback to regular replacement\n                                                                                                        result = result[:start] + original + result[start + len(token_value):]\n                                                                                                else:\n                                                                                                    # Regular token replacement\n                                                                                                    if '\\n' in original:\n                                                                                                        indent = _get_indentation_at_position(result, start)\n                                                                                                        indented = _indent_multiline_content(original, indent)\n                                                                                                        result = result[:start] + indented + result[start + len(token_value):]\n                                                                                                    else:\n                                                                                                        result = result[:start] + original + result[start + len(token_value):]\n                                                                                        \n                                                                                        # Second pass: Reunite inline comments that were separated by AST processing\n                                                                                        result = _reunite_inline_comments(result, token_map)\n                                                                                        \n                                                                                        return result\n                                                                                    \n                                                                                    def _reunite_inline_comments(source: str, token_map: Dict[str, str]) -> str:\n                                                                                        \"\"\"\n                                                                                        Post-process to reunite inline comments that were separated during AST processing.\n                                                                                        \"\"\"\n                                                                                        lines = source.split('\\n')\n                                                                                        result_lines = []\n                                                                                        i = 0\n                                                                                        \n                                                                                        while i < len(lines):\n                                                                                            current_line = lines[i]\n                                                                                            \n                                                                                            # Check if next line is a standalone comment that should be reunited\n                                                                                            if i + 1 < len(lines):\n                                                                                                next_line = lines[i + 1]\n                                                                                                next_line_stripped = next_line.strip()\n                                                                                                \n                                                                                                # Is next line a comment that was originally inline?\n                                                                                                if _should_reunite_comment(current_line, next_line_stripped, token_map):\n                                                                                                    # Reunite them: remove trailing whitespace from current, add comment\n                                                                                                    reunited = current_line.rstrip() + '  ' + next_line_stripped\n                                                                                                    result_lines.append(reunited)\n                                                                                                    i += 2  # Skip the next line since we consumed it\n                                                                                                    continue\n                                                                                            \n                                                                                            result_lines.append(current_line)\n                                                                                            i += 1\n                                                                                        \n                                                                                        return '\\n'.join(result_lines)\n                                                                                    \n                                                                                    def _should_reunite_comment(code_line: str, comment_line: str, token_map: Dict[str, str]) -> bool:\n                                                                                        \"\"\"\n                                                                                        Determine if a comment line should be reunited with the previous code line.\n                                                                                        \"\"\"\n                                                                                        # Must be a comment\n                                                                                        if not comment_line.startswith('#'):\n                                                                                            return False\n                                                                                        \n                                                                                        # Code line must have actual content (not just whitespace or comments)\n                                                                                        code_stripped = code_line.strip()\n                                                                                        if not code_stripped or code_stripped.startswith('#'):\n                                                                                            return False\n                                                                                        \n                                                                                        # Look for this comment in our token map as an inline comment\n                                                                                        for token_data in token_map.values():\n                                                                                            if isinstance(token_data, dict):\n                                                                                                if (token_data.get('type') == 'inline_comment' and \n                                                                                                    token_data.get('content') == comment_line):\n                                                                                                    # Additional validation: check if code part roughly matches\n                                                                                                    stored_code_part = token_data.get('code_part', '').strip()\n                                                                                                    if stored_code_part:\n                                                                                                        # Simple heuristic: check if the current line contains the stored code\n                                                                                                        # (accounting for possible AST reformatting)\n                                                                                                        if _code_parts_match(code_stripped, stored_code_part):\n                                                                                                            return True\n                                                                                                    else:\n                                                                                                        # If no code_part stored, be more permissive\n                                                                                                        return True\n                                                                                        \n                                                                                        return False\n                                                                                    \n                                                                                    def _code_parts_match(current_code: str, stored_code: str) -> bool:\n                                                                                        \"\"\"\n                                                                                        Check if two code parts match, accounting for AST reformatting.\n                                                                                        \"\"\"\n                                                                                        # Simple approach: check if the core content is similar\n                                                                                        # Remove extra whitespace and compare\n                                                                                        current_normalized = ' '.join(current_code.split())\n                                                                                        stored_normalized = ' '.join(stored_code.split())\n                                                                                        \n                                                                                        # Check if stored code is a substring of current (AST might add formatting)\n                                                                                        return stored_normalized in current_normalized or current_normalized in stored_normalized"
                                                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                                                       }
