                                                                                                                             "new_function_def": "\n                        def tokenize_source(source: str) -> Tuple[str, Dict[str, str]]:\n                            \"\"\"\n                            Tokenize source code, preserving exact formatting.\n                            \n                            Returns:\n                            - tokenized_source: Source with tokens inserted\n                            - token_map: Mapping of tokens to original content\n                            \"\"\"\n                            token_map = {}\n                            current_hash = get_file_hash(source)\n                            tokenized = source\n                            token_counter = 0\n                            \n                            # Handle full-line comments and blank lines first\n                            new_lines = []\n                            for line in tokenized.split('\\n'):\n                                stripped = line.strip()\n                                if not stripped or stripped.startswith('#'):\n                                    token = create_token(line, token_counter, current_hash)\n                                    token_map[token] = line\n                                    new_lines.append(token)\n                                    token_counter += 1\n                                else:\n                                    new_lines.append(line)\n                            tokenized = '\\n'.join(new_lines)\n                            \n                            # Handle string literals (both single and multiline)\n                            # Process triple-quoted strings first\n                            triple_quote_patterns = [\n                                (r'\"\"\"(?:[^\"\\\\]|\\\\.)*\"\"\"', '\"\"\"'),\n                                (r\"'''(?:[^'\\\\]|\\\\.)*'''\", \"'''\")\n                            ]\n                            \n                            for pattern, quote in triple_quote_patterns:\n                                offset = 0\n                                for match in re.finditer(pattern, tokenized):\n                                    start, end = match.span()\n                                    start += offset\n                                    end += offset\n                                    content = tokenized[start:end]\n                                    token = create_token(content, token_counter, current_hash)\n                                    token_map[token] = content\n                                    tokenized = tokenized[:start] + token + tokenized[end:]\n                                    offset += len(token) - (end - start)\n                                    token_counter += 1\n                            \n                            # Then single-quoted strings\n                            single_quote_patterns = [\n                                (r'\"(?:[^\"\\\\]|\\\\.)*\"', '\"'),\n                                (r\"'(?:[^'\\\\]|\\\\.)*'\", \"'\")\n                            ]\n                            \n                            for pattern, quote in single_quote_patterns:\n                                offset = 0\n                                for match in re.finditer(pattern, tokenized):\n                                    start, end = match.span()\n                                    start += offset\n                                    end += offset\n                                    content = tokenized[start:end]\n                                    if any(token in content for token in token_map):\n                                        continue  # Skip if already contains a token\n                                    token = create_token(content, token_counter, current_hash)\n                                    token_map[token] = content\n                                    tokenized = tokenized[:start] + token + tokenized[end:]\n                                    offset += len(token) - (end - start)\n                                    token_counter += 1\n                            \n                            # Finally handle inline comments\n                            lines = tokenized.split('\\n')\n                            for i, line in enumerate(lines):\n                                if '#' in line and not any(token in line for token in token_map):\n                                    code, comment = line.split('#', 1)\n                                    comment = '#' + comment\n                                    token = create_token(comment, token_counter, current_hash)\n                                    token_map[token] = comment\n                                    lines[i] = code.rstrip() + token\n                                    token_counter += 1\n                            tokenized = '\\n'.join(lines)\n                            \n                            return tokenized, token_map"
                                                                                                                            }
                                                                                                                           }
