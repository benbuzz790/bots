                    "tool_results": [
                     {
                      "type": "tool_result",
                      "tool_use_id": "toolu_01AYUXDtNFAm5KLnDZMRX4Sy",
                      "content": "\n        1:import ast\n        2:import os\n        3:import textwrap\n        4:TOKEN_START = ';;;'\n        5:TOKEN_END = ';;;'\n        6:from bots.utils.helpers import _process_error, _clean, _py_ast_to_source\n        7:import hashlib\n        8:import re\n        9:from typing import Dict, Tuple\n        10:from typing import Dict, Tuple, Union\n        11:\n        12:def python_edit(target_scope: str, code: str, *, insert_after: str=None) -> str:\n        13:    \"\"\"\n        14:    Edit Python code using pytest-style scope syntax.\n        15:    Default behavior: Replace entire target scope.\n        16:\n        17:    Parameters:\n        18:    ----------\n        19:    target_scope : str\n        20:        Location to edit in pytest-style scope syntax:\n        21:        - \"file.py\" (whole file)\n        22:        - \"file.py::MyClass\" (class)\n        23:        - \"file.py::my_function\" (function)\n        24:        - \"file.py::MyClass::method\" (method)\n        25:        - \"file.py::Outer::Inner::method\" (nested)\n        26:        - \"file.py::utils::helper_func\" (nested function)\n        27:\n        28:    code : str\n        29:        Python code to insert/replace. Will be cleaned/dedented.\n        30:        Import statements will be automatically extracted and handled.\n        31:\n        32:    insert_after : str, optional\n        33:        Where to insert the code. Can be either:\n        34:        - \"__FILE_START__\" (special token for file beginning)\n        35:        - A scope (\"MyClass::method\")\n        36:        - An exact line match (like a context line in git patches)\n        37:        If not specified, replaces the node at target_scope.\n        38:\n        39:    Returns:\n        40:    --------\n        41:    str\n        42:        Description of what was modified or error message\n        43:    \"\"\"\n        44:    try:\n        45:        file_path, *path_elements = target_scope.split('::')\n        46:        if not file_path.endswith('.py'):\n        47:            return _process_error(ValueError(f'File path must end with .py: {file_path}'))\n        48:        for element in path_elements:\n        49:            if not element.isidentifier():\n        50:                return _process_error(ValueError(f'Invalid identifier in path: {element}'))\n        51:        abs_path = _make_file(file_path)\n        52:        cleaned_code = _clean(code)\n        53:        tokenized_code, new_code_tokens = _tokenize_source(cleaned_code)\n        54:        try:\n        55:            new_tree = ast.parse(tokenized_code)\n        56:            import_nodes = []\n        57:            code_nodes = []\n        58:            for node in new_tree.body:\n        59:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        60:                    import_nodes.append(node)\n        61:                else:\n        62:                    code_nodes.append(node)\n        63:        except Exception as e:\n        64:            return _process_error(ValueError(f'Error parsing new code: {str(e)}'))\n        65:        try:\n        66:            with open(abs_path, 'r', encoding='utf-8') as file:\n        67:                content = file.read()\n        68:            tokenized_content, file_tokens = _tokenize_source(content) if content.strip() else ('', {})\n        69:            file_lines = tokenized_content.split('\\n')\n        70:            tree = ast.parse(tokenized_content) if content.strip() else ast.Module(body=[], type_ignores=[])\n        71:        except Exception as e:\n        72:            return _process_error(ValueError(f'Error reading/parsing file {abs_path}: {str(e)}'))\n        73:        existing_imports = []\n        74:        non_imports = []\n        75:        for node in tree.body:\n        76:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        77:                existing_imports.append(node)\n        78:            else:\n        79:                non_imports.append(node)\n        80:        if insert_after == '__FILE_START__':\n        81:            tree.body = import_nodes + code_nodes + existing_imports + non_imports\n        82:            try:\n        83:                updated_content = _py_ast_to_source(tree)\n        84:                all_tokens = {**file_tokens, **new_code_tokens}\n        85:                final_content = _detokenize_source(updated_content, all_tokens)\n        86:                with open(abs_path, 'w', encoding='utf-8') as file:\n        87:                    file.write(final_content)\n        88:                return f\"Code inserted at start of '{abs_path}'.\"\n        89:            except Exception as e:\n        90:                return _process_error(e)\n        91:        if not path_elements:\n        92:            tree.body = existing_imports + import_nodes + non_imports + code_nodes\n        93:            try:\n        94:                updated_content = _py_ast_to_source(tree)\n        95:                all_tokens = {**file_tokens, **new_code_tokens}\n        96:                final_content = _detokenize_source(updated_content, all_tokens)\n        97:                with open(abs_path, 'w', encoding='utf-8') as file:\n        98:                    file.write(final_content)\n        99:                return f\"Code added at file level in '{abs_path}'.\"\n        100:            except Exception as e:\n        101:                return _process_error(e)\n        102:        tree.body = existing_imports + import_nodes + non_imports\n        103:        transformer = ScopeTransformer(path_elements, code_nodes, insert_after, file_lines, file_tokens, new_code_tokens)\n        104:        modified_tree = transformer.visit(tree)\n        105:        if not transformer.success:\n        106:            if insert_after:\n        107:                return _process_error(ValueError(f'Insert point not found: {insert_after}'))\n        108:            else:\n        109:                return _process_error(ValueError(f'Target scope not found: {target_scope}'))\n        110:        try:\n        111:            updated_content = _py_ast_to_source(modified_tree)\n        112:            all_tokens = {**file_tokens, **new_code_tokens}\n        113:            final_content = _detokenize_source(updated_content, all_tokens)\n        114:            with open(abs_path, 'w', encoding='utf-8') as file:\n        115:                file.write(final_content)\n        116:            action = 'inserted after' if insert_after else 'replaced at'\n        117:            scope_str = '::'.join(path_elements) if path_elements else 'file level'\n        118:            return f\"Code {action} {scope_str} in '{abs_path}'.\"\n        119:        except Exception as e:\n        120:            return _process_error(e)\n        121:    except Exception as e:\n        122:        return _process_error(e)\n        123:\n        124:def _make_file(file_path: str) -> str:\n        125:    \"\"\"\n        126:    Creates a file and its parent directories if they don't exist.\n        127:    Converts relative paths to absolute paths.\n        128:\n        129:    Parameters:\n        130:    - file_path (str): The path to the file to be created\n        131:\n        132:    Returns:\n        133:    - str: The absolute path to the file\n        134:\n        135:    Raises:\n        136:    - ValueError: If there's an error creating the file or directories,\n        137:                 or if the file_path is empty\n        138:    \"\"\"\n        139:    if not file_path:\n        140:        raise ValueError('File path cannot be empty')\n        141:    abs_path = os.path.abspath(file_path)\n        142:    dir_path = os.path.dirname(abs_path)\n        143:    if dir_path:\n        144:        try:\n        145:            os.makedirs(dir_path, exist_ok=True)\n        146:        except Exception as e:\n        147:            raise ValueError(f'Error creating directories {dir_path}: {str(e)}')\n        148:    if not os.path.exists(abs_path):\n        149:        try:\n        150:            with open(abs_path, 'w', encoding='utf-8') as f:\n        151:                f.write('')\n        152:        except Exception as e:\n        153:            raise ValueError(f'Error creating file {abs_path}: {str(e)}')\n        154:    return abs_path\n        155:\n        156:class ScopeTransformer(ast.NodeTransformer):\n        157:    \"\"\"AST transformer that handles scope-based Python code modifications.\"\"\"\n        158:\n        159:    def __init__(self, path_elements, new_nodes, insert_after=None, file_lines=None, file_tokens=None, new_tokens=None):\n        160:        self.original_path = path_elements\n        161:        self.new_nodes = new_nodes\n        162:        self.insert_after = insert_after\n        163:        self.file_lines = file_lines\n        164:        self.file_tokens = file_tokens or {}\n        165:        self.new_tokens = new_tokens or {}\n        166:        self.current_path = []\n        167:        self.success = False\n        168:        self.line_match_count = 0\n        169:        self.all_tokens = {**self.file_tokens, **self.new_tokens}\n        170:\n        171:    def visit_ClassDef(self, node):\n        172:        \"\"\"Visit a class definition node.\"\"\"\n        173:        if not self.original_path or node.name != self.original_path[0]:\n        174:            return self.generic_visit(node)\n        175:        self.current_path.append(node.name)\n        176:        remaining_path = self.original_path[1:]\n        177:        if not remaining_path:\n        178:            if self.insert_after:\n        179:                node = self._handle_insertion(node)\n        180:            else:\n        181:                self.success = True\n        182:                if len(self.new_nodes) == 1:\n        183:                    return self.new_nodes[0]\n        184:                else:\n        185:                    node.body = self.new_nodes\n        186:                    return node\n        187:        else:\n        188:            saved_path = self.original_path\n        189:            self.original_path = remaining_path\n        190:            node.body = [self.visit(child) for child in node.body]\n        191:            self.original_path = saved_path\n        192:        self.current_path.pop()\n        193:        return node\n        194:\n        195:    def visit_FunctionDef(self, node):\n        196:        \"\"\"Visit a function definition node.\"\"\"\n        197:        return self._handle_function_node(node)\n        198:\n        199:    def visit_AsyncFunctionDef(self, node):\n        200:        \"\"\"Visit an async function definition node.\"\"\"\n        201:        return self._handle_function_node(node)\n        202:\n        203:    def _handle_function_node(self, node):\n        204:        \"\"\"Common handling for both regular and async functions.\"\"\"\n        205:        if not self.original_path or node.name != self.original_path[0]:\n        206:            return self.generic_visit(node)\n        207:        self.current_path.append(node.name)\n        208:        remaining_path = self.original_path[1:]\n        209:        if not remaining_path:\n        210:            if self.insert_after:\n        211:                node = self._handle_insertion(node)\n        212:            else:\n        213:                self.success = True\n        214:                if len(self.new_nodes) == 1:\n        215:                    return self.new_nodes[0]\n        216:                else:\n        217:                    node.body = self.new_nodes\n        218:                    return node\n        219:        else:\n        220:            saved_path = self.original_path\n        221:            self.original_path = remaining_path\n        222:            node.body = [self.visit(child) for child in node.body]\n        223:            self.original_path = saved_path\n        224:        self.current_path.pop()\n        225:        return node\n        226:\n        227:    def _handle_one_line_function(self, node, line):\n        228:        \"\"\"Special handling for one-line function definitions\"\"\"\n        229:        if ': pass' in line or ':pass' in line:\n        230:            base_indent = len(line) - len(line.lstrip())\n        231:            def_line = line.rstrip()\n        232:            if self.insert_after == 'pass':\n        233:                def_line = def_line.replace(': pass', ':').replace(':pass', ':')\n        234:                body_indent = base_indent + 4\n        235:                body_lines = []\n        236:                body_lines.append(' ' * body_indent + 'pass')\n        237:                for new_node in self.new_nodes:\n        238:                    node_lines = _py_ast_to_source(new_node).split('\\n')\n        239:                    for nl in node_lines:\n        240:                        if nl.strip():\n        241:                            body_lines.append(' ' * body_indent + nl.lstrip())\n        242:                new_source = def_line + '\\n' + '\\n'.join(body_lines)\n        243:                try:\n        244:                    new_node = ast.parse(new_source).body[0]\n        245:                    self.success = True\n        246:                    return new_node\n        247:                except Exception:\n        248:                    normalized = textwrap.dedent(new_source)\n        249:                    try:\n        250:                        new_node = ast.parse(normalized).body[0]\n        251:                        self.success = True\n        252:                        return new_node\n        253:                    except Exception:\n        254:                        pass\n        255:        return node\n        256:\n        257:    def _handle_insertion(self, node):\n        258:        \"\"\"Handle inserting nodes after a specific point.\"\"\"\n        259:        if isinstance(self.insert_after, str) and '::' not in self.insert_after:\n        260:            if not isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        261:                return node\n        262:            if node.lineno == node.end_lineno:\n        263:                return self._handle_one_line_function(node, self.file_lines[node.lineno - 1])\n        264:            func_lines = self.file_lines[node.lineno - 1:node.end_lineno]\n        265:            if not func_lines:\n        266:                return node\n        267:            target = self.insert_after.strip()\n        268:            target_line_idx = None\n        269:            for i, line in enumerate(func_lines):\n        270:                detokenized_line = _detokenize_source(line, self.all_tokens)\n        271:                if detokenized_line.strip() == target:\n        272:                    self.line_match_count += 1\n        273:                    if self.line_match_count == 1:\n        274:                        target_line_idx = i\n        275:            if self.line_match_count == 0:\n        276:                return node\n        277:            elif self.line_match_count > 1:\n        278:                raise ValueError(f'Ambiguous insert_after - found {self.line_match_count} matches for: {self.insert_after}')\n        279:            target_absolute_line = node.lineno + target_line_idx\n        280:            containing_node = self._find_containing_node(node, target_absolute_line)\n        281:            if containing_node and containing_node is not node:\n        282:                self._insert_into_node(containing_node, target_absolute_line)\n        283:            else:\n        284:                insert_index = len(node.body)\n        285:                for idx, child in enumerate(node.body):\n        286:                    if hasattr(child, 'lineno') and child.lineno > target_absolute_line:\n        287:                        insert_index = idx\n        288:                        break\n        289:                if insert_index == len(node.body):\n        290:                    node.body.extend(self.new_nodes)\n        291:                else:\n        292:                    for i, new_node in enumerate(self.new_nodes):\n        293:                        node.body.insert(insert_index + i, new_node)\n        294:            self.success = True\n        295:            return node\n        296:        else:\n        297:            if self.insert_after:\n        298:                target_path = self.insert_after.split('::')\n        299:                current_path = self.current_path\n        300:                if len(target_path) > 1 and len(current_path) == len(target_path) - 1:\n        301:                    if all((c == t for c, t in zip(current_path, target_path[:len(current_path)]))):\n        302:                        target_name = target_path[-1]\n        303:                        insert_index = None\n        304:                        for idx, child in enumerate(node.body):\n        305:                            if hasattr(child, 'name') and child.name == target_name:\n        306:                                insert_index = idx + 1\n        307:                                break\n        308:                        if insert_index is not None:\n        309:                            for i, new_node in enumerate(self.new_nodes):\n        310:                                node.body.insert(insert_index + i, new_node)\n        311:                            self.success = True\n        312:                            return node\n        313:                if len(current_path) == len(target_path) and all((c == t for c, t in zip(current_path, target_path))):\n        314:                    self.success = True\n        315:                    if isinstance(node, ast.ClassDef):\n        316:                        node.body.extend(self.new_nodes)\n        317:                    else:\n        318:                        for new_node in self.new_nodes:\n        319:                            node.body.append(new_node)\n        320:            return node\n        321:\n        322:    def _find_containing_node(self, node, target_line):\n        323:        \"\"\"Find the deepest AST node with a body that contains the target line.\"\"\"\n        324:        if not (hasattr(node, 'lineno') and hasattr(node, 'end_lineno')):\n        325:            return None\n        326:        if not node.lineno <= target_line <= node.end_lineno:\n        327:            return None\n        328:        deepest_with_body = node if hasattr(node, 'body') else None\n        329:        if hasattr(node, 'body'):\n        330:            for child in node.body:\n        331:                deeper_node = self._find_containing_node(child, target_line)\n        332:                if deeper_node:\n        333:                    return deeper_node\n        334:        if hasattr(node, 'orelse'):\n        335:            for child in node.orelse:\n        336:                deeper_node = self._find_containing_node(child, target_line)\n        337:                if deeper_node:\n        338:                    return deeper_node\n        339:        if deepest_with_body:\n        340:            return deepest_with_body\n        341:        return None\n        342:\n        343:    def _insert_into_node(self, node, target_line):\n        344:        \"\"\"Insert new nodes into the given node after the target line.\"\"\"\n        345:        if not hasattr(node, 'body'):\n        346:            return\n        347:        insert_index = len(node.body)\n        348:        for idx, child in enumerate(node.body):\n        349:            if hasattr(child, 'lineno') and child.lineno > target_line:\n        350:                insert_index = idx\n        351:                break\n        352:        for i, new_node in enumerate(self.new_nodes):\n        353:            node.body.insert(insert_index + i, new_node)\n        354:\n        355:def _create_token(content: str, index: int, current_hash: str) -> str:\n        356:    \"\"\"Create a token with our specific pattern\"\"\"\n        357:    token_name = f'__TOKEN__{current_hash}_{index}__'\n        358:    hex_content = content.encode('utf-8').hex()\n        359:    return (token_name, token_name)\n        360:\n        361:def _get_file_hash(content: str) -> str:\n        362:    \"\"\"Create a short hash of file content\"\"\"\n        363:    return hashlib.sha256(content.encode()).hexdigest()[:8]\n        364:\n        365:def _tokenize_source(source: str) -> Tuple[str, Dict[str, str]]:\n        366:    \"\"\"\n        367:    Tokenize source code, preserving exact formatting.\n        368:\n        369:    Returns:\n        370:    - tokenized_source: Source with tokens inserted\n        371:    - token_map: Mapping of tokens to original content\n        372:    \"\"\"\n        373:\n        374:    def contains_token(s: str) -> bool:\n        375:        return '__TOKEN__' in s\n        376:    token_map = {}\n        377:    current_hash = _get_file_hash(source)\n        378:    token_counter = 0\n        379:    tokenized = source\n        380:\n        381:    def find_complete_triple_quote(text, start_pos=0):\n        382:        \"\"\"Find complete triple-quoted strings manually\"\"\"\n        383:        for quote_type in ['\"\"\"', \"'''\"]:\n        384:            open_pos = text.find(quote_type, start_pos)\n        385:            if open_pos == -1:\n        386:                continue\n        387:            close_pos = text.find(quote_type, open_pos + 3)\n        388:            if close_pos == -1:\n        389:                continue\n        390:            complete_string = text[open_pos:close_pos + 3]\n        391:            if not contains_token(complete_string):\n        392:                return (open_pos, close_pos + 3, complete_string)\n        393:        return (None, None, None)\n        394:    processed_positions = set()\n        395:    iteration_count = 0\n        396:    MAX_ITERATIONS = 10\n        397:    while iteration_count < MAX_ITERATIONS:\n        398:        iteration_count += 1\n        399:        old_tokenized = tokenized\n        400:        start_pos, end_pos, string_content = find_complete_triple_quote(tokenized)\n        401:        if start_pos is None:\n        402:            break\n        403:        if start_pos in processed_positions or len(string_content) > 1000:\n        404:            break\n        405:        processed_positions.add(start_pos)\n        406:        token_name, hex_val = _create_token(string_content, token_counter, current_hash)\n        407:        token_map[hex_val] = string_content\n        408:        tokenized = tokenized[:start_pos] + hex_val + tokenized[end_pos:]\n        409:        token_counter += 1\n        410:        if tokenized == old_tokenized:\n        411:            break\n        412:    lines = tokenized.split('\\n')\n        413:    processed_lines = []\n        414:    for line in lines:\n        415:        if not line.strip():\n        416:            processed_lines.append(line)\n        417:            continue\n        418:        indent = len(line) - len(line.lstrip())\n        419:        indentation = ' ' * indent\n        420:        content = line[indent:]\n        421:        if contains_token(content):\n        422:            processed_lines.append(line)\n        423:            continue\n        424:        if content.strip().startswith('#'):\n        425:            token_name, hex_val = _create_token(content, token_counter, current_hash)\n        426:            token_map[hex_val] = content\n        427:            processed_lines.append(indentation + 'pass' + hex_val)\n        428:            token_counter += 1\n        429:            continue\n        430:        processed_line = content\n        431:        if '#' in processed_line:\n        432:            comment_start = processed_line.index('#')\n        433:            code = processed_line[:comment_start].rstrip()\n        434:            comment = processed_line[comment_start:]\n        435:            token_name, hex_val = _create_token(comment, token_counter, current_hash)\n        436:            token_map[hex_val] = comment\n        437:            processed_line = code + hex_val\n        438:            token_counter += 1\n        439:        if not contains_token(processed_line):\n        440:            for quote_char in ['\"', \"'\"]:\n        441:                if quote_char in processed_line:\n        442:                    start = processed_line.find(quote_char)\n        443:                    if start != -1:\n        444:                        end = start + 1\n        445:                        while end < len(processed_line):\n        446:                            if processed_line[end] == quote_char:\n        447:                                string_content = processed_line[start:end + 1]\n        448:                                token_name, hex_val = _create_token(string_content, token_counter, current_hash)\n        449:                                token_map[hex_val] = string_content\n        450:                                processed_line = processed_line[:start] + hex_val + processed_line[end + 1:]\n        451:                                token_counter += 1\n        452:                                break\n        453:                            elif processed_line[end] == '\\\\' and end + 1 < len(processed_line):\n        454:                                end += 2\n        455:                            else:\n        456:                                end += 1\n        457:                        break\n        458:        processed_lines.append(indentation + processed_line)\n        459:    return ('\\n'.join(processed_lines), token_map)\n        460:\n        461:def _detokenize_source(tokenized_source: str, token_map: Dict[str, str]) -> str:\n        462:    \"\"\"\n        463:    Restore original source from tokenized version.\n        464:\n        465:    Handles proper indentation of multiline content.\n        466:    \"\"\"\n        467:    result = tokenized_source\n        468:    for token_value, original in token_map.items():\n        469:        while token_value in result:\n        470:            start = result.find(token_value)\n        471:            if start == -1:\n        472:                break\n        473:            if '\\n' in original:\n        474:                indent = _get_indentation_at_position(result, start)\n        475:                indented = _indent_multiline_content(original, indent)\n        476:                result = result[:start] + indented + result[start + len(token_value):]\n        477:            else:\n        478:                result = result[:start] + original + result[start + len(token_value):]\n        479:    return result\n        480:\n        481:def _get_indentation_at_position(source: str, pos: int) -> str:\n        482:    \"\"\"Get the indentation level at a given position in source\"\"\"\n        483:    line_start = source.rfind('\\n', 0, pos) + 1\n        484:    return source[line_start:pos].replace(source[line_start:pos].lstrip(), '')\n        485:\n        486:def _indent_multiline_content(content: str, indent: str) -> str:\n        487:    \"\"\"Indent multiline content while preserving internal formatting\"\"\"\n        488:    if not content.strip():\n        489:        return content\n        490:    lines = content.split('\\n')\n        491:    if len(lines) == 1:\n        492:        return content\n        493:    if all((line.startswith(' ') for line in lines[1:] if line.strip())):\n        494:        return content\n        495:    result = [lines[0]]\n        496:    for line in lines[1:]:\n        497:        if line.strip():\n        498:            result.append(indent + line)\n        499:        else:\n        500:            result.append(line)\n        501:    return '\\n'.join(result)"
