                                                                                                                                                                                                                                                                                                                 "new_function_def": "\n                                                                                                                                                                                                def detokenize_source(tokenized_source: str, token_map: Dict[str, str]) -> str:\n                                                                                                                                                                                                    \"\"\"\n                                                                                                                                                                                                    Restore original source from tokenized version.\n                                                                                                                                                                                                    \n                                                                                                                                                                                                    Handles proper indentation of multiline content.\n                                                                                                                                                                                                    \"\"\"\n                                                                                                                                                                                                    result = tokenized_source\n                                                                                                                                                                                                    \n                                                                                                                                                                                                    # Replace all tokens with their original content\n                                                                                                                                                                                                    for token_name, original in token_map.items():\n                                                                                                                                                                                                        if '\\n' in original:\n                                                                                                                                                                                                            # Find each instance of the token and handle indentation\n                                                                                                                                                                                                            for match in re.finditer(re.escape(token_name), result):\n                                                                                                                                                                                                                indent = get_indentation_at_position(result, match.start())\n                                                                                                                                                                                                                indented = indent_multiline_content(original, indent)\n                                                                                                                                                                                                                result = result[:match.start()] + indented + result[match.end():]\n                                                                                                                                                                                                        else:\n                                                                                                                                                                                                            # Simple replacement for single-line content\n                                                                                                                                                                                                            result = result.replace(token_name, original)\n                                                                                                                                                                                                    \n                                                                                                                                                                                                    return result"
                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                               }
