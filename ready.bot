   if isinstance(node, (ast.Import, ast.ImportFrom)):\n        438:                add_imports(file_path, _py_ast_to_source(node).strip())\n        439:        found_function = False\n        440:        remaining_nodes = []\n        441:        for node in tree.body:\n        442:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        443:                found_function = True\n        444:                function_source = _py_ast_to_source(node)\n        445:                if class_name:\n        446:                    result = add_function_to_class(file_path, class_name,\n        447:                        function_source)\n        448:                else:\n        449:                    result = _add_single_function_to_file(file_path,\n        450:                        function_source)\n        451:                messages.append(result)\n        452:            elif not isinstance(node, (ast.Import, ast.ImportFrom)):\n        453:                remaining_nodes.append(node)\n        454:        if not found_function:\n        455:            return _process_error(ValueError(\n        456:                'No function definitions found in provided code'))\n        457:        if remaining_nodes:\n        458:            with open(file_path, 'r', encoding='utf-8') as file:\n        459:                content = file.read()\n        460:            existing_tree = ast.parse(content)\n        461:            existing_tree.body.extend(remaining_nodes)\n        462:            updated_content = _py_ast_to_source(existing_tree)\n        463:            with open(file_path, 'w', encoding='utf-8') as file:\n        464:                file.write(updated_content)\n        465:            messages.append(\n        466:                f'Added {len(remaining_nodes)} additional code blocks')\n        467:        return '\\n'.join(messages)\n        468:    except Exception as e:\n        469:        return _process_error(e)\n        470:\n        471:\n        472:def replace_function(file_path: str, new_function_def: str, class_name: str\n        473:    =None) ->str:\n        474:    \"\"\"\n        475:    Replaces one or more function definitions in a file with new function definitions.\n        476:\n        477:    Parameters:\n        478:    - file_path (str): The path to the file to modify\n        479:    - new_function_def (str): One or more function definitions as a string\n        480:    - class_name (str, optional): If provided, only replace functions within this class\n        481:\n        482:    Returns a confirmation message or an error message.\n        483:\n        484:    cost: very low\n        485:    \"\"\"\n        486:    try:\n        487:        tree = ast.parse(_clean(new_function_def))\n        488:        messages = []\n        489:        for node in tree.body:\n        490:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        491:                add_imports(file_path, _py_ast_to_source(node).strip())\n        492:        found_function = False\n        493:        for node in tree.body:\n        494:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        495:                found_function = True\n        496:                function_source = _py_ast_to_source(node)\n        497:                result = _replace_single_function(file_path,\n        498:                    function_source, class_name)\n        499:                messages.append(result)\n        500:        if not found_function:\n        501:            return _process_error(ValueError(\n        502:                'No function definitions found in provided code'))\n        503:        return '\\n'.join(messages)\n        504:    except Exception as e:\n        505:        return _process_error(e)\n        506:\n        507:\n        508:def _make_file(file_path: str) ->str:\n        509:    \"\"\"\n        510:    Creates a file and its parent directories if they don't exist.\n        511:    Converts relative paths to absolute paths.\n        512:\n        513:    Parameters:\n        514:    - file_path (str): The path to the file to be created\n        515:\n        516:    Returns:\n        517:    - str: The absolute path to the file\n        518:\n        519:    Raises:\n        520:    - ValueError: If there's an error creating the file or directories,\n        521:                 or if the file_path is empty\n        522:    \"\"\"\n        523:    if not file_path:\n        524:        raise ValueError('File path cannot be empty')\n        525:    abs_path = os.path.abspath(file_path)\n        526:    dir_path = os.path.dirname(abs_path)\n        527:    if dir_path:\n        528:        try:\n        529:            os.makedirs(dir_path, exist_ok=True)\n        530:        except Exception as e:\n        531:            raise ValueError(f'Error creating directories {dir_path}: {str(e)}'\n        532:                )\n        533:    if not os.path.exists(abs_path):\n        534:        try:\n        535:            with open(abs_path, 'w', encoding='utf-8') as f:\n        536:                f.write('')\n        537:        except Exception as e:\n        538:            raise ValueError(f'Error creating file {abs_path}: {str(e)}')\n        539:    return abs_path\n        540:\n        541:\n        542:def _add_single_function_to_class(file_path: str, class_name: str,\n        543:    new_method_def: str) ->str:\n        544:    \"\"\"Adds a single method to a class.\"\"\"\n        545:    try:\n        546:        abs_path = _make_file(file_path)\n        547:        try:\n        548:            new_tree = ast.parse(_clean(new_method_def))\n        549:            new_method_node = None\n        550:            for node in new_tree.body:\n        551:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        552:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        553:                elif isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        554:                    new_method_node = node\n        555:            if new_method_node is None:\n        556:                return _process_error(ValueError(\n        557:                    'No method definition found in provided code'))\n        558:            with open(abs_path, 'r', encoding='utf-8') as file:\n        559:                content = file.read()\n        560:            if not content.strip():\n        561:                content = f'class {class_name}:\\n    pass\\n'\n        562:            tree = ast.parse(content)\n        563:        except Exception as e:\n        564:            return _process_error(ValueError(\n        565:                f'Error processing code: {str(e)}'))\n        566:        transformer = MethodAdder(class_name, new_method_node)\n        567:        tree = transformer.visit(tree)\n        568:        if not transformer.success:\n        569:            return _process_error(ValueError(\n        570:                f\"Class '{class_name}' not found in the file.\"))\n        571:        try:\n        572:            updated_content = _py_ast_to_source(tree)\n        573:            with open(abs_path, 'w', encoding='utf-8') as file:\n        574:                file.write(updated_content)\n        575:        except Exception as e:\n        576:            return _process_error(e)\n        577:        return (\n        578:            f\"Method '{new_method_node.name}' has been added to class '{class_name}' in '{abs_path}'.\"\n        579:            )\n        580:    except Exception as e:\n        581:        return _process_error(e)\n        582:\n        583:\n        584:def _add_single_function_to_file(file_path: str, new_function_def: str) ->str:\n        585:    \"\"\"Adds a single function and preserves all code blocks, including any code following the function.\"\"\"\n        586:    try:\n        587:        abs_path = _make_file(file_path)\n        588:        try:\n        589:            new_tree = ast.parse(_clean(new_function_def))\n        590:            new_func_node = None\n        591:            found_func = False\n        592:            new_nodes = []\n        593:            for node in new_tree.body:\n        594:                if not found_func and isinstance(node, (ast.FunctionDef,\n        595:                    ast.AsyncFunctionDef)):\n        596:                    new_func_node = node\n        597:                    found_func = True\n        598:                elif found_func:\n        599:                    new_nodes.append(node)\n        600:            if not new_func_node:\n        601:                return _process_error(ValueError(\n        602:                    'No function definition found in provided code'))\n        603:        except Exception as e:\n        604:            return _process_error(ValueError(f'Error in code: {str(e)}'))\n        605:        with open(abs_path, 'r', encoding='utf-8') as file:\n        606:            content = file.read()\n        607:        if not content.strip():\n        608:            try:\n        609:                with open(abs_path, 'w', encoding='utf-8') as file:\n        610:                    file.write(_py_ast_to_source(new_tree))\n        611:                return (\n        612:                    f\"Code with function '{new_func_node.name}' has been added to new file '{abs_path}'.\"\n        613:                    )\n        614:            except Exception as e:\n        615:                return _process_error(e)\n        616:        try:\n        617:            existing_tree = ast.parse(content)\n        618:            combined_body = []\n        619:            imports = []\n        620:            for node in (existing_tree.body + new_tree.body):\n        621:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        622:                    imports.append(node)\n        623:            combined_body.extend(imports)\n        624:            for node in existing_tree.body:\n        625:                if not isinstance(node, (ast.Import, ast.ImportFrom)):\n        626:                    combined_body.append(node)\n        627:            combined_body.append(new_func_node)\n        628:            combined_body.extend(new_nodes)\n        629:            combined_tree = ast.Module(body=combined_body, type_ignores=[])\n        630:            updated_content = _py_ast_to_source(combined_tree)\n        631:            with open(abs_path, 'w', encoding='utf-8') as file:\n        632:                file.write(updated_content)\n        633:        except Exception as e:\n        634:            return _process_error(e)\n        635:        return (\n        636:            f\"Code with function '{new_func_node.name}' has been added to '{abs_path}'.\"\n        637:            )\n        638:    except Exception as e:\n        639:        return _process_error(e)\n        640:\n        641:\n        642:def _replace_single_function(file_path: str, new_function_def: str,\n        643:    class_name: str=None) ->str:\n        644:    \"\"\"Replaces a single function in a file, optionally within a specific class.\n        645:\n        646:    Args:\n        647:        file_path: Path to the file to modify\n        648:        new_function_def: The new function definition\n        649:        class_name: If provided, only replace within this class\n        650:    \"\"\"\n        651:    try:\n        652:        abs_path = _make_file(file_path)\n        653:        try:\n        654:            new_tree = ast.parse(_clean(new_function_def))\n        655:            new_func_node = None\n        656:            for node in new_tree.body:\n        657:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        658:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        659:                elif isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        660:                    new_func_node = node\n        661:            if new_func_node is None:\n        662:                return _process_error(ValueError(\n        663:                    'No function definition found in provided code'))\n        664:            with open(abs_path, 'r', encoding='utf-8') as file:\n        665:                content = file.read()\n        666:            tree = ast.parse(content)\n        667:        except Exception as e:\n        668:            return _process_error(ValueError(\n        669:                f'Error processing code: {str(e)}'))\n        670:\n        671:\n        672:        class ClassScopedFunctionReplacer(ast.NodeTransformer):\n        673:\n        674:            def __init__(self, new_func_node, target_class=None):\n        675:                self.new_func_node = new_func_node\n        676:                self.target_class = target_class\n        677:                self.success = False\n        678:                self.in_target_class = False\n        679:\n        680:            def visit_ClassDef(self, node):\n        681:                if self.target_class is None or node.name == self.target_class:\n        682:                    old_in_target_class = self.in_target_class\n        683:                    self.in_target_class = True\n        684:                    node = self.generic_visit(node)\n        685:                    self.in_target_class = old_in_target_class\n        686:                return node\n        687:\n        688:            def visit_FunctionDef(self, node):\n        689:                if node.name == self.new_func_node.name:\n        690:                    if self.target_class is None or self.in_target_class:\n        691:                        self.success = True\n        692:                        return self.new_func_node\n        693:                return node\n        694:\n        695:            def visit_AsyncFunctionDef(self, node):\n        696:                return self.visit_FunctionDef(node)\n        697:        transformer = ClassScopedFunctionReplacer(new_func_node, class_name)\n        698:        tree = transformer.visit(tree)\n        699:        if not transformer.success:\n        700:            if class_name:\n        701:                return _process_error(ValueError(\n        702:                    f\"Function '{new_func_node.name}' not found in class '{class_name}'\"\n        703:                    ))\n        704:            tree.body.append(new_func_node)\n        705:        try:\n        706:            updated_content = _py_ast_to_source(tree)\n        707:            with open(abs_path, 'w', encoding='utf-8') as file:\n        708:                file.write(updated_content)\n        709:        except Exception as e:\n        710:            return _process_error(e)\n        711:        context = f\"in class '{class_name}'\" if class_name else 'in file'\n        712:        action = 'replaced' if transformer.success else 'added'\n        713:        return (\n        714:            f\"Function '{new_func_node.name}' has been {action} {context} '{abs_path}'.\"\n        715:            )\n        716:    except Exception as e:\n        717:        return _process_error(e)"
