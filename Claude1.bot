#']\n        845:\n        846:        for hash_pos in hash_positions:\n        847:            # Check if this # is inside any existing token\n        848:            is_inside_token = False\n        849:            for token_name in token_map:\n        850:                if token_name in content:\n        851:                    token_start = content.find(token_name)\n        852:                    token_end = token_start + len(token_name)\n        853:                    if token_start <= hash_pos < token_end:\n        854:                        is_inside_token = True\n        855:                        break\n        856:\n        857:            if not is_inside_token:\n        858:                # This is a real comment, process it with the FULL line\n        859:                processed_line, new_counter = _process_inline_comment(\n        860:                    line, token_map, token_counter, current_hash\n        861:                )\n        862:                return processed_line, new_counter\n        863:\n        864:    return line, token_counter\n        865:\n        866:def _process_multiline_strings(source: str, token_map: dict, token_counter: int, current_hash: str) -> str:\n        867:    \"\"\"Process all triple-quoted strings in the source, including f-strings.\"\"\"\n        868:    tokenized = source\n        869:    processed_positions = set()\n        870:\n        871:    # Extended patterns to handle f-strings\n        872:    patterns = [\n        873:        ('\"\"\"', '\"\"\"'),\n        874:        (\"'''\", \"'''\"),\n        875:        ('f\"\"\"', '\"\"\"'),\n        876:        (\"f'''\", \"'''\"),\n        877:        ('F\"\"\"', '\"\"\"'),\n        878:        (\"F'''\", \"'''\"),\n        879:        ('rf\"\"\"', '\"\"\"'),\n        880:        (\"rf'''\", \"'''\"),\n        881:        ('fr\"\"\"', '\"\"\"'),\n        882:        (\"fr'''\", \"'''\"),\n        883:        # Add all case variations\n        884:        ('Rf\"\"\"', '\"\"\"'), (\"Rf'''\", \"'''\"),\n        885:        ('rF\"\"\"', '\"\"\"'), (\"rF'''\", \"'''\"),\n        886:        ('RF\"\"\"', '\"\"\"'), (\"RF'''\", \"'''\"),\n        887:        ('Fr\"\"\"', '\"\"\"'), (\"Fr'''\", \"'''\"),\n        888:        ('fR\"\"\"', '\"\"\"'), (\"fR'''\", \"'''\"),\n        889:        ('FR\"\"\"', '\"\"\"'), (\"FR'''\", \"'''\"),\n        890:    ]\n        891:\n        892:    for start_pattern, end_pattern in patterns:\n        893:        pos = 0\n        894:        while True:\n        895:            start_pos = tokenized.find(start_pattern, pos)\n        896:            if start_pos == -1:\n        897:                break\n        898:\n        899:            # Check if already processed\n        900:            if start_pos in processed_positions:\n        901:                pos = start_pos + 1\n        902:                continue\n        903:\n        904:            # Find the matching end\n        905:            end_pos = tokenized.find(end_pattern, start_pos + len(start_pattern))\n        906:            if end_pos == -1:\n        907:                pos = start_pos + 1\n        908:                continue\n        909:\n        910:            # Extract the complete string\n        911:            end_pos += len(end_pattern)\n        912:            string_content = tokenized[start_pos:end_pos]\n        913:\n        914:            # Skip if it contains tokens or is too large\n        915:            if _contains_token(string_content) or len(string_content) > 1000:\n        916:                pos = start_pos + 1\n        917:                continue\n        918:\n        919:            # Mark as processed\n        920:            processed_positions.add(start_pos)\n        921:\n        922:            # Determine if it's an f-string\n        923:            is_fstring = any(string_content.startswith(p) for p in ['f', 'F', 'rf', 'Rf', 'rF', 'RF', 'fr', 'Fr', 'fR', 'FR'])\n        924:\n        925:            # Create token\n        926:            token_name, token_data = _create_token(\n        927:                string_content, token_counter, current_hash,\n        928:                TokenType.MULTILINE_STRING,\n        929:                {'is_fstring': is_fstring} if is_fstring else None\n        930:            )\n        931:            token_map[token_name] = token_data\n        932:\n        933:            # Replace in source\n        934:            tokenized = tokenized[:start_pos] + token_name + tokenized[end_pos:]\n        935:            pos = start_pos + len(token_name)\n        936:            token_counter += 1\n        937:\n        938:    return tokenized\n        939:\n        940:def _process_all_string_literals(source, token_map, token_counter, current_hash):\n        941:    \"\"\"Process all string literals in the entire source at once, preserving escape sequences.\"\"\"\n        942:\n        943:    if _contains_token(source):\n        944:        # If source already contains tokens, we need to be more careful\n        945:        # Process line by line to avoid conflicts with existing tokens\n        946:        lines = source.split('\\n')\n        947:        processed_lines = []\n        948:\n        949:        for line in lines:\n        950:            processed_line, token_counter = _process_string_literals(line, token_map, token_counter, current_hash)\n        951:            processed_lines.append(processed_line)\n        952:\n        953:        return '\\n'.join(processed_lines), token_counter\n        954:\n        955:    # Step 1: Identify ALL string positions in the entire source\n        956:    string_locations = _find_all_string_locations_in_source(source)\n        957:\n        958:    if not string_locations:\n        959:        return source, token_counter\n        960:\n        961:    # Step 2: Process strings from right to left to avoid position shifts\n        962:    # Sort by start position in descending order\n        963:    string_locations.sort(key=lambda x: x['start'], reverse=True)\n        964:\n        965:    result = source\n        966:\n        967:    # Step 3: Replace each string with its token\n        968:    for string_info in string_locations:\n        969:        start = string_info['start']\n        970:        end = string_info['end']\n        971:        string_content = string_info['content']\n        972:        is_fstring = string_info['is_fstring']\n        973:        is_raw = string_info['is_raw']\n        974:        paren_depth = string_info['paren_depth']\n        975:        quote_char = string_info['quote_char']\n        976:\n        977:        # Create token with proper metadata\n        978:        metadata = {'is_fstring': is_fstring, 'is_raw': is_raw, 'in_parens': paren_depth > 0}\n        979:        if paren_depth > 0:\n        980:            metadata['quote_char'] = quote_char\n        981:\n        982:        token_name, token_data = _create_token(\n        983:            string_content, token_counter, current_hash, TokenType.STRING_LITERAL, metadata\n        984:        )\n        985:        token_map[token_name] = token_data\n        986:\n        987:        # Determine replacement text\n        988:        if paren_depth > 0:\n        989:            replacement = f'{quote_char}{token_name}{quote_char}'\n        990:        else:\n        991:            replacement = token_name\n        992:\n        993:        # Replace in result (working right-to-left so positions stay valid)\n        994:        result = result[:start] + replacement + result[end + 1:]\n        995:        token_counter += 1\n        996:\n        997:    return result, token_counter\n        998:\n        999:\n        1000:def _find_all_string_locations_in_source(source):\n        1001:    \"\"\"Find all string literal locations in the entire source, preserving escape sequences.\"\"\"\n        1002:    locations = []\n        1003:    paren_depth = 0\n        1004:    pos = 0\n        1005:\n        1006:    while pos < len(source):\n        1007:        char = source[pos]\n        1008:\n        1009:        # Track parentheses depth\n        1010:        if char == '(':\n        1011:            paren_depth += 1\n        1012:            pos += 1\n        1013:            continue\n        1014:        elif char == ')':\n        1015:            paren_depth -= 1\n        1016:            pos += 1\n        1017:            continue\n        1018:\n        1019:        # Look for string starts\n        1020:        if char in ['\"', \"'\"]:\n        1021:            string_info = _analyze_string_at_position_in_source(source, pos, paren_depth)\n        1022:            if string_info:\n        1023:                locations.append(string_info)\n        1024:                pos = string_info['end'] + 1  # Skip past this string\n        1025:            else:\n        1026:                pos += 1\n        1027:        else:\n        1028:            pos += 1\n        1029:\n        1030:    return locations\n        1031:\n        1032:\n        1033:def _analyze_string_at_position_in_source(source, pos, paren_depth):\n        1034:    \"\"\"Analyze a potential string starting at the given position in the full source.\"\"\"\n        1035:    char = source[pos]\n        1036:\n        1037:    # Check if this is an f-string\n        1038:    is_fstring, is_raw = _is_fstring_start(source, pos)\n        1039:\n        1040:    if is_fstring:\n        1041:        # Find the actual start of the f-string prefix\n        1042:        string_start = pos\n        1043:        for prefix in ['rf', 'Rf', 'rF', 'RF', 'fr', 'Fr', 'fR', 'FR', 'f', 'F']:\n        1044:            prefix_start = pos - len(prefix)\n        1045:            if (prefix_start >= 0 and\n        1046:                source[prefix_start:pos] == prefix and\n        1047:                (prefix_start == 0 or not source[prefix_start-1].isalnum())):\n        1048:                string_start = prefix_start\n        1049:                break\n        1050:\n        1051:        end_pos = _find_fstring_end(source, pos, char, is_raw)\n        1052:    else:\n        1053:        string_start = pos\n        1054:        end_pos = _find_string_end(source, pos, char)\n        1055:\n        1056:    if end_pos == -1:\n        1057:        # Invalid/unterminated string\n        1058:        return None\n        1059:\n        1060:    # Extract the complete string content\n        1061:    string_content = source[string_start:end_pos + 1]\n        1062:\n        1063:    # Validate the string\n        1064:    if len(string_content) < 2:\n        1065:        return None\n        1066:\n        1067:    return {\n        1068:        'start': string_start,\n        1069:        'end': end_pos,\n        1070:        'content': string_content,\n        1071:        'is_fstring': is_fstring,\n        1072:        'is_raw': is_raw,\n        1073:        'paren_depth': paren_depth,\n        1074:        'quote_char': char\n        1075:    }\n        1076:\n        1077:\n        1078:def _process_string_literals(processed_line, token_map, token_counter, current_hash):\n        1079:    \"\"\"Process all strings in a line at once - fallback for when source already has tokens.\"\"\"\n        1080:\n        1081:    if _contains_token(processed_line):\n        1082:        return processed_line, token_counter\n        1083:\n        1084:    # Step 1: Identify ALL string positions in the line\n        1085:    string_locations = _find_all_string_locations(processed_line)\n        1086:\n        1087:    if not string_locations:\n        1088:        return processed_line, token_counter\n        1089:\n        1090:    # Step 2: Process strings from right to left to avoid position shifts\n        1091:    # Sort by start position in descending order\n        1092:    string_locations.sort(key=lambda x: x['start'], reverse=True)\n        1093:\n        1094:    result = processed_line\n        1095:\n        1096:    # Step 3: Replace each string with its token\n        1097:    for string_info in string_locations:\n        1098:        start = string_info['start']\n        1099:        end = string_info['end']\n        1100:        string_content = string_info['content']\n        1101:        is_fstring = string_info['is_fstring']\n        1102:        is_raw = string_info['is_raw']\n        1103:        paren_depth = string_info['paren_depth']\n        1104:        quote_char = string_info['quote_char']\n        1105:\n        1106:        # Create token with proper metadata\n        1107:        metadata = {'is_fstring': is_fstring, 'is_raw': is_raw, 'in_parens': paren_depth > 0}\n        1108:        if paren_depth > 0:\n        1109:            metadata['quote_char'] = quote_char\n        1110:\n        1111:        token_name, token_data = _create_token(\n        1112:            string_content, token_counter, current_hash, TokenType.STRING_LITERAL, metadata\n        1113:        )\n        1114:        token_map[token_name] = token_data\n        1115:\n        1116:        # Determine replacement text\n        1117:        if paren_depth > 0:\n        1118:            replacement = f'{quote_char}{token_name}{quote_char}'\n        1119:        else:\n        1120:            replacement = token_name\n        1121:\n        1122:        # Replace in result (working right-to-left so positions stay valid)\n        1123:        result = result[:start] + replacement + result[end + 1:]\n        1124:        token_counter += 1\n        1125:\n        1126:    return result, token_counter\n        1127:\n        1128:\n        1129:def _find_all_string_locations(line):\n        1130:    \"\"\"Find all string literal locations in a line without tokenizing.\"\"\"\n        1131:    locations = []\n        1132:    paren_depth = 0\n        1133:    pos = 0\n        1134:\n        1135:    while pos < len(line):\n        1136:        char = line[pos]\n        1137:\n        1138:        # Track parentheses depth\n        1139:        if char == '(':\n        1140:            paren_depth += 1\n        1141:            pos += 1\n        1142:            continue\n        1143:        elif char == ')':\n        1144:            paren_depth -= 1\n        1145:            pos += 1\n        1146:            continue\n        1147:\n        1148:        # Look for string starts\n        1149:        if char in ['\"', \"'\"]:\n        1150:            string_info = _analyze_string_at_position(line, pos, paren_depth)\n        1151:            if string_info:\n        1152:                locations.append(string_info)\n        1153:                pos = string_info['end'] + 1  # Skip past this string\n        1154:            else:\n        1155:                pos += 1\n        1156:        else:\n        1157:            pos += 1\n        1158:\n        1159:    return locations\n        1160:\n        1161:\n        1162:def _analyze_string_at_position(line, pos, paren_depth):\n        1163:    \"\"\"Analyze a potential string starting at the given position.\"\"\"\n        1164:    char = line[pos]\n        1165:\n        1166:    # Check if this is an f-string\n        1167:    is_fstring, is_raw = _is_fstring_start(line, pos)\n        1168:\n        1169:    if is_fstring:\n        1170:        # Find the actual start of the f-string prefix\n        1171:        string_start = pos\n        1172:        for prefix in ['rf', 'Rf', 'rF', 'RF', 'fr', 'Fr', 'fR', 'FR', 'f', 'F']:\n        1173:            prefix_start = pos - len(prefix)\n        1174:            if (prefix_start >= 0 and\n        1175:                line[prefix_start:pos] == prefix and\n        1176:                (prefix_start == 0 or not line[prefix_start-1].isalnum())):\n        1177:                string_start = prefix_start\n        1178:                break\n        1179:\n        1180:        end_pos = _find_fstring_end(line, pos, char, is_raw)\n        1181:    else:\n        1182:        string_start = pos\n        1183:        end_pos = _find_string_end(line, pos, char)\n        1184:\n        1185:    if end_pos == -1:\n        1186:        # Invalid/unterminated string\n        1187:        return None\n        1188:\n        1189:    # Extract the complete string content\n        1190:    string_content = line[string_start:end_pos + 1]\n        1191:\n        1192:    # Validate the string\n        1193:    if len(string_content) < 2:\n        1194:        return None\n        1195:\n        1196:    return {\n        1197:        'start': string_start,\n        1198:        'end': end_pos,\n        1199:        'content': string_content,\n        1200:        'is_fstring': is_fstring,\n        1201:        'is_raw': is_raw,\n        1202:        'paren_depth': paren_depth,\n        1203:        'quote_char': char\n        1204:    }\n        1205:\n        1206:def _process_inline_comment(line: str, token_map: dict, token_counter: int, current_hash: str) -> Tuple[str, int]:\n        1207:    \"\"\"Process inline comments, determining their type based on the preceding code.\"\"\"\n        1208:    # First check if the # is inside a string token\n        1209:    hash_positions = [i for i, c in enumerate(line) if c == '#']\n        1210:\n        1211:    for hash_pos in hash_positions:\n        1212:        # Check if this # is inside any token\n        1213:        is_inside_token = False\n        1214:        for token_name in token_map:\n        1215:            if token_name in line:\n        1216:                token_start = line.find(token_name)\n        1217:                token_end = token_start + len(token_name)\n        1218:                if token_start <= hash_pos < token_end:\n        1219:                    is_inside_token = True\n        1220:                    break\n        1221:\n        1222:        if not is_inside_token:\n        1223:            # This is a real comment\n        1224:            comment_start = hash_pos\n        1225:            code = line[:comment_start]\n        1226:            code_end = len(code.rstrip())\n        1227:            spacing_and_comment = line[code_end:]\n        1228:            code_stripped = code.rstrip()\n        1229:\n        1230:            # Determine comment type and metadata\n        1231:            token_type, extra_metadata = _determine_comment_type(code_stripped)\n        1232:            token_name, token_data = _create_token(\n        1233:                spacing_and_comment, token_counter, current_hash, token_type, extra_metadata\n        1234:            )\n        1235:            token_map[token_name] = token_data\n        1236:\n        1237:            # For compound comments AND import comments, put token on separate line\n        1238:            if token_type == TokenType.COMPOUND_COMMENT:\n        1239:                # Get the base indentation of the current line\n        1240:                base_indent = len(line) - len(line.lstrip())\n        1241:                # Add 4 spaces for the expected function/class body indentation\n        1242:                token_indent = ' ' * (base_indent + 4)\n        1243:                processed_line = f\"{code.rstrip()}\\n{token_indent}{token_name}\"\n        1244:                return processed_line, token_counter + 1\n        1245:            elif token_type == TokenType.IMPORT_COMMENT:\n        1246:                # For import comments, also move to separate line (like compound comments)\n        1247:                # This ensures the import statement remains valid for AST parsing\n        1248:                base_indent = len(line) - len(line.lstrip())\n        1249:                token_indent = ' ' * base_indent  # Same indentation as import\n        1250:                processed_line = f\"{code.rstrip()}\\n{token_indent}{token_name}\"\n        1251:                return processed_line, token_counter + 1\n        1252:            else:\n        1253:                # For regular inline comments, check if we need semicolon\n        1254:                # Don't add semicolon if the code ends with certain characters\n        1255:                code_trimmed = code.rstrip()\n        1256:\n        1257:                # Characters where semicolon is inappropriate\n        1258:                no_semicolon_endings = [',', ':', '(', '[', '{', '\\\\']\n        1259:\n        1260:                if any(code_trimmed.endswith(char) for char in no_semicolon_endings):\n        1261:                    # For commas and other special endings, move comment to next line\n        1262:                    if code_trimmed.endswith(','):\n        1263:                        # Get the base indentation of the current line\n        1264:                        base_indent = len(line) - len(line.lstrip())\n        1265:                        # Use same indentation for the comment\n        1266:                        token_indent = ' ' * base_indent\n        1267:                        processed_line = f\"{code_trimmed}\\n{token_indent}{token_name}\"\n        1268:                    else:\n        1269:                        # For other special characters, preserve spacing but replace comment with token\n        1270:                        spacing_before_comment = line[len(code_trimmed):comment_start]\n        1271:                        processed_line = f\"{code_trimmed}{spacing_before_comment}{token_name}\"\n        1272:                else:\n        1273:                    # Add semicolon for regular inline comments\n        1274:                    processed_line = f\"{code.rstrip()}; {token_name}\"\n        1275:\n        1276:                return processed_line, token_counter + 1\n        1277:\n        1278:    # No comments found\n        1279:    return line, token_counter\n        1280:\n        1281:### DETOKENIZATION ###\n        1282:\n        1283:def _detokenize_source(tokenized_source: str, token_map: Dict[str, Dict]) -> str:\n        1284:    \"\"\"\n        1285:    Restore original source from tokenized version using reverse tokenization order.\n        1286:    This prevents issues with nested tokens and maintains proper reconstruction sequence.\n        1287:    \"\"\"\n        1288:    result = tokenized_source\n        1289:\n        1290:    # Group tokens by type for ordered processing\n        1291:    comment_tokens = []\n        1292:    string_tokens = []\n        1293:    multiline_tokens = []\n        1294:    other_tokens = []\n        1295:\n        1296:    for token_name, token_data in token_map.items():\n        1297:        metadata = token_data['metadata']\n        1298:        token_type = metadata.get('type')\n        1299:\n        1300:        if token_type in [TokenType.STANDALONE_COMMENT.value, TokenType.INLINE_COMMENT.value,\n        1301:                         TokenType.IMPORT_COMMENT.value, TokenType.COMPOUND_COMMENT.value]:\n        1302:            comment_tokens.append((token_name, token_data))\n        1303:        elif token_type == TokenType.STRING_LITERAL.value:\n        1304:            string_tokens.append((token_name, token_data))\n        1305:        elif token_type == TokenType.MULTILINE_STRING.value:\n        1306:            multiline_tokens.append((token_name, token_data))\n        1307:        else:\n        1308:            other_tokens.append((token_name, token_data))\n        1309:\n        1310:    # Sort each group by token name length (longest first) to avoid substring conflicts\n        1311:    comment_tokens.sort(key=lambda x: len(x[0]), reverse=True)\n        1312:    string_tokens.sort(key=lambda x: len(x[0]), reverse=True)\n        1313:    multiline_tokens.sort(key=lambda x: len(x[0]), reverse=True)\n        1314:    other_tokens.sort(key=lambda x: len(x[0]), reverse=True)\n        1315:\n        1316:    # Process in REVERSE order of tokenization:\n        1317:    # 3. Comments (last tokenized, first detokenized)\n        1318:    # 2. String literals\n        1319:    # 1. Multi-line strings (first tokenized, last detokenized)\n        1320:\n        1321:    # Step 1: Process comment tokens first\n        1322:    for token_name, token_data in comment_tokens:\n        1323:        result = _process_single_token(result, token_name, token_data)\n        1324:\n        1325:    # Step 2: Process string literal tokens\n        1326:    for token_name, token_data in string_tokens:\n        1327:        result = _process_single_token(result, token_name, token_data)\n        1328:\n        1329:    # Step 3: Process multiline string tokens last\n        1330:    for token_name, token_data in multiline_tokens:\n        1331:        result = _process_single_token(result, token_name, token_data)\n        1332:\n        1333:    # Step 4: Process any remaining tokens\n        1334:    for token_name, token_data in other_tokens:\n        1335:        result = _process_single_token(result, token_name, token_data)\n        1336:\n        1337:    return result\n        1338:\n        1339:def _process_single_token(result: str, token_name: str, token_data: Dict) -> str:\n        1340:    \"\"\"Process a single token replacement with all its occurrences.\"\"\"\n        1341:    content = token_data['content']\n        1342:    metadata = token_data['metadata']\n        1343:    token_type = metadata.get('type')\n        1344:\n        1345:    # Replace all occurrences of this token\n        1346:    while token_name in result:\n        1347:        # Handle string concatenation patterns first\n        1348:        if token_type == TokenType.STRING_LITERAL.value:\n        1349:            # Check for concatenation patterns - use the stored quote character\n        1350:            if metadata.get('in_parens', False):\n        1351:                quote_char = metadata.get('quote_char', '\"')\n        1352:                pattern = f'{quote_char}{token_name}{quote_char}'\n        1353:                if pattern in result:\n        1354:                    result = result.replace(pattern, content)\n        1355:                    continue\n        1356:\n        1357:            # Fallback: check both quote types if quote_char not stored\n        1358:            quote_patterns = [f'\"{token_name}\"', f\"'{token_name}'\"]\n        1359:            found_pattern = False\n        1360:\n        1361:            for pattern in quote_patterns:\n        1362:                if pattern in result:\n        1363:                    result = result.replace(pattern, content)\n        1364:                    found_pattern = True\n        1365:                    break\n        1366:\n        1367:            if found_pattern:\n        1368:                continue\n        1369:\n        1370:        start = result.find(token_name)\n        1371:        if start == -1:\n        1372:            break\n        1373:\n        1374:        # Use the appropriate handler based on token type\n        1375:        if token_type == TokenType.COMPOUND_COMMENT.value:\n        1376:            result = _handle_compound_comment(result, token_name, content, start)\n        1377:        elif token_type == TokenType.IMPORT_COMMENT.value:\n        1378:            result = _handle_import_comment(result, token_name, content, start, metadata)\n        1379:        elif token_type == TokenType.INLINE_COMMENT.value:\n        1380:            result = _handle_inline_comment(result, token_name, content, start)\n        1381:        elif token_type == TokenType.STANDALONE_COMMENT.value:\n        1382:            result = _handle_standalone_comment(result, token_name, content, start)\n        1383:        elif token_type == TokenType.MULTILINE_STRING.value:\n        1384:            result = _handle_multiline_string(result, token_name, content, start)\n        1385:        elif token_type == TokenType.STRING_LITERAL.value:\n        1386:            result = _handle_string_literal(result, token_name, content, start)\n        1387:        else:\n        1388:            result = _handle_default_token(result, token_name, content, start)\n        1389:\n        1390:    return result\n        1391:\n        1392:def _handle_compound_comment(result: str, token_name: str, content: str, start: int) -> str:\n        1393:    \"\"\"Handle compound statement comments (def, class, if, etc.) with smart reunification\"\"\"\n        1394:    line_start = result.rfind('\\n', 0, start) + 1\n        1395:    line_end = result.find('\\n', start)\n        1396:    if line_end == -1:\n        1397:        line_end = len(result)\n        1398:    line = result[line_start:line_end]\n        1399:    line_stripped = line.strip()\n        1400:\n        1401:    # Check if this token is alone on its line (moved during tokenization)\n        1402:    if line_stripped == token_name:\n        1403:        # Look for the compound statement on the previous line\n        1404:        search_start = line_start - 1\n        1405:        while search_start > 0:\n        1406:            prev_line_start = result.rfind('\\n', 0, search_start) + 1\n        1407:            prev_line = result[prev_line_start:search_start]\n        1408:            if prev_line.strip():\n        1409:                # Found the compound statement - reunite them\n        1410:                if prev_line.strip().endswith(':'):\n        1411:                    reunited = prev_line.rstrip() + content\n        1412:                    return result[:prev_line_start] + reunited + result[line_end:]\n        1413:                break\n        1414:            search_start = prev_line_start - 1\n        1415:\n        1416:    # Fallback: just replace the token\n        1417:    return result[:start] + content + result[start + len(token_name):]\n        1418:\n        1419:def _handle_import_comment(result: str, token_name: str, content: str, start: int, metadata: dict) -> str:\n        1420:    \"\"\"Handle import statement comments with metadata-driven reunification\"\"\"\n        1421:    line_start = result.rfind('\\n', 0, start) + 1\n        1422:    line_end = result.find('\\n', start)\n        1423:    if line_end == -1:\n        1424:        line_end = len(result)\n        1425:    line = result[line_start:line_end]\n        1426:    line_stripped = line.strip()\n        1427:\n        1428:    # Check if this token is alone on its line (moved during tokenization)\n        1429:    if line_stripped == token_name:\n        1430:        # Look for the import statement on the previous line\n        1431:        search_start = line_start - 1\n        1432:        while search_start > 0:\n        1433:            prev_line_start = result.rfind('\\n', 0, search_start) + 1\n        1434:            prev_line = result[prev_line_start:search_start]\n        1435:            import_statement = metadata.get('import_statement', '').strip()\n        1436:\n        1437:            if prev_line.strip() == import_statement:\n        1438:                # Found the import statement - reunite them\n        1439:                reunited = prev_line.rstrip() + content\n        1440:                return result[:prev_line_start] + reunited + result[line_end:]\n        1441:            search_start = prev_line_start - 1\n        1442:\n        1443:    # Fallback: just replace the token\n        1444:    return result[:start] + content + result[start + len(token_name):]\n        1445:\n        1446:def _handle_inline_comment(result: str, token_name: str, content: str, start: int) -> str:\n        1447:    \"\"\"Handle inline comments (non-import, non-compound) with smart reunification\"\"\"\n        1448:    line_start = result.rfind('\\n', 0, start) + 1\n        1449:    line_end = result.find('\\n', start)\n        1450:    if line_end == -1:\n        1451:        line_end = len(result)\n        1452:    line = result[line_start:line_end]\n        1453:\n        1454:    # Check if this is a semicolon-separated inline comment that needs reunification\n        1455:    if '; ' + token_name in line:\n        1456:        # Remove the semicolon and space, then add the comment content\n        1457:        new_line = line.replace('; ' + token_name, content)\n        1458:        return result[:line_start] + new_line + result[line_end:]\n        1459:\n        1460:    # Check if this is a direct replacement (no semicolon case)\n        1461:    # This handles cases where the comment was after comma, colon, etc.\n        1462:    if token_name in line:\n        1463:        # Find the position of the token in the line\n        1464:        token_pos_in_line = line.find(token_name)\n        1465:\n        1466:        # Check what comes before the token\n        1467:        before_token = line[:token_pos_in_line].rstrip()\n        1468:\n        1469:        # Characters that indicate we should do direct replacement (no semicolon was added)\n        1470:        no_semicolon_endings = [',', ':', '(', '[', '{', '\\\\']\n        1471:\n        1472:        if any(before_token.endswith(char) for char in no_semicolon_endings):\n        1473:            # Direct replacement - the comment was processed without semicolon\n        1474:            new_line = line.replace(token_name, content)\n        1475:            return result[:line_start] + new_line + result[line_end:]\n        1476:\n        1477:    # Check if token is on its own line (moved during compound comment processing)\n        1478:    line_stripped = line.strip()\n        1479:    if line_stripped == token_name:\n        1480:        search_start = line_start - 1\n        1481:        while search_start > 0:\n        1482:            prev_line_start = result.rfind('\\n', 0, search_start) + 1\n        1483:            prev_line = result[prev_line_start:search_st