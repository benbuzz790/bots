                                      "tool_use_id": "toolu_01QrA7978XUDY6uCkUpvP9QN",
                                      "content": "\n        1:import ast\n        2:import os\n        3:from bots.utils.helpers import _process_error, _clean, _py_ast_to_source\n        4:\n        5:class NodeTransformerWithAsyncSupport(ast.NodeTransformer):\n        6:    \"\"\"Base class for AST transformers that need to handle both sync and async functions.\"\"\"\n        7:\n        8:    def __init__(self):\n        9:        self.success = False\n        10:\n        11:    def visit_FunctionDef(self, node):\n        12:        return self._handle_function(node)\n        13:\n        14:    def visit_AsyncFunctionDef(self, node):\n        15:        return self._handle_function(node)\n        16:\n        17:    def _handle_function(self, node):\n        18:        \"\"\"Override this method in subclasses to implement specific transformation logic\"\"\"\n        19:        raise NotImplementedError\n        20:\n        21:class FunctionReplacer(NodeTransformerWithAsyncSupport):\n        22:\n        23:    def __init__(self, new_func_node):\n        24:        super().__init__()\n        25:        self.new_func_node = new_func_node\n        26:\n        27:    def _handle_function(self, node):\n        28:        if node.name == self.new_func_node.name:\n        29:            self.success = True\n        30:            return self.new_func_node\n        31:        return node\n        32:\n        33:class MethodAdder(NodeTransformerWithAsyncSupport):\n        34:\n        35:    def __init__(self, class_name, new_method_node):\n        36:        super().__init__()\n        37:        self.class_name = class_name\n        38:        self.new_method_node = new_method_node\n        39:\n        40:    def visit_ClassDef(self, node):\n        41:        if node.name == self.class_name:\n        42:            self.success = True\n        43:            node.body.append(self.new_method_node)\n        44:            return node\n        45:        return node\n        46:\n        47:    def _handle_function(self, node):\n        48:        return node\n        49:\n        50:def add_imports(file_path: str, code: str) -> str:\n        51:    \"\"\"\n        52:    Adds multiple import statements to a Python file.\n        53:    Avoids adding duplicate imports.\n        54:\n        55:    Parameters:\n        56:    - file_path (str): The path to the file where the imports will be added\n        57:    - code (str): Import statements, which can include parenthesized multi-line imports\n        58:\n        59:    Returns a confirmation message or an error message.\n        60:\n        61:    cost: very low\n        62:    \"\"\"\n        63:    try:\n        64:        abs_path = _make_file(file_path)\n        65:        lines = code.strip().split('\\n')\n        66:        import_blocks = []\n        67:        current_block = []\n        68:        in_parentheses = False\n        69:        for line in lines:\n        70:            stripped = line.strip()\n        71:            if not stripped:\n        72:                continue\n        73:            if '(' in stripped and (not stripped.endswith(')')):\n        74:                in_parentheses = True\n        75:                current_block.append(stripped)\n        76:            elif ')' in stripped and in_parentheses:\n        77:                in_parentheses = False\n        78:                current_block.append(stripped)\n        79:                import_blocks.append('\\n'.join(current_block))\n        80:                current_block = []\n        81:            elif in_parentheses:\n        82:                current_block.append(stripped)\n        83:            elif current_block:\n        84:                current_block.append(stripped)\n        85:            else:\n        86:                import_blocks.append(stripped)\n        87:        if current_block:\n        88:            import_blocks.append('\\n'.join(current_block))\n        89:        new_import_nodes = []\n        90:        for stmt in import_blocks:\n        91:            try:\n        92:                node = ast.parse(_clean(stmt)).body[0]\n        93:                if not isinstance(node, (ast.Import, ast.ImportFrom)):\n        94:                    return _process_error(ValueError(f'Invalid import statement: {stmt}'))\n        95:                new_import_nodes.append(node)\n        96:            except Exception as e:\n        97:                return _process_error(ValueError(f'Error parsing import statement \"{stmt}\": {str(e)}'))\n        98:        try:\n        99:            with open(abs_path, 'r', encoding='utf-8') as file:\n        100:                content = file.read()\n        101:        except Exception as e:\n        102:            return _process_error(ValueError(f'Error reading file {abs_path}: {str(e)}'))\n        103:        if not content.strip():\n        104:            with open(abs_path, 'w', encoding='utf-8') as file:\n        105:                file.write('\\n'.join(import_blocks) + '\\n')\n        106:            return f\"{len(import_blocks)} imports have been added to new file '{abs_path}'.\"\n        107:        try:\n        108:            tree = ast.parse(content)\n        109:        except Exception as e:\n        110:            return _process_error(ValueError(f'Error parsing the file {abs_path}: {str(e)}'))\n        111:        added_imports = []\n        112:        existing_imports = []\n        113:\n        114:        def normalize_import(node):\n        115:            \"\"\"Helper to normalize import node to string for comparison\"\"\"\n        116:            return _py_ast_to_source(node).strip().replace(' ', '')\n        117:        for new_node in new_import_nodes:\n        118:            new_stmt_normalized = normalize_import(new_node)\n        119:            is_duplicate = False\n        120:            for existing_node in tree.body:\n        121:                if isinstance(existing_node, (ast.Import, ast.ImportFrom)):\n        122:                    if normalize_import(existing_node) == new_stmt_normalized:\n        123:                        existing_imports.append(_py_ast_to_source(new_node).strip())\n        124:                        is_duplicate = True\n        125:                        break\n        126:            if not is_duplicate:\n        127:                added_imports.append(_py_ast_to_source(new_node).strip())\n        128:        if added_imports:\n        129:            last_import_idx = -1\n        130:            for i, node in enumerate(tree.body):\n        131:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        132:                    last_import_idx = i\n        133:            for node in new_import_nodes:\n        134:                if _py_ast_to_source(node).strip() in added_imports:\n        135:                    tree.body.insert(last_import_idx + 1, node)\n        136:                    last_import_idx += 1\n        137:            try:\n        138:                updated_content = _py_ast_to_source(tree)\n        139:                with open(abs_path, 'w', encoding='utf-8') as file:\n        140:                    file.write(updated_content)\n        141:            except Exception as e:\n        142:                return _process_error(e)\n        143:        result_parts = []\n        144:        if added_imports:\n        145:            result_parts.append(f\"Added {len(added_imports)} new imports to '{abs_path}'\")\n        146:        if existing_imports:\n        147:            result_parts.append(f'Found {len(existing_imports)} existing imports')\n        148:        if not result_parts:\n        149:            raise ValueError('No valid import statements found')\n        150:        return '. '.join(result_parts) + '.'\n        151:    except Exception as e:\n        152:        return _process_error(e)\n        153:\n        154:def remove_import(file_path: str, import_to_remove: str) -> str:\n        155:    \"\"\"\n        156:    Removes an import statement from a Python file.\n        157:\n        158:    Parameters:\n        159:    - file_path (str): The path to the file to modify\n        160:    - import_to_remove (str): The import statement to remove (e.g., \"import os\" or \"from typing import List\")\n        161:        Must match the existing import statement exactly.\n        162:\n        163:    Returns a confirmation message or an error message.\n        164:\n        165:    cost: very low\n        166:    \"\"\"\n        167:    if not os.path.exists(file_path):\n        168:        return _process_error(ValueError(f'File {file_path} does not exist'))\n        169:    try:\n        170:        remove_node = ast.parse(import_to_remove).body[0]\n        171:        if not isinstance(remove_node, (ast.Import, ast.ImportFrom)):\n        172:            return _process_error(ValueError('Provided statement is not a valid import'))\n        173:    except Exception as e:\n        174:        return _process_error(ValueError(f'Error parsing import statement: {str(e)}'))\n        175:    try:\n        176:        with open(file_path, 'r', encoding='utf-8') as file:\n        177:            content = file.read()\n        178:        tree = ast.parse(content)\n        179:    except Exception as e:\n        180:        return _process_error(ValueError(f'Error parsing the file {file_path}: {str(e)}'))\n        181:    original_length = len(tree.body)\n        182:    new_body = []\n        183:    found = False\n        184:    for node in tree.body:\n        185:        if isinstance(node, (ast.Import, ast.ImportFrom)):\n        186:            node_str = _py_ast_to_source(node).strip()\n        187:            if node_str == import_to_remove:\n        188:                found = True\n        189:                continue\n        190:        new_body.append(node)\n        191:    if not found:\n        192:        return f\"Import '{import_to_remove}' not found in '{file_path}'.\"\n        193:    tree.body = new_body\n        194:    try:\n        195:        updated_content = _py_ast_to_source(tree)\n        196:        with open(file_path, 'w', encoding='utf-8') as file:\n        197:            file.write(updated_content)\n        198:    except Exception as e:\n        199:        return _process_error(e)\n        200:    return f\"Import '{import_to_remove}' has been removed from '{file_path}'.\"\n        201:\n        202:def replace_import(file_path: str, old_import: str, new_import: str) -> str:\n        203:    \"\"\"\n        204:    Replaces an existing import statement in a Python file.\n        205:\n        206:    Parameters:\n        207:    - file_path (str): The path to the file to modify\n        208:    - old_import (str): The existing import statement to replace\n        209:    - new_import (str): The new import statement\n        210:\n        211:    Returns a confirmation message or an error message.\n        212:\n        213:    cost: very low\n        214:    \"\"\"\n        215:    if not os.path.exists(file_path):\n        216:        return _process_error(ValueError(f'File {file_path} does not exist'))\n        217:    try:\n        218:        old_node = ast.parse(_clean(old_import)).body[0]\n        219:        new_node = ast.parse(_clean(new_import)).body[0]\n        220:        if not isinstance(old_node, (ast.Import, ast.ImportFrom)) or not isinstance(new_node, (ast.Import, ast.ImportFrom)):\n        221:            return _process_error(ValueError('Both statements must be valid imports'))\n        222:    except Exception as e:\n        223:        return _process_error(ValueError(f'Error parsing import statements: {str(e)}'))\n        224:    try:\n        225:        with open(file_path, 'r', encoding='utf-8') as file:\n        226:            content = file.read()\n        227:        tree = ast.parse(content)\n 