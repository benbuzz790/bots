                                      "content": "\n        1:import traceback\n        2:import os\n        3:import bots.tools.code_tools as code_tools\n        4:import bots.tools.terminal_tools as terminal_tools\n        5:import bots.tools.python_editing_tools as python_editing_tools\n        6:from bots.foundation.anthropic_bots import AnthropicBot\n        7:from bots.foundation.base import Bot\n        8:import bots.flows.functional_prompts as fp\n        9:\n        10:\n        11:def message_bot(bot_path, message):\n        12:    \"\"\"\n        13:    Loads a bot, sends it a message, and allows it to work.\n        14:\n        15:    Use to prepare a bot to do a task and to allow it to work. Returns control when the\n        16:    bot replies with '/DONE'.\n        17:\n        18:    Parameters:\n        19:    - bot_path (str): File path to the saved bot\n        20:    - message (str): The message to send to the bot\n        21:\n        22:    Returns the bot's first response, a list of tool-uses in order, and final response as a string.\n        23:\n        24:    Does NOT save the bot.\n        25:\n        26:    cost: varies\n        27:    \"\"\"\n        28:    try:\n        29:        bot = Bot.load(bot_path)\n        30:        bot.autosave = True\n        31:        first_message = 'MESSAGE:\\n\\n' + message\n        32:        continue_prompt = \"reply '/DONE' to stop when MESSAGE is addressed.\"\n        33:\n        34:        def stop_condition(bot: Bot):\n        35:            tool_name = ''\n        36:            tools = ''\n        37:            if bot.tool_handler.requests:\n        38:                for request in bot.tool_handler.requests:\n        39:                    tool_name, _ = bot.tool_handler.tool_name_and_input(request)\n        40:                tools += '- ' + tool_name + '\\n'\n        41:            response = bot.conversation.content\n        42:            print(bot.name + ': ' + response + '\\n' + tool_name)\n        43:            return '/DONE' in response\n        44:        _, nodes = fp.prompt_while(bot, first_message, continue_prompt,\n        45:            stop_condition)\n        46:        tools = ''\n        47:        for node in nodes:\n        48:            tool_name = ''\n        49:            if node.tool_calls:\n        50:                for call in node.tool_calls:\n        51:                    tool_name, _ = bot.tool_handler.tool_name_and_input(call)\n        52:                    tools += '- ' + tool_name + '\\n'\n        53:        return nodes[0].content + ':\\n' + tools + '\\n---' + nodes[-1].content\n        54:    except Exception as error:\n        55:        return _process_error(error)\n        56:\n        57:\n        58:def initialize_file_bot(file_name: str, system_message: str) ->str:\n        59:    \"\"\"\n        60:    Creates and initializes a new file-editing bot, saving it to disk.\n        61:    Creates any necessary directories from the file_name path if they don't exist.\n        62:\n        63:    Use when you need to create a new bot to handle implementation of a specific file.\n        64:    The bot will be initialized with appropriate file-level tools and context.\n        65:\n        66:    Parameters:\n        67:    - file_name (str): Name of the file this bot will manage (can include directory path)\n        68:\n        69:    Returns success message with bot's file path or an error message string.\n        70:\n        71:    cost: low\n        72:    \"\"\"\n        73:    try:\n        74:        directory = os.path.dirname(file_name)\n        75:        if directory:\n        76:            os.makedirs(directory, exist_ok=True)\n        77:        name, _ = os.path.splitext(file_name)\n        78:        file_bot = AnthropicBot(name=f'{name}')\n        79:        file_bot.set_system_message(system_message)\n        80:        file_bot.add_tools(code_tools)\n        81:        file_bot.add_tools(terminal_tools)\n        82:        file_bot.add_tools(python_editing_tools)\n        83:        path = file_bot.save(file_bot.name)\n        84:        return f'Success: file bot created at {path}'\n        85:    except Exception as error:\n        86:        return _process_error(error)\n        87:\n        88:\n        89:def _process_error(error):\n        90:    error_message = f'Tool Failed: {str(error)}\\n'\n        91:    error_message += (\n        92:        f\"Traceback:\\n{''.join(traceback.format_tb(error.__traceback__))}\")\n        93:    return error_message\n        94:\n        95:\n        96:def generate_project(spec: str) ->str:\n        97:    \"\"\"\n        98:    Executes the standard process for project generation using a hierarchical system of specialized AI assistants.\n        99:\n        100:    Use when you need to create a complete Python project from a specification. The system will:\n        101:    1. Analyze project specifications and create module requirements\n        102:    2. Break down the project into logical modules\n        103:    3. Create and coordinate specialized bots for implementation\n        104:    4. Implement and test the code\n        105:    5. Validate against requirements\n        106:\n        107:    Parameters:\n        108:    - spec (str): Project specification text describing the desired system\n        109:\n        110:    Returns:\n        111:    str: Success message or error message string\n        112:\n        113:    cost: very high\n        114:    \"\"\"\n        115:    import bots.flows.project_tree.project_tree as project_tree\n        116:    return project_tree.generate_project(spec)"
