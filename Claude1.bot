textual code based on the specified context level.\n        433:\n        434:    Use when you need to gather source code context for an LLM to understand\n        435:    the environment of a function or class.\n        436:\n        437:    Parameters:\n        438:        obj (Any): The function or class to get context for\n        439:        context_level (str): Level of context to retrieve:\n        440:            - 'None': Returns empty string\n        441:            - 'low': Returns class/module level context depending on object type\n        442:            - 'medium': Returns entire current file\n        443:            - 'high': Returns current file and interfaces of other files\n        444:            - 'very high': Returns all Python files in directory\n        445:\n        446:    Returns:\n        447:        str: The requested context as a string\n        448:\n        449:    Raises:\n        450:        ValueError: If context_level is not one of the valid options\n        451:    \"\"\"\n        452:    if context_level == 'None':\n        453:        return ''\n        454:\n        455:    try:\n        456:        source_file = inspect.getfile(obj)\n        457:    except (TypeError, OSError):\n        458:        return ''\n        459:\n        460:    source_dir = os.path.dirname(source_file)\n        461:\n        462:    # Check if we're dealing with a function or class\n        463:    is_class = isinstance(obj, type)\n        464:\n        465:    if context_level == 'low':\n        466:        source_code = inspect.getsource(inspect.getmodule(obj))\n        467:        tree = ast.parse(source_code)\n        468:\n        469:        if is_class:\n        470:            # For classes, return module imports and global variables\n        471:            imports_and_globals = []\n        472:            for node in tree.body:\n        473:                if isinstance(node, (ast.Import, ast.ImportFrom, ast.Assign)):\n        474:                    imports_and_globals.append(ast.unparse(node))\n        475:            return '\\n'.join(imports_and_globals)\n        476:        else:\n        477:            # For functions, return the containing class if applicable\n        478:            for node in ast.walk(tree):\n        479:                if isinstance(node, ast.ClassDef):\n        480:                    for sub_node in node.body:\n        481:                        if isinstance(sub_node, ast.FunctionDef) and sub_node.name == obj.__name__:\n        482:                            return ast.unparse(node)\n        483:            return ''\n        484:\n        485:    elif context_level == 'medium':\n        486:        with open(source_file, 'r', encoding='utf-8') as file:\n        487:            return file.read()\n        488:\n        489:    elif context_level == 'high':\n        490:        context = ''\n        491:        with open(source_file, 'r', encoding='utf-8') as file:\n        492:            context += f'Current file ({os.path.basename(source_file)}):\\n{file.read()}\\n\\n'\n        493:        for filename in os.listdir(source_dir):\n        494:            if filename.endswith('.py') and filename != os.path.basename(source_file):\n        495:                file_path = os.path.join(source_dir, filename)\n        496:                context += f'Interface of {filename}:\\n{_get_py_interface(file_path)}\\n\\n'\n        497:        return context\n        498:\n        499:    elif context_level == 'very high':\n        500:        context = ''\n        501:        for filename in os.listdir(source_dir):\n        502:            if filename.endswith('.py'):\n        503:                file_path = os.path.join(source_dir, filename)\n        504:                with open(file_path, 'r', encoding='utf-8') as file:\n        505:                    context += f'File: {filename}\\n{file.read()}\\n\\n'\n        506:        return context\n        507:\n        508:    else:\n        509:        raise ValueError(f'Invalid context level: {context_level}')\n        510:\n        511:def _get_py_interface(file_path: str) -> str:\n        512:    \"\"\"Extracts the public interface (classes and functions) from a Python file.\n        513:\n        514:    Use when you need to get a high-level overview of a Python module's structure\n        515:    without including implementation details.\n        516:\n        517:    Parameters:\n        518:        file_path (str): Path to the Python file to analyze\n        519:\n        520:    Returns:\n        521:        str: A string containing the module's interface, including class and function\n        522:            signatures with their docstrings\n        523:    \"\"\"\n        524:\n        525:    def get_docstring(node: ast.AST) -> str:\n        526:        \"\"\"Extract docstring from an AST node.\n        527:\n        528:        Parameters:\n        529:            node (ast.AST): The AST node to extract docstring from\n        530:\n        531:        Returns:\n        532:            str: The node's docstring or empty string if none exists\n        533:        \"\"\"\n        534:        return ast.get_docstring(node) or ''\n        535:\n        536:    def format_function(node: ast.FunctionDef) -> str:\n        537:        \"\"\"Format a function definition with its signature and docstring.\n        538:\n        539:        Parameters:\n        540:            node (ast.FunctionDef): The function definition node to format\n        541:\n        542:        Returns:\n        543:            str: Formatted string containing the function signature and docstring\n        544:        \"\"\"\n        545:        return f'def {node.name}{ast.unparse(node.args)}:\\n    \"\"\"{get_docstring(node)}\"\"\"\\n'\n        546:\n        547:    def format_class(node: ast.ClassDef) -> str:\n        548:        \"\"\"Format a class definition with its signature, docstring, and method interfaces.\n        549:\n        550:        Parameters:\n        551:            node (ast.ClassDef): The class definition node to format\n        552:\n        553:        Returns:\n        554:            str: Formatted string containing the class definition, including base classes,\n        555:                docstring, and method signatures\n        556:        \"\"\"\n        557:        class_str = f'class {node.name}'\n        558:        if node.bases:\n        559:            class_str += f\"({', '.join((ast.unparse(base) for base in node.bases))})\"\n        560:        class_str += f':\\n    \"\"\"{get_docstring(node)}\"\"\"\\n'\n        561:        for item in node.body:\n        562:            if isinstance(item, ast.FunctionDef):\n        563:                class_str += f'    {format_function(item)}\\n'\n        564:        return class_str\n        565:    with open(file_path, 'r', encoding='utf-8') as file:\n        566:        tree = ast.parse(file.read())\n        567:    interface = ''\n        568:    for node in tree.body:\n        569:        if isinstance(node, ast.ClassDef):\n        570:            interface += format_class(node) + '\\n'\n        571:        elif isinstance(node, ast.FunctionDef):\n        572:            interface += format_function(node) + '\\n'\n        573:    return interface.strip()\n        574:\n        575:def lazy(prompt: Optional[str]=None, bot: Optional[Bot]=None, context: Optional[str]=None) -> Callable:\n        576:    \"\"\"Smart decorator that implements a function or class using an LLM at runtime.\n        577:\n        578:    This is a convenience decorator that automatically chooses between @lazy and\n        579:    @lazy_class based on the type of the decorated object. It provides a unified\n        580:    interface for lazy implementation of both functions and classes.\n        581:\n        582:    Parameters:\n        583:        prompt (Optional[str]): Additional instructions for the LLM about how to implement\n        584:            the function or class. Defaults to empty string.\n        585:        bot (Optional[Bot]): The bot instance to use for implementation. Defaults to\n        586:            a new AnthropicBot instance.\n        587:        context (Optional[str]): Level of context to provide to the LLM. Options are:\n        588:            - 'None': No additional context\n        589:            - 'low': Type-appropriate lowest level context\n        590:            - 'medium': The entire current file\n        591:            - 'high': Current file and interfaces of other files in directory\n        592:            - 'very high': All Python files in directory\n        593:            Defaults to 'None'.\n        594:\n        595:    Returns:\n        596:        Callable: A decorator that applies either lazy or lazy_class based on the decorated object type\n        597:\n        598:    Example:\n        599:        @lazy(\"Implement a sorting algorithm\")\n        600:        def quicksort(items: list) -> list:\n        601:            pass  # Will be implemented by LLM\n        602:\n        603:        @lazy(\"Implement a key-value store with TTL\")\n        604:        class Cache:\n        605:            pass  # Will be implemented by LLM\n        606:    \"\"\"\n        607:    def decorator(obj: Any) -> Any:\n        608:        \"\"\"Inner decorator that dispatches to either lazy or lazy_class.\n        609:\n        610:        Parameters:\n        611:            obj (Any): The function or class to be lazily implemented\n        612:\n        613:        Returns:\n        614:            Any: The decorated function or class\n        615:        \"\"\"\n        616:        if isinstance(obj, type):\n        617:            # If obj is a class, use lazy_class\n        618:            logger.debug(f\"lazy_impl: Detected class {obj.__name__}, using lazy_class\")\n        619:            return lazy_class(prompt, bot, context)(obj)\n        620:        else:\n        621:            # Otherwise assume it's a function and use lazy\n        622:            logger.debug(f\"lazy_impl: Detected function {obj.__name__}, using lazy\")\n        623:            return lazy_fn(prompt, bot, context)(obj)\n        624:\n        625:    return decorator\n        626:\n        627:def debug_on_error(func: Callable) -> Callable:\n        628:    \"\"\"Decorator that launches post-mortem debugging on exception.\n        629:\n        630:    Use when you need to automatically start a debugging session when a function\n        631:    raises an unhandled exception. This is particularly useful during development\n        632:    and troubleshooting.\n        633:\n        634:    Parameters:\n        635:        func (Callable): The function to wrap with debugging capabilities\n        636:\n        637:    Returns:\n        638:        Callable: A wrapped version of the function that will launch pdb on error\n        639:\n        640:    Example:\n        641:        @debug_on_error\n        642:        def might_fail():\n        643:            # If this raises an exception, you'll get a pdb prompt\n        644:            risky_operation()\n        645:    \"\"\"\n        646:\n        647:    @wraps(func)\n        648:    def wrapper(*args: Any, **kwargs: Any) -> Any:\n        649:        try:\n        650:            return func(*args, **kwargs)\n        651:        except Exception:\n        652:            type, value, tb = sys.exc_info()\n        653:            traceback.print_exception(type, value, tb)\n        654:            print('\\n--- Entering post-mortem debugging ---')\n        655:            import pdb\n        656:            pdb.post_mortem(tb)\n        657:    return wrapper\n        658:\n        659:def log_errors(func: Callable) -> Callable:\n        660:    \"\"\"Decorator that logs errors to a file when a function raises an exception or returns an error message.\n        661:\n        662:    This decorator captures both exceptions and return values that contain \"Error\" in the first few words,\n        663:    logging them to 'error_log.txt' in the same directory as this decorators file.\n        664:\n        665:    Parameters:\n        666:        func (Callable): The function to wrap with error logging capabilities\n        667:\n        668:    Returns:\n        669:        Callable: A wrapped version of the function that logs errors\n        670:\n        671:    Example:\n        672:        @log_errors\n        673:        def risky_function():\n        674:            # Any exceptions or \"Error\" messages will be logged\n        675:            return \"Error: Something went wrong\"\n        676:    \"\"\"\n        677:\n        678:    @wraps(func)\n        679:    def wrapper(*args: Any, **kwargs: Any) -> Any:\n        680:        try:\n        681:            result = func(*args, **kwargs)\n        682:\n        683:            # Check if result is a string that starts with \"Error\" (case insensitive)\n        684:            if isinstance(result, str):\n        685:                # Check first few words for \"Error\"\n        686:                first_words = ' '.join(result.split()[:5]).lower()\n        687:                if 'error' in first_words:\n        688:                    _log_error_to_file(func.__name__, f\"Function returned error message: {result}\", args, kwargs)\n        689:\n        690:            return result\n        691:\n        692:        except Exception as e:\n        693:            # Log the exception\n        694:            error_msg = f\"Exception in {func.__name__}: {str(e)}\\nTraceback:\\n{traceback.format_exc()}\"\n        695:            _log_error_to_file(func.__name__, error_msg, args, kwargs)\n        696:            # Re-raise the exception\n        697:            raise\n        698:\n        699:    return wrapper\n        700:\n        701:\n        702:def _log_error_to_file(function_name: str, error_message: str, args: tuple = None, kwargs: dict = None) -> None:\n        703:    \"\"\"Helper function to log errors to the error log file.\n        704:\n        705:    Parameters:\n        706:        function_name (str): Name of the function that had the error\n        707:        error_message (str): The error message to log\n        708:        args (tuple, optional): Positional arguments passed to the function\n        709:        kwargs (dict, optional): Keyword arguments passed to the function\n        710:    \"\"\"\n        711:    # Get the directory where this decorators file is located\n        712:    decorators_dir = os.path.dirname(os.path.abspath(__file__))\n        713:    log_file_path = os.path.join(decorators_dir, 'error_log.txt')\n        714:\n        715:    # Create timestamp\n        716:    timestamp = datetime.datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n        717:\n        718:    args_parts = []\n        719:    if args:\n        720:        args_parts.append(f\"args={args}\")\n        721:    if kwargs:\n        722:        args_parts.append(f\"kwargs={kwargs}\")\n        723:    if args_parts:\n        724:        args_str = f\"\\nArguments: {', '.join(args_parts)}\"\n        725:\n        726:    # Format the log entry\n        727:    log_entry = f\"[{timestamp}] Function: {function_name}{args_str}\\n{error_message}\\n{'-' * 80}\\n\\n\"\n        728:\n        729:    # Append to the log file\n        730:    try:\n        731:        with open(log_file_path, 'a', encoding='utf-8') as log_file:\n        732:            log_file.write(log_entry)\n        733:    except Exception as e:\n        734:        # If we can't write to the log file, at least print to stderr\n        735:        print(f\"Failed to write to error log: {e}\", file=sys.stderr)\n        736:        print(f\"Original error: {log_entry}\", file=sys.stderr)"
                 }
