                                                                                        "id": "toolu_013KfDpdTBBuxegSxcACivfL",
                                                                                        "name": "execute_powershell",
                                                                                        "input": {
                                                                                         "command": "\n            python -c \"\n            import re\n            \n            # Read the original file\n            with open('bots/tools/python_editing_tools.py', 'r', encoding='utf-8') as f:\n                content = f.read()\n            \n            # Add the import for handle_errors\n            content = content.replace(\n                'from bots.utils.helpers import _process_error, _clean, _py_ast_to_source',\n                'from bots.utils.helpers import _process_error, _clean, _py_ast_to_source\\nfrom bots.dev.decorators import handle_errors'\n            )\n            \n            # List of functions to decorate\n            functions_to_decorate = [\n                'add_imports', 'remove_import', 'replace_import', 'add_class', \n                'replace_class', 'add_function_to_class', 'add_function_to_file', \n                'replace_function', '_add_single_function_to_class', \n                '_add_single_function_to_file', '_replace_single_function'\n            ]\n            \n            # Add decorator to each function and remove try-except blocks\n            for func_name in functions_to_decorate:\n                # Pattern to match function definition\n                pattern = rf'^def {func_name}\\('\n                \n                # Find the function and add decorator\n                lines = content.split('\\n')\n                new_lines = []\n                i = 0\n                while i < len(lines):\n                    line = lines[i]\n                    if re.match(pattern, line):\n                        # Add decorator before function\n                        new_lines.append('@handle_errors')\n                        new_lines.append(line)\n                        i += 1\n                        \n                        # Process function body to remove try-except\n                        indent_level = len(line) - len(line.lstrip())\n                        \n                        while i < len(lines):\n                            current_line = lines[i]\n                            \n                            # If we hit another function or class, break\n                            if (current_line.strip() and \n                                not current_line.startswith(' ') and \n                                (current_line.startswith('def ') or current_line.startswith('class '))):\n                                break\n                                \n                            # Skip try: lines at function level\n                            if current_line.strip() == 'try:' and len(current_line) - len(current_line.lstrip()) == indent_level + 4:\n                                i += 1\n                                continue\n                                \n                            # Skip except Exception as e: and return _process_error(e) blocks\n                            if ('except Exception as e:' in current_line and \n                                len(current_line) - len(current_line.lstrip()) == indent_level + 4):\n                                # Skip the except block\n                                i += 1\n                                while i < len(lines) and lines[i].strip():\n                                    if 'return _process_error(e)' in lines[i]:\n                                        i += 1\n                                        break\n                                    i += 1\n                                continue\n                            \n                            new_lines.append(current_line)\n                            i += 1\n                    else:\n                        new_lines.append(line)\n                        i += 1\n                \n                content = '\\n'.join(new_lines)\n            \n            # Write the updated content\n            with open('bots/tools/python_editing_tools_updated.py', 'w', encoding='utf-8') as f:\n                f.write(content)\n            \n            print('File updated successfully')\n            \""
