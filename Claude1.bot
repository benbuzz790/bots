05:            new_class_node = None\n        306:            for node in new_tree.body:\n        307:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        308:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        309:                elif isinstance(node, ast.ClassDef):\n        310:                    new_class_node = node\n        311:                    if old_class_name is None:\n        312:                        old_class_name = node.name\n        313:            if new_class_node is None:\n        314:                return _process_error(ValueError('No class definition found in provided code'))\n        315:            with open(abs_path, 'r', encoding='utf-8') as file:\n        316:                content = file.read()\n        317:            tree = ast.parse(content)\n        318:        except Exception as e:\n        319:            return _process_error(ValueError(f'Error processing code: {str(e)}'))\n        320:\n        321:        class ClassReplacer(NodeTransformerWithAsyncSupport):\n        322:\n        323:            def visit_ClassDef(self, node):\n        324:                if node.name == old_class_name:\n        325:                    self.success = True\n        326:                    return new_class_node\n        327:                return node\n        328:\n        329:            def _handle_function(self, node):\n        330:                return node\n        331:        transformer = ClassReplacer()\n        332:        tree = transformer.visit(tree)\n        333:        if not transformer.success:\n        334:            tree.body.append(new_class_node)\n        335:        try:\n        336:            updated_content = _py_ast_to_source(tree)\n        337:            with open(abs_path, 'w', encoding='utf-8') as file:\n        338:                file.write(updated_content)\n        339:        except Exception as e:\n        340:            return _process_error(e)\n        341:        action = 'replaced in' if transformer.success else 'added to'\n        342:        return f\"Class '{new_class_node.name}' has been {action} '{abs_path}'.\"\n        343:    except Exception as e:\n        344:        return _process_error(e)\n        345:\n        346:def add_function_to_class(file_path: str, class_name: str, new_method_def: str) -> str:\n        347:    \"\"\"\n        348:    Adds one or more methods to an existing class in a Python file.\n        349:\n        350:    Parameters:\n        351:    - file_path (str): The path to the file to modify\n        352:    - class_name (str): The name of the class to modify\n        353:    - new_method_def (str): One or more method definitions as a string\n        354:\n        355:    Returns a confirmation message or an error message.\n        356:\n        357:    cost: very low\n        358:    \"\"\"\n        359:    try:\n        360:        tree = ast.parse(_clean(new_method_def))\n        361:        messages = []\n        362:        for node in tree.body:\n        363:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        364:                add_imports(file_path, _py_ast_to_source(node).strip())\n        365:        found_method = False\n        366:        for node in tree.body:\n        367:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        368:                found_method = True\n        369:                method_source = _py_ast_to_source(node)\n        370:                result = _add_single_function_to_class(file_path, class_name, method_source)\n        371:                messages.append(result)\n        372:        if not found_method:\n        373:            return _process_error(ValueError('No method definitions found in provided code'))\n        374:        return '\\n'.join(messages)\n        375:    except Exception as e:\n        376:        return _process_error(e)\n        377:\n        378:def add_function_to_file(file_path: str, new_function_def: str, class_name: str=None) -> str:\n        379:    \"\"\"\n        380:    Adds one or more function definitions to an existing Python file.\n        381:\n        382:    When adding complex code blocks:\n        383:    - Imports are moved to the top of the file\n        384:    - Functions are added in order of appearance\n        385:    - Non-function code (assignments, if blocks, etc.) is preserved but may be reordered\n        386:    - Comments are not preserved (limitation of AST)\n        387:\n        388:    Parameters:\n        389:    - file_path (str): The path to the file to modify\n        390:    - new_function_def (str): One or more function definitions as a string\n        391:    - class_name (str, optional): If provided, add functions to this class\n        392:\n        393:    Returns a confirmation message or an error message.\n        394:\n        395:    cost: very low\n        396:    \"\"\"\n        397:    try:\n        398:        tree = ast.parse(_clean(new_function_def))\n        399:        messages = []\n        400:        for node in tree.body:\n        401:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        402:                add_imports(file_path, _py_ast_to_source(node).strip())\n        403:        found_function = False\n        404:        remaining_nodes = []\n        405:        for node in tree.body:\n        406:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        407:                found_function = True\n        408:                function_source = _py_ast_to_source(node)\n        409:                if class_name:\n        410:                    result = add_function_to_class(file_path, class_name, function_source)\n        411:                else:\n        412:                    result = _add_single_function_to_file(file_path, function_source)\n        413:                messages.append(result)\n        414:            elif not isinstance(node, (ast.Import, ast.ImportFrom)):\n        415:                remaining_nodes.append(node)\n        416:        if not found_function:\n        417:            return _process_error(ValueError('No function definitions found in provided code'))\n        418:        if remaining_nodes:\n        419:            with open(file_path, 'r', encoding='utf-8') as file:\n        420:                content = file.read()\n        421:            existing_tree = ast.parse(content)\n        422:            existing_tree.body.extend(remaining_nodes)\n        423:            updated_content = _py_ast_to_source(existing_tree)\n        424:            with open(file_path, 'w', encoding='utf-8') as file:\n        425:                file.write(updated_content)\n        426:            messages.append(f'Added {len(remaining_nodes)} additional code blocks')\n        427:        return '\\n'.join(messages)\n        428:    except Exception as e:\n        429:        return _process_error(e)\n        430:\n        431:def replace_function(file_path: str, new_function_def: str, class_name: str=None) -> str:\n        432:    \"\"\"\n        433:    Replaces one or more function definitions in a file with new function definitions.\n        434:\n        435:    Parameters:\n        436:    - file_path (str): The path to the file to modify\n        437:    - new_function_def (str): One or more function definitions as a string\n        438:    - class_name (str, optional): If provided, only replace functions within this class\n        439:\n        440:    Returns a confirmation message or an error message.\n        441:\n        442:    cost: very low\n        443:    \"\"\"\n        444:    try:\n        445:        tree = ast.parse(_clean(new_function_def))\n        446:        messages = []\n        447:        for node in tree.body:\n        448:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        449:                add_imports(file_path, _py_ast_to_source(node).strip())\n        450:        found_function = False\n        451:        for node in tree.body:\n        452:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        453:                found_function = True\n        454:                function_source = _py_ast_to_source(node)\n        455:                result = _replace_single_function(file_path, function_source, class_name)\n        456:                messages.append(result)\n        457:        if not found_function:\n        458:            return _process_error(ValueError('No function definitions found in provided code'))\n        459:        return '\\n'.join(messages)\n        460:    except Exception as e:\n        461:        return _process_error(e)\n        462:\n        463:def _make_file(file_path: str) -> str:\n        464:    \"\"\"\n        465:    Creates a file and its parent directories if they don't exist.\n        466:    Converts relative paths to absolute paths.\n        467:\n        468:    Parameters:\n        469:    - file_path (str): The path to the file to be created\n        470:\n        471:    Returns:\n        472:    - str: The absolute path to the file\n        473:\n        474:    Raises:\n        475:    - ValueError: If there's an error creating the file or directories,\n        476:                 or if the file_path is empty\n        477:    \"\"\"\n        478:    if not file_path:\n        479:        raise ValueError('File path cannot be empty')\n        480:    abs_path = os.path.abspath(file_path)\n        481:    dir_path = os.path.dirname(abs_path)\n        482:    if dir_path:\n        483:        try:\n        484:            os.makedirs(dir_path, exist_ok=True)\n        485:        except Exception as e:\n        486:            raise ValueError(f'Error creating directories {dir_path}: {str(e)}')\n        487:    if not os.path.exists(abs_path):\n        488:        try:\n        489:            with open(abs_path, 'w', encoding='utf-8') as f:\n        490:                f.write('')\n        491:        except Exception as e:\n        492:            raise ValueError(f'Error creating file {abs_path}: {str(e)}')\n        493:    return abs_path\n        494:\n        495:def _add_single_function_to_class(file_path: str, class_name: str, new_method_def: str) -> str:\n        496:    \"\"\"Adds a single method to a class.\"\"\"\n        497:    try:\n        498:        abs_path = _make_file(file_path)\n        499:        try:\n        500:            new_tree = ast.parse(_clean(new_method_def))\n        501:            new_method_node = None\n        502:            for node in new_tree.body:\n        503:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        504:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        505:                elif isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        506:                    new_method_node = node\n        507:            if new_method_node is None:\n        508:                return _process_error(ValueError('No method definition found in provided code'))\n        509:            with open(abs_path, 'r', encoding='utf-8') as file:\n        510:                content = file.read()\n        511:            if not content.strip():\n        512:                content = f'class {class_name}:\\n    pass\\n'\n        513:            tree = ast.parse(content)\n        514:        except Exception as e:\n        515:            return _process_error(ValueError(f'Error processing code: {str(e)}'))\n        516:        transformer = MethodAdder(class_name, new_method_node)\n        517:        tree = transformer.visit(tree)\n        518:        if not transformer.success:\n        519:            return _process_error(ValueError(f\"Class '{class_name}' not found in the file.\"))\n        520:        try:\n        521:            updated_content = _py_ast_to_source(tree)\n  