                                      "content": "\n        1:import ast\n        2:import os\n        3:import textwrap\n        4:from bots.utils.helpers import _process_error, _clean, _py_ast_to_source\n        5:import hashlib\n        6:import re\n        7:from typing import Dict, Tuple, List\n        8:from enum import Enum\n        9:\n        10:\n        11:### CLASSES ##\n        12:\n        13:class TokenType(Enum):\n        14:    \"\"\"Types of tokens for metadata-driven processing\"\"\"\n        15:    STANDALONE_COMMENT = 'standalone_comment'\n        16:    INLINE_COMMENT = 'inline_comment'\n        17:    IMPORT_COMMENT = 'import_comment'\n        18:    COMPOUND_COMMENT = 'compound_comment'\n        19:    STRING_LITERAL = 'string_literal'\n        20:    FSTRING_LITERAL = 'fstring_literal'\n        21:    MULTILINE_STRING = 'multiline_string'\n        22:\n        23:class ScopeTransformer(ast.NodeTransformer):\n        24:    \"\"\"AST transformer that handles scope-based Python code modifications.\"\"\"\n        25:\n        26:    def __init__(self, path_elements, new_nodes, insert_after=None, file_lines=None, file_tokens=None, new_tokens=None):\n        27:        self.original_path = path_elements\n        28:        self.new_nodes = new_nodes\n        29:        self.insert_after = insert_after\n        30:        self.file_lines = file_lines\n        31:        self.file_tokens = file_tokens or {}\n        32:        self.new_tokens = new_tokens or {}\n        33:        self.current_path = []\n        34:        self.success = False\n        35:        self.line_match_count = 0\n        36:        self.all_tokens = {**self.file_tokens, **self.new_tokens}\n        37:\n        38:    def visit_ClassDef(self, node):\n        39:        \"\"\"Visit a class definition node.\"\"\"\n        40:        if not self.original_path or node.name != self.original_path[0]:\n        41:            return self.generic_visit(node)\n        42:        self.current_path.append(node.name)\n        43:        remaining_path = self.original_path[1:]\n        44:        if not remaining_path:\n        45:            if self.insert_after:\n        46:                node = self._handle_insertion(node)\n        47:            else:\n        48:                self.success = True\n        49:                if len(self.new_nodes) == 1:\n        50:                    return self.new_nodes[0]\n        51:                else:\n        52:                    node.body = self.new_nodes\n        53:                    return node\n        54:        else:\n        55:            saved_path = self.original_path\n        56:            self.original_path = remaining_path\n        57:            node.body = [self.visit(child) for child in node.body]\n        58:            self.original_path = saved_path\n        59:        self.current_path.pop()\n        60:        return node\n        61:\n        62:    def visit_FunctionDef(self, node):\n        63:        \"\"\"Visit a function definition node.\"\"\"\n        64:        return self._handle_function_node(node)\n        65:\n        66:    def visit_AsyncFunctionDef(self, node):\n        67:        \"\"\"Visit an async function definition node.\"\"\"\n        68:        return self._handle_function_node(node)\n        69:\n        70:    def _handle_function_node(self, node):\n        71:        \"\"\"Common handling for both regular and async functions.\"\"\"\n        72:        if not self.original_path or node.name != self.original_path[0]:\n        73:            return self.generic_visit(node)\n        74:        self.current_path.append(node.name)\n        75:        remaining_path = self.original_path[1:]\n        76:        if not remaining_path:\n        77:            if self.insert_after:\n        78:                node = self._handle_insertion(node)\n        79:            else:\n        80:                self.success = True\n        81:                if len(self.new_nodes) == 1:\n        82:                    return self.new_nodes[0]\n        83:                else:\n        84:                    node.body = self.new_nodes\n        85:                    return node\n        86:        else:\n        87:            saved_path = self.original_path\n        88:            self.original_path = remaining_path\n        89:            node.body = [self.visit(child) for child in node.body]\n        90:            self.original_path = saved_path\n        91:        self.current_path.pop()\n        92:        return node\n        93:\n        94:    def _handle_one_line_function(self, node, line):\n        95:        \"\"\"Special handling for one-line function definitions\"\"\"\n        96:        if ': pass' in line or ':pass' in line:\n        97:            base_indent = len(line) - len(line.lstrip())\n        98:            def_line = line.rstrip()\n        99:            if self.insert_after == 'pass':\n        100:                def_line = def_line.replace(': pass', ':').replace(':pass', ':')\n        101:                body_indent = base_indent + 4\n        102:                body_lines = []\n        103:                body_lines.append(' ' * body_indent + 'pass')\n        104:                for new_node in self.new_nodes:\n        105:                    node_lines = _py_ast_to_source(new_node).split('\\n')\n        106:                    for nl in node_lines:\n        107:                        if nl.strip():\n        108:                            body_lines.append(' ' * body_indent + nl.lstrip())\n        109:                new_source = def_line + '\\n' + '\\n'.join(body_lines)\n        110:                try:\n        111:                    new_node = ast.parse(new_source).body[0]\n        112:                    self.success = True\n        113:                    return new_node\n        114:                except Exception:\n        115:                    normalized = textwrap.dedent(new_source)\n        116:                    try:\n        117:                        new_node = ast.parse(normalized).body[0]\n        118:                        self.success = True\n        119:                        return new_node\n        120:                    except Exception:\n        121:                        pass\n        122:        return node\n        123:\n        124:    def _handle_insertion(self, node):\n        125:        \"\"\"Handle inserting nodes after a specific point.\"\"\"\n        126:        if isinstance(self.insert_after, str) and '::' not in self.insert_after:\n        127:            if not isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        128:                return node\n        129:            if node.lineno == node.end_lineno:\n        130:                return self._handle_one_line_function(node, self.file_lines[node.lineno - 1])\n        131:            func_lines = self.file_lines[node.lineno - 1:node.end_lineno]\n        132:            if not func_lines:\n        133:                return node\n        134:            target = self.insert_after.strip()\n        135:            target_line_idx = None\n        136:            for i, line in enumerate(func_lines):\n        137:                detokenized_line = _detokenize_source(line, self.all_tokens)\n        138:                if detokenized_line.strip() == target:\n        139:                    self.line_match_count += 1\n        140:                    if self.line_match_count == 1:\n        141:                        target_line_idx = i\n        142:            if self.line_match_count == 0:\n        143:                return node\n        144:            elif self.line_match_count > 1:\n        145:                raise ValueError(f'Ambiguous insert_after - found {self.line_match_count} matches for: {self.insert_after}')\n        146:            target_absolute_line = node.lineno + target_line_idx\n        147:            containing_node = self._find_containing_node(node, target_absolute_line)\n        148:            if containing_node and containing_node is not node:\n        149:                self._insert_into_node(containing_node, target_absolute_line)\n        150:            else:\n        151:                insert_index = len(node.body)\n        152:                for idx, child in enumerate(node.body):\n        153:                    if hasattr(child, 'lineno') and child.lineno > target_absolute_line:\n        154:                        insert_index = idx\n        155:                        break\n        156:                if insert_index == len(node.body):\n        157:                    node.body.extend(self.new_nodes)\n        158:                else:\n        159:                    for i, new_node in enumerate(self.new_nodes):\n        160:                        node.body.insert(insert_index + i, new_node)\n        161:            self.success = True\n        162:            return node\n        163:        else:\n        164:            if self.insert_after:\n        165:                target_path = self.insert_after.split('::')\n        166:                current_path = self.current_path\n        167:                if len(target_path) > 1 and len(current_path) == len(target_path) - 1:\n        168:                    if all((c == t for c, t in zip(current_path, target_path[:len(current_path)]))):\n        169:                        target_name = target_path[-1]\n        170:                        insert_index = None\n        171:                        for idx, child in enumerate(node.body):\n        172:                            if hasattr(child, 'name') and child.name == target_name:\n        173:                                insert_index = idx + 1\n        174:                                break\n        175:                        if insert_index is not None:\n        176:                            for i, new_node in enumerate(self.new_nodes):\n        177:                                node.body.insert(insert_index + i, new_node)\n        178:                            self.success = True\n        179:                            return node\n        180:                if len(current_path) == len(target_path) and all((c == t for c, t in zip(current_path, target_path))):\n        181:                    self.success = True\n        182:                    if isinstance(node, ast.ClassDef):\n        183:                        node.body.extend(self.new_nodes)\n        184:                    else:\n        185:                        for new_node in self.new_nodes:\n        186:                            node.body.append(new_node)\n        187:            return node\n        188:\n        189:    def _find_containing_node(self, node, target_line):\n        190:        \"\"\"Find the deepest AST node with a body that contains the target line.\"\"\"\n        191:        if not (hasattr(node, 'lineno') and hasattr(node, 'end_lineno')):\n        192:            return None\n        193:        if not node.lineno <= target_line <= node.end_lineno:\n        194:            return None\n        195:        deepest_with_body = node if hasattr(node, 'body') else None\n        196:        if hasattr(node, 'body'):\n        197:            for child in node.body:\n        198:                deeper_node = self._find_containing_node(child, target_line)\n        199:                if deeper_node:\n        200:                    return deeper_node\n        201:        if hasattr(node, 'orelse'):\n        202:            for child in node.orelse:\n        203:                deeper_node = self._find_containing_node(child, target_line)\n        204:                if deeper_node:\n        205:                    return deeper_node\n        206:        if deepest_with_body:\n        207:            return deepest_with_body\n        208:        return None\n        209:\n        210:    def _insert_into_node(self, node, target_line):\n        211:        \"\"\"Insert new nodes into the given node after the target line.\"\"\"\n        212:        if not hasattr(node, 'body'):\n        213:            return\n        214:        insert_index = len(node.body)\n        215:        for idx, child in enumerate(node.body):\n        216:            if hasattr(child, 'lineno') and child.lineno > target_line:\n        217:                insert_index = idx\n        218:                break\n        219:        for i, new_node in enumerate(self.new_nodes):\n        220:            node.body.insert(insert_index + i, new_node)\n        221:\n        222:### ENTRY POINT ###\n        223:\n        224:from bots.dev.decorators import log_errors\n        225:@log_errors\n        226:def python_edit(target_scope: str, code: str, *, insert_after: str=None) -> str:\n        227:    \"\"\"\n        228:    Edit Python code using pytest-style scope syntax.\n        229:    Default behavior: Replace entire target scope.\n        230:\n        231:    Parameters:\n        232:    ----------\n        233:    target_scope : str\n        234:        Location to edit in pytest-style scope syntax:\n        235:        - \"file.py\" (whole file)\n        236:        - \"file.py::MyClass\" (class)\n        237:        - \"file.py::my_function\" (function)\n        238:        - \"file.py::MyClass::method\" (method)\n        239:        - \"file.py::Outer::Inner::method\" (nested)\n        240:        - \"file.py::utils::helper_func\" (nested function)\n        241:\n        242:    code : str\n        243:        Python code to insert/replace. Will be cleaned/dedented.\n        244:        Import statements will be automatically extracted and handled.\n        245:\n        246:    insert_after : str, optional\n        247:        Where to insert the code. Can be either:\n        248:        - \"__FILE_START__\" (special token for file beginning)\n        249:        - A scope (\"MyClass::method\")\n        250:        - An exact line match (like a context line in git patches)\n        251:        If not specified, replaces the node at target_scope.\n        252:\n        253:    Returns:\n        254:    --------\n        255:    str\n        256:        Description of what was modified or error message\n        257:    \"\"\"\n        258:    try:\n        259:        file_path, *path_elements = target_scope.split('::')\n        260:        if not file_path.endswith('.py'):\n        261:            return _process_error(ValueError(f'File path must end with .py: {file_path}'))\n        262:        for element in path_elements:\n        263:            if not element.isidentifier():\n        264:                return _process_error(ValueError(f'Invalid identifier in path: {element}'))\n        265:        abs_path = _make_file(file_path)\n        266:        cleaned_code = _clean(code)\n        267:        tokenized_code, new_code_tokens = _tokenize_source(cleaned_code)\n        268:        try:\n        269:            new_tree = ast.parse(tokenized_code)\n        270:            import_nodes = []\n        271:            code_nodes = []\n        272:            for node in new_tree.body:\n        273:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        274:                    import_nodes.append(node)\n        275:                else:\n        276:                    code_nodes.append(node)\n        277:        except Exception as e:\n        278:            return _process_error(ValueError(f'Error parsing new code: {str(e)}'))\n        279:        try:\n        280:            with open(abs_path, 'r', encoding='utf-8') as file:\n        281:                original_content = file.read()\n        282:\n        283:            # Extract top-level comments before processing\n        284:            top_level_comments = []\n        285:            if original_content.strip():\n        286:                original_content, top_level_comments = _extract_top_level_comments(original_content)\n        287:\n        288:            tokenized_content, file_tokens = _tokenize_source(original_content) if original_content.strip() else ('', {})\n        289:            file_lines = tokenized_content.split('\\n')\n        290:            tree = ast.parse(tokenized_content) if original_content.strip() else ast.Module(body=[], type_ignores=[])\n        291:        except Exception as e:\n        292:            return _process_error(ValueError(f'Error reading/parsing file {abs_path}: {str(e)}'))\n        293:        existing_imports = []\n        294:        non_imports = []\n        295:        for node in tree.body:\n        296:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        297:                existing_imports.append(node)\n        298:            else:\n        299:                non_imports.append(node)\n        300:        if insert_after == '__FILE_START__':\n        301:            tree.body = import_nodes + code_nodes + existing_imports + non_imports\n        302:            try:\n        303:                updated_content = _py_ast_to_source(tree)\n        304:                all_tokens = {**file_tokens, **new_code_tokens}\n        305:                final_content = _detokenize_source(updated_content, all_tokens)\n        306:                final_content = _preserve_blank_lines(final_content, original_content)\n        307:                # Restore top-level comments\n        308:                final_content = _restore_top_level_comments(final_content, top_level_comments)\n        309:                with open(abs_path, 'w', encoding='utf-8') as file:\n        310:                    file.write(final_content)\n        311:                return f\"Code inserted at start of '{abs_path}'.\"\n        312:            except Exception as e:\n        313:                return _process_error(e)\n        314:        if not path_elements:\n        315:            tree.body = existing_imports + import_nodes + non_imports + code_nodes\n        316:            try:\n        317:                updated_content = _py_ast_to_source(tree)\n        318:                all_tokens = {**file_tokens, **new_code_tokens}\n        319:                final_content = _detokenize_source(updated_content, all_tokens)\n        320:                final_content = _preserve_blank_lines(final_content, original_content)\n        321:                # Restore top-level comments\n        322:                final_content = _restore_top_level_comments(final_content, top_level_comments)\n        323:                with open(abs_path, 'w', encoding='utf-8') as file:\n        324:                    file.write(final_content)\n        325:                return f\"Code added at file level in '{abs_path}'.\"\n        326:            except Exception as e:\n        327:                return _process_error(e)\n        328:        tree.body = existing_imports + import_nodes + non_imports\n        329:        transformer = ScopeTransformer(path_elements, code_nodes, insert_after, file_lines, file_tokens, new_code_tokens)\n        330:        modified_tree = transformer.visit(tree)\n        331:        if not transformer.success:\n        332:            if insert_after:\n        333:                return _process_error(ValueError(f'Insert point not found: {insert_after}'))\n        334:            else:\n        335:                return _process_error(ValueError(f'Target scope not found: {target_scope}'))\n        336:        try:\n        337:            updated_content = _py_ast_to_source(modified_tree)\n        338:            all_tokens = {**file_tokens, **new_code_tokens}\n        339:            final_content = _detokenize_source(updated_content, all_tokens)\n        340:            final_content = _preserve_blank_lines(final_content, original_content)\n        341:            # Restore top-level comments\n        342:            final_content = _restore_top_level_comments(final_content, top_level_comments)\n        343:            with open(abs_path, 'w', encoding='utf-8') as file:\n        344:                file.write(final_content)\n        345:            action = 'inserted after' if insert_after else 'replaced at'\n        346:            scope_str = '::'.join(path_elements) if path_elements else 'file level'\n        347:            return f\"Code {action} {scope_str} in '{abs_path}'.\"\n        348:        except Exception as e:\n        349:            return _process_error(e)\n        350:    except Exception as e:\n        351:        return _process_error(e)\n        352:\n        353:\n        354:### HELPER FUNCTIONS ###\n        355:\n        356:def _make_file(file_path: str) -> str:\n        357:    \"\"\"\n        358:    Creates a file and its parent directories if they don't exist.\n        359:    Converts relative paths to absolute paths.\n        360:\n        361:    Parameters:\n        362:    - file_path (str): The path to the file to be created\n        363:\n        364:    Returns:\n        365:    - str: The absolute path to the file\n        366:\n        367:    Raises:\n        368:    - ValueError: If there's an error creating the file or directories,\n        369:                 or if the file_path is empty\n        370:    \"\"\"\n        371:    if not file_path:\n        372:        raise ValueError('File path cannot be empty')\n        373:    abs_path = os.path.abspath(file_path)\n        374:    dir_path = os.path.dirname(abs_path)\n        375:    if dir_path:\n        376:        try:\n        377:            os.makedirs(dir_path, exist_ok=True)\n        378:        except Exception as e:\n        379:            raise ValueError(f'Error creating directories {dir_path}: {str(e)}')\n        380:    if not os.path.exists(abs_path):\n        381:        try:\n        382:            with open(abs_path, 'w', encoding='utf-8') as f:\n        383:                f.write('')\n        384:        except Exception as e:\n        385:            raise ValueError(f'Error creating file {abs_path}: {str(e)}')\n        386:    return abs_path\n        387:\n        388:def _create_token(content: str, index: int, current_hash: str, token_type: TokenType=None, extra_metadata: dict=None) -> Tuple[str, Dict]:\n        389:    \"\"\"Create a token with our specific pattern and metadata\"\"\"\n        390:    token_name = f'TOKEN_{current_hash}_{index}'\n        391:    metadata = extra_metadata or {}\n        392:    if token_type:\n        393:        metadata['type'] = token_type.value\n        394:    token_data = {'content': content, 'metadata': metadata}\n        395:    return (token_name, token_data)\n        396:\n        397:def _get_file_hash(content: str) -> str:\n        398:    \"\"\"Create a short hash of file content\"\"\"\n        399:    return hashlib.sha256(content.encode()).hexdigest()[:8]\n        400:\n        401:def _contains_token(s: str) -> bool:\n        402:    return 'TOKEN_' in s\n        403:\n        404:def _find_string_end(line, start_pos, quote_char):\n        405:    \"\"\"Find the end position of a quoted string, handling escape sequences properly.\"\"\"\n        406:    pos = start_pos + 1\n        407:    while pos < len(line):\n        408:        if line[pos] == '\\\\' and pos + 1 < len(line):\n        409:            # Skip the backslash and the escaped character\n        410:            pos += 2\n        411:        elif line[pos] == quote_char:\n        412:            return pos\n        413:        else:\n        414:            pos += 1\n        415:    return -1  # No closing quote found\n        416:\n        417:def _is_fstring_start(line, pos):\n        418:    \"\"\"Check if position starts an f-string (f\", f', rf\", etc.)\"\"\"\n        419:    if pos >= len(line) or line[pos] not in ['\"', \"'\"]:\n        420:        return False, False  # Return tuple (is_fstring, is_raw)\n        421:\n        422:    # Check for f-string prefixes\n        423:    prefixes = {\n        424:        'f': (True, False),\n        425:        'F': (True, False),\n        426:        'rf': (True, True),\n        427:        'Rf': (True, True),\n        428:        'rF': (True, True),\n        429:        'RF': (True, True),\n        430:        'fr': (True, True),\n        431:        'Fr': (True, True),\n        432:        'fR': (True, True),\n        433:        'FR': (True, True)\n        434:    }\n        435:\n        436:    for prefix, (is_f, is_raw) in prefixes.items():\n        437:        prefix_start = pos - len(prefix)\n        438:        if (prefix_start >= 0 and\n        439:            line[prefix_start:pos] == prefix and\n        440:            (prefix_start == 0 or not line[prefix_start-1].isalnum())):\n        441:            return is_f, is_raw\n        442:\n        443:    return False, False\n        444:\n        445:def _find_fstring_end(line, start_pos, quote_char, is_raw=False):\n        446:    \"\"\"Find the end of an f-string, handling nested braces and expressions.\"\"\"\n        447:    pos = start_pos + 1\n        448:    brace_depth = 0\n        449:\n        450:    while pos < len(line):\n        451:        char = line[pos]\n        452:\n        453:        if char == '{':\n        454:            if pos + 1 < len(line) and line[pos + 1] == '{':\n        455:                # Escaped brace {{\n        456:                pos += 2\n        457:                continue\n        458:            else:\n        459:                # Start of expression\n        460:                brace_depth += 1\n        461:                pos += 1\n        462:                continue\n        463:\n        464:        elif char == '}':\n        465:            if pos + 1 < len(line) and line[pos + 1] == '}':\n        466:                # Escaped brace }}\n        467:                pos += 2\n        468:                continue\n        469:            else:\n        470:                # End of expression\n        471:                brace_depth -= 1\n        472:                pos += 1\n        473:                continue\n        474:\n        475:        elif char == quote_char and brace_depth == 0:\n        476:            # Found closing quote at top level\n        477:            return pos\n        478:\n        479:        elif char == '\\\\' and not is_raw and pos + 1 < len(line):\n        480:            # Handle escape sequences (but not in raw strings)\n        481:            pos += 2\n        482:            continue\n        483:\n        484:        elif char in ['\"', \"'\"] and brace_depth > 0:\n        485:            # Handle nested quotes inside f-string expressions\n        486:            nested_end = _find_string_end(line, pos, char)\n        487:            if nested_end == -1:\n        488:                return -1\n        489:            pos = nested_end + 1\n        490:            continue\n        491:\n        492:        pos += 1\n        493:\n        494:    return -1  # Unterminated f-string\n        495:\n        496:def _determine_comment_type(code_stripped: str) -> Tuple[TokenType, dict]:\n        497:    \"\"\"Determine the type of comment based on the preceding code.\"\"\"\n        498:\n        499:    # Strip indentation for pattern matching\n        500:    code_no_indent = code_stripped.lstrip()\n        501:\n        502:    if code_no_indent.startswith(('import ', 'from ')):\n        503:        return TokenType.IMPORT_COMMENT, {'import_statement': code_stripped}\n        504:\n        505:    compound_patterns = [\n        506:        'def ', 'class ', 'if ', 'elif ', 'for ', 'while ', 'with ', 'async def ', 'try:', 'except ', 'finally:', 'else:'\n        507:    ]\n        508:\n        509:    # Check if this is a compound statement (starts with compound keyword and ends with colon)\n        510:    # Use the stripped version for pattern matching but keep original for colon check\n        511:    is_compound = (\n        512:        any(code_no_indent.startswith(pattern) for pattern in compound_patterns)\n        513:        and code_stripped.endswith(':')\n        514:    ) or code_stripped.strip() in ['else:', 'try:', 'finally:']\n        515:\n        516:    if is_compound:\n        517:        return TokenType.COMPOUND_COMMENT, {'statement': code_stripped}\n        518:\n        519:    return TokenType.INLINE_COMMENT, {}\n        520:\n        521:def _get_indentation_at_position(source: str, pos: int) -> str:\n        522:    \"\"\"Get the indentation level at a given position in source\"\"\"\n        523:    line_start = source.rfind('\\n', 0, pos) + 1\n        524:    return source[line_start:pos].replace(source[line_start:pos].lstrip(), '')\n        525:\n        526:def _indent_multiline_content(content: str, indent: str) -> str:\n        527:    \"\"\"Indent multiline content while preserving internal formatting\"\"\"\n        528:    if not content.strip():\n        529:        return content\n        530:    lines = content.split('\\n')\n        531:    if len(lines) == 1:\n        532:        return content\n        533:    if all((line.startswith(' ') for line in lines[1:] if line.strip())):\n        534:        return content\n        535:    result = [lines[0]]\n        536:    for line in lines[1:]:\n        537:        if line.strip():\n        538:            result.append(indent + line)\n        539:        else:\n        540:            result.append(line)\n        541:    return '\\n'.join(result)\n        542:\n        543:def _preserve_blank_lines(result: str, original_source: str) -> str:\n        544:    \"\"\"\n        545:    Restore blank lines around comments that had them in the original source.\n        546:    \"\"\"\n        547:    original_lines = original_source.split('\\n')\n        548:    result_lines = result.split('\\n')\n        549:    comments_with_blanks = {}\n        550:    for i, line in enumerate(original_lines):\n        551:        if line.strip().startswith('#') and 'marker' in line.lower():\n        552:            blank_before = i > 0 and (not original_lines[i - 1].strip())\n        553:            blank_after = i < len(original_lines) - 1 and (not original_lines[i + 1].strip())\n        554:            if blank_before or blank_after:\n        555:                comments_with_blanks[line.strip()] = {'blank_before': blank_before, 'blank_after': blank_after}\n        556:    if not comments_with_blanks:\n        557:        return result\n        558:    new_result_lines = []\n        559:    i = 0\n        560:    while i < len(result_lines):\n        561:        line = result_lines[i]\n        562:        line_stripped = line.strip()\n        563:        if line_stripped in comments_with_blanks:\n        564:            info = comments_with_blanks[line_stripped]\n        565:            if info['blank_before']:\n        566:                if i > 0 and new_result_lines[-1].strip():\n        567:                    new_result_lines.append('')\n        568:            new_result_lines.append(line)\n        569:            if info['blank_after']:\n        570:                if i < len(result_lines) - 1 and result_lines[i + 1].strip():\n        571:                    new_result_lines.append('')\n        572:        else:\n        573:            new_result_lines.append(line)\n        574:        i += 1\n        575:    return '\\n'.join(new_result_lines)\n        576:\n        577:\n        578:def _analyze_string_at_position_in_source(source, pos, paren_depth):\n        579:    \"\"\"\n        580:    Analyze a potential string starting at the given position in the full source.\n        581:    Enhanced with better bounds checking and comment awareness.\n        582:    \"\"\"\n        583:    if pos >= len(source):\n        584:        return None\n        585:\n        586:    char = source[pos]\n        587:    if char not in ['\"', \"'\"]:\n        588:        return None\n        589:\n        590:    # Check if this is an f-string\n        591:    is_fstring, is_raw = _is_fstring_start(source, pos)\n        592:\n        593:    if is_fstring:\n        594:        # Find the actual start of the f-string prefix\n        595:        string_start = pos\n        596:        for prefix in ['rf', 'Rf', 'rF', 'RF', 'fr', 'Fr', 'fR', 'FR', 'f', 'F']:\n        597:            prefix_start = pos - len(prefix)\n        598:            if (prefix_start >= 0 and\n        599:                source[prefix_start:pos] == prefix and\n        600:                (prefix_start == 0 or not source[prefix_start-1].isalnum())):\n        601:                string_start = prefix_start\n        602:                break\n        603:\n        604:        end_pos = _find_fstring_end(source, pos, char, is_raw)\n        605:    else:\n        606:        string_start = pos\n        607:        end_pos = _find_string_end(source, pos, char)\n        608:\n        609:    if end_pos == -1:\n        610:        # Invalid/unterminated string\n        611:        return None\n        612:\n        613:    # Extract the complete string content\n        614:    string_content = source[string_start:end_pos + 1]\n        615:\n        616:    # Validate the string - additional safety checks\n        617:    if len(string_content) < 2:\n        618:        return None\n        619:\n        620:    # Sanity check: if this is a single-quoted string, it shouldn't contain\n        621:    # unescaped newlines (except for triple quotes)\n        622:    if (string_content.startswith(\"'\") and not string_content.startswith(\"'''\") and\n        623:        '\\n' in string_content):\n        624:        # This is likely an over-capture - reject it\n        625:        return None\n        626:\n        627:    if (string_content.startswith('\"') and not string_content.startswith('\"\"\"') and\n        628:        '\\n' in string_content and not is_fstring):\n        629:        # This is likely an over-capture - reject it\n        630:        return None\n        631:\n        632:    return {\n        633:        'start': string_start,\n        634:        'end': end_pos,\n        635:        'content': string_content,\n        636:        'is_fstring': is_fstring,\n        637:        'is_raw': is_raw,\n        638:        'paren_depth': paren_depth,\n        639:        'quote_char': char\n        640:    }\n        641:\n        642:def _find_string_end(line, start_pos, quote_char):\n        643:    \"\"\"\n        644:    Find the end position of a quoted string, handling escape sequences properly.\n        645:    Enhanced with better validation.\n        646:    \"\"\"\n        647:    if start_pos >= len(line):\n        648:        return -1\n        649:\n        650:    pos = start_pos + 1\n        651:    while pos < len(line):\n        652:        if line[pos] == '\\\\' and pos + 1 < len(line):\n        653:            # Skip the backslash and the escaped character\n        654:            pos += 2\n        655:        elif line[pos] == quote_char:\n        656:            return pos\n        657:        elif line[pos] == '\\n' and quote_char in ['\"', \"'\"]:\n        658:            # Single/double quoted strings shouldn't span lines (unless escaped)\n        659:            # This indicates we've gone too far\n        660:            return -1\n        661:        else:\n        662:            pos += 1\n        663:    return -1  # No closing quote found\n        664:\n        665:def _find_all_string_locations_in_source(source):\n        666:    \"\"\"\n        667:    Find all string literal locations in the entire source, being aware of comments.\n        668:    Skip quotes that appear inside comments to avoid over-capturing.\n        669:    \"\"\"\n        670:    locations = []\n        671:    paren_depth = 0\n        672:    pos = 0\n        673:\n        674:    while pos < len(source):\n        675:        char = source[pos]\n        676:\n        677:        # Track parentheses depth\n        678:        if char == '(':\n        679:            paren_depth += 1\n        680:            pos += 1\n        681:            continue\n        682:        elif char == ')':\n        683:            paren_depth -= 1\n        684:            pos += 1\n        685:            continue\n        686:\n        687:        # Check for comments - if we hit a '#', skip to end of line\n        688:        if char == '#':\n        689:            # Skip to end of line to avoid processing quotes in comments\n        690:            while pos < len(source) and source[pos] != '\\n':\n        691:                pos += 1\n        692:            # pos is now at '\\n' or end of source\n        693:            continue\n        694:\n        695:        # Look for string starts\n        696:        if char in ['\"', \"'\"]:\n        697:            # Check if this quote is inside a comment by looking back on the current line\n        698:            line_start = source.rfind('\\n', 0, pos) + 1\n        699:            line_before_quote = source[line_start:pos]\n        700:\n        701:            # If there's a '#' in the line before this quote (and no string quotes to protect it),\n        702:            # then this quote is inside a comment\n        703:            if _is_quote_in_comment(line_before_quote):\n        704:                pos += 1\n        705:                continue\n        706:\n        707:            # This is a real string quote, process it\n        708:            string_info = _analyze_string_at_position_in_source(source, pos, paren_depth)\n        709:            if string_info:\n        710:                locations.append(string_info)\n        711:                pos = string_info['end'] + 1  # Skip past this string\n        712:            else:\n        713:                pos += 1\n        714:        else:\n        715:            pos += 1\n        716:\n        717:    return locations\n        718:\n        719:def _is_quote_in_comment(line_before_quote):\n        720:    \"\"\"\n        721:    Determine if a quote is inside a comment by analyzing the line content before it.\n        722:\n        723:    Returns True if the quote is inside a comment, False otherwise.\n        724:    \"\"\"\n        725:    # Simple approach: look for '#' that's not inside a string\n        726:    in_string = False\n        727:    string_char = None\n        728:    i = 0\n        729:\n        730:    while i < len(line_before_quote):\n        731:        char = line_before_quote[i]\n        732:\n        733:        if not in_string:\n        734:            if char == '#':\n        735:                # Found unprotected '#' - everything after is a comment\n        736:                return True\n        737:            elif char in ['\"', \"'\"]:\n        738:                # Start of string\n        739:                in_string = True\n        740:                string_char = char\n        741:        else:\n        742:            # Inside a string\n        743:            if char == '\\\\' and i + 1 < len(line_before_quote):\n        744:                # Skip escaped character\n        745:                i += 2\n        746:                continue\n        747:            elif char == string_char:\n        748:                # End of string\n        749:                in_string = False\n        750:                string_char = None\n        751:\n        752:        i += 1\n        753:\n        754:    return False\n        755:\n        756:### TOKENIZATION ###\n        757:\n        758:def _tokenize_source(source: str) -> Tuple[str, Dict[str, Dict]]:\n        759:    \"\"\"\n        760:    Tokenize source code, preserving exact formatting.\n        761:\n        762:    Returns:\n        763:    - tokenized_source: Source with tokens inserted\n        764:    - token_map: Mapping of tokens to {'content': str, 'metadata': dict}\n        765:    \"\"\"\n        766:    token_map = {}\n        767:    current_hash = _get_file_hash(source)\n        768:    token_counter = 0\n        769:\n        770:    # First pass: handle multi-line strings BEFORE any other processing\n        771:    tokenized = _process_multiline_strings(source, token_map, token_counter, current_hash)\n        772:    token_counter = len(token_map)\n        773:\n        774:    # Second pass: process ALL string literals in the entire source at once\n        775:    # CRITICAL: Do this BEFORE splitting into lines to preserve escape sequences\n        776:    tokenized, token_counter = _process_all_string_literals(tokenized, token_map, token_counter, current_hash)\n        777:\n        778:    # Third pass: process line by line for comments ONLY after string processing is complete\n        779:    lines = tokenized.split('\\n')\n        780:    processed_lines = []\n        781:\n        782:    for line in lines:\n        783:        processed_line, token_counter = _process_line_comments(\n        784:            line, token_map, token_counter, current_hash\n        785:        )\n        786:        processed_lines.append(processed_line)\n        787:\n        788:    return '\\n'.join(processed_lines), token_map\n        789:\n        790:\n        791:def _extract_top_level_comments(source: str) -> Tuple[str, List[str]]:\n        792:    \"\"\"\n        793:    Extract top-level standalone comments that appear before any code.\n        794:\n        795:    Returns:\n        796:        (source_without_top_comments, list_of_top_comment_lines)\n        797:    \"\"\"\n        798:    lines = source.split('\\n')\n        799:    top_comments = []\n        800:    first_code_line_idx = 0\n        801:\n        802:    # Find all leading comments and blank lines\n        803:    for i, line in enumerate(lines):\n        804:        stripped = line.strip()\n        805:        if not stripped:  # Blank