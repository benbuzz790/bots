                                      "content": "\n        1:import textwrap, ast, os, subprocess, traceback\n        2:from bots.utils.helpers import _clean\n        3:from bots.utils.helpers import _py_ast_to_source\n        4:\n        5:\n        6:\n        7:def _execute_python_code(code: str, timeout: int=300) ->str:\n        8:    \"\"\"\n        9:    Executes python code in a stateless environment with cross-platform timeout handling.\n        10:\n        11:    Parameters:\n        12:    - code (str): Syntactically correct python code\n        13:    - timeout (int): Maximum execution time in seconds (default: 300)\n        14:\n        15:    Returns stdout or an error message.\n        16:\n        17:    cost: varies\n        18:    \"\"\"\n        19:\n        20:    def create_wrapper_ast():\n        21:        wrapper_code = textwrap.dedent(\n        22:            \"\"\"\n        23:            import os\n        24:            import sys\n        25:            import traceback\n        26:            import time\n        27:            sys.path.append(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))\n        28:\n        29:            if sys.platform == 'win32':\n        30:                import codecs\n        31:                sys.stdout = codecs.getwriter('utf-8')(sys.stdout.buffer, 'strict')\n        32:                sys.stderr = codecs.getwriter('utf-8')(sys.stderr.buffer, 'strict')\n        33:\n        34:            def main():\n        35:                pass  # Placeholder for user code\n        36:\n        37:            if __name__ == '__main__':\n        38:                try:\n        39:                    main()\n        40:                except Exception as error:\n        41:                    print(f\"An error occurred: {str(error)}\", file=sys.stderr)\n        42:                    traceback.print_exc(file=sys.stderr)\n        43:                    sys.exit(1)\n        44:            \"\"\"\n        45:            )\n        46:        return ast.parse(wrapper_code)\n        47:\n        48:    def insert_code_into_wrapper(wrapper_ast, code_ast, timeout_value):\n        49:        main_func = next(node for node in wrapper_ast.body if isinstance(\n        50:            node, ast.FunctionDef) and node.name == 'main')\n        51:        main_func.body = code_ast.body\n        52:        return wrapper_ast\n        53:    try:\n        54:        if not isinstance(timeout, int) or timeout <= 0:\n        55:            return _process_error(ValueError(\n        56:                'Timeout must be a positive integer'))\n        57:        try:\n        58:            code_ast = ast.parse(_clean(code))\n        59:        except SyntaxError as e:\n        60:            return f'SyntaxError: {str(e)}'\n        61:        wrapper_ast = create_wrapper_ast()\n        62:        combined_ast = insert_code_into_wrapper(wrapper_ast, code_ast, timeout)\n        63:        final_code = _py_ast_to_source(combined_ast)\n        64:    except Exception as e:\n        65:        return _process_error(e)\n        66:    package_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))\n        67:    scripts_dir = os.path.join(package_root, 'scripts')\n        68:    if not os.path.exists(scripts_dir):\n        69:        os.makedirs(scripts_dir)\n        70:    temp_file_name = os.path.join(scripts_dir, f'temp_script_{os.getpid()}.py')\n        71:    try:\n        72:        with open(temp_file_name, 'w', encoding='utf-8') as temp_file:\n        73:            temp_file.write(final_code)\n        74:            temp_file.flush()\n        75:            os.fsync(temp_file.fileno())\n        76:        env = os.environ.copy()\n        77:        env['PYTHONIOENCODING'] = 'utf-8'\n        78:        process = subprocess.Popen(['python', temp_file_name], stdout=\n        79:            subprocess.PIPE, stderr=subprocess.PIPE, text=True, encoding=\n        80:            'utf-8', creationflags=subprocess.CREATE_NO_WINDOW if os.name ==\n        81:            'nt' else 0, env=env)\n        82:        try:\n        83:            stdout, stderr = process.communicate(timeout=timeout)\n        84:            if process.returncode != 0:\n        85:                return stderr or 'Process failed with no error message'\n        86:            return stdout + stderr\n        87:        except subprocess.TimeoutExpired:\n        88:            process.terminate()\n        89:            try:\n        90:                process.wait(timeout=1)\n        91:            except subprocess.TimeoutExpired:\n        92:                process.kill()\n        93:            return f'Error: Code execution timed out after {timeout} seconds'\n        94:    except Exception as e:\n        95:        return _process_error(e)\n        96:    finally:\n        97:        try:\n        98:            if os.path.exists(temp_file_name):\n        99:                os.remove(temp_file_name)\n        100:        except Exception:\n        101:            pass\n        102:\n        103:\n        104:\n        105:def _process_error(error: Exception) ->str:\n        106:    \"\"\"Format error message with traceback.\"\"\"\n        107:    error_message = f'Tool Failed: {str(error)}\\n'\n        108:    error_message += (\n        109:        f\"Traceback:\\n{''.join(traceback.format_tb(error.__traceback__))}\")\n        110:    return error_message"
