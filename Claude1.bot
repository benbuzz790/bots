                                      "content": "\n        1:import os\n        2:import traceback\n        3:import textwrap\n        4:import difflib\n        5:\n        6:def view(file_path: str, start_line: str = None, end_line: str = None,\n        7:         around_str_match: str = None, dist_from_match: str = '10'):\n        8:    \"\"\"\n        9:    Display the contents of a file with line numbers.\n        10:\n        11:    Parameters:\n        12:    - file_path (str): The path to the file to be viewed.\n        13:    - start_line (int, optional): Starting line number (1-indexed). If None, starts from beginning.\n        14:    - end_line (int, optional): Ending line number (1-indexed). If None, goes to end of file.\n        15:    - around_str_match (str, optional): String to search for. If provided, shows lines around matches.\n        16:    - dist_from_match (int, optional): Number of lines to show before and after each match. Defaults to 10.\n        17:\n        18:    Returns:\n        19:    A string containing the file contents with line numbers,\n        20:    filtered according to the specified parameters.\n        21:    \"\"\"\n        22:    encodings = ['utf-8', 'utf-16', 'utf-16le', 'ascii', 'cp1252', 'iso-8859-1']\n        23:\n        24:    start_line = int(start_line) if start_line is not None else None\n        25:    end_line = int(end_line) if end_line is not None else None\n        26:    dist_from_match = int(dist_from_match) if dist_from_match is not None else None\n        27:\n        28:    for encoding in encodings:\n        29:        try:\n        30:            with open(file_path, 'r', encoding=encoding) as file:\n        31:                lines = file.readlines()\n        32:\n        33:            # If searching for a string match\n        34:            if around_str_match:\n        35:                matching_line_numbers = []\n        36:                for i, line in enumerate(lines):\n        37:                    if around_str_match in line:\n        38:                        matching_line_numbers.append(i)\n        39:\n        40:                if not matching_line_numbers:\n        41:                    return f\"No matches found for '{around_str_match}'\"\n        42:\n        43:                # Collect line ranges around matches\n        44:                line_ranges = set()\n        45:                for match_line in matching_line_numbers:\n        46:                    start = max(0, match_line - dist_from_match)\n        47:                    end = min(len(lines), match_line + dist_from_match + 1)\n        48:                    for line_num in range(start, end):\n        49:                        line_ranges.add(line_num)\n        50:\n        51:                # Sort and create output\n        52:                sorted_lines = sorted(line_ranges)\n        53:                numbered_lines = []\n        54:                prev_line = None  # To detect gaps\n        55:\n        56:                for line_num in sorted_lines:\n        57:                    if prev_line is not None and line_num > prev_line + 1:\n        58:                        numbered_lines.append(\"...\")  # Add separator for gaps\n        59:                    numbered_lines.append(f'{line_num + 1}:{lines[line_num].rstrip()}')\n        60:                    prev_line = line_num\n        61:\n        62:                return '\\n'.join(numbered_lines)\n        63:\n        64:            # If using start_line and end_line parameters\n        65:            else:\n        66:                start_idx = (start_line - 1) if start_line else 0\n        67:                end_idx = end_line if end_line else len(lines)\n        68:\n        69:                # Validate line numbers\n        70:                start_idx = max(0, start_idx)\n        71:                end_idx = min(len(lines), end_idx)\n        72:\n        73:                if start_idx >= len(lines):\n        74:                    return f\"Error: start_line ({start_line}) exceeds file length ({len(lines)} lines)\"\n        75:\n        76:                selected_lines = lines[start_idx:end_idx]\n        77:                numbered_lines = [f'{i + start_idx + 1}:{line.rstrip()}' for i, line in enumerate(selected_lines)]\n        78:                return '\\n'.join(numbered_lines)\n        79:\n        80:        except UnicodeDecodeError:\n        81:            continue\n        82:        except Exception as e:\n        83:            return f'Error: {str(e)}'\n        84:\n        85:    return f\"Error: Unable to read file with any of the attempted encodings: {', '.join(encodings)}\"\n        86:\n        87:def view_dir(start_path: str='.', output_file=None, target_extensions: str=\"['py', 'txt', 'md']\"):\n        88:    \"\"\"\n        89:    Creates a summary of the directory structure starting from the given path, writing only files\n        90:    with specified extensions and showing venv directories without their contents.\n        91:\n        92:    Parameters:\n        93:    - start_path (str): The root directory to start scanning from.\n        94:    - output_file (str): The name of the file to optionally write the directory structure to.\n        95:    - target_extensions (str): String representation of a list of file extensions (e.g. \"['py', 'txt']\").\n        96:\n        97:    Returns:\n        98:    str: A formatted string containing the directory structure, with each directory and file properly indented.\n        99:\n        100:    Example output:\n        101:    my_project/\n        102:        venv/\n        103:        module1/\n        104:            script.py\n        105:            README.md\n        106:        module2/\n        107:            utils.py\n        108:\n        109:    cost: low\n        110:    \"\"\"\n        111:    extensions_list = [ext.strip().strip('\\'\"') for ext in target_extensions.strip('[]').split(',')]\n        112:    extensions_list = ['.' + ext if not ext.startswith('.') else ext for ext in extensions_list]\n        113:    output_text = []\n        114:    for root, dirs, files in os.walk(start_path):\n        115:        level = root.replace(start_path, '').count(os.sep)\n        116:        indent = '    ' * level\n        117:        basename = os.path.basename(root)\n        118:        is_venv = basename in ['venv', 'env', '.env'] or 'pyvenv.cfg' in files\n        119:        if is_venv:\n        120:            line = f'{indent}{basename}/'\n        121:            output_text.append(line)\n        122:            dirs[:] = []\n        123:            continue\n        124:        has_relevant_files = False\n        125:        for _, _, fs in os.walk(root):\n        126:            if any((f.endswith(tuple(extensions_list)) for f in fs)):\n        127:                has_relevant_files = True\n        128:                break\n        129:        if has_relevant_files:\n        130:            line = f'{indent}{basename}/'\n        131:            output_text.append(line)\n        132:            subindent = '    ' * (level + 1)\n        133:            for file in files:\n        134:                if file.endswith(tuple(extensions_list)):\n        135:                    line = f'{subindent}{file}'\n        136:                    output_text.append(line)\n        137:    if output_file is not None:\n        138:        with open(output_file, 'w') as file:\n        139:            file.write('\\n'.join(output_text))\n        140:    return '\\n'.join(output_text)\n        141:\n        142:from bots.dev.decorators import log_errors\n        143:@log_errors\n        144:def patch_edit(file_path: str, patch_content: str):\n        145:    \"\"\"\n        146:    Apply a git-style unified diff patch to a file.\n        147:\n        148:    Use when you need to make a precise change to a file\n        149:\n        150:    Tips:\n        151:    - Small, focused changes work best\n        152:    - Exact content matching is important\n        153:    - Including surrounding context helps matching\n        154:    - Whitespace in the target lines matters\n        155:\n        156:    Parameters:\n        157:    - file_path (str): Path to the file to modify\n        158:    - patch_content (str): Unified diff format patch content\n        159:\n        160:    Returns:\n        161:    str: Description of changes made or error message\n        162:\n        163:    cost: low\n        164:    \"\"\"\n        165:    try:\n        166:        file_path = _normalize_path(file_path)\n        167:        encodings = ['utf-8', 'utf-16', 'utf-16le', 'ascii', 'cp1252', 'iso-8859-1']\n        168:        content = None\n        169:        used_encoding = 'utf-8'\n        170:        dir_path = os.path.dirname(file_path)\n        171:        if dir_path:\n        172:            os.makedirs(dir_path, exist_ok=True)\n        173:        if not os.path.exists(file_path):\n        174:            content = ''\n        175:        else:\n        176:            for encoding in encodings:\n        177:                try:\n        178:                    with open(file_path, 'r', encoding=encoding) as file:\n        179:                        content = file.read()\n        180:                        used_encoding = encoding\n        181:                        break\n        182:                except UnicodeDecodeError:\n        183:                    continue\n        184:        if content is None and os.path.exists(file_path):\n        185:            return f\"Error: Unable to read existing file with any of the attempted encodings: {', '.join(encodings)}\"\n        186:        if not patch_content.strip():\n        187:            return 'Error: patch_content is empty.'\n        188:        original_lines = content.splitlines() if content else []\n        189:        current_lines = original_lines.copy()\n        190:        changes_made = []\n        191:        line_offset = 0\n        192:\n        193:        # Clean up to prevent some common errors.\n        194:        patch_content = textwrap.dedent(patch_content)\n        195:        patch_content = '\\n' + patch_content\n        196:\n        197:        hunks = patch_content.split('\\n@@')[1:]\n        198:        if not hunks:\n        199:            return 'Error: No valid patch hunks found. (No instances of \"\\\\n@@\". Did you accidentally indent the headers?)'\n        200:        for hunk in hunks:\n        201:            hunk = hunk.strip()\n        202:            if not hunk:\n        203:                continue\n        204:            try:\n        205:                header_end = hunk.index('\\n')\n        206:                header = hunk[:header_end].strip()\n        207:                if not header.endswith('@@'):\n        208:                    header = header + ' @@'\n        209:                old_range, new_range = header.rstrip(' @').split(' +')\n        210:                old_start = int(old_range.split(',')[0].lstrip('- ')) - 1  # Convert to 0-based\n        211:                # new_start = int(new_range.split(',')[0]) - 1  # Unused, also would be 0-based\n        212:                hunk_lines = _normalize_header_lines(hunk[header_end:].splitlines()[1:])\n        213:            except (ValueError, IndexError) as e:\n        214:                return f'Error parsing hunk header: {str(e)}\\nHeader: {header}'\n        215:            context_before = []\n        216:            context_after = []\n        217:            removals = []\n        218:            additions = []\n        219:            for line in hunk_lines:\n        220:                if not line:\n        221:                    continue\n        222:                if not (line.startswith('+') or line.startswith('-')):\n        223:                    if not removals and (not additions):\n        224:                        context_before.append(line)\n        225:                    else:\n        226:                        context_after.append(line)\n        227:                elif line.startswith('-'):\n        228:                    removals.append(line[1:])\n        229:                elif line.startswith('+'):\n        230:                    additions.append(line[1:])\n        231:            if not removals and (not additions):\n        232:                return f'Error: No additons or removals found in hunk starting with {hunk_lines[0][0:20]}'\n        233:                continue\n        234:\n        235:            # Create a new file if appropriate\n        236:            if len(current_lines) == 0 and old_start == 0 and (not context_before) and (not removals):\n        237:                current_lines.extend(additions)\n        238:                changes_made.append('Applied changes to new file')\n        239:                continue\n        240:\n        241:            adjusted_start = old_start + line_offset\n        242:            found = False\n        243:            match_line = adjusted_start\n        244:            exact_match = False\n        245:\n        246:            # Try to match at expected position with or without whitespace (0-based)\n        247:            if adjusted_start <= len(current_lines):\n        248:                found, was_whitespace = _check_match_type(current_lines, adjusted_start, context_before)\n        249:                if found:\n        250:                    exact_match = not was_whitespace\n        251:                    if was_whitespace:\n        252:                        changes_made.append(f'Note: Applied hunk starting with {hunk_lines[0][0:20]}, but had to ignore whitespace to find match')\n        253:                    else:\n        254:                        changes_made.append(f'Applied hunk starting with {hunk_lines[0][0:20]} with exact match')\n        255:\n        256:            # Try to match at any position with or without whitespace\n        257:            if not found:\n        258:                matches = []\n        259:                whitespace_matches = []\n        260:                for i in range(0, len(current_lines) - len(context_before) + 1):  # start at 0!\n        261:                    found, was_whitespace = _check_match_type(current_lines, i, context_before)\n        262:                    if found:\n        263:                        if was_whitespace:\n        264:                            whitespace_matches.append(i)\n        265:                        else:\n        266:                            matches.append(i)\n        267:                            exact_match = True\n        268:\n        269:                # Apply exact match if exactly one is found\n        270:                if matches:\n        271:                    if len(matches) > 1:\n        272:                        match_locations = '\\n'.join((f'- at line {m + 1}' for m in matches))\n        273:                        return f'Error: Multiple possible matches found:\\n{match_locations} for hunk starting with {hunk_lines[0][0:20]}\\nPlease provide more context to disambiguate.'\n        274:                    match_line = matches[0]\n        275:                    changes_made.append(f'Note: Applied hunk starting with {hunk_lines[0][0:20]} at line {match_line + 1} (different from specified line {old_start + 1})')\n        276:                    found = True\n        277:\n        278:                # Apply whitespace match if exactly one is found (and no exact match found)\n        279:                elif whitespace_matches:\n        280:                    if len(whitespace_matches) > 1:\n        281:                        match_locations = '\\n'.join((f'- at line {m + 1}' for m in whitespace_matches))\n        282:                        return f'Error: Multiple possible matches found:\\n{match_locations}\\nPlease provide more context to disambiguate.'\n        283:                    match_line = whitespace_matches[0]\n        284:                    changes_made.append(f'Note: Applied hunk starting with {hunk_lines[0][0:20]} at line {match_line + 1} (different from specified line {old_start + 1}), and had to ignore whitespace to find match')\n        285:                    found = True\n        286:\n        287:            # If no match found ignoring position and whitespace, send error with best match.\n        288:            if not found and context_before:\n        289:                _, best_line, match_quality, _ = _find_block_in_content(current_lines, context_before, ignore_whitespace=True)\n        290:                if match_quality > 0.05:\n        291:                    context = _get_context(current_lines, best_line - 1, 2)\n        292:                    return f'Error: Could not find match. Best potential match: {best_line}\\nContext:\\n{context}\\nMatch quality: {match_quality:.2f}'\n        293:                else:\n        294:                    context = _get_context(current_lines, old_start, 2) if old_start >= 0 else []\n        295:                    return f'Error: Could not find match or close match.\\nExpected:\\n{context_before}\\nFound:\\n{context}'\n        296:\n        297:            # Apply changes\n        298:            pos = match_line + len(context_before)\n        299:            if exact_match:\n        300:                indented_additions = additions\n        301:            else:\n        302:                target_indent = ''\n        303:                if len(current_lines) > 0:\n        304:                    if pos < len(current_lines):\n        305:                        if removals:\n        306:                            target_indent = _get_line_indentation(current_lines[pos])\n        307:                        else:\n        308:                            target_indent = _get_line_indentation(current_lines[pos - 1]) if pos > 0 else ''\n        309:                    elif pos > 0:\n        310:                        target_indent = _get_line_indentation(current_lines[pos - 1])\n        311:                indented_additions = _adjust_indentation(additions, target_indent)\n        312:            if removals:\n        313:                current_lines[pos:pos + len(removals)] = indented_additions\n        314:            else:\n        315:                current_lines[pos:pos] = indented_additions\n        316:            line_offset += len(additions) - len(removals)\n        317:        if changes_made:\n        318:            new_content = '\\n'.join(current_lines)\n        319:            if not new_content.endswith('\\n'):\n        320:                new_content += '\\n'\n        321:            with open(file_path, 'w', encoding=used_encoding) as file:\n        322:                file.write(new_content)\n        323:            return 'Successfully applied patches:\\n' + '\\n'.join(changes_made)\n        324:        return 'No changes were applied'\n        325:    except Exception as e:\n        326:        return f'Error: {str(e)}\\n{traceback.format_exc()}'\n        327:\n        328:def _get_context(lines, center_idx, context_size):\n        329:    \"\"\"Get context lines around an index with line numbers.\"\"\"\n        330:    start = max(0, center_idx - context_size)\n        331:    end = min(len(lines), center_idx + context_size + 1)\n        332:    return [f'{i + 1}:{line}' for i, line in enumerate(lines[start:end], start)]\n        333:\n        334:def _find_block_in_content(content_lines: list, block_lines: list, ignore_whitespace: bool=False) -> tuple[bool, int, float, bool]:\n        335:    \"\"\"Helper function to find a block of lines anywhere in the content.\n        336:    Returns (found, line_number, match_quality, was_whitespace_match)\"\"\"\n        337:    if not block_lines:\n        338:        return (False, 0, 0.0, False)\n        339:    for i in range(len(content_lines) - len(block_lines) + 1):\n        340:        current_block = content_lines[i:i + len(block_lines)]\n        341:        if current_block == block_lines:\n        342:            return (True, i + 1, 1.0, False)\n        343:    if ignore_whitespace:\n        344:        for i in range(len(content_lines) - len(block_lines) + 1):\n        345:            current_block = [l.strip() for l in content_lines[i:i + len(block_lines)]]\n        346:            block_to_match = [l.strip() for l in block_lines]\n        347:            if current_block == block_to_match:\n        348:                return (True, i + 1, 0.9, True)\n        349:    best_match = 0.0\n        350:    best_line = 0\n        351:    for i in range(len(content_lines) - len(block_lines) + 1):\n        352:        current_block = content_lines[i:i + len(block_lines)]\n        353:        matcher = difflib.SequenceMatcher(None, '\\n'.join(current_block), '\\n'.join(block_lines))\n        354:        ratio = matcher.ratio()\n        355:        if ratio > best_match:\n        356:            best_match = ratio\n        357:            best_line = i + 1\n        358:    return (False, best_line, best_match, False)\n        359:\n        360:def _get_line_indentation(line: str) -> str:\n        361:    \"\"\"Extract the indentation from a line.\"\"\"\n        362:    return line[:len(line) - len(line.lstrip())]\n        363:\n        364:def _check_match_type(content_lines: list, start_pos: int, context_lines: list, removal_lines: list=None) -> tuple[bool, bool]:\n        365:    \"\"\"\n        366:    Check if there's a match at the given position (0-based).\n        367:    Returns (found_match, was_whitespace_match)\n        368:    \"\"\"\n        369:    if start_pos + len(context_lines) > len(content_lines):\n        370:        return (False, False)\n        371:    context_exact = True\n        372:    context_whitespace = True\n        373:    for i, ctx_line in enumerate(context_lines):\n        374:        content_line = content_lines[start_pos + i]\n        375:        if content_line != ctx_line:\n        376:            context_exact = False\n        377:        if content_line.strip() != ctx_line.strip():\n        378:            context_whitespace = False\n        379:    if not context_whitespace:\n        380:        return (False, False)\n        381:    if removal_lines:\n        382:        pos = start_pos + len(context_lines)\n        383:        if pos + len(removal_lines) > len(content_lines):\n        384:            return (False, False)\n        385:        for i, rem_line in enumerate(removal_lines):\n        386:            content_line = content_lines[pos + i]\n        387:            if content_line != rem_line:\n        388:                context_exact = False\n        389:            if content_line.strip() != rem_line.strip():\n        390:                return (False, False)\n        391:    return (True, not context_exact)\n        392:\n        393:def _normalize_path(file_path: str) -> str:\n        394:    \"\"\"\n        395:    Normalize file path to use consistent separators and handle both / and \\\\.\n        396:\n        397:    Args:\n        398:        file_path (str): The file path to normalize\n        399:\n        400:    Returns:\n        401:        str: Normalized path using os.path.sep\n        402:    \"\"\"\n        403:    return os.path.normpath(file_path.replace('\\\\', '/').replace('//', '/'))\n        404:\n        405:def _normalize_header_lines(lines):\n        406:    \"\"\"\n        407:    Normalize only the hunk headers (@@ lines) in a patch.\n        408:    Leaves all other lines unchanged.\n        409:\n        410:    Args:\n        411:        lines (list[str]): List of patch lines\n        412:\n        413:    Returns:\n        414:        list[str]: Lines with normalized hunk headers\n        415:    \"\"\"\n        416:    normalized = []\n        417:    for line in lines:\n        418:        if not line:\n        419:            normalized.append(line)\n        420:            continue\n        421:        if line.startswith('@@'):\n        422:            parts = line.split('@@')\n        423:            if len(parts) >= 2:\n        424:                ranges = parts[1].strip()\n        425:                line = f'@@ {ranges} @@'\n        426:        normalized.append(line)\n        427:    return normalized\n        428:\n        429:def _adjust_indentation(lines: list, target_indent: str) -> list:\n        430:    \"\"\"\n        431:    Adjust indentation of a block of lines to match target indent while preserving relative indentation.\n        432:    First applies target indentation to all lines, then preserves additional relative indentation.\n        433:\n        434:    Args:\n        435:        lines (list[str]): Lines to adjust\n        436:        target_indent (str): Target base indentation\n        437:\n        438:    Returns:\n        439:        list[str]: Lines with adjusted indentation\n        440:    \"\"\"\n        441:    if not lines:\n        442:        return lines\n        443:    base_indent = None\n        444:    for line in lines:\n        445:        if line.strip():\n        446:            base_indent = _get_line_indentation(line)\n        447:            break\n        448:    if base_indent is None:\n        449:        return lines\n        450:    adjusted_lines = []\n        451:    for line in lines:\n        452:        if not line.strip():\n        453:            adjusted_lines.append('')\n        454:            continue\n        455:        current_indent = _get_line_indentation(line)\n        456:        relative_indent = len(current_indent) - len(base_indent)\n        457:        new_indent = target_indent + ' ' * max(0, relative_indent)\n        458:        adjusted_lines.append(new_indent + line.lstrip())\n        459:    return adjusted_lines"
