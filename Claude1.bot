                                          "tool_use_id": "toolu_01QLLmpQ1mLMsoLd4brdUNc4",
                                          "content": "\n        728:\n        729:    # Append to the log file\n        730:    try:\n        731:        with open(log_file_path, 'a', encoding='utf-8') as log_file:\n        732:            log_file.write(log_entry)\n        733:    except Exception as e:\n        734:        # If we can't write to the log file, at least print to stderr\n        735:        print(f\"Failed to write to error log: {e}\", file=sys.stderr)\n        736:        print(f\"Original error: {log_entry}\", file=sys.stderr)\n        737:\n        738:def handle_errors(func: Callable) -> Callable:\n        739:    \"\"\"Decorator that catches exceptions and returns formatted error strings instead of raising.\n        740:    Use when you want a function to return error messages as strings rather than raising\n        741:    exceptions. This is useful for tools and APIs that need to handle errors gracefully\n        742:    and return error information to callers.\n        743:    The decorator uses the _process_error helper function to format exceptions into\n        744:    detailed error messages including tracebacks.\n        745:    Parameters:\n        746:        func (Callable): The function to wrap with error handling\n        747:    Returns:\n        748:        Callable: A wrapped version of the function that returns error strings instead of raising\n        749:    Example:\n        750:        @handle_errors\n        751:        def risky_operation(data):\n        752:            # If this raises an exception, it will be caught and returned as a string\n        753:            return process_data(data)\n        754:        result = risky_operation(bad_data)\n        755:        if result.startswith(\"Tool Failed:\"):\n        756:            print(f\"Operation failed: {result}\")\n        757:    \"\"\"\n        758:    from bots.utils.helpers import _process_error\n        759:    @wraps(func)\n        760:    def wrapper(*args: Any, **kwargs: Any) -> Any:"
