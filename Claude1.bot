              "tool_use_id": "toolu_01B9xEQUHR2dLtet81ahLecd",
              "content": "\n        1:\"\"\"Utility functions for error handling, file operations, and text processing.\n        2:\n        3:This module provides helper functions for common operations including:\n        4:- Error formatting and traceback handling\n        5:- File system operations and timestamp-based file filtering\n        6:- Code block extraction from markdown text\n        7:- AST manipulation and code cleaning\n        8:- Datetime formatting for filenames\n        9:\"\"\"\n        10:\n        11:import traceback\n        12:import os\n        13:from typing import List, Tuple\n        14:import datetime as DT\n        15:import re\n        16:import textwrap\n        17:import ast\n        18:\n        19:def _process_error(error: Exception) -> str:\n        20:    \"\"\"Format an exception into a detailed error message string.\n        21:\n        22:    Internal helper function for consistent error message formatting.\n        23:    Combines the error message with a full traceback for debugging.\n        24:    Used by tool functions to provide detailed error information\n        25:    without raising exceptions.\n        26:\n        27:    Parameters:\n        28:        error (Exception): The exception to process. Can be any exception type.\n        29:\n        30:    Returns:\n        31:        str: Formatted error message including:\n        32:            - Error type and message\n        33:            - Full traceback with line numbers and context\n        34:    \"\"\"\n        35:    error_message = f'Tool Failed: {str(error)}\\n'\n        36:    error_message += (\n        37:        f\"Traceback:\\n{''.join(traceback.format_tb(error.__traceback__))}\")\n        38:    return error_message\n        39:\n        40:def _get_new_files(start_time: float, directory: str = \".\", extension: str = None) -> List[str]:\n        41:    \"\"\"Get all files created after a specified timestamp in a directory tree.\n        42:\n        43:    Internal helper function for finding newly created files.\n        44:    Performs a recursive search through the directory tree and its subdirectories.\n        45:\n        46:    Parameters:\n        47:        start_time (float): Unix timestamp to filter files created after\n        48:        directory (str, optional): Root directory to start search from. Defaults to current directory\n        49:        extension (str, optional): File extension to filter by including the dot (e.g. '.py', '.txt').\n        50:            If None, returns files with any extension. Defaults to None\n        51:\n        52:    Returns:\n        53:        List[str]: List of absolute file paths for files created after start_time.\n        54:            Paths are returned in the order they are discovered during directory traversal.\n        55:    \"\"\"\n        56:    new_files = []\n        57:\n        58:    for root, _, files in os.walk(directory):\n        59:        for file in files:\n        60:            path = os.path.join(root, file)\n        61:            if os.path.getctime(path) >= start_time:\n        62:                if extension is None or os.path.splitext(path)[1] == extension:\n        63:                    new_files.append(path)\n        64:\n        65:    return new_files\n        66:\n        67:def _clean(code: str) -> str:\n        68:    \"\"\"Clean and dedent code before parsing by removing common leading whitespace.\n        69:\n        70:    Internal helper function for code formatting. Removes any common leading\n        71:    whitespace (spaces or tabs) from every line in the text while preserving\n        72:    relative indentation. Also strips leading/trailing whitespace from the\n        73:    entire string.\n        74:\n        75:    Parameters:\n        76:        code (str): The code string to clean. Can be single or multiple lines.\n        77:\n        78:    Returns:\n        79:        str: The cleaned and dedented code with consistent indentation\n        80:\n        81:    Example:\n        82:        >>> code = '''\n        83:        ...     def example():\n        84:        ...         print(\"hello\")\n        85:        ... '''\n        86:        >>> _clean(code)\n        87:        'def example():\\n    print(\"hello\")'\n        88:    \"\"\"\n        89:    return textwrap.dedent(code).strip()\n        90:\n        91:def _py_ast_to_source(node: ast.AST) -> str:\n        92:    \"\"\"Convert a Python AST node back to valid Python source code.\n        93:\n        94:    Internal helper function for AST manipulation. Uses ast.unparse() to convert\n        95:    AST nodes back to source code. Works with any valid Python AST node type\n        96:    (Module, FunctionDef, ClassDef, etc.).\n        97:\n        98:    Parameters:\n        99:        node (ast.AST): The AST node to convert. Must be a valid node from the ast module.\n        100:            Common types include: ast.Module, ast.FunctionDef, ast.ClassDef, ast.Expr\n        101:\n        102:    Returns:\n        103:        str: The source code representation of the AST node. The output will be\n        104:            valid Python code that could be executed or compiled.\n        105:\n        106:    Note:\n        107:        Requires Python 3.9+ for ast.unparse(). Comments and formatting from the\n        108:        original source code are not preserved in the output.\n        109:    \"\"\"\n        110:    return ast.unparse(node)\n        111:\n        112:def remove_code_blocks(text: str) -> Tuple[List[str], List[str]]:\n        113:    \"\"\"Extract code blocks and their language labels from markdown-formatted text.\n        114:\n        115:    Use when you need to parse markdown text containing fenced code blocks\n        116:    (```language code```) and separate the code blocks from the rest of the text.\n        117:    Handles multiple code blocks and preserves their order. The function matches\n        118:    code blocks using a regex pattern that supports optional language labels and\n        119:    handles both single and multi-line code blocks.\n        120:\n        121:    Parameters:\n        122:        text (str): Markdown-formatted text containing code blocks. Code blocks\n        123:            must be fenced with triple backticks (```). Language label after\n        124:            opening fence is optional.\n        125:\n        126:    Returns:\n        127:        Tuple[List[str], List[str]]: A tuple containing:\n        128:            - List[str]: Extracted code blocks with whitespace trimmed, in order of appearance\n        129:            - List[str]: Language labels (empty string if no label specified)\n        130:            The lists will have matching lengths, with each index corresponding\n        131:            to the same code block.\n        132:\n        133:    Example:\n        134:        >>> text = '''\n        135:        ... Here's some Python code:\n        136:        ... ```python\n        137:        ... def hello():\n        138:        ...     print('hello')\n        139:        ... ```\n        140:        ... And some unlabeled code:\n        141:        ... ```\n        142:        ... console.log('hi');\n        143:        ... ```\n        144:        ... '''\n        145:        >>> code_blocks, labels = remove_code_blocks(text)\n        146:        >>> code_blocks  # [\"def hello():\\n    print('hello')\", \"console.log('hi');\"]\n        147:        >>> labels      # [\"python\", \"\"]\n        148:    \"\"\"\n        149:    pattern = '```(\\\\w*)\\\\s*([\\\\s\\\\S]*?)```'\n        150:    matches = re.findall(pattern, text)\n        151:    code_blocks = [match[1].strip() for match in matches]\n        152:    labels = [match[0].strip() for match in matches]\n        153:    text = re.sub(pattern, '', text)\n        154:    return code_blocks, labels\n        155:\n        156:def formatted_datetime() -> str:\n        157:    \"\"\"Get current datetime formatted as a string suitable for filenames.\n        158:\n        159:    Use when you need a timestamp string that is safe to use in file paths\n        160:    across different operating systems. The format uses only characters that\n        161:    are valid in filenames on Windows, macOS, and Linux.\n        162:\n        163:    Format components:\n        164:        YYYY: Four-digit year\n        165:        MM: Two-digit month (01-12)\n        166:        DD: Two-digit day (01-31)\n        167:        HH: Two-digit hour in 24-hour format (00-23)\n        168:        MM: Two-digit minute (00-59)\n        169:        SS: Two-digit second (00-59)\n        170:\n        171:    Returns:\n        172:        str: Current local datetime formatted as 'YYYY-MM-DD_HH-MM-SS'.\n        173:            Uses system's local timezone. Time components are separated\n        174:            by hyphens, date and time are separated by underscore.\n        175:\n        176:    Example:\n        177:        >>> formatted_datetime()\n        178:        '2023-12-25_14-30-45'  # December 25th, 2023, 2:30:45 PM local time\n        179:\n        180:    Note:\n        181:        Uses local system time. For timezone-aware timestamps, consider using\n        182:        datetime.datetime.now(timezone.utc) instead.\n        183:    \"\"\"\n        184:    now = DT.datetime.now()\n        185:    return now.strftime('%Y-%m-%d_%H-%M-%S')"
             }
