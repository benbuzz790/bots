                                      "type": "tool_result",
                                      "tool_use_id": "toolu_01B3MLSbLHHhuzKoafYgWpkM",
                                      "content": "\n        1:import ast\n        2:import os\n        3:from bots.utils.helpers import _process_error, _clean, _py_ast_to_source\n        4:from bots.dev.decorators import handle_errors\n        5:\n        6:class NodeTransformerWithAsyncSupport(ast.NodeTransformer):\n        7:    \"\"\"Base class for AST transformers that need to handle both sync and async functions.\"\"\"\n        8:\n        9:    def __init__(self):\n        10:        self.success = False\n        11:\n        12:    def visit_FunctionDef(self, node):\n        13:        return self._handle_function(node)\n        14:\n        15:    def visit_AsyncFunctionDef(self, node):\n        16:        return self._handle_function(node)\n        17:\n        18:    def _handle_function(self, node):\n        19:        \"\"\"Override this method in subclasses to implement specific transformation logic\"\"\"\n        20:        raise NotImplementedError\n        21:\n        22:class FunctionReplacer(NodeTransformerWithAsyncSupport):\n        23:\n        24:    def __init__(self, new_func_node):\n        25:        super().__init__()\n        26:        self.new_func_node = new_func_node\n        27:\n        28:    def _handle_function(self, node):\n        29:        if node.name == self.new_func_node.name:\n        30:            self.success = True\n        31:            return self.new_func_node\n        32:        return node\n        33:\n        34:class MethodAdder(NodeTransformerWithAsyncSupport):\n        35:\n        36:    def __init__(self, class_name, new_method_node):\n        37:        super().__init__()\n        38:        self.class_name = class_name\n        39:        self.new_method_node = new_method_node\n        40:\n        41:    def visit_ClassDef(self, node):\n        42:        if node.name == self.class_name:\n        43:            self.success = True\n        44:            node.body.append(self.new_method_node)\n        45:            return node\n        46:        return node\n        47:\n        48:    def _handle_function(self, node):\n        49:        return node\n        50:\n        51:@handle_errors\n        52:def add_imports(file_path: str, code: str) -> str:\n        53:    \"\"\"\n        54:    Adds multiple import statements to a Python file.\n        55:    Avoids adding duplicate imports.\n        56:\n        57:    Parameters:\n        58:    - file_path (str): The path to the file where the imports will be added\n        59:    - code (str): Import statements, which can include parenthesized multi-line imports\n        60:\n        61:    Returns a confirmation message or an error message.\n        62:\n        63:    cost: very low\n        64:    \"\"\"\n        65:    try:\n        66:        abs_path = _make_file(file_path)\n        67:        lines = code.strip().split('\\n')\n        68:        import_blocks = []\n        69:        current_block = []\n        70:        in_parentheses = False\n        71:        for line in lines:\n        72:            stripped = line.strip()\n        73:            if not stripped:\n        74:                continue\n        75:            if '(' in stripped and (not stripped.endswith(')')):\n        76:                in_parentheses = True\n        77:                current_block.append(stripped)\n        78:            elif ')' in stripped and in_parentheses:\n        79:                in_parentheses = False\n        80:                current_block.append(stripped)\n        81:                import_blocks.append('\\n'.join(current_block))\n        82:                current_block = []\n        83:            elif in_parentheses:\n        84:                current_block.append(stripped)\n        85:            elif current_block:\n        86:                current_block.append(stripped)\n        87:            else:\n        88:                import_blocks.append(stripped)\n        89:        if current_block:\n        90:            import_blocks.append('\\n'.join(current_block))\n        91:        new_import_nodes = []\n        92:        for stmt in import_blocks:\n        93:            try:\n        94:                node = ast.parse(_clean(stmt)).body[0]\n        95:                if not isinstance(node, (ast.Import, ast.ImportFrom)):\n        96:                    return _process_error(ValueError(f'Invalid import statement: {stmt}'))\n        97:                new_import_nodes.append(node)\n        98:            except Exception as e:\n        99:                return _process_error(ValueError(f'Error parsing import statement \"{stmt}\": {str(e)}'))\n        100:        try:\n        101:            with open(abs_path, 'r', encoding='utf-8') as file:\n        102:                content = file.read()\n        103:        except Exception as e:\n        104:            return _process_error(ValueError(f'Error reading file {abs_path}: {str(e)}'))\n        105:        if not content.strip():\n        106:            with open(abs_path, 'w', encoding='utf-8') as file:\n        107:                file.write('\\n'.join(import_blocks) + '\\n')\n        108:            return f\"{len(import_blocks)} imports have been added to new file '{abs_path}'.\"\n        109:        try:\n        110:            tree = ast.parse(content)\n        111:        except Exception as e:\n        112:            return _process_error(ValueError(f'Error parsing the file {abs_path}: {str(e)}'))\n        113:        added_imports = []\n        114:        existing_imports = []\n        115:\n        116:        def normalize_import(node):\n        117:            \"\"\"Helper to normalize import node to string for comparison\"\"\"\n        118:            return _py_ast_to_source(node).strip().replace(' ', '')\n        119:        for new_node in new_import_nodes:\n        120:            new_stmt_normalized = normalize_import(new_node)\n        121:            is_duplicate = False\n        122:            for existing_node in tree.body:\n        123:                if isinstance(existing_node, (ast.Import, ast.ImportFrom)):\n        124:                    if normalize_import(existing_node) == new_stmt_normalized:\n        125:                        existing_imports.append(_py_ast_to_source(new_node).strip())\n        126:                        is_duplicate = True\n        127:                        break\n        128:            if not is_duplicate:\n        129:                added_imports.append(_py_ast_to_source(new_node).strip())\n        130:        if added_imports:\n        131:            last_import_idx = -1\n        132:            for i, node in enumerate(tree.body):\n        133:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        134:                    last_import_idx = i\n        135:            for node in new_import_nodes:\n        136:                if _py_ast_to_source(node).strip() in added_imports:\n        137:                    tree.body.insert(last_import_idx + 1, node)\n        138:                    last_import_idx += 1\n        139:            try:\n        140:                updated_content = _py_ast_to_source(tree)\n        141:                with open(abs_path, 'w', encoding='utf-8') as file:\n        142:                    file.write(updated_content)\n        143:            except Exception as e:\n        144:                return _process_error(e)\n        145:        result_parts = []\n        146:        if added_imports:\n        147:            result_parts.append(f\"Added {len(added_imports)} new imports to '{abs_path}'\")\n        148:        if existing_imports:\n        149:            result_parts.append(f'Found {len(existing_imports)} existing imports')\n        150:        if not result_parts:\n        151:            raise ValueError('No valid import statements found')\n        152:        return '. '.join(result_parts) + '.'\n        153:    except Exception as e:\n        154:        return _process_error(e)\n        155:\n        156:@handle_errors\n        157:def remove_import(file_path: str, import_to_remove: str) -> str:\n        158:    \"\"\"\n        159:    Removes an import statement from a Python file.\n        160:\n        161:    Parameters:\n        162:    - file_path (str): The path to the file to modify\n        163:    - import_to_remove (str): The import statement to remove (e.g., \"import os\" or \"from typing import List\")\n        164:        Must match the existing import statement exactly.\n        165:\n        166:    Returns a confirmation message or an error message.\n        167:\n        168:    cost: very low\n        169:    \"\"\"\n        170:    if not os.path.exists(file_path):\n        171:        return _process_error(ValueError(f'File {file_path} does not exist'))\n        172:    try:\n        173:        remove_node = ast.parse(import_to_remove).body[0]\n        174:        if not isinstance(remove_node, (ast.Import, ast.ImportFrom)):\n        175:            return _process_error(ValueError('Provided statement is not a valid import'))\n        176:    except Exception as e:\n        177:        return _process_error(ValueError(f'Error parsing import statement: {str(e)}'))\n        178:    try:\n        179:        with open(file_path, 'r', encoding='utf-8') as file:\n        180:            content = file.read()\n        181:        tree = ast.parse(content)\n        182:    except Exception as e:\n        183:        return _process_error(ValueError(f'Error parsing the file {file_path}: {str(e)}'))\n        184:    original_length = len(tree.body)\n        185:    new_body = []\n        186:    found = False\n        187:    for node in tree.body:\n        188:        if isinstance(node, (ast.Import, ast.ImportFrom)):\n        189:            node_str = _py_ast_to_source(node).strip()\n        190:            if node_str == import_to_remove:\n        191:                found = True\n        192:                continue\n        193:        new_body.append(node)\n        194:    if not found:\n        195:        return f\"Import '{import_to_remove}' not found in '{file_path}'.\"\n        196:    tree.body = new_body\n        197:    try:\n        198:        updated_content = _py_ast_to_source(tree)\n        199:        with open(file_path, 'w', encoding='utf-8') as file:\n        200:            file.write(updated_content)\n        201:    except Exception as e:\n        202:        return _process_error(e)\n        203:    return f\"Import '{import_to_remove}' has been removed from '{file_path}'.\"\n        204:\n        205:@handle_errors\n        206:def replace_import(file_path: str, old_import: str, new_import: str) -> str:\n        207:    \"\"\"\n        208:    Replaces an existing import statement in a Python file.\n        209:\n        210:    Parameters:\n        211:    - file_path (str): The path to the file to modify\n        212:    - old_import (str): The existing import statement to replace\n        213:    - new_import (str): The new import statement\n        214:\n        215:    Returns a confirmation message or an error message.\n        216:\n        217:    cost: very low\n        218:    \"\"\"\n        219:    if not os.path.exists(file_path):\n        220:        return _process_error(ValueError(f'File {file_path} does not exist'))\n        221:    try:\n        222:        old_node = ast.parse(_clean(old_import)).body[0]\n        223:        new_node = ast.parse(_clean(new_import)).body[0]\n        224:        if not isinstance(old_node, (ast.Import, ast.ImportFrom)) or not isinstance(new_node, (ast.Import, ast.ImportFrom)):\n        225:            return _process_error(ValueError('Both statements must be valid imports'))\n        226:    except Exception as e:\n        227:        return _process_error(ValueError(f'Error parsing import statements: {str(e)}'))\n        228:    try:\n        229:        with open(file_path, 'r', encoding='utf-8') as file:\n        230:            content = file.read()\n        231:        tree = ast.parse(content)\n        232:    except Exception as e:\n        233:        return _process_error(ValueError(f'Error parsing the file {file_path}: {str(e)}'))\n        234:    found = False\n        235:    for i, node in enumerate(tree.body):\n        236:        if isinstance(node, (ast.Import, ast.ImportFrom)):\n        237:            node_str = _py_ast_to_source(node).strip()\n        238:            if node_str == old_import:\n        239:                tree.body[i] = new_node\n        240:                found = True\n        241:                break\n        242:    if not found:\n        243:        return f\"Import '{old_import}' not found in '{file_path}'.\"\n        244:    try:\n        245:        updated_content = _py_ast_to_source(tree)\n        246:        with open(file_path, 'w', encoding='utf-8') as file:\n        247:            file.write(updated_content)\n        248:    except Exception as e:\n        249:        return _process_error(e)\n        250:    return f\"Import '{old_import}' has been updated to '{new_import}' in '{file_path}'.\"\n        251:\n        252:@handle_errors\n        253:def add_class(file_path: str, class_def: str) -> str:\n        254:    \"\"\"\n        255:    Adds a new class definition to an existing Python file.\n        256:\n        257:    Parameters:\n        258:    - file_path (str): The path to the file where the new class will be added\n        259:    - class_def (str): The new class definition as a string\n        260:\n        261:    Returns a confirmation message or an error message.\n        262:\n        263:    cost: low\n        264:    \"\"\"\n        265:    try:\n        266:        abs_path = _make_file(file_path)\n        267:        try:\n        268:            new_tree = ast.parse(_clean(class_def))\n        269:            new_class_node = None\n        270:            for node in new_tree.body:\n        271:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        272:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        273:                elif isinstance(node, ast.ClassDef):\n        274:                    new_class_node = node\n        275:            if new_class_node is None:\n        276:                return _process_error(ValueError('No class definition found in provided code'))\n        277:            with open(abs_path, 'r', encoding='utf-8') as file:\n        278:                content = file.read()\n        279:            tree = ast.parse(content)\n        280:        except Exception as e:\n        281:            return _process_error(ValueError(f'Error processing code: {str(e)}'))\n        282:        tree.body.append(new_class_node)\n        283:        try:\n        284:            updated_content = _py_ast_to_source(tree)\n        285:            with open(abs_path, 'w', encoding='utf-8') as file:\n        286:                file.write(updated_content)\n        287:        except Exception as e:\n        288:            return _process_error(e)\n        289:        return f\"Class '{new_class_node.name}' has been added to '{abs_path}'.\"\n        290:    except Exception as e:\n        291:        return _process_error(e)\n        292:\n        293:@handle_errors\n        294:def replace_class(file_path: str, new_class_def: str, old_class_name: str=None) -> str:\n        295:    \"\"\"\n        296:    Replaces a class definition in a file with a new class definition.\n        297:\n        298:    Parameters:\n        299:    - file_path (str): The path to the file to modify\n        300:    - new_class_def (str): The new class definition\n        301:    - old_class_name (str, optional): The name of the class to replace\n        302:\n        303:    Returns a confirmation message or an error message.\n        304:\n        305:    cost: low\n        306:    \"\"\"\n        307:    try:\n        308:        abs_path = _make_file(file_path)\n        309:        try:\n        310:            new_tree = ast.parse(_clean(new_class_def))\n        311:            new_class_node = None\n        312:            for node in new_tree.body:\n        313:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        314:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        315:                elif isinstance(node, ast.ClassDef):\n        316:                    new_class_node = node\n        317:                    if old_class_name is None:\n        318:                        old_class_name = node.name\n        319:            if new_class_node is None:\n        320:                return _process_error(ValueError('No class definition found in provided code'))\n        321:            with open(abs_path, 'r', encoding='utf-8') as file:\n        322:                content = file.read()\n        323:            tree = ast.parse(content)\n        324:        except Exception as e:\n        325:            return _process_error(ValueError(f'Error processing code: {str(e)}'))\n        326:\n        327:        class ClassReplacer(NodeTransformerWithAsyncSupport):\n        328:\n        329:            def visit_ClassDef(self, node):\n        330:                if node.name == old_class_name:\n        331:                    self.success = True\n        332:                    return new_class_node\n        333:                return node\n        334:\n        335:            def _handle_function(self, node):\n        336:                return node\n        337:        transformer = ClassReplacer()\n        338:        tree = transformer.visit(tree)\n        339:        if not transformer.success:\n        340:            tree.body.append(new_class_node)\n        341:        try:\n        342:            updated_content = _py_ast_to_source(tree)\n        343:            with open(abs_path, 'w', encoding='utf-8') as file:\n        344:                file.write(updated_content)\n        345:        except Exception as e:\n        346:            return _process_error(e)\n        347:        action = 'replaced in' if transformer.success else 'added to'\n        348:        return f\"Class '{new_class_node.name}' has been {action} '{abs_path}'.\"\n        349:    except Exception as e:\n        350:        return _process_error(e)\n        351:\n        352:@handle_errors\n        353:def add_function_to_class(file_path: str, class_name: str, new_method_def: str) -> str:\n        354:    \"\"\"\n        355:    Adds one or more methods to an existing class in a Python file.\n        356:\n        357:    Parameters:\n        358:    - file_path (str): The path to the file to modify\n        359:    - class_name (str): The name of the class to modify\n        360:    - new_method_def (str): One or more method definitions as a string\n        361:\n        362:    Returns a confirmation message or an error message.\n        363:\n        364:    cost: very low\n        365:    \"\"\"\n        366:    try:\n        367:        tree = ast.parse(_clean(new_method_def))\n        368:        messages = []\n        369:        for node in tree.body:\n        370:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        371:                add_imports(file_path, _py_ast_to_source(node).strip())\n        372:        found_method = False\n        373:        for node in tree.body:\n        374:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        375:                found_method = True\n        376:                method_source = _py_ast_to_source(node)\n        377:                result = _add_single_function_to_class(file_path, class_name, method_source)\n        378:                messages.append(result)\n        379:        if not found_method:\n        380:            return _process_error(ValueError('No method definitions found in provided code'))\n        381:        return '\\n'.join(messages)\n        382:    except Exception as e:\n        383:        return _process_error(e)\n        384:\n        385:@handle_errors\n        386:def add_function_to_file(file_path: str, new_function_def: str, class_name: str=None) -> str:\n        387:    \"\"\"\n        388:    Adds one or more function definitions to an existing Python file.\n        389:\n        390:    When adding complex code blocks:\n        391:    - Imports are moved to the top of the file\n        392:    - Functions are added in order of appearance\n        393:    - Non-function code (assignments, if blocks, etc.) is preserved but may be reordered\n        394:    - Comments are not preserved (limitation of AST)\n        395:\n        396:    Parameters:\n        397:    - file_path (str): The path to the file to modify\n        398:    - new_function_def (str): One or more function definitions as a string\n        399:    - class_name (str, optional): If provided, add functions to this class\n        400:\n        401:    Returns a confirmation message or an error message.\n        402:\n        403:    cost: very low\n        404:    \"\"\"\n        405:    try:\n        406:        tree = ast.parse(_clean(new_function_def))\n        407:        messages = []\n        408:        for node in tree.body:\n        409:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        410:                add_imports(file_path, _py_ast_to_source(node).strip())\n        411:        found_function = False\n        412:        remaining_nodes = []\n        413:        for node in tree.body:\n        414:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        415:                found_function = True\n        416:                function_source = _py_ast_to_source(node)\n        417:                if class_name:\n        418:                    result = add_function_to_class(file_path, class_name, function_source)\n        419:                else:\n        420:                    result = _add_single_function_to_file(file_path, function_source)\n        421:                messages.append(result)\n        422:            elif not isinstance(node, (ast.Import, ast.ImportFrom)):\n        423:                remaining_nodes.append(node)\n        424:        if not found_function:\n        425:            return _process_error(ValueError('No function definitions found in provided code'))\n        426:        if remaining_nodes:\n        427:            with open(file_path, 'r', encoding='utf-8') as file:\n        428:                content = file.read()\n        429:            existing_tree = ast.parse(content)\n        430:            existing_tree.body.extend(remaining_nodes)\n        431:            updated_content = _py_ast_to_source(existing_tree)\n        432:            with open(file_path, 'w', encoding='utf-8') as file:\n        433:                file.write(updated_content)\n        434:            messages.append(f'Added {len(remaining_nodes)} additional code blocks')\n        435:        return '\\n'.join(messages)\n        436:    except Exception as e:\n        437:        return _process_error(e)\n        438:\n        439:@handle_errors\n        440:def replace_function(file_path: str, new_function_def: str, class_name: str=None) -> str:\n        441:    \"\"\"\n        442:    Replaces one or more function definitions in a file with new function definitions.\n        443:\n        444:    Parameters:\n        445:    - file_path (str): The path to the file to modify\n        446:    - new_function_def (str): One or more function definitions as a string\n        447:    - class_name (str, optional): If provided, only replace functions within this class\n        448:\n        449:    Returns a confirmation message or an error message.\n        450:\n        451:    cost: very low\n        452:    \"\"\"\n        453:    try:\n        454:        tree = ast.parse(_clean(new_function_def))\n        455:        messages = []\n        456:        for node in tree.body:\n        457:            if isinstance(node, (ast.Import, ast.ImportFrom)):\n        458:                add_imports(file_path, _py_ast_to_source(node).strip())\n        459:        found_function = False\n        460:        for node in tree.body:\n        461:            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        462:                found_function = True\n        463:                function_source = _py_ast_to_source(node)\n        464:                result = _replace_single_function(file_path, function_source, class_name)\n        465:                messages.append(result)\n        466:        if not found_function:\n        467:            return _process_error(ValueError('No function definitions found in provided code'))\n        468:        return '\\n'.join(messages)\n        469:    except Exception as e:\n        470:        return _process_error(e)\n        471:\n        472:def _make_file(file_path: str) -> str:\n        473:    \"\"\"\n        474:    Creates a file and its parent directories if they don't exist.\n        475:    Converts relative paths to absolute paths.\n        476:\n        477:    Parameters:\n        478:    - file_path (str): The path to the file to be created\n        479:\n        480:    Returns:\n        481:    - str: The absolute path to the file\n        482:\n        483:    Raises:\n        484:    - ValueError: If there's an error creating the file or directories,\n        485:                 or if the file_path is empty\n        486:    \"\"\"\n        487:    if not file_path:\n        488:        raise ValueError('File path cannot be empty')\n        489:    abs_path = os.path.abspath(file_path)\n        490:    dir_path = os.path.dirname(abs_path)\n        491:    if dir_path:\n        492:        try:\n        493:            os.makedirs(dir_path, exist_ok=True)\n        494:        except Exception as e:\n        495:            raise ValueError(f'Error creating directories {dir_path}: {str(e)}')\n        496:    if not os.path.exists(abs_path):\n        497:        try:\n        498:            with open(abs_path, 'w', encoding='utf-8') as f:\n        499:                f.write('')\n        500:        except Exception as e:\n        501:            raise ValueError(f'Error creating file {abs_path}: {str(e)}')\n        502:    return abs_path\n        503:\n        504:@handle_errors\n        505:def _add_single_function_to_class(file_path: str, class_name: str, new_method_def: str) -> str:\n        506:    \"\"\"Adds a single method to a class.\"\"\"\n        507:    try:\n        508:        abs_path = _make_file(file_path)\n        509:        try:\n        510:            new_tree = ast.parse(_clean(new_method_def))\n        511:            new_method_node = None\n        512:            for node in new_tree.body:\n        513:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        514:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        515:                elif isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        516:                    new_method_node = node\n        517:            if new_method_node is None:\n        518:                return _process_error(ValueError('No method definition found in provided code'))\n        519:            with open(abs_path, 'r', encoding='utf-8') as file:\n        520:                content = file.read()\n        521:            if not content.strip():\n        522:                content = f'class {class_name}:\\n    pass\\n'\n        523:            tree = ast.parse(content)\n        524:        except Exception as e:\n        525:            return _process_error(ValueError(f'Error processing code: {str(e)}'))\n        526:        transformer = MethodAdder(class_name, new_method_node)\n        527:        tree = transformer.visit(tree)\n        528:        if not transformer.success:\n        529:            return _process_error(ValueError(f\"Class '{class_name}' not found in the file.\"))\n        530:        try:\n        531:            updated_content = _py_ast_to_source(tree)\n        532:            with open(abs_path, 'w', encoding='utf-8') as file:\n        533:                file.write(updated_content)\n        534:        except Exception as e:\n        535:            return _process_error(e)\n        536:        return f\"Method '{new_method_node.name}' has been added to class '{class_name}' in '{abs_path}'.\"\n        537:    except Exception as e:\n        538:        return _process_error(e)\n        539:\n        540:@handle_errors\n        541:def _add_single_function_to_file(file_path: str, new_function_def: str) -> str:\n        542:    \"\"\"Adds a single function and preserves all code blocks, including any code following the function.\"\"\"\n        543:    try:\n        544:        abs_path = _make_file(file_path)\n        545:        try:\n        546:            new_tree = ast.parse(_clean(new_function_def))\n        547:            new_func_node = None\n        548:            found_func = False\n        549:            new_nodes = []\n        550:            for node in new_tree.body:\n        551:                if not found_func and isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        552:                    new_func_node = node\n        553:                    found_func = True\n        554:                elif found_func:\n        555:                    new_nodes.append(node)\n        556:            if not new_func_node:\n        557:                return _process_error(ValueError('No function definition found in provided code'))\n        558:        except Exception as e:\n        559:            return _process_error(ValueError(f'Error in code: {str(e)}'))\n        560:        with open(abs_path, 'r', encoding='utf-8') as file:\n        561:            content = file.read()\n        562:        if not content.strip():\n        563:            try:\n        564:                with open(abs_path, 'w', encoding='utf-8') as file:\n        565:                    file.write(_py_ast_to_source(new_tree))\n        566:                return f\"Code with function '{new_func_node.name}' has been added to new file '{abs_path}'.\"\n        567:            except Exception as e:\n        568:                return _process_error(e)\n        569:        try:\n        570:            existing_tree = ast.parse(content)\n        571:            combined_body = []\n        572:            imports = []\n        573:            for node in existing_tree.body + new_tree.body:\n        574:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        575:                    imports.append(node)\n        576:            combined_body.extend(imports)\n        577:            for node in existing_tree.body:\n        578:                if not isinstance(node, (ast.Import, ast.ImportFrom)):\n        579:                    combined_body.append(node)\n        580:            combined_body.append(new_func_node)\n        581:            combined_body.extend(new_nodes)\n        582:            combined_tree = ast.Module(body=combined_body, type_ignores=[])\n        583:            updated_content = _py_ast_to_source(combined_tree)\n        584:            with open(abs_path, 'w', encoding='utf-8') as file:\n        585:                file.write(updated_content)\n        586:        except Exception as e:\n        587:            return _process_error(e)\n        588:        return f\"Code with function '{new_func_node.name}' has been added to '{abs_path}'.\"\n        589:    except Exception as e:\n        590:        return _process_error(e)\n        591:\n        592:@handle_errors\n        593:def _replace_single_function(file_path: str, new_function_def: str, class_name: str=None) -> str:\n        594:    \"\"\"Replaces a single function in a file, optionally within a specific class.\n        595:\n        596:    Args:\n        597:        file_path: Path to the file to modify\n        598:        new_function_def: The new function definition\n        599:        class_name: If provided, only replace within this class\n        600:    \"\"\"\n        601:    try:\n        602:        abs_path = _make_file(file_path)\n        603:        try:\n        604:            new_tree = ast.parse(_clean(new_function_def))\n        605:            new_func_node = None\n        606:            for node in new_tree.body:\n        607:                if isinstance(node, (ast.Import, ast.ImportFrom)):\n        608:                    add_imports(file_path, _py_ast_to_source(node).strip())\n        609:                elif isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):\n        610:                    new_func_node = node\n        611:            if new_func_node is None:\n        612:                return _process_error(ValueError('No function definition found in provided code'))\n        613:            with open(abs_path, 'r', encoding='utf-8') as file:\n        614:                content = file.read()\n        615:            tree = ast.parse(content)\n        616:        except Exception as e:\n        617:            return _process_error(ValueError(f'Error processing code: {str(e)}'))\n        618:\n        619:        class ClassScopedFunctionReplacer(ast.NodeTransformer):\n        620:\n        621:            def __init__(self, new_func_node, target_class=None):\n        622:                self.new_func_node = new_func_node\n        623:                self.target_class = target_class\n        624:                self.success = False\n        625:                self.in_target_class = False\n        626:\n        627:            def visit_ClassDef(self, node):\n        628:                if self.target_class is None or node.name == self.target_class:\n        629:                    old_in_target_class = self.in_target_class\n        630:                    self.in_target_class = True\n        631:                    node = self.generic_visit(node)\n        632:                    self.in_target_class = old_in_target_class\n        633:                return node\n        634:\n        635:            def visit_FunctionDef(self, node):\n        636:                if node.name == self.new_func_node.name:\n        637:                    if self.target_class is None or self.in_target_class:\n        638:                        self.success = True\n        639:                        return self.new_func_node\n        640:                return node\n        641:\n        642:            def visit_AsyncFunctionDef(self, node):\n        643:                return self.visit_FunctionDef(node)\n        644:        transformer = ClassScopedFunctionReplacer(new_func_node, class_name)\n        645:        tree = transformer.visit(tree)\n        646:        if not transformer.success:\n        647:            if class_name:\n        648:                return _process_error(ValueError(f\"Function '{new_func_node.name}' not found in class '{class_name}'\"))\n        649:            tree.body.append(new_func_node)\n        650:        try:\n        651:            updated_content = _py_ast_to_source(tree)\n        652:            with open(abs_path, 'w', encoding='utf-8') as file:\n        653:                file.write(updated_content)\n        654:        except Exception as e:\n        655:            return _process_error(e)\n        656:        context = f\"in class '{class_name}'\" if class_name else 'in file'\n        657:        action = 'replaced' if transformer.success else 'added'\n        658:        return f\"Function '{new_func_node.name}' has been {action} {context} '{abs_path}'.\"\n        659:    except Exception as e:\n        660:        return _process_error(e)"
